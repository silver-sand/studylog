---
export interface Props {
  todayEntry?: {
    id: string;
    date: string;
    content: string;
    hoursStudied: number;
    studyType: string;
    focusRating: number;
    examType: string;
  } | null;
}

const { todayEntry } = Astro.props;
const isEditing = !!todayEntry;

const STUDY_TYPES = [
  { value: 'theory', label: '📖 Theory' },
  { value: 'problem_solving', label: '✍️ Problem Solving' },
  { value: 'revision', label: '🔄 Revision' },
  { value: 'test', label: '📝 Test' },
  { value: 'other', label: 'Other' },
];
---

<div class="card" id="entry-form-container">
  <h2 class="form-title">
    {isEditing ? 'Update today\'s log' : 'What did you study today?'}
  </h2>

  <form id="entry-form" class="space-y-4">
    <input type="hidden" name="id" value={todayEntry?.id || ''} />

    <!-- Main content textarea -->
    <div>
      <textarea
        id="entry-content"
        name="content"
        rows="5"
        placeholder="e.g. Studied Physics chapter 3 — Kinematics. Covered motion in 1D and 2D, solved 15 problems..."
        class="form-input"
        required
        minlength="10"
        maxlength="10000"
      >{todayEntry?.content || ''}</textarea>
      <div class="flex justify-between mt-1.5">
        <p class="char-hint" id="char-count">{todayEntry?.content?.length || 0} / 10000</p>
        <p class="char-hint">Min 10 characters</p>
      </div>
    </div>

    <!-- Row 1: Hours + Study Type -->
    <div class="field-row">
      <div class="field-group flex-1">
        <label for="hours" class="field-label">Hours studied</label>
        <input
          type="number"
          id="hours"
          name="hoursStudied"
          min="0"
          max="24"
          step="0.5"
          placeholder="e.g. 4.5"
          value={todayEntry?.hoursStudied || ''}
          class="form-input w-full"
        />
      </div>

      <div class="field-group flex-1">
        <label for="study-type" class="field-label">Study type</label>
        <select id="study-type" name="studyType" class="form-input w-full">
          {STUDY_TYPES.map(st => (
            <option value={st.value} selected={todayEntry?.studyType === st.value}>
              {st.label}
            </option>
          ))}
        </select>
      </div>
    </div>

    <!-- Row 2: Focus Rating + Exam Type -->
    <div class="field-row">
      <div class="field-group flex-1">
        <label class="field-label">Focus rating</label>
        <div class="star-rating" id="star-rating" data-rating={todayEntry?.focusRating || 0}>
          {[1, 2, 3, 4, 5].map(n => (
            <button
              type="button"
              class:list={{ 'star': true, 'filled': n <= (todayEntry?.focusRating || 0) }}
              data-value={n}
              aria-label={`${n} star${n > 1 ? 's' : ''}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </button>
          ))}
        </div>
        <input type="hidden" name="focusRating" id="focus-rating-input" value={todayEntry?.focusRating || 0} />
      </div>

      <div class="field-group flex-1">
        <label for="exam-type" class="field-label">Exam</label>
        <input
          type="text"
          id="exam-type"
          name="examType"
          placeholder="e.g. JEE Main, NEET"
          value={todayEntry?.examType || ''}
          class="form-input w-full"
          readonly
        />
        <p class="char-hint">Set in <a href="/settings" class="text-blue-400 hover:text-blue-300">Settings</a></p>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex items-end">
      <button
        type="submit"
        id="submit-btn"
        class="btn-primary"
      >
        {isEditing ? 'Update Entry' : 'Log Entry'}
      </button>
    </div>

    <div id="form-error" class="error hidden"></div>
  </form>
</div>

<script>
  const form = document.getElementById('entry-form') as HTMLFormElement;
  const textarea = document.getElementById('entry-content') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count') as HTMLParagraphElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorDiv = document.getElementById('form-error') as HTMLDivElement;
  const idInput = form.querySelector('input[name="id"]') as HTMLInputElement;
  const starRating = document.getElementById('star-rating') as HTMLDivElement;
  const focusInput = document.getElementById('focus-rating-input') as HTMLInputElement;
  const hoursInput = document.getElementById('hours') as HTMLInputElement;
  const studyTypeSelect = document.getElementById('study-type') as HTMLSelectElement;
  const examTypeInput = document.getElementById('exam-type') as HTMLInputElement;

  // Char count
  textarea.addEventListener('input', () => {
    charCount.textContent = `${textarea.value.length} / 10000`;
  });

  // Star rating
  starRating.querySelectorAll('.star').forEach(star => {
    star.addEventListener('click', () => {
      const value = parseInt(star.getAttribute('data-value') || '0');
      focusInput.value = value.toString();
      starRating.querySelectorAll('.star').forEach(s => {
        const sv = parseInt(s.getAttribute('data-value') || '0');
        s.classList.toggle('filled', sv <= value);
      });
    });

    star.addEventListener('mouseenter', () => {
      const value = parseInt(star.getAttribute('data-value') || '0');
      starRating.querySelectorAll('.star').forEach(s => {
        const sv = parseInt(s.getAttribute('data-value') || '0');
        s.classList.toggle('hover', sv <= value);
      });
    });

    star.addEventListener('mouseleave', () => {
      starRating.querySelectorAll('.star').forEach(s => s.classList.remove('hover'));
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const content = textarea.value.trim();
    if (content.length < 10) {
      showError('Write at least 10 characters about what you studied.');
      return;
    }

    const hoursStudied = hoursInput.value ? parseFloat(hoursInput.value) : undefined;
    const studyType = studyTypeSelect.value;
    const focusRating = parseInt(focusInput.value) || 0;

    submitBtn.disabled = true;
    submitBtn.textContent = idInput.value ? 'Updating...' : 'Saving...';

    try {
      const isEditing = !!idInput.value;
      const url = isEditing ? `/api/entries/${idInput.value}` : '/api/entries';
      const method = isEditing ? 'PATCH' : 'POST';

      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          content,
          hoursStudied,
          studyType,
          focusRating: focusRating > 0 ? focusRating : undefined,
          examType: examTypeInput.value || undefined,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed to save entry' }));
        throw new Error(err.error || `HTTP ${res.status}`);
      }

      window.location.reload();
    } catch (err) {
      showError(err instanceof Error ? err.message : 'Something went wrong');
      submitBtn.disabled = false;
      submitBtn.textContent = idInput.value ? 'Update Entry' : 'Log Entry';
    }
  });

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }
</script>

<style>
  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  .form-title {
    font-size: 1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 1rem;
  }
  .field-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .field-row {
      flex-direction: row;
      gap: 1rem;
    }
  }
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .field-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 500;
    color: #94a3b8;
  }
  .form-input {
    width: 100%;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.6);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #e2e8f0;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    box-sizing: border-box;
  }
  .form-input:focus {
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.2);
  }
  .form-input::placeholder {
    color: #475569;
  }
  .form-input[readonly] {
    color: #64748b;
    cursor: default;
  }
  select.form-input {
    appearance: auto;
    cursor: pointer;
  }
  textarea.form-input {
    resize: vertical;
    min-height: 7rem;
  }
  .char-hint {
    font-size: 0.7rem;
    color: #475569;
  }
  .char-hint a {
    text-decoration: underline;
  }
  .star-rating {
    display: flex;
    gap: 0.25rem;
    padding: 0.375rem 0;
  }
  .star {
    background: none;
    border: none;
    padding: 0.2rem;
    cursor: pointer;
    color: #334155;
    transition: color 0.15s, transform 0.1s;
  }
  .star.filled {
    color: #f59e0b;
  }
  .star.hover {
    color: #fbbf24;
  }
  .star:hover {
    transform: scale(1.15);
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2563eb;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .btn-primary:hover:not(:disabled) {
    background: #3b82f6;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .error {
    color: #ef4444;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
  }
</style>
