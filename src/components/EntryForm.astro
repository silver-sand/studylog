---
export interface Props {
  todayEntry?: {
    id: string;
    date: string;
    content: string;
    hoursStudied: number;
    studyType: string;
    focusRating: number;
    examType: string;
  } | null;
  defaultExamType?: string;
}

const { todayEntry, defaultExamType } = Astro.props;
const isEditing = !!todayEntry;
const initialExamType = todayEntry?.examType || defaultExamType || '';

const STUDY_TYPES = [
  { value: 'theory', label: '📖 Theory' },
  { value: 'problem_solving', label: '✍️ Problem Solving' },
  { value: 'revision', label: '🔄 Revision' },
  { value: 'test', label: '📝 Test' },
  { value: 'other', label: 'Other' },
];
---

<div class="card" id="entry-form-container">
  <h2 class="form-title">
    {isEditing ? "Update today's log" : 'What did you study today?'}
  </h2>

  <form id="entry-form" class="space-y-4">
    <input type="hidden" name="id" value={todayEntry?.id || ''} />

    <!-- Main content textarea -->
    <div>
      <textarea
        id="entry-content"
        name="content"
        rows="5"
        placeholder="e.g. Studied Physics chapter 3 — Kinematics. Covered motion in 1D and 2D, solved 15 problems..."
        class="form-input"
        required
        minlength="10"
        maxlength="10000"
      >{todayEntry?.content || ''}</textarea>
      <div class="flex justify-between mt-1.5">
        <p class="char-hint" id="char-count">{todayEntry?.content?.length || 0} / 10000</p>
        <p class="char-hint">Min 10 characters</p>
      </div>
    </div>

    <!-- Row 1: Hours + Study Type -->
    <div class="field-row">
      <div class="field-group flex-1">
        <label for="hours" class="field-label">Hours studied</label>
        <input
          type="number"
          id="hours"
          name="hoursStudied"
          min="0"
          max="24"
          step="0.5"
          placeholder="e.g. 4.5"
          value={todayEntry?.hoursStudied || ''}
          class="form-input w-full"
        />
      </div>

      <div class="field-group flex-1">
        <label for="study-type" class="field-label">Study type</label>
        <select id="study-type" name="studyType" class="form-input w-full">
          {STUDY_TYPES.map(st => (
            <option value={st.value} selected={todayEntry?.studyType === st.value}>
              {st.label}
            </option>
          ))}
        </select>
      </div>
    </div>

    <!-- Row 2: Focus Rating + Exam Type -->
    <div class="field-row">
      <div class="field-group flex-1">
        <label class="field-label">Focus rating</label>
        <div class="star-rating" id="star-rating" data-rating={todayEntry?.focusRating || 0}>
          {[1, 2, 3, 4, 5].map(n => (
            <button
              type="button"
              class:list={{ 'star': true, 'filled': n <= (todayEntry?.focusRating || 0) }}
              data-value={n}
              aria-label={`${n} star${n > 1 ? 's' : ''}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </button>
          ))}
        </div>
        <input type="hidden" name="focusRating" id="focus-rating-input" value={todayEntry?.focusRating || 0} />
      </div>

      <div class="field-group flex-1">
        <label for="exam-type" class="field-label">Exam</label>
        <select id="exam-type" name="examType" class="form-input w-full">
          <option value="">— Select exam —</option>
          <option value="JEE" selected={initialExamType === 'JEE'}>JEE</option>
          <option value="JEE Main" selected={initialExamType === 'JEE Main'}>JEE Main</option>
          <option value="JEE Advanced" selected={initialExamType === 'JEE Advanced'}>JEE Advanced</option>
          <option value="NEET" selected={initialExamType === 'NEET'}>NEET</option>
          <option value="CET" selected={initialExamType === 'CET'}>CET</option>
          <option value="Boards (PCM)" selected={initialExamType === 'Boards (PCM)'}>Boards (PCM)</option>
          <option value="Boards (PCB)" selected={initialExamType === 'Boards (PCB)'}>Boards (PCB)</option>
          <option value="Boards (Commerce)" selected={initialExamType === 'Boards (Commerce)'}>Boards (Commerce)</option>
          <option value="CUET" selected={initialExamType === 'CUET'}>CUET</option>
          <option value="GATE" selected={initialExamType === 'GATE'}>GATE</option>
          <option value="CAT" selected={initialExamType === 'CAT'}>CAT</option>
          <option value="UPSC" selected={initialExamType === 'UPSC'}>UPSC</option>
          <option value="Other" selected={initialExamType === 'Other'}>Other</option>
        </select>
      </div>
    </div>

    <!-- Syllabus chapter selection -->
    <div id="syllabus-section" class="syllabus-section">
      <button type="button" id="syllabus-toggle" class="syllabus-toggle">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><path d="m9 18 6-6-6-6"/></svg>
        Update syllabus
      </button>
      <div id="syllabus-panel" class="syllabus-panel hidden">
        <p id="syllabus-loading" style="color:#64748b;font-size:0.8rem;padding:0.5rem 0;">Loading chapters...</p>
        <div id="syllabus-chapters"></div>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex items-end">
      <button
        type="submit"
        id="submit-btn"
        class="btn-primary"
      >
        {isEditing ? 'Update Entry' : 'Log Entry'}
      </button>
    </div>

    <div id="form-error" class="error hidden"></div>
  </form>
</div>

<script>
  const form = document.getElementById('entry-form');
  const textarea = document.getElementById('entry-content');
  const charCount = document.getElementById('char-count');
  const submitBtn = document.getElementById('submit-btn');
  const errorDiv = document.getElementById('form-error');
  const idInput = form.querySelector('input[name="id"]');
  const starRating = document.getElementById('star-rating');
  const focusInput = document.getElementById('focus-rating-input');
  const hoursInput = document.getElementById('hours');
  const studyTypeSelect = document.getElementById('study-type');
  const examTypeInput = document.getElementById('exam-type');

  // Char count
  textarea.addEventListener('input', () => {
    charCount.textContent = `${textarea.value.length} / 10000`;
  });

  // Star rating
  starRating.querySelectorAll('.star').forEach(star => {
    star.addEventListener('click', () => {
      const value = parseInt(star.getAttribute('data-value') || '0');
      focusInput.value = value.toString();
      starRating.querySelectorAll('.star').forEach(s => {
        const sv = parseInt(s.getAttribute('data-value') || '0');
        s.classList.toggle('filled', sv <= value);
      });
    });

    star.addEventListener('mouseenter', () => {
      const value = parseInt(star.getAttribute('data-value') || '0');
      starRating.querySelectorAll('.star').forEach(s => {
        const sv = parseInt(s.getAttribute('data-value') || '0');
        s.classList.toggle('hover', sv <= value);
      });
    });

    star.addEventListener('mouseleave', () => {
      starRating.querySelectorAll('.star').forEach(s => s.classList.remove('hover'));
    });
  });

  // ── Syllabus chapter selection ──
  const syllabusToggle = document.getElementById('syllabus-toggle');
  const syllabusPanel = document.getElementById('syllabus-panel');
  const syllabusLoading = document.getElementById('syllabus-loading');
  const syllabusChapters = document.getElementById('syllabus-chapters');

  let syllabusData = null;

  syllabusToggle.addEventListener('click', () => {
    const isHidden = syllabusPanel.classList.toggle('hidden');
    syllabusToggle.querySelector('.chevron').classList.toggle('open', !isHidden);
    if (!isHidden && !syllabusData) {
      loadSyllabus();
    }
  });

  examTypeInput.addEventListener('change', () => {
    // Reset syllabus when exam changes
    syllabusData = null;
    syllabusChapters.innerHTML = '';
    if (!syllabusPanel.classList.contains('hidden')) {
      loadSyllabus();
    }
  });

  async function loadSyllabus() {
    const exam = examTypeInput.value.trim();
    if (!exam) {
      syllabusLoading.textContent = 'Select an exam above to see syllabus chapters.';
      syllabusLoading.style.display = 'block';
      return;
    }

    // Map UI exam names to syllabus DB keys
    const examMap = {
      'JEE': 'JEE', 'JEE Main': 'JEE', 'JEE Advanced': 'JEE',
      'NEET': 'NEET', 'CET': 'MHT_CET',
      'Boards (PCM)': 'CBSE_12', 'Boards (PCB)': 'CBSE_12', 'Boards (Commerce)': 'CBSE_12',
      'CUET': 'CUET', 'GATE': 'GATE', 'CAT': 'CAT', 'UPSC': 'UPSC',
    };
    const examKey = examMap[exam] || exam;

    syllabusLoading.textContent = 'Loading...';
    syllabusLoading.style.display = 'block';

    try {
      const res = await fetch(`/api/syllabus?exam=${encodeURIComponent(examKey)}`);
      if (!res.ok) throw new Error('Failed to load');
      const data = await res.json();
      if (!data.chapters || data.chapters.length === 0) {
        syllabusLoading.textContent = 'No chapters found for this exam.';
        return;
      }

      syllabusData = data.chapters;
      renderSyllabus(data.chapters, data.progress);
      syllabusLoading.style.display = 'none';
    } catch (err) {
      syllabusLoading.textContent = 'Failed to load chapters.';
    }
  }

  function renderSyllabus(chapters, progress) {
    // Group by subject
    const subjects = {};
    for (const ch of chapters) {
      if (!subjects[ch.subject]) subjects[ch.subject] = [];
      subjects[ch.subject].push(ch);
    }

    const subjectColors = { Physics: '#3b82f6', Chemistry: '#22c55e', Mathematics: '#f59e0b', Maths: '#f59e0b', Biology: '#ec4899' };

    let html = '';
    for (const [subject, chs] of Object.entries(subjects)) {
      const color = subjectColors[subject] || '#64748b';
      const prog = progress ? progress.find(p => p.subject === subject) : null;
      const pct = prog ? prog.percent : 0;

      html += `<div style="margin-bottom:0.75rem;">`;
      // Subject header
      html += `<div style="display:flex;align-items:center;justify-content:space-between;padding:0.3rem 0.5rem;border-left:3px solid ${color};margin-bottom:0.25rem;" data-syl-subject="${subject}">`;
      html += `<span style="font-size:0.8rem;font-weight:600;color:#e2e8f0;">${subject}</span>`;
      html += `<span class="syl-pct" style="font-size:0.7rem;font-family:monospace;color:#64748b;">${pct}%</span>`;
      html += `</div>`;
      // Chapters
      for (const ch of chs) {
        const isDone = ch.status === 'completed';
        const isProgress = ch.status === 'in_progress';
        html += `<div data-syl-row="${ch.id}" style="display:flex;align-items:center;gap:0.5rem;padding:0.25rem 0.5rem 0.25rem 0.75rem;border-radius:0.25rem;" onmouseover="this.style.background='rgba(51,65,85,0.3)'" onmouseout="this.style.background='transparent'">`;
        // Three status buttons as a slider group
        html += `<div style="display:flex;border-radius:0.35rem;overflow:hidden;border:1px solid rgba(51,65,85,0.4);flex-shrink:0;">`;
        html += buildStatusBtn(ch.id, 'not_started', '○', ch.status === 'not_started');
        html += buildStatusBtn(ch.id, 'in_progress', '◐', ch.status === 'in_progress');
        html += buildStatusBtn(ch.id, 'completed', '●', ch.status === 'completed');
        html += `</div>`;
        // Chapter name
        html += `<span class="syl-ch-name" style="font-size:0.78rem;color:${isDone ? '#64748b' : isProgress ? '#fcd34d' : '#cbd5e1'};flex:1;${isDone ? 'text-decoration:line-through;' : ''}">${ch.chapter}</span>`;
        if (ch.classLevel) {
          html += `<span style="font-size:0.6rem;padding:0.05rem 0.3rem;border-radius:0.2rem;background:rgba(100,116,139,0.2);color:#94a3b8;font-family:monospace;">Cls ${ch.classLevel}</span>`;
        }
        html += `</div>`;
      }
      html += `</div>`;
    }

    syllabusChapters.innerHTML = html;

    // Add click handlers to status buttons
    syllabusChapters.querySelectorAll('.syl-status-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const chapterId = btn.dataset.chapterId;
        const status = btn.dataset.status;
        const row = btn.closest('[data-syl-row]');
        if (!chapterId || !status) return;

        // Disable all buttons in this row during update
        const rowBtns = row.querySelectorAll('.syl-status-btn');
        rowBtns.forEach(b => b.disabled = true);

        try {
          const res = await fetch('/api/syllabus', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: chapterId, status }),
          });
          if (!res.ok) throw new Error('Update failed');

          // Update button visuals
          const activeColors = { not_started: '#64748b', in_progress: '#f59e0b', completed: '#22c55e' };
          rowBtns.forEach(b => {
            const s = b.dataset.status;
            const isActive = s === status;
            b.style.background = isActive ? `${activeColors[s]}22` : 'rgba(15,23,42,0.8)';
            b.style.color = isActive ? activeColors[s] : '#475569';
            b.style.fontWeight = isActive ? '500' : '400';
          });

          // Update chapter name style
          const nameSpan = row.querySelector('.syl-ch-name');
          if (nameSpan) {
            nameSpan.style.color = status === 'completed' ? '#64748b' : status === 'in_progress' ? '#fcd34d' : '#cbd5e1';
            nameSpan.style.textDecoration = status === 'completed' ? 'line-through' : 'none';
          }

          // Reload to refresh percentages
          const exam = examTypeInput.value.trim();
          const examMap = { 'JEE': 'JEE', 'JEE Main': 'JEE', 'JEE Advanced': 'JEE', 'NEET': 'NEET', 'CET': 'MHT_CET', 'Boards (PCM)': 'CBSE_12', 'Boards (PCB)': 'CBSE_12', 'Boards (Commerce)': 'CBSE_12', 'CUET': 'CUET', 'GATE': 'GATE', 'CAT': 'CAT', 'UPSC': 'UPSC' };
          const examKey = examMap[exam] || exam;
          const res2 = await fetch(`/api/syllabus?exam=${encodeURIComponent(examKey)}`);
          if (res2.ok) {
            const data2 = await res2.json();
            if (data2.progress) {
              // Update subject percentages
              data2.progress.forEach(p => {
                // Find the subject header
                const headers = syllabusChapters.querySelectorAll('[data-syl-subject]');
                headers.forEach(h => {
                  if (h.dataset.sylSubject === p.subject) {
                    const pctEl = h.querySelector('.syl-pct');
                    if (pctEl) pctEl.textContent = `${p.percent}%`;
                  }
                });
              });
            }
          }
        } catch (err) {
          alert('Failed: ' + err.message);
        } finally {
          rowBtns.forEach(b => b.disabled = false);
        }
      });
    });
  }

  function buildStatusBtn(chapterId, status, icon, isActive) {
    const activeColors = { not_started: '#64748b', in_progress: '#f59e0b', completed: '#22c55e' };
    const labels = { not_started: 'Not Started', in_progress: 'In Progress', completed: 'Done' };
    const bg = isActive ? `${activeColors[status]}22` : 'rgba(15,23,42,0.8)';
    const color = isActive ? activeColors[status] : '#475569';
    return `<button class="syl-status-btn" data-chapter-id="${chapterId}" data-status="${status}" type="button" style="font-size:0.65rem;padding:0.25rem 0.45rem;border:none;border-right:1px solid rgba(51,65,85,0.3);background:${bg};color:${color};cursor:pointer;font-family:'Inter',sans-serif;transition:all 0.1s;white-space:nowrap;${isActive ? 'font-weight:500;' : ''}" title="${labels[status]}">${labels[status]}</button>`;
  }

  // ── Form submit ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const content = textarea.value.trim();
    if (content.length < 10) {
      showError('Write at least 10 characters about what you studied.');
      return;
    }

    const hoursStudied = hoursInput.value ? parseFloat(hoursInput.value) : undefined;
    const studyType = studyTypeSelect.value;
    const focusRating = parseInt(focusInput.value) || 0;

    submitBtn.disabled = true;
    submitBtn.textContent = idInput.value ? 'Updating...' : 'Saving...';

    try {
      const isEditing = !!idInput.value;
      const url = isEditing ? `/api/entries/${idInput.value}` : '/api/entries';
      const method = isEditing ? 'PATCH' : 'POST';

      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          content,
          hoursStudied,
          studyType,
          focusRating: focusRating > 0 ? focusRating : undefined,
          examType: examTypeInput.value || undefined,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed to save entry' }));
        throw new Error(err.error || `HTTP ${res.status}`);
      }

      window.location.reload();
    } catch (err) {
      showError(err instanceof Error ? err.message : 'Something went wrong');
      submitBtn.disabled = false;
      submitBtn.textContent = idInput.value ? 'Update Entry' : 'Log Entry';
    }
  });

  function showError(msg) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }
</script>

<style>
  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  .form-title {
    font-size: 1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 1rem;
  }
  .field-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .field-row {
      flex-direction: row;
      gap: 1rem;
    }
  }
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .field-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 500;
    color: #94a3b8;
  }
  .form-input {
    width: 100%;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.6);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #e2e8f0;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    box-sizing: border-box;
  }
  .form-input:focus {
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.2);
  }
  .form-input::placeholder {
    color: #475569;
  }
  .form-input[readonly] {
    color: #64748b;
    cursor: default;
  }
  select.form-input {
    appearance: auto;
    cursor: pointer;
  }
  textarea.form-input {
    resize: vertical;
    min-height: 7rem;
  }
  .char-hint {
    font-size: 0.7rem;
    color: #475569;
  }
  .char-hint a {
    text-decoration: underline;
  }
  .star-rating {
    display: flex;
    gap: 0.25rem;
    padding: 0.375rem 0;
  }
  .star {
    background: none;
    border: none;
    padding: 0.2rem;
    cursor: pointer;
    color: #334155;
    transition: color 0.15s, transform 0.1s;
  }
  .star.filled {
    color: #f59e0b;
  }
  .star.hover {
    color: #fbbf24;
  }
  .star:hover {
    transform: scale(1.15);
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2563eb;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .btn-primary:hover:not(:disabled) {
    background: #3b82f6;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .error {
    color: #ef4444;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
  }

  /* Syllabus section */
  .syllabus-section {
    margin-top: 0.5rem;
  }
  .syllabus-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: transparent;
    border: 1px solid rgba(51, 65, 85, 0.4);
    color: #64748b;
    font-size: 0.8rem;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.15s;
  }
  .syllabus-toggle:hover {
    color: #94a3b8;
    border-color: rgba(71, 85, 105, 0.6);
  }
  .chevron {
    transition: transform 0.2s;
  }
  .chevron.open {
    transform: rotate(90deg);
  }
  .syllabus-panel {
    margin-top: 0.75rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.5rem;
    padding: 1rem;
    max-height: 400px;
    overflow-y: auto;
  }

  .space-y-4 > :not([hidden]) ~ :not([hidden]) {
    margin-top: 1rem;
  }
  .hidden {
    display: none;
  }
</style>
