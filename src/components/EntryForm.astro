---
export interface Props {
  todayEntry?: {
    id: string;
    date: string;
    content: string;
    hoursStudied: number;
    studyType: string;
    focusRating: number;
    examType: string;
  } | null;
  defaultExamType?: string;
  subjects?: string[];
  exams?: string[];
}

const { todayEntry, defaultExamType, subjects: propSubjects, exams: propExams } = Astro.props;
const isEditing = !!todayEntry;
const initialExamType = todayEntry?.examType || defaultExamType || '';

// Dynamic subjects and exams — fallbacks instead of hardcoded science defaults
const SUBJECTS = propSubjects?.length ? propSubjects : ['Add subjects in Settings first'];
const EXAM_TYPES = propExams?.length ? propExams : ['JEE', 'NEET', 'CET', 'CUET', 'GATE', 'Boards', 'Other'];

const SUBJECT_COLORS: Record<string, string> = {
  Physics: 'bg-blue-400',
  Chemistry: 'bg-emerald-400',
  Maths: 'bg-amber-400',
  Mathematics: 'bg-amber-400',
  Biology: 'bg-rose-400',
};
// Dynamic color for any subject not in the hardcoded map
const COLOR_PALETTE = ['bg-blue-400', 'bg-emerald-400', 'bg-amber-400', 'bg-rose-400', 'bg-violet-400', 'bg-cyan-400', 'bg-pink-400', 'bg-lime-400', 'bg-orange-400', 'bg-teal-400'];
function getSubjectColor(subject: string): string {
  return SUBJECT_COLORS[subject] || COLOR_PALETTE[Math.abs(hashCode(subject)) % COLOR_PALETTE.length];
}

// Simple string hash for deterministic color assignment
function hashCode(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash = hash & hash; // Convert to 32bit integer
  }
  return hash;
}

const STUDY_TYPES = [
  { value: 'theory', label: 'Theory 📖' },
  { value: 'problem_solving', label: 'Problem Solving ✍️' },
  { value: 'revision', label: 'Revision 🔄' },
  { value: 'test', label: 'Test 📝' },
  { value: 'other', label: 'Other' },
];

const inputClass = 'w-full bg-[#050b18] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/40 focus:border-indigo-500/30 transition-all placeholder:text-neutral-600';
const labelClass = 'block text-xs font-label text-neutral-500 mb-2 tracking-wide';
---

<div id="entry-form-container">
  <form id="entry-form" class="space-y-7" data-colors={JSON.stringify(Object.fromEntries(SUBJECTS.map(s => [s, getSubjectColor(s)])))}>
    <input type="hidden" name="id" value={todayEntry?.id || ''} />

    <!-- Subject Chips -->
    <div>
      <label class={labelClass}>Subject Studied</label>
      <input type="hidden" name="subject" id="subject-input" value="" />
      <div class="flex flex-wrap gap-3">
        {SUBJECTS.map(subject => (
          <button
            type="button"
            class="subject-chip px-5 py-2.5 rounded-full border border-white/10 bg-[#050b18] text-white hover:border-indigo-500/40 transition-all font-label text-sm flex items-center gap-2"
            data-selected="false"
            data-subject={subject}
          >
            <span class={`w-2 h-2 rounded-full ${getSubjectColor(subject)}`}></span>
            {subject}
          </button>
        ))}
      </div>
    </div>

    <!-- Hours + Focus Rating Row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Hours Studied -->
      <div>
        <label class={labelClass} for="hours">Hours Studied</label>
        <div class="relative">
          <input
            type="number"
            id="hours"
            name="hoursStudied"
            min="0"
            max="24"
            step="0.5"
            placeholder="e.g. 4.5"
            value={todayEntry?.hoursStudied || ''}
            class={inputClass}
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-neutral-600 font-label text-sm">hrs</span>
        </div>
      </div>

      <!-- Focus Rating -->
      <div>
        <label class={labelClass}>Focus Rating</label>
        <input type="hidden" name="focusRating" id="focus-rating-input" value={todayEntry?.focusRating || 0} />
        <div class="flex gap-2" id="focus-rating-group">
          {[1, 2, 3, 4, 5].map(n => (
            <button
              type="button"
              class="focus-segment w-full h-11 rounded-lg bg-[#050b18] border border-white/10 hover:border-indigo-500/30 transition-all flex items-center justify-center text-base font-bold text-white"
              data-val={n}
              class:list={{
                'bg-indigo-500 text-white border-indigo-500 shadow-sm shadow-indigo-500/20': n <= (todayEntry?.focusRating || 0),
                'bg-[#050b18] text-white border-white/10': n > (todayEntry?.focusRating || 0),
              }}
            >{n}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- Study Type + Exam Select -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class={labelClass} for="study-type">Study Type</label>
        <select id="study-type" name="studyType" class={`appearance-none ${inputClass}`}>
          {STUDY_TYPES.map(st => (
            <option value={st.value} selected={todayEntry?.studyType === st.value}>{st.label}</option>
          ))}
        </select>
      </div>
      <div>
        <label class={labelClass} for="exam-type">Exam</label>
        <select id="exam-type" name="examType" class={`appearance-none ${inputClass}`}>
          <option value="">— Select —</option>
          {EXAM_TYPES.map(ex => (
            <option value={ex} selected={initialExamType === ex}>{ex}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Notes -->
    <div>
      <label class={labelClass} for="entry-content">What did you accomplish today?</label>
      <textarea
        id="entry-content"
        name="content"
        rows="4"
        placeholder="Solved 20 HC Verma problems, revised electrostatics..."
        class={`${inputClass} resize-none min-h-[120px]`}
        required
        minlength="10"
        maxlength="10000"
      >{todayEntry?.content || ''}</textarea>
      <div class="flex justify-between mt-1.5">
        <span class="text-xs text-neutral-600" id="char-count">{todayEntry?.content?.length || 0} / 10000</span>
      </div>
    </div>

    <!-- Syllabus chapter selection (collapsible) -->
    <div>
      <button type="button" id="syllabus-toggle" class="text-neutral-500 hover:text-indigo-400 text-sm font-label transition-colors flex items-center gap-2">
        <span class="material-symbols-outlined text-sm chevron">chevron_right</span>
        Update syllabus progress
      </button>
      <div id="syllabus-panel" class="hidden mt-3 bg-[#050b18] border border-white/10 rounded-xl p-4 max-h-80 overflow-y-auto">
        <p id="syllabus-loading" class="text-sm text-neutral-500">Loading chapters...</p>
        <div id="syllabus-chapters"></div>
      </div>
    </div>

    <!-- Submit Button -->
    <button type="submit" id="submit-btn" class="w-full bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-400 text-white font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2 active:scale-[0.98] shadow-lg shadow-indigo-500/20 ripple-btn">
      <span class="material-symbols-outlined filled-icon text-[20px]">save</span>
      {isEditing ? 'Update Entry' : 'Save Daily Log'}
    </button>

    <div id="form-error" class="hidden mt-2 text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg p-3"></div>
  </form>
</div>

<script>
  const form = document.getElementById('entry-form');
  const textarea = document.getElementById('entry-content');
  const charCount = document.getElementById('char-count');
  const submitBtn = document.getElementById('submit-btn');
  const errorDiv = document.getElementById('form-error');
  const idInput = form.querySelector('input[name="id"]');
  const focusInput = document.getElementById('focus-rating-input');
  const hoursInput = document.getElementById('hours');
  const studyTypeSelect = document.getElementById('study-type');
  const examTypeInput = document.getElementById('exam-type');
  const subjectInput = document.getElementById('subject-input');

  // Char count
  textarea.addEventListener('input', () => {
    charCount.textContent = `${textarea.value.length} / 10000`;
  });

  // Parse subject colors from server-generated data
  var SUBJECT_COLORS_MAP = {};
  try {
    if (form && form.dataset.colors) {
      SUBJECT_COLORS_MAP = JSON.parse(form.dataset.colors);
    }
  } catch(e) {}

  function getChipColor(subject) {
    return SUBJECT_COLORS_MAP[subject] || 'bg-slate-400';
  }

  // Subject Chips — toggle selection
  const subjectChips = document.querySelectorAll('.subject-chip');
  subjectChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const isSelected = chip.getAttribute('data-selected') === 'true';
      chip.setAttribute('data-selected', !isSelected);
      if (!isSelected) {
        chip.classList.remove('bg-[#050b18]', 'text-white', 'border-white/10');
        chip.classList.add('bg-indigo-500', 'text-white', 'border-indigo-500');
        const dot = chip.querySelector('span');
        dot.className = 'w-2 h-2 rounded-full bg-white';
      } else {
        chip.classList.add('bg-[#050b18]', 'text-white', 'border-white/10');
        chip.classList.remove('bg-indigo-500', 'text-white', 'border-indigo-500');
        const dot = chip.querySelector('span');
        const subject = chip.dataset.subject;
        dot.className = 'w-2 h-2 rounded-full ' + getChipColor(subject);
      }
      updateSubjectInput();
    });
  });

  function updateSubjectInput() {
    const selected = [];
    document.querySelectorAll('.subject-chip[data-selected="true"]').forEach(chip => {
      selected.push(chip.dataset.subject);
    });
    subjectInput.value = selected.join(', ');
  }

  // Focus Segment Selection — toggle buttons
  const focusSegments = document.querySelectorAll('#focus-rating-group .focus-segment');
  focusSegments.forEach(segment => {
    segment.addEventListener('click', () => {
      const val = parseInt(segment.dataset.val);
      focusInput.value = val;
      focusSegments.forEach(s => {
        const sv = parseInt(s.dataset.val);
        if (sv <= val) {
          s.classList.remove('bg-[#050b18]', 'text-white', 'border-white/10');
          s.classList.add('bg-indigo-500', 'text-white', 'border-indigo-500');
        } else {
          s.classList.add('bg-[#050b18]', 'text-white', 'border-white/10');
          s.classList.remove('bg-indigo-500', 'text-white', 'border-indigo-500');
        }
      });
    });
  });

  // ── Syllabus chapter selection ──
  const syllabusToggle = document.getElementById('syllabus-toggle');
  const syllabusPanel = document.getElementById('syllabus-panel');
  const syllabusLoading = document.getElementById('syllabus-loading');
  const syllabusChapters = document.getElementById('syllabus-chapters');

  let syllabusData = null;

  syllabusToggle.addEventListener('click', () => {
    const isHidden = syllabusPanel.classList.toggle('hidden');
    const chevron = syllabusToggle.querySelector('.chevron');
    if (chevron) {
      chevron.textContent = isHidden ? 'chevron_right' : 'expand_more';
    }
    if (!isHidden && !syllabusData) {
      loadSyllabus();
    }
  });

  examTypeInput.addEventListener('change', () => {
    syllabusData = null;
    syllabusChapters.innerHTML = '';
    if (!syllabusPanel.classList.contains('hidden')) {
      loadSyllabus();
    }
  });

  async function loadSyllabus() {
    const exam = examTypeInput.value.trim();
    if (!exam) {
      syllabusLoading.textContent = 'Select an exam above to see syllabus chapters.';
      syllabusLoading.style.display = 'block';
      return;
    }

    const examMap = {
      'JEE': 'JEE', 'JEE Main': 'JEE', 'JEE Advanced': 'JEE',
      'NEET': 'NEET', 'CET': 'MHT_CET',
      'Boards (PCM)': 'CBSE_12', 'Boards (PCB)': 'CBSE_12', 'Boards (Commerce)': 'CBSE_12',
      'CUET': 'CUET', 'GATE': 'GATE', 'CAT': 'CAT', 'UPSC': 'UPSC',
    };
    const examKey = examMap[exam] || exam;

    syllabusLoading.textContent = 'Loading...';
    syllabusLoading.style.display = 'block';

    try {
      const res = await fetch(`/api/syllabus?exam=${encodeURIComponent(examKey)}`);
      if (!res.ok) throw new Error('Failed to load');
      const data = await res.json();
      if (!data.chapters || data.chapters.length === 0) {
        syllabusLoading.textContent = 'No chapters found for this exam.';
        return;
      }

      syllabusData = data.chapters;
      renderSyllabus(data.chapters, data.progress);
      syllabusLoading.style.display = 'none';
    } catch (err) {
      syllabusLoading.textContent = 'Failed to load chapters.';
    }
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderSyllabus(chapters, progress) {
    const subjects = {};
    for (const ch of chapters) {
      if (!subjects[ch.subject]) subjects[ch.subject] = [];
      subjects[ch.subject].push(ch);
    }

    // Build hex color map from the Tailwind bg classes
    var sylColors = {};
    for (var subj in SUBJECT_COLORS_MAP) {
      var bgClass = SUBJECT_COLORS_MAP[subj];
      // Map Tailwind bg-* classes to hex colors
      var colorMap = { 'bg-blue-400': '#60a5fa', 'bg-emerald-400': '#34d399', 'bg-amber-400': '#fbbf24', 'bg-rose-400': '#fb7185', 'bg-violet-400': '#a78bfa', 'bg-cyan-400': '#22d3ee', 'bg-pink-400': '#f472b6', 'bg-lime-400': '#a3e635', 'bg-orange-400': '#fb923c', 'bg-teal-400': '#2dd4bf' };
      sylColors[subj] = colorMap[bgClass] || '#64748b';
    }

    syllabusChapters.innerHTML = '';

    for (const [subject, chs] of Object.entries(subjects)) {
      const color = sylColors[subject] || '#64748b';
      const prog = progress ? progress.find(p => p.subject === subject) : null;
      const pct = prog ? prog.weightedPercent : 0;

      const subjectDiv = document.createElement('div');
      subjectDiv.style.marginBottom = '0.75rem';

      const header = document.createElement('div');
      header.style.display = 'flex';
      header.style.alignItems = 'center';
      header.style.justifyContent = 'space-between';
      header.style.padding = '0.3rem 0.5rem';
      header.style.borderLeft = `3px solid ${color}`;
      header.style.marginBottom = '0.25rem';
      header.dataset.sylSubject = subject;
      const nameSpan = document.createElement('span');
      nameSpan.style.fontSize = '0.8rem';
      nameSpan.style.fontWeight = '600';
      nameSpan.style.color = '#f1f5f9';
      nameSpan.textContent = subject;
      header.appendChild(nameSpan);
      const pctSpan = document.createElement('span');
      pctSpan.className = 'syl-pct';
      pctSpan.style.fontSize = '0.7rem';
      pctSpan.style.fontFamily = 'monospace';
      pctSpan.style.color = '#64748b';
      pctSpan.textContent = `${pct}%`;
      header.appendChild(pctSpan);
      subjectDiv.appendChild(header);

      const STATUS_LIST = ['not_started', 'studied', 'revision_1', 'revision_2', 'revision_3', 'mastered'];

      for (const ch of chs) {
        const row = document.createElement('div');
        row.dataset.sylRow = ch.id;
        row.style.display = 'flex';
        row.style.alignItems = 'center';
        row.style.gap = '0.5rem';
        row.style.padding = '0.25rem 0.5rem 0.25rem 0.75rem';
        row.style.borderRadius = '0.25rem';
        row.addEventListener('mouseenter', () => { row.style.background = 'rgba(99,102,241,0.08)'; });
        row.addEventListener('mouseleave', () => { row.style.background = 'transparent'; });

        const btnGroup = document.createElement('div');
        btnGroup.style.display = 'flex';
        btnGroup.style.borderRadius = '0.35rem';
        btnGroup.style.overflow = 'hidden';
        btnGroup.style.border = '1px solid rgba(99,102,241,0.15)';
        btnGroup.style.flexShrink = '0';
        for (const s of STATUS_LIST) {
          btnGroup.appendChild(buildStatusBtnDom(ch.id, s, ch.status === s));
        }
        row.appendChild(btnGroup);

        const chName = document.createElement('span');
        chName.className = 'syl-ch-name';
        chName.style.fontSize = '0.78rem';
        chName.style.color = '#e2e8f0';
        chName.style.flex = '1';
        chName.textContent = ch.chapter;
        row.appendChild(chName);

        if (ch.classLevel) {
          const badge = document.createElement('span');
          badge.style.fontSize = '0.6rem';
          badge.style.padding = '0.05rem 0.3rem';
          badge.style.borderRadius = '0.2rem';
          badge.style.background = 'rgba(99,102,241,0.1)';
          badge.style.color = '#818cf8';
          badge.style.fontFamily = 'monospace';
          badge.textContent = `Cls ${ch.classLevel}`;
          row.appendChild(badge);
        }

        subjectDiv.appendChild(row);
      }
      syllabusChapters.appendChild(subjectDiv);
    }

    syllabusChapters.querySelectorAll('.syl-status-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const chapterId = btn.dataset.chapterId;
        const status = btn.dataset.status;
        const row = btn.closest('[data-syl-row]');
        if (!chapterId || !status) return;

        const rowBtns = row.querySelectorAll('.syl-status-btn');
        rowBtns.forEach(b => b.disabled = true);

        try {
          const res = await fetch('/api/syllabus', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: chapterId, status }),
          });
          if (!res.ok) throw new Error('Update failed');

          const ACTIVE_COLORS = {
            not_started: '#64748b', studied: '#f59e0b', revision_1: '#818cf8',
            revision_2: '#a78bfa', revision_3: '#e879f9', mastered: '#22c55e',
          };
          rowBtns.forEach(b => {
            const s = b.dataset.status;
            const isActive = s === status;
            b.style.background = isActive ? `${ACTIVE_COLORS[s]}22` : 'rgba(15,23,42,0.8)';
            b.style.color = isActive ? ACTIVE_COLORS[s] : '#475569';
            b.style.fontWeight = isActive ? '600' : '400';
          });

          const exam = examTypeInput.value.trim();
          const examMap = { 'JEE': 'JEE', 'JEE Main': 'JEE', 'JEE Advanced': 'JEE', 'NEET': 'NEET', 'CET': 'MHT_CET', 'Boards (PCM)': 'CBSE_12', 'Boards (PCB)': 'CBSE_12', 'Boards (Commerce)': 'CBSE_12', 'CUET': 'CUET', 'GATE': 'GATE', 'CAT': 'CAT', 'UPSC': 'UPSC' };
          const examKey = examMap[exam] || exam;
          const res2 = await fetch(`/api/syllabus?exam=${encodeURIComponent(examKey)}`);
          if (res2.ok) {
            const data2 = await res2.json();
            if (data2.progress) {
              data2.progress.forEach(p => {
                const headers = syllabusChapters.querySelectorAll('[data-syl-subject]');
                headers.forEach(h => {
                  if (h.dataset.sylSubject === p.subject) {
                    const pctEl = h.querySelector('.syl-pct');
                    if (pctEl) pctEl.textContent = `${p.weightedPercent}%`;
                  }
                });
              });
            }
          }
        } catch (err) {
          alert('Failed: ' + err.message);
        } finally {
          rowBtns.forEach(b => b.disabled = false);
        }
      });
    });
  }

  function buildStatusBtnDom(chapterId, status, isActive) {
    const colors = {
      not_started: '#64748b', studied: '#f59e0b', revision_1: '#818cf8',
      revision_2: '#a78bfa', revision_3: '#e879f9', mastered: '#22c55e',
    };
    const labels = {
      not_started: 'NS', studied: 'S', revision_1: 'R1',
      revision_2: 'R2', revision_3: 'R3', mastered: 'M',
    };
    const titles = {
      not_started: 'Not Started', studied: 'Studied', revision_1: 'Revision 1',
      revision_2: 'Revision 2', revision_3: 'Revision 3', mastered: 'Mastered',
    };
    const c = colors[status] || '#64748b';
    const bg = isActive ? `${c}22` : 'rgba(15,23,42,0.8)';
    const txtColor = isActive ? c : '#475569';

    const btn = document.createElement('button');
    btn.className = 'syl-status-btn';
    btn.type = 'button';
    btn.dataset.chapterId = String(chapterId);
    btn.dataset.status = status;
    btn.title = titles[status] || status;
    btn.style.fontSize = '0.6rem';
    btn.style.padding = '0.2rem 0.35rem';
    btn.style.minWidth = '1.6rem';
    btn.style.border = 'none';
    btn.style.borderRight = '1px solid rgba(99,102,241,0.1)';
    btn.style.background = bg;
    btn.style.color = txtColor;
    btn.style.cursor = 'pointer';
    btn.style.fontFamily = "'JetBrains Mono', monospace";
    btn.style.transition = 'all 0.1s';
    if (isActive) btn.style.fontWeight = '600';
    btn.textContent = labels[status] || status;
    return btn;
  }

  // ── Form submit ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const content = textarea.value.trim();
    if (content.length < 10) {
      showError('Write at least 10 characters about what you studied.');
      return;
    }

    const hoursStudied = hoursInput.value ? parseFloat(hoursInput.value) : undefined;
    const studyType = studyTypeSelect.value;
    const focusRating = parseInt(focusInput.value) || 0;

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Saving...';

    try {
      const isEditing = !!idInput.value;
      const url = isEditing ? `/api/entries/${idInput.value}` : '/api/entries';
      const method = isEditing ? 'PATCH' : 'POST';

      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          content,
          hoursStudied,
          studyType,
          focusRating: focusRating > 0 ? focusRating : undefined,
          examType: examTypeInput.value || undefined,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed to save entry' }));
        throw new Error(err.error || `HTTP ${res.status}`);
      }

      showSuccess();
      try { localStorage.setItem('sl-checklist-entry', '1'); } catch(e) {}
    } catch (err) {
      showError(err instanceof Error ? err.message : 'Something went wrong');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-symbols-outlined">save</span> ' + (idInput.value ? 'Update Entry' : 'Save Daily Log');
    }
  });

  function showSuccess() {
    submitBtn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Saved Successfully!';
    submitBtn.classList.remove('bg-indigo-600');
    submitBtn.classList.add('bg-emerald-600');
    setTimeout(() => {
      window.location.reload();
    }, 1500);
  }

  function showError(msg) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }
</script>

<style>
  .hidden { display: none !important; }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style>
