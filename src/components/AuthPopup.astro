<div class="ds-overlay hidden" id="auth-popup">
  <div class="ds-modal ds-modal-sm" style="position:relative;padding-bottom:var(--ds-space-3);">

    <!-- Close button -->
    <button id="auth-popup-close" style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:none;color:var(--ds-text-muted);font-size:1.25rem;cursor:pointer;line-height:1;width:2rem;height:2rem;display:flex;align-items:center;justify-content:center;border-radius:var(--ds-radius-md);transition:background var(--ds-transition-fast);" aria-label="Close">&times;</button>

    <!-- Header -->
    <div style="text-align:center;margin-bottom:var(--ds-space-3);padding-top:var(--ds-space-1);">
      <h2 class="ds-heading-section" id="auth-popup-title" style="margin:0 0 0.25rem;font-size:var(--ds-text-lg);">Welcome back</h2>
      <p class="ds-caption" id="auth-popup-sub" style="margin:0;">Log in to continue your study journey</p>
    </div>

    <!-- Tabs -->
    <div class="ds-tabs" style="margin-bottom:var(--ds-space-2);">
      <button class="ds-tab active" data-tab="login" id="tab-login">Log In</button>
      <button class="ds-tab" data-tab="signup" id="tab-signup">Sign Up</button>
    </div>

    <!-- Login form -->
    <form id="login-form" style="display:flex;flex-direction:column;gap:var(--ds-space-2);">
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-email" class="ds-label-form">Email</label>
        <input type="email" id="popup-email" class="ds-input" placeholder="you@example.com" required autocomplete="email" />
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-password" class="ds-label-form">Password</label>
        <div style="position:relative;">
          <input type="password" id="popup-password" class="ds-input" placeholder="At least 6 characters" required minlength="6" autocomplete="current-password" style="padding-right:2.5rem;" />
          <button type="button" id="popup-password-toggle" style="position:absolute;right:0.5rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--ds-text-muted);cursor:pointer;padding:0.25rem;line-height:1;border-radius:var(--ds-radius-sm);" aria-label="Toggle password visibility">
            <svg id="popup-pw-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg id="popup-pw-eye-off" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>
      <div class="ds-error-text hidden" id="popup-error" style="padding:var(--ds-space-1) var(--ds-space-2);background:var(--ds-danger-bg);border:1px solid var(--ds-danger-border);border-radius:var(--ds-radius-md);"></div>
      <button type="submit" class="ds-btn ds-btn-primary ripple-btn" id="popup-submit-btn" style="width:100%;margin-top:var(--ds-space-1);">Log in</button>
    </form>

    <!-- Signup form -->
    <form id="signup-form" class="hidden" style="display:flex;flex-direction:column;gap:var(--ds-space-2);">
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-name" class="ds-label-form">Name</label>
        <input type="text" id="popup-name" class="ds-input" placeholder="Your name" required autocomplete="name" />
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-signup-email" class="ds-label-form">Email</label>
        <input type="email" id="popup-signup-email" class="ds-input" placeholder="you@example.com" required autocomplete="email" />
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-signup-password" class="ds-label-form">Password</label>
        <div style="position:relative;">
          <input type="password" id="popup-signup-password" class="ds-input" placeholder="At least 6 characters" required minlength="6" autocomplete="new-password" style="padding-right:2.5rem;" />
          <button type="button" id="popup-signup-password-toggle" style="position:absolute;right:0.5rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--ds-text-muted);cursor:pointer;padding:0.25rem;line-height:1;border-radius:var(--ds-radius-sm);" aria-label="Toggle password visibility">
            <svg id="signup-pw-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg id="signup-pw-eye-off" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>
      <div class="ds-error-text hidden" id="popup-signup-error" style="padding:var(--ds-space-1) var(--ds-space-2);background:var(--ds-danger-bg);border:1px solid var(--ds-danger-border);border-radius:var(--ds-radius-md);"></div>
      <button type="submit" class="ds-btn ds-btn-primary ripple-btn" id="popup-signup-btn" style="width:100%;margin-top:var(--ds-space-1);">Create account</button>
    </form>

    <!-- Footer -->
    <div style="margin-top:var(--ds-space-2);display:flex;flex-direction:column;align-items:center;gap:var(--ds-space-1);">
      <p style="font-size:var(--ds-text-2xs);color:var(--ds-text-muted);margin:0;">An account is required to use StudyLog. Your data stays safe across updates.</p>
      <a href="/" id="auth-popup-home" class="ds-link" style="font-size:var(--ds-text-2xs);color:var(--ds-text-muted);">Back to Home</a>
    </div>
  </div>
</div>

<script>
(function () {
  const popup = document.getElementById('auth-popup');
  const closeBtn = document.getElementById('auth-popup-close');

  const tabLogin = document.getElementById('tab-login');
  const tabSignup = document.getElementById('tab-signup');
  const loginForm = document.getElementById('login-form');
  const signupForm = document.getElementById('signup-form');
  const popupTitle = document.getElementById('auth-popup-title');
  const popupSub = document.getElementById('auth-popup-sub');

  const loginEmail = document.getElementById('popup-email');
  const loginPassword = document.getElementById('popup-password');
  const loginError = document.getElementById('popup-error');
  const loginBtn = document.getElementById('popup-submit-btn');

  const signupName = document.getElementById('popup-name');
  const signupEmail = document.getElementById('popup-signup-email');
  const signupPassword = document.getElementById('popup-signup-password');
  const signupError = document.getElementById('popup-signup-error');
  const signupBtn = document.getElementById('popup-signup-btn');

  // ── Password visibility toggles ──
  function setupPasswordToggle(inputId, eyeId, eyeOffId, toggleId) {
    const input = document.getElementById(inputId);
    const eye = document.getElementById(eyeId);
    const eyeOff = document.getElementById(eyeOffId);
    const toggle = document.getElementById(toggleId);
    if (!input || !toggle) return;
    toggle.addEventListener('click', () => {
      const show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      eye.classList.toggle('hidden', !show);
      eyeOff.classList.toggle('hidden', show);
    });
  }
  setupPasswordToggle('popup-password', 'popup-pw-eye', 'popup-pw-eye-off', 'popup-password-toggle');
  setupPasswordToggle('popup-signup-password', 'signup-pw-eye', 'signup-pw-eye-off', 'popup-signup-password-toggle');

  // ── Global open function ──
  window.openAuthPopup = function (tab) {
    popup.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (tab === 'signup') showTab('signup');
    else showTab('login');
  };

  // ── Tab switching ──
  function showTab(tab) {
    const isLogin = tab === 'login';
    tabLogin.classList.toggle('active', isLogin);
    tabSignup.classList.toggle('active', !isLogin);
    loginForm.classList.toggle('hidden', !isLogin);
    signupForm.classList.toggle('hidden', isLogin);
    popupTitle.textContent = isLogin ? 'Welcome back' : 'Create your account';
    popupSub.textContent = isLogin ? 'Log in to continue your study journey' : 'Start tracking your study journey';
  }

  tabLogin.addEventListener('click', () => showTab('login'));
  tabSignup.addEventListener('click', () => showTab('signup'));

  // ── Close ──
  function closePopup() {
    popup.classList.add('hidden');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closePopup);
  popup.addEventListener('click', (e) => {
    if (e.target === popup) closePopup();
  });

  // ── Login submit ──
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.classList.add('hidden');
    loginBtn.disabled = true;
    loginBtn.textContent = 'Logging in...';

    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: loginEmail.value.trim(),
          password: loginPassword.value,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Login failed');

      window.location.reload();
    } catch (err) {
      loginError.textContent = err instanceof Error ? err.message : 'Something went wrong';
      loginError.classList.remove('hidden');
      loginBtn.disabled = false;
      loginBtn.textContent = 'Log in';
    }
  });

  // ── Signup submit ──
  signupForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    signupError.classList.add('hidden');
    signupBtn.disabled = true;
    signupBtn.textContent = 'Creating account...';

    const name = signupName.value.trim();
    if (!name) {
      signupError.textContent = 'Name is required';
      signupError.classList.remove('hidden');
      signupBtn.disabled = false;
      signupBtn.textContent = 'Create account';
      return;
    }
    if (signupPassword.value.length < 6) {
      signupError.textContent = 'Password must be at least 6 characters';
      signupError.classList.remove('hidden');
      signupBtn.disabled = false;
      signupBtn.textContent = 'Create account';
      return;
    }

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email: signupEmail.value.trim(),
          password: signupPassword.value,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Signup failed');

      window.location.href = '/onboarding';
    } catch (err) {
      signupError.textContent = err instanceof Error ? err.message : 'Something went wrong';
      signupError.classList.remove('hidden');
      signupBtn.disabled = false;
      signupBtn.textContent = 'Create account';
    }
  });
})();
</script>

<style>
  .hidden { display: none !important; }
  #auth-popup-close:hover { background: var(--ds-bg-hover); color: var(--ds-text-primary); }
</style>
