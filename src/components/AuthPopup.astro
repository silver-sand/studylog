<div class="ds-overlay hidden" id="auth-popup">
  <div class="ds-modal ds-modal-sm" style="position:relative;">

    <!-- Close button -->
    <button id="auth-popup-close" style="position:absolute;top:var(--ds-space-3);right:var(--ds-space-3);background:none;border:none;color:var(--ds-text-muted);font-size:1.25rem;cursor:pointer;line-height:1;padding:var(--ds-space-1);border-radius:var(--ds-radius-sm);" aria-label="Close">&times;</button>

    <!-- Tabs -->
    <div class="ds-tabs" style="margin-bottom:var(--ds-space-5);">
      <button class="ds-tab active" data-tab="login" id="tab-login">Log In</button>
      <button class="ds-tab" data-tab="signup" id="tab-signup">Sign Up</button>
    </div>

    <div style="text-align:center;margin-bottom:var(--ds-space-5);">
      <h2 class="ds-heading-section" id="auth-popup-title" style="margin:0 0 0.25rem;">Welcome back</h2>
      <p class="ds-caption" id="auth-popup-sub" style="margin:0;">Log in to continue your study journey</p>
    </div>

    <!-- Login form -->
    <form id="login-form" style="display:flex;flex-direction:column;gap:var(--ds-space-3-5);">
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-email" class="ds-label-form">Email</label>
        <input type="email" id="popup-email" class="ds-input" placeholder="you@example.com" required autocomplete="email" />
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-password" class="ds-label-form">Password</label>
        <input type="password" id="popup-password" class="ds-input" placeholder="At least 6 characters" required minlength="6" autocomplete="current-password" />
      </div>
      <div class="ds-error-text hidden" id="popup-error" style="padding:var(--ds-space-1-5) var(--ds-space-3);background:var(--ds-danger-bg);border:1px solid var(--ds-danger-border);border-radius:var(--ds-radius-md);"></div>
      <button type="submit" class="ds-btn ds-btn-primary" id="popup-submit-btn" style="width:100%;">Log in</button>
    </form>

    <!-- Signup form -->
    <form id="signup-form" class="hidden" style="display:flex;flex-direction:column;gap:var(--ds-space-3-5);">
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-name" class="ds-label-form">Name</label>
        <input type="text" id="popup-name" class="ds-input" placeholder="Your name" required autocomplete="name" />
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-signup-email" class="ds-label-form">Email</label>
        <input type="email" id="popup-signup-email" class="ds-input" placeholder="you@example.com" required autocomplete="email" />
      </div>
      <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
        <label for="popup-signup-password" class="ds-label-form">Password</label>
        <input type="password" id="popup-signup-password" class="ds-input" placeholder="At least 6 characters" required minlength="6" autocomplete="new-password" />
      </div>
      <div class="ds-error-text hidden" id="popup-signup-error" style="padding:var(--ds-space-1-5) var(--ds-space-3);background:var(--ds-danger-bg);border:1px solid var(--ds-danger-border);border-radius:var(--ds-radius-md);"></div>
      <button type="submit" class="ds-btn ds-btn-primary" id="popup-signup-btn" style="width:100%;">Create account</button>
    </form>

    <!-- Footer links -->
    <div style="margin-top:var(--ds-space-4);display:flex;flex-direction:column;align-items:center;gap:var(--ds-space-2);">
      <a href="/daily" id="auth-popup-guest" class="ds-link" style="font-size:var(--ds-text-sm);">Continue as Guest</a>
      <a href="/" id="auth-popup-home" class="ds-link" style="font-size:var(--ds-text-xs);color:var(--ds-text-muted);">Back to Home</a>
    </div>
  </div>
</div>

<script>
(function () {
  const popup = document.getElementById('auth-popup');
  const closeBtn = document.getElementById('auth-popup-close');

  const tabLogin = document.getElementById('tab-login');
  const tabSignup = document.getElementById('tab-signup');
  const loginForm = document.getElementById('login-form');
  const signupForm = document.getElementById('signup-form');
  const popupTitle = document.getElementById('auth-popup-title');
  const popupSub = document.getElementById('auth-popup-sub');

  const loginEmail = document.getElementById('popup-email');
  const loginPassword = document.getElementById('popup-password');
  const loginError = document.getElementById('popup-error');
  const loginBtn = document.getElementById('popup-submit-btn');

  const signupName = document.getElementById('popup-name');
  const signupEmail = document.getElementById('popup-signup-email');
  const signupPassword = document.getElementById('popup-signup-password');
  const signupError = document.getElementById('popup-signup-error');
  const signupBtn = document.getElementById('popup-signup-btn');

  // ── Global open function (called from sidebar buttons) ──
  window.openAuthPopup = function (tab) {
    popup.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (tab === 'signup') showTab('signup');
    else showTab('login');
  };

  // ── Tab switching ──
  function showTab(tab) {
    const isLogin = tab === 'login';
    tabLogin.classList.toggle('active', isLogin);
    tabSignup.classList.toggle('active', !isLogin);
    loginForm.classList.toggle('hidden', !isLogin);
    signupForm.classList.toggle('hidden', isLogin);
    popupTitle.textContent = isLogin ? 'Welcome back' : 'Create your account';
    popupSub.textContent = isLogin ? 'Log in to continue your study journey' : 'Start tracking your study journey';
  }

  tabLogin.addEventListener('click', () => showTab('login'));
  tabSignup.addEventListener('click', () => showTab('signup'));

  // ── Close ──
  function closePopup() {
    popup.classList.add('hidden');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closePopup);
  popup.addEventListener('click', (e) => {
    if (e.target === popup) closePopup();
  });

  // ── Login submit ──
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.classList.add('hidden');
    loginBtn.disabled = true;
    loginBtn.textContent = 'Logging in...';

    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: loginEmail.value.trim(),
          password: loginPassword.value,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Login failed');

      window.location.reload();
    } catch (err) {
      loginError.textContent = err instanceof Error ? err.message : 'Something went wrong';
      loginError.classList.remove('hidden');
      loginBtn.disabled = false;
      loginBtn.textContent = 'Log in';
    }
  });

  // ── Signup submit (converts guest to authenticated) ──
  signupForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    signupError.classList.add('hidden');
    signupBtn.disabled = true;
    signupBtn.textContent = 'Creating account...';

    const name = signupName.value.trim();
    if (!name) {
      signupError.textContent = 'Name is required';
      signupError.classList.remove('hidden');
      signupBtn.disabled = false;
      signupBtn.textContent = 'Create account';
      return;
    }
    if (signupPassword.value.length < 6) {
      signupError.textContent = 'Password must be at least 6 characters';
      signupError.classList.remove('hidden');
      signupBtn.disabled = false;
      signupBtn.textContent = 'Create account';
      return;
    }

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email: signupEmail.value.trim(),
          password: signupPassword.value,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Signup failed');

      window.location.href = '/onboarding';
    } catch (err) {
      signupError.textContent = err instanceof Error ? err.message : 'Something went wrong';
      signupError.classList.remove('hidden');
      signupBtn.disabled = false;
      signupBtn.textContent = 'Create account';
    }
  });
})();
</script>

<style>
  .hidden { display: none !important; }
</style>

