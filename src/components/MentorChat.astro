---
export interface Props {
  title?: string;
}

const { title = 'AI Mentor' } = Astro.props;
---

<div class="mentor-chat" id="mentor-chat">
  <div class="chat-header">
    <div class="chat-title-row">
      <span class="chat-icon">🧠</span>
      <div>
        <h3 class="chat-title">{title}</h3>
        <p class="chat-subtitle">Your AI study partner</p>
      </div>
    </div>
  </div>

  <div class="messages-area" id="messages-area">
    <div class="message mentor welcome">
      <div class="msg-content">
        <p>Hi! I'm your AI study mentor. I can see your study history and syllabus progress.</p>
        <p>Try asking me:</p>
        <ul class="suggestion-list">
          <li>"What should I study today?"</li>
          <li>"Quiz me on Physics"</li>
          <li>"I'm stuck on [topic], help me understand"</li>
          <li>"What are my weak areas?"</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="input-area">
    <div class="chips" id="chips">
      <button class="chip" data-prompt="What should I study today?">📚 What to study?</button>
      <button class="chip" data-prompt="Quiz me on something I studied recently">❓ Quiz me</button>
      <button class="chip" data-prompt="What are my weak areas?">⚠️ Weak areas</button>
    </div>
    <div class="input-row">
      <textarea
        id="mentor-input"
        class="mentor-input"
        placeholder="Ask your mentor..."
        rows="1"
      ></textarea>
      <button id="send-btn" class="send-btn" disabled>
        <span>Send</span>
      </button>
    </div>
    <p class="disclaimer">Responses are AI-generated. Verify critical information independently.</p>
  </div>
</div>

<script>
  const messagesArea = document.getElementById('messages-area');
  const input = document.getElementById('mentor-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;

  let isStreaming = false;
  let history: { role: string; content: string }[] = [];

  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }

  input.addEventListener('input', autoResize);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  input.addEventListener('input', () => {
    sendBtn.disabled = input.value.trim().length === 0 || isStreaming;
  });

  // Chip buttons
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const prompt = chip.dataset.prompt;
      if (prompt && !isStreaming) {
        input.value = prompt;
        autoResize();
        sendBtn.disabled = false;
        sendMessage();
      }
    });
  });

  function addMessage(role: string, content: string, isStreaming_ = false) {
    const div = document.createElement('div');
    div.className = `message ${role}`;
    if (isStreaming_) div.classList.add('streaming');

    const inner = document.createElement('div');
    inner.className = 'msg-content';

    if (role === 'user') {
      inner.innerHTML = `<p>${escapeHtml(content)}</p>`;
    } else {
      inner.innerHTML = renderMarkdown(content);
    }

    div.appendChild(inner);
    messagesArea.appendChild(div);
    messagesArea.scrollTop = messagesArea.scrollHeight;
    return inner;
  }

  function getLastMentorContent(): HTMLElement | null {
    const msgs = messagesArea.querySelectorAll('.message.mentor.streaming');
    if (msgs.length > 0) {
      const el = msgs[msgs.length - 1].querySelector('.msg-content') as HTMLElement;
      return el;
    }
    return null;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderMarkdown(text: string): string {
    // Simple markdown rendering
    let html = escapeHtml(text);

    // Code blocks
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>');

    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

    // Bold
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

    // Italic
    html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');

    // Blockquotes
    html = html.replace(/^>\s*(.+)$/gm, '<blockquote>$1</blockquote>');

    // Unordered lists
    html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
    html = html.replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul>$1</ul>');

    // Ordered lists
    html = html.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');

    // Paragraphs (double newlines)
    html = html.replace(/\n\n/g, '</p><p>');
    html = html.replace(/^(.+)$/gm, (match) => {
      if (match.startsWith('<') || match.startsWith('</p>')) return match;
      return match;
    });

    // Single newlines within paragraphs
    html = html.replace(/([^>])\n(?!\n)/g, '$1<br>');

    return `<p>${html}</p>`;
  }

  async function sendMessage() {
    const text = input.value.trim();
    if (!text || isStreaming) return;

    input.value = '';
    autoResize();
    sendBtn.disabled = true;

    // Add user message
    addMessage('user', text);
    history.push({ role: 'user', content: text });

    // Add placeholder mentor message
    addMessage('mentor', '▊', true);
    isStreaming = true;

    try {
      const res = await fetch('/api/mentor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: text, history: history.slice(-6) }), // last 3 exchanges
      });

      if (!res.ok) throw new Error('Failed to get response');

      const reader = res.body?.getReader();
      if (!reader) throw new Error('No response stream');

      const decoder = new TextDecoder();
      let buffer = '';
      let fullResponse = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          try {
            const data = JSON.parse(line.slice(6));
            if (data.type === 'chunk') {
              fullResponse += data.text;
              const contentEl = getLastMentorContent();
              if (contentEl) {
                contentEl.innerHTML = renderMarkdown(fullResponse);
              }
              messagesArea.scrollTop = messagesArea.scrollHeight;
            } else if (data.type === 'done') {
              // Done — finalize
            } else if (data.type === 'error') {
              const contentEl = getLastMentorContent();
              if (contentEl) {
                contentEl.innerHTML = `<p class="error-msg">Error: ${escapeHtml(data.text)}</p>`;
              }
            }
          } catch {}
        }
      }

      // Finalize the streaming message
      const streamingMsg = messagesArea.querySelector('.message.mentor.streaming');
      if (streamingMsg) {
        streamingMsg.classList.remove('streaming');
        if (fullResponse) {
          history.push({ role: 'mentor', content: fullResponse });
        }
      }

    } catch (err) {
      const contentEl = getLastMentorContent();
      if (contentEl) {
        contentEl.innerHTML = `<p class="error-msg">Failed to get response. Please try again.</p>`;
      }
      const streamingMsg = messagesArea.querySelector('.message.mentor.streaming');
      if (streamingMsg) streamingMsg.classList.remove('streaming');
    } finally {
      isStreaming = false;
      sendBtn.disabled = input.value.trim().length === 0;
    }
  }
</script>

<style>
  .mentor-chat {
    display: flex;
    flex-direction: column;
    height: 70vh;
    max-height: 700px;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .chat-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(51, 65, 85, 0.3);
    flex-shrink: 0;
  }
  .chat-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .chat-icon {
    font-size: 1.5rem;
  }
  .chat-title {
    font-size: 1rem;
    font-weight: 600;
    color: #e2e8f0;
    margin: 0;
  }
  .chat-subtitle {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0.1rem 0 0;
  }
  .messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .message {
    max-width: 88%;
  }
  .message.user {
    align-self: flex-end;
  }
  .message.mentor {
    align-self: flex-start;
  }
  .msg-content {
    padding: 0.6rem 0.9rem;
    border-radius: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .message.user .msg-content {
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.25);
    color: #cbd5e1;
  }
  .message.mentor .msg-content {
    background: rgba(30, 41, 59, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    color: #cbd5e1;
  }
  .message.mentor .msg-content p {
    margin: 0.3rem 0;
  }
  .message.mentor .msg-content p:first-child {
    margin-top: 0;
  }
  .message.mentor .msg-content p:last-child {
    margin-bottom: 0;
  }
  .message.mentor .msg-content ul, .message.mentor .msg-content ol {
    margin: 0.3rem 0;
    padding-left: 1.2rem;
  }
  .message.mentor .msg-content li {
    margin: 0.15rem 0;
  }
  .message.mentor .msg-content code {
    background: rgba(15, 23, 42, 0.6);
    padding: 0.1rem 0.3rem;
    border-radius: 0.25rem;
    font-size: 0.8rem;
    font-family: 'JetBrains Mono', monospace;
    color: #93c5fd;
  }
  .message.mentor .msg-content pre {
    background: rgba(15, 23, 42, 0.6);
    padding: 0.75rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 0.5rem 0;
  }
  .message.mentor .msg-content pre code {
    background: none;
    padding: 0;
  }
  .message.mentor .msg-content blockquote {
    border-left: 3px solid rgba(59, 130, 246, 0.4);
    padding-left: 0.75rem;
    margin: 0.5rem 0;
    color: #94a3b8;
  }
  .suggestion-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .suggestion-list li {
    font-size: 0.8rem;
    color: #64748b;
    padding: 0.15rem 0;
    font-family: 'JetBrains Mono', monospace;
  }
  .message.streaming .msg-content::after {
    content: '▊';
    animation: blink 0.8s infinite;
    color: #3b82f6;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .input-area {
    flex-shrink: 0;
    padding: 0.75rem 1.25rem 1rem;
    border-top: 1px solid rgba(51, 65, 85, 0.3);
  }
  .chips {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }
  .chip {
    font-size: 0.7rem;
    padding: 0.3rem 0.6rem;
    border-radius: 0.5rem;
    background: rgba(30, 41, 59, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.4);
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .chip:hover {
    border-color: rgba(71, 85, 105, 0.7);
    color: #e2e8f0;
  }
  .input-row {
    display: flex;
    gap: 0.5rem;
  }
  .mentor-input {
    flex: 1;
    padding: 0.6rem 0.75rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.6);
    border-radius: 0.5rem;
    color: #e2e8f0;
    font-size: 0.85rem;
    font-family: 'Inter', sans-serif;
    resize: none;
    outline: none;
    transition: border-color 0.15s;
    max-height: 120px;
  }
  .mentor-input:focus {
    border-color: rgba(59, 130, 246, 0.5);
  }
  .mentor-input::placeholder {
    color: #475569;
  }
  .send-btn {
    padding: 0.6rem 1rem;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.825rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
    align-self: flex-end;
  }
  .send-btn:hover:not(:disabled) {
    background: #3b82f6;
  }
  .send-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .disclaimer {
    font-size: 0.6rem;
    color: #475569;
    text-align: center;
    margin: 0.4rem 0 0;
  }
  .error-msg {
    color: #f87171;
  }
</style>
