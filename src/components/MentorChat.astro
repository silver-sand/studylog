---
export interface Props {
  title?: string;
}

const { title = 'AI Mentor' } = Astro.props;

const quickActions = [
  { icon: 'summarize', label: 'Analyze my week', prompt: 'Analyze my study patterns this week and give me insights on what I should focus on.' },
  { icon: 'science', label: 'Explain a concept', prompt: 'Explain a physics concept I should know for competitive exams.' },
  { icon: 'calendar_month', label: 'Suggest study plan', prompt: 'Suggest a study plan for the next week based on common competitive exam syllabi.' },
  { icon: 'quiz', label: 'Quiz me', prompt: 'Quiz me on something I recently studied.' },
];
---

<div class="flex-1 flex flex-col h-full relative" id="mentor-chat">
  <!-- Chat Messages Canvas -->
  <div class="flex-1 overflow-y-auto scroll-smooth" id="chat-container">
    <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8" id="messages-area">
      <!-- ── Empty State ── -->
      <div id="empty-state" class="flex flex-col items-center justify-center min-h-[65vh] text-center">
        <!-- Glow avatar -->
        <div class="relative mb-8">
          <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-indigo-500/15 via-purple-500/10 to-indigo-500/5 border border-indigo-500/20 flex items-center justify-center shadow-xl shadow-indigo-500/10">
            <span class="material-symbols-outlined text-4xl text-indigo-400" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
          </div>
          <div class="absolute -bottom-1 -right-1 w-7 h-7 rounded-full bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center">
            <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-sm shadow-emerald-500/50"></span>
          </div>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">
          What would you like to know?
        </h2>
        <p class="text-neutral-500 text-sm md:text-base max-w-md mb-10 leading-relaxed">
          Get instant answers, personalized insights, and deep explanations — all tailored to your competitive exam journey.
        </p>

        <!-- Quick Action Grid -->
        <div class="grid grid-cols-2 gap-3 w-full max-w-xl mb-6">
          {quickActions.map(action => (
            <button
              class="quick-action-btn group relative flex items-center gap-3 p-4 rounded-xl bg-[#0d1321]/60 border border-white/[0.06] hover:border-indigo-500/20 hover:bg-indigo-500/5 transition-all duration-200 text-left"
              data-prompt={action.prompt}
            >
              <div class="w-9 h-9 rounded-lg bg-indigo-500/10 border border-indigo-500/10 flex items-center justify-center shrink-0 group-hover:bg-indigo-500/20 group-hover:border-indigo-500/20 transition-all">
                <span class="material-symbols-outlined text-lg text-indigo-400">{action.icon}</span>
              </div>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{action.label}</span>
            </button>
          ))}
        </div>

        <!-- Model selector in empty state -->
        <div class="flex items-center gap-2 text-xs text-neutral-600">
          <span>Powered by</span>
          <div class="relative inline-block">
            <select id="empty-model-select" class="appearance-none bg-[#0d1321] border border-white/10 rounded-lg px-3 py-1.5 pr-8 text-neutral-300 text-xs cursor-pointer hover:border-indigo-500/30 focus:outline-none focus:border-indigo-500/40 transition-colors">
              <option value="gemini">Gemini 2.0</option>
              <option value="groq">Groq</option>
              <option value="llama">Llama 3</option>
            </select>
            <span class="absolute right-2 top-1/2 -translate-y-1/2 text-neutral-500 pointer-events-none material-symbols-outlined text-[14px]">expand_more</span>
          </div>
        </div>
      </div>

      <!-- ── History Messages ── -->
      <div id="history-messages" class="py-6 space-y-6" style="display: none;"></div>
    </div>
  </div>

  <!-- ── Input Area ── -->
  <div class="shrink-0 border-t border-white/[0.04] bg-gradient-to-t from-[#050b18] via-[#050b18]/98 to-transparent pt-4 pb-5 px-4 md:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Active Context Chips (shown in chat mode) -->
      <div id="context-chips" class="flex flex-wrap gap-2 mb-3" style="display: none;">
        <button class="context-chip px-3 py-1.5 rounded-lg bg-[#0d1321]/60 border border-white/[0.06] text-[11px] text-neutral-500 hover:text-neutral-300 hover:border-indigo-500/20 hover:bg-indigo-500/5 transition-all" data-prompt="Analyze my study patterns this week and give me insights.">
          <span class="material-symbols-outlined text-[14px] align-middle mr-1">summarize</span>
          Analyze my week
        </button>
        <button class="context-chip px-3 py-1.5 rounded-lg bg-[#0d1321]/60 border border-white/[0.06] text-[11px] text-neutral-500 hover:text-neutral-300 hover:border-indigo-500/20 hover:bg-indigo-500/5 transition-all" data-prompt="Explain a physics concept I should know for competitive exams.">
          <span class="material-symbols-outlined text-[14px] align-middle mr-1">science</span>
          Explain concept
        </button>
        <button class="context-chip px-3 py-1.5 rounded-lg bg-[#0d1321]/60 border border-white/[0.06] text-[11px] text-neutral-500 hover:text-neutral-300 hover:border-indigo-500/20 hover:bg-indigo-500/5 transition-all" data-prompt="Suggest a study plan for the next week.">
          <span class="material-symbols-outlined text-[14px] align-middle mr-1">calendar_month</span>
          Study plan
        </button>
      </div>

      <!-- Gradient Glass Input -->
      <div class="gradient-glass-input relative flex items-end gap-1.5 bg-[#0d1321]/80 backdrop-blur-xl border border-white/[0.07] rounded-2xl p-1.5 focus-within:border-indigo-500/25 focus-within:ring-1 focus-within:ring-indigo-500/15 transition-all duration-300 shadow-lg shadow-black/20" id="input-container">
        <!-- Model Selector Dropdown -->
        <div class="relative shrink-0" id="model-selector-group">
          <button id="model-select-btn" class="model-select-btn flex items-center gap-1.5 px-2.5 py-2.5 rounded-xl text-[11px] text-neutral-500 hover:text-neutral-300 hover:bg-white/[0.04] transition-colors border border-transparent hover:border-white/[0.06]">
            <span class="material-symbols-outlined text-[16px] text-indigo-400/70" id="model-icon">auto_awesome</span>
            <span id="model-name" class="hidden sm:inline font-medium">Gemini 2.0</span>
            <span class="material-symbols-outlined text-[14px] -mr-1">expand_more</span>
          </button>
          <div id="model-dropdown" class="absolute bottom-full left-0 mb-2 w-48 bg-[#0d1321] border border-white/[0.08] rounded-xl shadow-2xl shadow-black/50 overflow-hidden z-50 backdrop-blur-xl" style="display: none;">
            <div class="py-1">
              <button class="model-option flex items-center gap-3 w-full px-4 py-2.5 text-xs text-neutral-400 hover:bg-indigo-500/10 hover:text-indigo-300 transition-colors" data-model="gemini" data-icon="auto_awesome">
                <span class="material-symbols-outlined text-[18px] text-indigo-400/70">auto_awesome</span>
                <div class="text-left">
                  <div class="font-medium">Gemini 2.0</div>
                  <div class="text-[10px] text-neutral-600">Fast & capable</div>
                </div>
                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-emerald-500/60"></span>
              </button>
              <button class="model-option flex items-center gap-3 w-full px-4 py-2.5 text-xs text-neutral-400 hover:bg-indigo-500/10 hover:text-indigo-300 transition-colors" data-model="groq" data-icon="bolt">
                <span class="material-symbols-outlined text-[18px] text-neutral-500">bolt</span>
                <div class="text-left">
                  <div class="font-medium">Groq</div>
                  <div class="text-[10px] text-neutral-600">Lightning fast</div>
                </div>
              </button>
              <button class="model-option flex items-center gap-3 w-full px-4 py-2.5 text-xs text-neutral-400 hover:bg-indigo-500/10 hover:text-indigo-300 transition-colors" data-model="llama" data-icon="psychiatry">
                <span class="material-symbols-outlined text-[18px] text-neutral-500">psychiatry</span>
                <div class="text-left">
                  <div class="font-medium">Llama 3</div>
                  <div class="text-[10px] text-neutral-600">Deep reasoning</div>
                </div>
              </button>
            </div>
          </div>
        </div>

        <div class="h-7 w-px bg-white/[0.06] shrink-0"></div>

        <!-- Attachment Button -->
        <button id="attach-btn" class="p-2.5 text-neutral-600 hover:text-indigo-400 hover:bg-indigo-500/10 rounded-xl transition-all shrink-0 group relative" title="Upload image or file">
          <span class="material-symbols-outlined text-[20px]">attach_file</span>
          <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-neutral-800 text-[10px] text-white rounded-md opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-lg">
            Upload Image
          </span>
        </button>

        <!-- Textarea -->
        <textarea
          id="mentor-input"
          class="w-full bg-transparent border-none text-neutral-200 placeholder-neutral-600 focus:ring-0 resize-none py-3 max-h-36 min-h-[44px] text-sm leading-relaxed tracking-wide"
          placeholder="Ask anything about your studies..."
          rows="1"
        ></textarea>

        <!-- Send Button -->
        <button id="send-btn" class="p-2.5 bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-400 text-white rounded-xl transition-all shrink-0 flex items-center justify-center h-[44px] w-[44px] shadow-sm shadow-indigo-500/20 disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:bg-indigo-600" disabled>
          <span class="material-symbols-outlined text-[20px]">arrow_upward</span>
        </button>
      </div>

      <!-- Footer -->
      <div class="flex justify-between items-center px-3 mt-2.5">
        <span class="text-[10px] text-neutral-700 tracking-wide">
          <span class="hidden sm:inline">Shift + Enter for new line · </span>$ for inline math · ``` for code
        </span>
        <span class="text-[10px] flex items-center gap-1.5" id="ai-status">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500/70 shadow-sm shadow-emerald-500/20"></span>
          <span class="text-emerald-500/60">AI ready</span>
        </span>
      </div>
    </div>
  </div>
</div>

<script>
  import katex from 'katex';

  // ── KaTeX rendering ──
  function renderMath(text) {
    if (!text) return text;
    try {
      text = text.replace(/\$\$(.+?)\$\$/gs, (_, expr) => {
        try { return katex.renderToString(expr.trim(), { displayMode: true, throwOnError: false }); }
        catch(e) { return `$$${expr}$$`; }
      });
      text = text.replace(/\$(.+?)\$/g, (_, expr) => {
        try { return katex.renderToString(expr.trim(), { displayMode: false, throwOnError: false }); }
        catch(e) { return `$${expr}$`; }
      });
    } catch(e) {}
    return text;
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderMarkdown(text) {
    if (!text) return '<div class="text-neutral-400 text-sm italic">Empty response</div>';
    let html = escapeHtml(text);
    // Code blocks
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre class="p-4 rounded-xl bg-[#0a0f1a] border border-white/[0.06] text-sm text-indigo-300/80 overflow-x-auto my-4 font-mono leading-relaxed"><code>$2</code></pre>');
    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code class="px-1.5 py-0.5 rounded-md bg-[#0a0f1a] text-indigo-300/80 text-xs font-mono border border-white/[0.04]">$1</code>');
    // Bold
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="font-semibold text-white">$1</strong>');
    // Italic
    html = html.replace(/\*(.+?)\*/g, '<em class="text-neutral-300">$1</em>');
    // Line breaks
    html = html.replace(/\n\n/g, '</p><p class="text-neutral-300 leading-[1.75]">');
    html = html.replace(/\n/g, '<br/>');
    // LaTeX
    html = renderMath(html);
    return `<p class="text-neutral-300 leading-[1.75]">${html}</p>`;
  }

  // ── State ──
  const CHAT_STORAGE_KEY = 'sl-mentor-history';
  const MODEL_STORAGE_KEY = 'sl-mentor-model';
  const messagesArea = document.getElementById('messages-area');
  const input = document.getElementById('mentor-input');
  const sendBtn = document.getElementById('send-btn');
  const chatContainer = document.getElementById('chat-container');
  const emptyState = document.getElementById('empty-state');
  const historyMessages = document.getElementById('history-messages');
  const contextChips = document.getElementById('context-chips');

  // Model selector
  const modelSelectBtn = document.getElementById('model-select-btn');
  const modelDropdown = document.getElementById('model-dropdown');
  const modelName = document.getElementById('model-name');
  const modelIcon = document.getElementById('model-icon');
  const emptyModelSelect = document.getElementById('empty-model-select');

  let isStreaming = false;
  let history = [];
  let selectedModel = localStorage.getItem(MODEL_STORAGE_KEY) || 'gemini';

  // ── Model selector UI ──
  function updateModelUI(model) {
    const options = document.querySelectorAll('.model-option');
    options.forEach(opt => {
      if (opt.dataset.model === model) {
        const icon = opt.querySelector('.material-symbols-outlined');
        const label = opt.querySelector('.font-medium');
        if (modelName && label) modelName.textContent = label.textContent;
        if (modelIcon && icon) modelIcon.textContent = icon.textContent;
      }
    });
    if (emptyModelSelect) emptyModelSelect.value = model;
    selectedModel = model;
    localStorage.setItem(MODEL_STORAGE_KEY, model);
  }

  function toggleModelDropdown() {
    const isHidden = modelDropdown.style.display === 'none';
    modelDropdown.style.display = isHidden ? 'block' : 'none';
  }

  // ── Toggle empty state / history ──
  function toggleUI(hasHistory) {
    if (hasHistory) {
      emptyState.style.display = 'none';
      historyMessages.style.display = 'block';
      contextChips.style.display = 'flex';
    } else {
      emptyState.style.display = 'flex';
      historyMessages.style.display = 'none';
      contextChips.style.display = 'none';
    }
  }

  // ── History ──
  function loadHistory() {
    try {
      const saved = localStorage.getItem(CHAT_STORAGE_KEY);
      if (saved) {
        const parsed = JSON.parse(saved);
        if (Array.isArray(parsed) && parsed.length > 0) {
          history = parsed.slice(-20);
          return true;
        }
      }
    } catch (e) {}
    return false;
  }

  function saveHistory() {
    try {
      localStorage.setItem(CHAT_STORAGE_KEY, JSON.stringify(history.slice(-20)));
    } catch (e) {}
  }

  function renderHistory() {
    historyMessages.innerHTML = '';
    for (const msg of history) {
      const wrapper = document.createElement('div');
      if (msg.role === 'user') {
        wrapper.className = 'flex justify-end message-entrance';
        wrapper.innerHTML = `<div class="user-bubble max-w-[85%] md:max-w-[75%]">
          <p class="text-neutral-200 leading-relaxed text-sm">${escapeHtml(msg.content)}</p>
        </div>`;
      } else {
        wrapper.className = 'flex gap-3 message-entrance';
        wrapper.innerHTML = `<div class="ai-avatar w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0 mt-1">
          <span class="material-symbols-outlined text-[16px] text-indigo-400" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
        </div>
        <div class="ai-bubble flex-1 max-w-[95%]">
          ${renderMarkdown(msg.content)}
        </div>`;
      }
      historyMessages.appendChild(wrapper);
    }
    chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
  }

  function autoResize() {
    if (input) {
      input.style.height = '';
      input.style.height = Math.min(input.scrollHeight, 144) + 'px';
    }
  }

  // ── Send message ──
  async function sendMessage(text) {
    if (!text.trim() || isStreaming) return;

    const trimmed = text.trim();
    history.push({ role: 'user', content: trimmed });
    if (history.length === 1) toggleUI(true);

    // User bubble
    const userWrapper = document.createElement('div');
    userWrapper.className = 'flex justify-end message-entrance';
    userWrapper.innerHTML = `<div class="user-bubble max-w-[85%] md:max-w-[75%]">
      <p class="text-neutral-200 leading-relaxed text-sm">${escapeHtml(trimmed)}</p>
    </div>`;
    historyMessages.appendChild(userWrapper);

    input.value = '';
    autoResize();
    sendBtn.disabled = true;
    isStreaming = true;
    chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });

    // AI thinking indicator
    const aiWrapper = document.createElement('div');
    aiWrapper.className = 'flex gap-3 message-entrance';
    aiWrapper.id = 'streaming-msg';
    aiWrapper.innerHTML = `<div class="ai-avatar w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0 mt-1">
      <span class="material-symbols-outlined text-[16px] text-indigo-400" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
    </div>
    <div class="ai-bubble flex-1 max-w-[95%]">
      <div class="flex items-center gap-2.5 text-neutral-500 py-1">
        <div class="thinking-dots flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500/60 animate-bounce" style="animation-delay: 0ms;"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500/60 animate-bounce" style="animation-delay: 150ms;"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500/60 animate-bounce" style="animation-delay: 300ms;"></span>
        </div>
        <span class="text-xs italic">Thinking...</span>
      </div>
    </div>`;
    historyMessages.appendChild(aiWrapper);
    chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });

    try {
      const lastMsg = history[history.length - 1];
      const prevHistory = history.slice(0, -1).map(h => ({ role: h.role, content: h.content }));
      const res = await fetch('/api/mentor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: lastMsg.content, history: prevHistory, model: selectedModel }),
      });
      if (!res.ok) throw new Error(`API Error (${res.status})`);

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let reply = '';
      let streamingEl = document.getElementById('streaming-msg');

      // Replace thinking indicator with live streaming bubble
      if (streamingEl) {
        const bubbleDiv = streamingEl.querySelector('.ai-bubble');
        if (bubbleDiv) {
          bubbleDiv.innerHTML = '<div class="text-neutral-300 leading-relaxed text-sm streaming-content"></div>';
        }
      }

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        const chunk = decoder.decode(value, { stream: true });
        const lines = chunk.split('\n');
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          try {
            const data = JSON.parse(line.slice(6));
            if (data.type === 'chunk' && data.text) {
              reply += data.text;
              const msgEl = document.getElementById('streaming-msg');
              if (msgEl) {
                const contentDiv = msgEl.querySelector('.streaming-content');
                if (contentDiv) {
                  contentDiv.innerHTML = renderMarkdown(reply) + '<span class="inline-block w-2 h-4 bg-indigo-400/70 ml-0.5 animate-pulse rounded-sm typewriter-cursor"></span>';
                  chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
                }
              }
            } else if (data.type === 'error') {
              throw new Error(data.text);
            }
          } catch (e) {
            if (e instanceof SyntaxError) continue;
            throw e;
          }
        }
      }

      // Remove streaming msg, add permanent one
      const streaming = document.getElementById('streaming-msg');
      if (streaming) streaming.remove();

      history.push({ role: 'assistant', content: reply });
      saveHistory();

      const aiComplete = document.createElement('div');
      aiComplete.className = 'flex gap-3 message-entrance';
      aiComplete.innerHTML = `<div class="ai-avatar w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/10 border border-indigo-500/20 flex items-center justify-center shrink-0 mt-1">
        <span class="material-symbols-outlined text-[16px] text-indigo-400" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
      </div>
      <div class="ai-bubble flex-1 max-w-[95%]">
        ${renderMarkdown(reply)}
      </div>`;
      historyMessages.appendChild(aiComplete);
      chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
    } catch (err) {
      const streaming = document.getElementById('streaming-msg');
      if (streaming) streaming.remove();

      const errWrapper = document.createElement('div');
      errWrapper.className = 'flex gap-3 message-entrance';
      errWrapper.innerHTML = `<div class="w-8 h-8 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center shrink-0 mt-1">
        <span class="material-symbols-outlined text-[16px] text-red-400">error</span>
      </div>
      <div class="flex-1 bg-red-500/5 border border-red-500/10 rounded-2xl rounded-tl-sm p-4 max-w-[95%]">
        <p class="text-sm text-red-400/80 leading-relaxed">${escapeHtml(err.message)}</p>
        <button onclick="retryLastMessage()" class="mt-2 text-xs text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">refresh</span> Try again
        </button>
      </div>`;
      historyMessages.appendChild(errWrapper);
    } finally {
      isStreaming = false;
      sendBtn.disabled = false;
      chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
    }
  }

  // ── Retry ──
  window.retryLastMessage = function() {
    // If the last entry is user (from a failed stream), pop it to avoid duplication
    if (history.length > 0 && history[history.length - 1].role === 'user') {
      history.pop();
      saveHistory();
    } else if (history.length >= 2 && history[history.length - 1].role === 'assistant') {
      history.pop();
      saveHistory();
    }
    const lastUser = history.filter(m => m.role === 'user').pop();
    if (lastUser) {
      sendMessage(lastUser.content);
    }
  };

  // ── Event listeners ──

  // Model selector toggle
  modelSelectBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleModelDropdown();
  });

  document.addEventListener('click', () => {
    if (modelDropdown) modelDropdown.style.display = 'none';
  });

  modelDropdown?.addEventListener('click', (e) => e.stopPropagation());

  document.querySelectorAll('.model-option').forEach(opt => {
    opt.addEventListener('click', () => {
      updateModelUI(opt.dataset.model);
      modelDropdown.style.display = 'none';
    });
  });

  emptyModelSelect?.addEventListener('change', (e) => {
    updateModelUI(e.target.value);
  });

  // Input
  input?.addEventListener('input', () => {
    autoResize();
    sendBtn.disabled = !input.value.trim() || isStreaming;
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (input.value.trim() && !isStreaming) {
        sendMessage(input.value);
      }
    }
  });

  sendBtn?.addEventListener('click', () => {
    if (input.value.trim() && !isStreaming) {
      sendMessage(input.value);
    }
  });

  // Quick actions (empty state)
  document.querySelectorAll('.quick-action-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const prompt = btn.dataset.prompt;
      if (prompt) sendMessage(prompt);
    });
  });

  // Context chips (chat mode)
  document.querySelectorAll('.context-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const prompt = chip.dataset.prompt;
      if (prompt) sendMessage(prompt);
    });
  });

  // Attachment button
  document.getElementById('attach-btn')?.addEventListener('click', () => {
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/*,.pdf';
    fileInput.onchange = (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        const note = `[Uploaded: ${file.name}] Explain this for me.`;
        input.value = note;
        autoResize();
        sendBtn.disabled = false;
        input.focus();
      };
      reader.readAsDataURL(file);
    };
    fileInput.click();
  });

  // ── Init ──
  const hasHistory = loadHistory();
  if (hasHistory) {
    toggleUI(true);
    renderHistory();
  }
  sendBtn.disabled = true;
  updateModelUI(selectedModel);
</script>

