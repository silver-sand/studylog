---
export interface Props {
  title?: string;
}

const { title = 'AI Mentor' } = Astro.props;
---

<div class="flex-1 flex flex-col h-full relative" id="mentor-chat">
  <!-- Chat Messages -->
  <div class="flex-1 overflow-y-auto p-4 md:p-8 scroll-smooth" id="chat-container">
    <div class="max-w-4xl mx-auto space-y-8 pb-4" id="messages-area">
      <!-- Messages rendered by JS -->
    </div>
  </div>

  <!-- Input Area -->
  <div class="p-4 bg-[#050b18]/90 backdrop-blur-md border-t border-white/5 shrink-0">
    <div class="max-w-4xl mx-auto">
      <!-- Suggestion Chips -->
      <div class="flex flex-wrap gap-2 mb-3" id="chips">
        <button class="suggestion-chip px-3 py-1.5 rounded-lg bg-[#0d1321] border border-white/5 text-xs text-neutral-400 hover:text-neutral-200 hover:border-indigo-500/30 transition-all" data-prompt="What should I study today?">What to study?</button>
        <button class="suggestion-chip px-3 py-1.5 rounded-lg bg-[#0d1321] border border-white/5 text-xs text-neutral-400 hover:text-neutral-200 hover:border-indigo-500/30 transition-all" data-prompt="Quiz me on something I studied recently">Quiz me</button>
        <button class="suggestion-chip px-3 py-1.5 rounded-lg bg-[#0d1321] border border-white/5 text-xs text-neutral-400 hover:text-neutral-200 hover:border-indigo-500/30 transition-all" data-prompt="I'm stuck, help me figure out what to do">I'm stuck</button>
        <button class="suggestion-chip px-3 py-1.5 rounded-lg bg-[#0d1321] border border-white/5 text-xs text-neutral-400 hover:text-neutral-200 hover:border-indigo-500/30 transition-all" data-prompt="What are my weak areas?">Weak areas</button>
      </div>

      <div class="relative flex items-end gap-2 bg-[#0d1321] border border-white/10 rounded-2xl p-2 focus-within:border-indigo-500/50 focus-within:ring-1 focus-within:ring-indigo-500/50 transition-all shadow-sm">
        <button class="p-2 text-neutral-400 hover:text-indigo-400 hover:bg-indigo-500/10 rounded-xl transition-colors shrink-0 group relative" title="Solve Image">
          <span class="material-symbols-outlined">add_a_photo</span>
          <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-neutral-800 text-xs text-white rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">Solve Image</span>
        </button>
        <textarea
          id="mentor-input"
          class="w-full bg-transparent border-none text-neutral-200 placeholder-neutral-500 focus:ring-0 resize-none py-2.5 max-h-32 min-h-[44px] text-sm leading-relaxed"
          placeholder="Ask a question or upload a problem (LaTeX supported)..."
          rows="1"
        ></textarea>
        <button id="send-btn" class="p-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl transition-colors shrink-0 shadow-sm flex items-center justify-center h-[44px] w-[44px]" disabled>
          <span class="material-symbols-outlined text-[20px]">send</span>
        </button>
      </div>
      <div class="flex justify-between items-center px-2 mt-2">
        <span class="text-[10px] font-label text-neutral-500">Shift + Enter for new line • Use $ for inline math</span>
        <span class="text-[10px] font-label text-neutral-500 flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span> AI is ready
        </span>
      </div>
    </div>
  </div>
</div>

<script>
  // ── KaTeX rendering function ──
  function renderMath(text) {
    if (window.katex) {
      try {
        // Try to render display math first ($$...$$)
        text = text.replace(/\$\$(.+?)\$\$/gs, (_, expr) => {
          try { return katex.renderToString(expr.trim(), { displayMode: true, throwOnError: false }); }
          catch(e) { return `$$${expr}$$`; }
        });
        // Then inline math ($...$)
        text = text.replace(/\$(.+?)\$/g, (_, expr) => {
          try { return katex.renderToString(expr.trim(), { displayMode: false, throwOnError: false }); }
          catch(e) { return `$${expr}$`; }
        });
      } catch(e) {}
    }
    return text;
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderMarkdown(text) {
    if (!text) return '';
    // Simple markdown-like rendering
    let html = escapeHtml(text);
    // Code blocks
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre class="p-4 rounded-xl bg-[#0d1321] border border-white/5 text-sm text-indigo-300/80 overflow-x-auto my-4"><code>$2</code></pre>');
    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code class="px-1.5 py-0.5 rounded bg-[#0d1321] text-indigo-300 text-xs">$1</code>');
    // Bold
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong class="font-semibold text-white">$1</strong>');
    // Italic
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
    // Line breaks
    html = html.replace(/\n\n/g, '</p><p class="text-neutral-300 leading-relaxed">');
    html = html.replace(/\n/g, '<br/>');
    // Render LaTeX
    html = renderMath(html);
    return `<p class="text-neutral-300 leading-relaxed">${html}</p>`;
  }

  const CHAT_STORAGE_KEY = 'sl-mentor-history';
  const messagesArea = document.getElementById('messages-area');
  const input = document.getElementById('mentor-input');
  const sendBtn = document.getElementById('send-btn');
  const chipsContainer = document.getElementById('chips');
  const chatContainer = document.getElementById('chat-container');

  let isStreaming = false;
  let history = [];

  function loadHistory() {
    try {
      const saved = localStorage.getItem(CHAT_STORAGE_KEY);
      if (saved) {
        const parsed = JSON.parse(saved);
        if (Array.isArray(parsed) && parsed.length > 0) {
          history = parsed.slice(-20);
          return true;
        }
      }
    } catch (e) {}
    return false;
  }

  function saveHistory() {
    try {
      localStorage.setItem(CHAT_STORAGE_KEY, JSON.stringify(history.slice(-20)));
    } catch (e) {}
  }

  function renderHistory() {
    messagesArea.innerHTML = '';
    for (const msg of history) {
      const wrapper = document.createElement('div');
      if (msg.role === 'user') {
        wrapper.className = 'flex justify-end message-entrance';
        const bubble = document.createElement('div');
        bubble.className = 'bg-[#0d1321] border border-white/5 rounded-2xl rounded-tr-sm p-5 max-w-[85%] md:max-w-[75%] shadow-sm';
        bubble.innerHTML = `<p class="text-neutral-200 leading-relaxed">${escapeHtml(msg.content)}</p>`;
        wrapper.appendChild(bubble);
      } else {
        wrapper.className = 'flex gap-4 message-entrance';
        const avatar = document.createElement('div');
        avatar.className = 'w-8 h-8 rounded bg-indigo-500/20 text-indigo-500 flex items-center justify-center shrink-0 border border-indigo-500/30 mt-1';
        avatar.innerHTML = '<span class="material-symbols-outlined text-[18px]" style="font-variation-settings: \'FILL\' 1;">smart_toy</span>';
        wrapper.appendChild(avatar);
        const bubble = document.createElement('div');
        bubble.className = 'flex-1 bg-[#0d1321]/30 border border-white/5 rounded-2xl rounded-tl-sm p-5 md:p-6 max-w-[95%] shadow-sm';
        bubble.innerHTML = renderMarkdown(msg.content);
        wrapper.appendChild(bubble);
      }
      messagesArea.appendChild(wrapper);
    }
    chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
  }

  function autoResize() {
    if (input) {
      input.style.height = '';
      input.style.height = input.scrollHeight + 'px';
    }
  }

  // ── Send message ──
  async function sendMessage(text) {
    if (!text.trim() || isStreaming) return;

    history.push({ role: 'user', content: text.trim() });
    const userWrapper = document.createElement('div');
    userWrapper.className = 'flex justify-end message-entrance';
    const bubble = document.createElement('div');
    bubble.className = 'bg-[#0d1321] border border-white/5 rounded-2xl rounded-tr-sm p-5 max-w-[85%] md:max-w-[75%] shadow-sm';
    bubble.innerHTML = `<p class="text-neutral-200 leading-relaxed">${escapeHtml(text.trim())}</p>`;
    userWrapper.appendChild(bubble);
    messagesArea.appendChild(userWrapper);

    input.value = '';
    autoResize();
    sendBtn.disabled = true;
    isStreaming = true;
    chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });

    // AI thinking indicator
    const aiWrapper = document.createElement('div');
    aiWrapper.className = 'flex gap-4 message-entrance';
    aiWrapper.id = 'streaming-msg';
    const avatar = document.createElement('div');
    avatar.className = 'w-8 h-8 rounded bg-indigo-500/20 text-indigo-500 flex items-center justify-center shrink-0 border border-indigo-500/30 mt-1';
    avatar.innerHTML = '<span class="material-symbols-outlined text-[18px]" style="font-variation-settings: \'FILL\' 1;">smart_toy</span>';
    aiWrapper.appendChild(avatar);
    const bubbleDiv = document.createElement('div');
    bubbleDiv.className = 'flex-1 bg-[#0d1321]/30 border border-white/5 rounded-2xl rounded-tl-sm p-5 md:p-6 max-w-[95%] shadow-sm';
    bubbleDiv.innerHTML = '<div class="flex items-center gap-2 text-neutral-400"><div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div><span class="text-sm">Thinking...</span></div>';
    aiWrapper.appendChild(bubbleDiv);
    messagesArea.appendChild(aiWrapper);
    chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });

    try {
      // Build conversation for API
      const messages = history.map(h => ({ role: h.role, content: h.content }));
      const res = await fetch('/api/mentor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      });
      if (!res.ok) throw new Error('API Error');

      const data = await res.json();
      const reply = data.message || data.content || data.text || '';

      // Remove thinking indicator
      const streaming = document.getElementById('streaming-msg');
      if (streaming) streaming.remove();

      history.push({ role: 'assistant', content: reply });
      saveHistory();

      const aiComplete = document.createElement('div');
      aiComplete.className = 'flex gap-4 message-entrance';
      const av = document.createElement('div');
      av.className = 'w-8 h-8 rounded bg-indigo-500/20 text-indigo-500 flex items-center justify-center shrink-0 border border-indigo-500/30 mt-1';
      av.innerHTML = '<span class="material-symbols-outlined text-[18px]" style="font-variation-settings: \'FILL\' 1;">smart_toy</span>';
      aiComplete.appendChild(av);
      const bbl = document.createElement('div');
      bbl.className = 'flex-1 bg-[#0d1321]/30 border border-white/5 rounded-2xl rounded-tl-sm p-5 md:p-6 max-w-[95%] shadow-sm';
      bbl.innerHTML = renderMarkdown(reply);
      aiComplete.appendChild(bbl);
      messagesArea.appendChild(aiComplete);
      chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
    } catch (err) {
      const streaming = document.getElementById('streaming-msg');
      if (streaming) streaming.remove();
      const errWrapper = document.createElement('div');
      errWrapper.className = 'flex gap-4 message-entrance';
      const av = document.createElement('div');
      av.className = 'w-8 h-8 rounded bg-red-500/20 text-red-400 flex items-center justify-center shrink-0 border border-red-500/30 mt-1';
      av.innerHTML = '<span class="material-symbols-outlined text-[18px]">error</span>';
      errWrapper.appendChild(av);
      const bbl = document.createElement('div');
      bbl.className = 'flex-1 bg-red-500/5 border border-red-500/20 rounded-2xl rounded-tl-sm p-5 max-w-[95%]';
      bbl.innerHTML = `<p class="text-sm text-red-400">Failed to get response: ${err.message}. Please try again.</p>`;
      errWrapper.appendChild(bbl);
      messagesArea.appendChild(errWrapper);
    } finally {
      isStreaming = false;
      sendBtn.disabled = false;
      chatContainer?.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
    }
  }

  // ── Event listeners ──
  input?.addEventListener('input', () => {
    autoResize();
    sendBtn.disabled = !input.value.trim() || isStreaming;
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (input.value.trim() && !isStreaming) {
        sendMessage(input.value);
      }
    }
  });

  sendBtn?.addEventListener('click', () => {
    if (input.value.trim() && !isStreaming) {
      sendMessage(input.value);
    }
  });

  chipsContainer?.addEventListener('click', (e) => {
    const chip = e.target.closest('.suggestion-chip');
    if (chip) {
      const prompt = chip.dataset.prompt;
      if (prompt) sendMessage(prompt);
    }
  });

  // ── Init ──
  if (loadHistory()) renderHistory();
  sendBtn.disabled = true;
</script>

<style>
  .message-entrance {
    animation: slide-up-fade 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes slide-up-fade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
