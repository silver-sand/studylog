---
export interface Props {
  title?: string;
}

const { title = 'AI Mentor' } = Astro.props;
---

<div class="mentor-chat" id="mentor-chat">
  <div class="chat-header">
    <div class="chat-title-row">
      <div class="chat-avatar" style="background:var(--ds-accent-bg);border:1px solid var(--ds-accent-border);color:var(--ds-accent-400);width:2.25rem;height:2.25rem;border-radius:var(--ds-radius-lg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M16 14H8a4 4 0 0 0-4 4v2h16v-2a4 4 0 0 0-4-4z"/></svg>
      </div>
      <div>
        <h3 class="ds-heading-card" style="margin:0;">{title}</h3>
        <p class="ds-caption" style="margin:0.1rem 0 0;">Your AI study partner</p>
      </div>
    </div>
    <div class="chat-diagnostics" id="chat-diagnostics">
      <span class="diag-item" id="diag-provider">—</span>
      <span class="diag-sep">·</span>
      <span class="diag-item" id="diag-latency">—</span>
    </div>
  </div>

  <div class="messages-area" id="messages-area">
    <div class="message mentor welcome">
      <div class="msg-content">
        <p>Hi! I'm your AI study mentor. I can see your study history and syllabus progress.</p>
        <p>Try asking me:</p>
        <ul class="suggestion-list">
          <li>"What should I study today?"</li>
          <li>"Quiz me on Physics"</li>
          <li>"I'm stuck on [topic], help me understand"</li>
          <li>"What are my weak areas?"</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="input-area">
    <div class="chips" id="chips">
      <button class="ds-chip" data-prompt="What should I study today?" style="font-size:var(--ds-text-xs);padding:var(--ds-space-1-5) var(--ds-space-2-5);">What to study?</button>
      <button class="ds-chip" data-prompt="Quiz me on something I studied recently" style="font-size:var(--ds-text-xs);padding:var(--ds-space-1-5) var(--ds-space-2-5);">Quiz me</button>
      <button class="ds-chip" data-prompt="What are my weak areas?" style="font-size:var(--ds-text-xs);padding:var(--ds-space-1-5) var(--ds-space-2-5);">Weak areas</button>
    </div>
    <div class="input-row">
      <textarea
        id="mentor-input"
        class="ds-input"
        placeholder="Ask your mentor..."
        rows="1"
        style="flex:1;resize:none;max-height:120px;"
      ></textarea>
      <button id="send-btn" class="ds-btn ds-btn-primary" disabled style="height:2.75rem;flex-shrink:0;align-self:flex-end;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        <span>Send</span>
      </button>
    </div>
    <p class="disclaimer">Responses are AI-generated. Verify critical information independently.</p>
  </div>
</div>

<script>
  const messagesArea = document.getElementById('messages-area');
  const input = document.getElementById('mentor-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
  const diagProvider = document.getElementById('diag-provider');
  const diagLatency = document.getElementById('diag-latency');

  let isStreaming = false;
  let history: { role: string; content: string }[] = [];
  let lastQueryText = '';
  let lastError = '';

  // Send button click handler
  sendBtn.addEventListener('click', sendMessage);

  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }

  input.addEventListener('input', autoResize);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  input.addEventListener('input', () => {
    sendBtn.disabled = input.value.trim().length === 0 || isStreaming;
  });

  // Chip buttons
  document.querySelectorAll('.ds-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const prompt = chip.dataset.prompt;
      if (prompt && !isStreaming) {
        input.value = prompt;
        autoResize();
        sendBtn.disabled = false;
        sendMessage();
      }
    });
  });

  function addMessage(role: string, content: string, isStreaming_ = false) {
    const div = document.createElement('div');
    div.className = `message ${role}`;
    if (isStreaming_) div.classList.add('streaming');

    const inner = document.createElement('div');
    inner.className = 'msg-content';

    if (role === 'user') {
      inner.innerHTML = `<p>${escapeHtml(content)}</p>`;
    } else {
      inner.innerHTML = renderMarkdown(content);
    }

    div.appendChild(inner);
    messagesArea.appendChild(div);
    messagesArea.scrollTop = messagesArea.scrollHeight;
    return inner;
  }

  function getLastMentorContent(): HTMLElement | null {
    const msgs = messagesArea.querySelectorAll('.message.mentor.streaming');
    if (msgs.length > 0) {
      const el = msgs[msgs.length - 1].querySelector('.msg-content') as HTMLElement;
      return el;
    }
    return null;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderMarkdown(text: string): string {
    // Simple markdown rendering
    let html = escapeHtml(text);

    // Code blocks
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>');

    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

    // Bold
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

    // Italic
    html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');

    // Blockquotes
    html = html.replace(/^>\s*(.+)$/gm, '<blockquote>$1</blockquote>');

    // Unordered lists
    html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
    html = html.replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul>$1</ul>');

    // Ordered lists
    html = html.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');

    // Paragraphs (double newlines)
    html = html.replace(/\n\n/g, '</p><p>');

    // Single newlines within paragraphs
    html = html.replace(/([^>])\n(?!\n)/g, '$1<br>');

    return `<p>${html}</p>`;
  }

  function updateDiagnostics(provider: string, model: string, latencyMs?: number) {
    const parts: string[] = [];
    if (provider && provider !== 'unknown') {
      parts.push(model ? `${provider} · ${model}` : provider);
    }
    if (diagProvider) {
      diagProvider.textContent = parts.length > 0 ? parts[0] : '—';
    }
    if (diagLatency && latencyMs !== undefined) {
      const secs = (latencyMs / 1000).toFixed(1);
      diagLatency.textContent = `${secs}s`;
    }
  }

  function showRetryButton(mentorEl: HTMLElement) {
    // Remove any existing retry button
    const existing = mentorEl.querySelector('.retry-btn');
    if (existing) existing.remove();

    const retry = document.createElement('button');
    retry.className = 'retry-btn';
    retry.textContent = '🔄 Retry';
    retry.addEventListener('click', () => {
      // Remove the failed message
      const msgEl = mentorEl.closest('.message');
      if (msgEl) msgEl.remove();
      // Remove the user's last message from history
      if (history.length > 0 && history[history.length - 1].role === 'user') {
        history.pop();
      }
      // Re-send
      sendMessageWithText(lastQueryText);
    });
    mentorEl.appendChild(retry);
  }

  async function sendMessageWithText(text: string) {
    if (!text || isStreaming) return;

    input.value = '';
    autoResize();
    sendBtn.disabled = true;

    // Add user message
    addMessage('user', text);
    history.push({ role: 'user', content: text });

    // Track for getting-started checklist
    try { localStorage.setItem('sl-checklist-mentor', '1'); } catch(e) {}

    // Add placeholder mentor message
    addMessage('mentor', '▊', true);
    isStreaming = true;
    lastError = '';

    try {
      const res = await fetch('/api/mentor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: text, history: history.slice(-6) }), // last 3 exchanges
      });

      if (!res.ok) throw new Error('Failed to get response');

      const reader = res.body?.getReader();
      if (!reader) throw new Error('No response stream');

      const decoder = new TextDecoder();
      let buffer = '';
      let fullResponse = '';
      let hasError = false;

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          try {
            const data = JSON.parse(line.slice(6));

            if (data.type === 'meta') {
              updateDiagnostics(data.provider, data.model);
            } else if (data.type === 'chunk') {
              fullResponse += data.text;
              const contentEl = getLastMentorContent();
              if (contentEl) {
                contentEl.innerHTML = renderMarkdown(fullResponse);
              }
              messagesArea.scrollTop = messagesArea.scrollHeight;
            } else if (data.type === 'done') {
              updateDiagnostics(
                (document.getElementById('diag-provider')?.textContent || '').split(' · ')[0] || '',
                '',
                data.latency
              );
              // Done — finalize below
            } else if (data.type === 'error') {
              hasError = true;
              lastError = data.text || 'Request failed';
              const contentEl = getLastMentorContent();
              if (contentEl) {
                contentEl.innerHTML = `<p class="error-msg">Error: ${escapeHtml(lastError)}</p>`;
                showRetryButton(contentEl);
              }
            }
          } catch {}
        }
      }

      // Finalize the streaming message
      const streamingMsg = messagesArea.querySelector('.message.mentor.streaming');
      if (streamingMsg) {
        streamingMsg.classList.remove('streaming');
        if (fullResponse && !hasError) {
          history.push({ role: 'mentor', content: fullResponse });
        }
      }

    } catch (err) {
      const contentEl = getLastMentorContent();
      if (contentEl) {
        const msg = err instanceof Error ? err.message : 'Failed to get response';
        contentEl.innerHTML = `<p class="error-msg">${escapeHtml(msg)}</p>`;
        showRetryButton(contentEl);
      }
      const streamingMsg = messagesArea.querySelector('.message.mentor.streaming');
      if (streamingMsg) streamingMsg.classList.remove('streaming');
    } finally {
      isStreaming = false;
      sendBtn.disabled = input.value.trim().length === 0;
    }
  }

  async function sendMessage() {
    const text = input.value.trim();
    if (!text || isStreaming) return;
    lastQueryText = text;
    await sendMessageWithText(text);
  }
</script>

<style>
  /* ── Chat container ── */
  .mentor-chat {
    display: flex;
    flex-direction: column;
    height: 70vh;
    max-height: 700px;
    background: var(--ds-surface-900);
    border: 1px solid var(--ds-border-subtle);
    border-radius: var(--ds-radius-lg);
    overflow: hidden;
  }
  .chat-header {
    padding: var(--ds-space-3) var(--ds-space-5);
    border-bottom: 1px solid var(--ds-border-subtle);
    flex-shrink: 0;
  }
  .chat-title-row {
    display: flex;
    align-items: center;
    gap: var(--ds-space-2-5);
  }
  .chat-diagnostics {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
    margin-top: 0.35rem;
    padding-left: 2.85rem;
  }
  .diag-item {
    font-size: var(--ds-text-2xs);
    color: var(--ds-text-tertiary);
    font-family: var(--ds-font-mono);
  }
  .diag-sep {
    font-size: var(--ds-text-2xs);
    color: var(--ds-border-subtle);
  }

  /* ── Messages area ── */
  .messages-area {
    flex: 1;
    overflow-y: auto;
    padding: var(--ds-space-4) var(--ds-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-3);
  }
  .message {
    max-width: 88%;
  }
  .message.user { align-self: flex-end; }
  .message.mentor { align-self: flex-start; }

  .msg-content {
    padding: var(--ds-space-2-5) var(--ds-space-3-5);
    border-radius: var(--ds-radius-lg);
    font-size: var(--ds-text-sm);
    line-height: 1.6;
  }
  .message.user .msg-content {
    background: var(--ds-accent-bg);
    border: 1px solid var(--ds-accent-border);
    color: var(--ds-text-secondary);
  }
  .message.mentor .msg-content {
    background: var(--ds-surface-800);
    border: 1px solid var(--ds-border-subtle);
    color: var(--ds-text-secondary);
  }

  /* ── Markdown content ── */
  .message.mentor .msg-content p { margin: 0.3rem 0; }
  .message.mentor .msg-content p:first-child { margin-top: 0; }
  .message.mentor .msg-content p:last-child { margin-bottom: 0; }
  .message.mentor .msg-content ul,
  .message.mentor .msg-content ol {
    margin: 0.3rem 0;
    padding-left: 1.2rem;
  }
  .message.mentor .msg-content li { margin: 0.15rem 0; }
  .message.mentor .msg-content code {
    background: var(--ds-surface-950);
    padding: 0.1rem 0.3rem;
    border-radius: var(--ds-radius-sm);
    font-size: var(--ds-text-xs);
    font-family: var(--ds-font-mono);
    color: var(--ds-accent-300);
  }
  .message.mentor .msg-content pre {
    background: var(--ds-surface-950);
    padding: var(--ds-space-3);
    border-radius: var(--ds-radius-md);
    overflow-x: auto;
    margin: var(--ds-space-2) 0;
  }
  .message.mentor .msg-content pre code {
    background: none;
    padding: 0;
  }
  .message.mentor .msg-content blockquote {
    border-left: 3px solid var(--ds-accent-border);
    padding-left: var(--ds-space-3);
    margin: var(--ds-space-2) 0;
    color: var(--ds-text-tertiary);
  }

  /* ── Welcome suggestions ── */
  .suggestion-list {
    list-style: none;
    padding: 0;
    margin: var(--ds-space-2) 0 0;
  }
  .suggestion-list li {
    font-size: var(--ds-text-xs);
    color: var(--ds-text-tertiary);
    padding: 0.15rem 0;
    font-family: var(--ds-font-mono);
  }

  /* ── Streaming cursor ── */
  .message.streaming .msg-content::after {
    content: '▊';
    animation: ds-blink 0.8s infinite;
    color: var(--ds-accent-500);
  }

  /* ── Input area ── */
  .input-area {
    flex-shrink: 0;
    padding: var(--ds-space-3) var(--ds-space-5) var(--ds-space-4);
    border-top: 1px solid var(--ds-border-subtle);
  }
  .chips {
    display: flex;
    gap: var(--ds-space-1-5);
    margin-bottom: var(--ds-space-2-5);
    flex-wrap: wrap;
  }
  .input-row {
    display: flex;
    gap: var(--ds-space-2);
  }

  /* ── Disclaimer ── */
  .disclaimer {
    font-size: var(--ds-text-2xs);
    color: var(--ds-text-tertiary);
    text-align: center;
    margin: var(--ds-space-1-5) 0 0;
  }

  /* ── Error / Retry ── */
  .error-msg {
    color: var(--ds-danger-500);
  }
  .retry-btn {
    display: block;
    margin-top: var(--ds-space-2-5);
    padding: 0.35rem 0.75rem;
    background: var(--ds-danger-bg);
    border: 1px solid var(--ds-danger-border);
    border-radius: var(--ds-radius-md);
    color: var(--ds-danger-400);
    font-size: var(--ds-text-xs);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .retry-btn:hover {
    background: rgba(239, 68, 68, 0.25);
    border-color: var(--ds-danger-500);
  }
</style>
