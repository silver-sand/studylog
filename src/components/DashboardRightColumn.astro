---
import DailyActionCard from './DailyActionCard.astro';
import type { DailyTrendItem, SubjectBreakdownItem, WeekComparisonData } from '../services/stats-service';

export interface Props {
  totalHoursThisWeek: number;
  targetHoursPerWeek: number;
  weeklyProgressPercent: number;
  entriesThisWeek: number;
  studyDaysPerWeek: number;
  recentEntries: { subject: string; content: string; hoursStudied: number; date: string }[];
  examKey: string;
  hasEntries: boolean;
  dailyTrend?: DailyTrendItem[];
  subjectBreakdown?: SubjectBreakdownItem[];
  weekComparison?: WeekComparisonData;
  user?: { name?: string } | null;
  subjects?: string[];
}

const {
  totalHoursThisWeek, targetHoursPerWeek, hasEntries,
  subjectBreakdown = [], weekComparison, user,
  dailyTrend = [], examKey, weeklyProgressPercent,
  subjects = [],
} = Astro.props;

// Use user's actual subjects for fallback display, or generic placeholders
const fallbackSubjects = subjects.length > 0 ? subjects.slice(0, 3) : ['Physics', 'Maths', 'Chemistry'];

const today = new Date();
const hour = today.getHours();
const greeting = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';

// Compute grades
function getGrade(pct: number): { letter: string } {
  if (pct >= 90) return { letter: 'A+' };
  if (pct >= 80) return { letter: 'A' };
  if (pct >= 70) return { letter: 'B+' };
  if (pct >= 60) return { letter: 'B' };
  if (pct >= 50) return { letter: 'C+' };
  if (pct >= 40) return { letter: 'C' };
  return { letter: 'D' };
}

const subjectGrades = subjectBreakdown.map(s => ({
  subject: s.subject,
  ...getGrade(s.percentage),
  hours: s.hours,
  percentage: s.percentage,
}));

// Weekly hours bar chart data (Mon-Sun)
const weekBars = Array.from({ length: 7 }, (_, i) => {
  const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
  const trend = dailyTrend?.find(d => {
    const dDate = new Date(d.date);
    const dDay = dDate.getDay(); // 0=Sun
    const mondayIndex = dDay === 0 ? 6 : dDay - 1;
    return mondayIndex === i;
  });
  return {
    day: dayNames[i].charAt(0),
    hours: trend?.hoursStudied || 0,
    maxHours: Math.max(...(dailyTrend?.map(d => d.hoursStudied) || [1]), 1),
  };
});

const maxBarHours = Math.max(...weekBars.map(b => b.hours), 1);

// Insight text
function getInsight(): { title: string; body: string } {
  if (weekComparison && weekComparison.change > 0) {
    return {
      title: 'Peak Productivity Insight',
      body: `Data from last 7 days shows strong momentum — you've studied ${weekComparison.change}h more than last week, a ${weekComparison.changePercent}% increase. Keep scheduling your most difficult topics during peak hours.`,
    };
  }
  if (weekComparison && weekComparison.change < 0) {
    return {
      title: 'Recovery Mode',
      body: `You studied ${Math.abs(weekComparison.change)}h less than last week. Consider scheduling a short session today to rebuild momentum — even 25 minutes counts.`,
    };
  }
  return {
    title: 'Getting Started',
    body: 'Log your first study session to unlock personalized insights and track your progress over time.',
  };
}
const insight = getInsight();
---

<div class="flex flex-col gap-8 animate-stagger" style="--stagger-index:0">

  <!-- Greeting -->
  <div>
    <h1 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-2">
      {greeting}{user?.name && user.name !== 'Guest' ? `, ${user.name.split(' ')[0]}.` : '.'}
    </h1>
    <p class="text-neutral-500 max-w-lg">
      {hasEntries
        ? `You've completed ${weeklyProgressPercent ?? 0}% of your weekly goal. Stay focused for your next session.`
        : 'Ready to start your study journey? Log your first session to unlock insights.'}
    </p>
  </div>

  <!-- 2-Column Grid: Today's Quests + Weekly Hours -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" style="--stagger-index:1">
    <!-- Today's Quests -->
    <div class="ds-card-gradient rounded-2xl p-6 card-lift">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-sm font-bold text-white flex items-center gap-2">
          <span class="material-symbols-outlined text-indigo-400 text-lg">checklist</span>
          Today's Priority
        </h3>
        <span class="text-[10px] text-neutral-500">{hasEntries ? `${entriesThisWeek} sessions` : 'Get started'}</span>
      </div>
      <DailyActionCard examType={examKey} />
    </div>

    <!-- Weekly Hours Bar Chart -->
    <div class="obsidian-glass rounded-2xl p-6 card-lift">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-sm font-bold text-white flex items-center gap-2">
          <span class="material-symbols-outlined text-indigo-400 text-lg">timer</span>
          Weekly Study
        </h3>
        <div class="flex items-baseline gap-1">
          <span class="text-lg font-bold text-white">{totalHoursThisWeek.toFixed(1)}</span>
          <span class="text-xs text-neutral-500">/{targetHoursPerWeek}h</span>
        </div>
      </div>
      <div class="flex items-end justify-between h-20 gap-2 px-2">
        {weekBars.map((bar, i) => {
          const pct = Math.max((bar.hours / maxBarHours) * 100, 2);
          const hasValue = bar.hours > 0;
          return (
            <div class={`w-full rounded-t-sm relative group ${hasValue ? 'bg-indigo-500/20' : 'bg-white/5'}`}>
              <div
                class={`absolute bottom-0 w-full rounded-t-sm transition-all duration-700 ${
                  hasValue ? 'bg-indigo-500' : 'bg-neutral-700'
                }`}
                style={`height: ${hasValue ? pct : 5}%;`}
              ></div>
              <span class="absolute -top-6 left-1/2 -translate-x-1/2 text-[9px] text-neutral-500">{bar.day}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Weekly Insight -->
  <div class="obsidian-glass rounded-2xl p-6 flex items-start gap-5 border-l-4 border-indigo-500 card-lift" style="--stagger-index:2">
    <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center shrink-0">
      <span class="material-symbols-outlined text-indigo-400 text-2xl filled-icon">lightbulb</span>
    </div>
    <div>
      <h4 class="text-sm font-bold text-white mb-1">{insight.title}</h4>
      <p class="text-sm text-neutral-400 leading-relaxed">
        {insight.body}
      </p>
    </div>
  </div>

  <!-- Subject Stats Bento Grid -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4" style="--stagger-index:3">
    {subjectGrades.length > 0 ? subjectGrades.slice(0, 3).map((sg, i) => (
      <div class="p-4 ds-card-gradient rounded-2xl card-lift" style={`--stagger-index:${i}`}>
        <p class="text-[10px] text-neutral-500 uppercase tracking-widest mb-1">{sg.subject}</p>
        <p class="text-xl font-bold text-white">{sg.letter}</p>
      </div>
    )) : (
      fallbackSubjects.map((subject, i) => (
        <div class="p-4 obsidian-glass rounded-2xl" style={`--stagger-index:${i}`}>
          <p class="text-[10px] text-neutral-500 uppercase tracking-widest mb-1">{subject}</p>
          <p class="text-xl font-bold text-neutral-600">--</p>
        </div>
      ))
    )}
    <!-- Avg Score always shown -->
    <div class="p-4 ds-card-gradient rounded-2xl card-lift" style="--stagger-index:4">
      <p class="text-[10px] text-neutral-500 uppercase tracking-widest mb-1">Avg Score</p>
      {subjectGrades.length > 0 ? (
        <div class="flex items-center gap-1 text-emerald-400">
          <p class="text-xl font-bold">
            {subjectGrades.length > 0
              ? `${Math.round(subjectGrades.reduce((a, b) => a + b.percentage, 0) / subjectGrades.length)}%`
              : '--'}
          </p>
          {weekComparison && weekComparison.change > 0 && (
            <span class="material-symbols-outlined text-sm">trending_up</span>
          )}
        </div>
      ) : (
        <p class="text-xl font-bold text-neutral-600">--</p>
      )}
    </div>
  </div>

  <!-- Focus CTA -->
  <div class="mt-auto pt-4" style="--stagger-index:5">
    <a href="/timer" class="w-full bg-indigo-500 hover:bg-indigo-400 text-white font-bold text-sm py-3 rounded-xl flex items-center justify-center gap-3 glow-button pulse-glow tracking-widest uppercase shadow-lg transition-all active:scale-[0.98] no-underline">
      <span class="material-symbols-outlined">rocket_launch</span>
      START FOCUS SESSION
    </a>
  </div>
</div>

<style>
  .glow-button {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
    transition: all 0.3s ease;
  }
  .glow-button:hover {
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.5);
    transform: translateY(-2px);
  }
</style>
