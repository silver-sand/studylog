---
import DailyActionCard from './DailyActionCard.astro';
import WeakChapters from './WeakChapters.astro';
import DashboardAnalytics from './DashboardAnalytics.astro';
import CalendarWidget from './CalendarWidget.astro';
import type { DailyTrendItem, WeekComparisonData, FocusTrendItem, SubjectBreakdownItem } from '../services/stats-service';

export interface Props {
  totalHoursThisWeek: number;
  targetHoursPerWeek: number;
  weeklyProgressPercent: number;
  entriesThisWeek: number;
  studyDaysPerWeek: number;
  recentEntries: { subject: string; content: string; hoursStudied: number; date: string }[];
  examKey: string;
  hasEntries: boolean;
  dailyTrend?: DailyTrendItem[];
  subjectBreakdown?: SubjectBreakdownItem[];
  weekComparison?: WeekComparisonData;
  focusTrend?: FocusTrendItem[];
  monthlyEntryDates?: Set<string>;
  calendarYear?: number;
  calendarMonth?: number;
}

const {
  totalHoursThisWeek, targetHoursPerWeek, weeklyProgressPercent,
  entriesThisWeek, studyDaysPerWeek,
  recentEntries = [], examKey, hasEntries,
  dailyTrend = [], subjectBreakdown = [], weekComparison, focusTrend = [],
  monthlyEntryDates = new Set(), calendarYear = 2026, calendarMonth = 6,
} = Astro.props;
---

<div class="right-column">
  <!-- Tab Navigation -->
  <div class="ds-tabs" id="dashboard-tabs">
    <button class="ds-tab active" data-tab="quests">Overview</button>
    <button class="ds-tab" data-tab="analytics">Analytics</button>
    <button class="ds-tab" data-tab="calendar">Calendar</button>
  </div>

  <!-- Tab: Quests / Overview — Stitch layout -->
  <div class="tab-panel" id="panel-quests" data-tab-panel="quests">
    <!-- Today's Quests — Stitch style -->
    <div class="glass-card rounded-xl p-card-padding">
      <div class="quests-header">
        <span class="quests-header-icon material-symbols-outlined">task_alt</span>
        <h2 class="quests-header-title">Today's Quests</h2>
      </div>
      <div class="quests-list">
        <DailyActionCard examType={examKey} />
      </div>
    </div>

    <!-- Stats Grid — Stitch style 2-col -->
    <div class="stats-grid">
      <!-- This Week -->
      <div class="glass-card rounded-xl p-card-padding">
        <div class="stat-card-header">
          <h3 class="stat-card-label">This Week</h3>
          <span class="stat-card-icon material-symbols-outlined">query_stats</span>
        </div>
        <div class="stat-card-body">
          <div class="stat-card-value-row">
            <span class="stat-card-value">{totalHoursThisWeek}</span>
            <span class="stat-card-divider">/ {targetHoursPerWeek}h</span>
          </div>
          <p class="stat-card-subtext">Study Goal Progress</p>
          <div class="stat-progress-track">
            <div
              class="stat-progress-fill"
              style={`width:${Math.min(weeklyProgressPercent, 100)}%`}
            ></div>
          </div>
        </div>
      </div>

      <!-- Up Next -->
      <div class="glass-card rounded-xl p-card-padding">
        <div class="stat-card-header">
          <h3 class="stat-card-label">Up Next</h3>
          <span class="stat-card-icon material-symbols-outlined">event</span>
        </div>
        {hasEntries && recentEntries.length > 0 ? (
          <div class="upnext-card">
            <span class="upnext-badge">Coming Up</span>
            <h4 class="upnext-title">{recentEntries[0].subject}</h4>
            <p class="upnext-desc">{recentEntries[0].content}</p>
          </div>
        ) : (
          <div class="upnext-card upnext-empty">
            <span class="upnext-badge">Get Started</span>
            <h4 class="upnext-title">Ready to Study?</h4>
            <p class="upnext-desc">Log your first session to see what's next.</p>
          </div>
        )}
      </div>
    </div>

    <!-- Weak Chapters (if any) -->
    {hasEntries && <WeakChapters examType={examKey} />}

    <!-- Weekly Insight — Stitch style -->
    {hasEntries && (
      <div class="glass-card rounded-xl p-card-padding insight-card">
        <div class="insight-row">
          <div class="insight-icon-wrap">
            <span class="insight-icon material-symbols-outlined">lightbulb</span>
          </div>
          <div class="insight-text-wrap">
            <h3 class="insight-label">Weekly Insight</h3>
            <p class="insight-body">
              Keep building momentum! Your consistency this week is setting a strong foundation.
              Focus on your weaker chapters to maximize score gains.
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- Focus Session CTA — Stitch style gradient -->
    <a href="/timer" class="focus-cta">
      <span class="focus-cta-icon material-symbols-outlined">play_arrow</span>
      <span class="focus-cta-text">START FOCUS SESSION</span>
    </a>
    <p class="focus-quote">"Focus is the art of knowing what to ignore."</p>
  </div>

  <!-- Tab: Analytics -->
  <div class="tab-panel" id="panel-analytics" data-tab-panel="analytics" style="display:none;">
    {dailyTrend.length > 0 ? (
      <DashboardAnalytics
        dailyTrend={dailyTrend}
        subjectBreakdown={subjectBreakdown}
        weekComparison={weekComparison}
        focusTrend={focusTrend}
      />
    ) : (
      <div class="glass-card rounded-xl p-card-padding">
        <div class="empty-state">
          <div class="empty-icon">📊</div>
          <p class="empty-title">No data yet</p>
          <p class="empty-desc">Log your study sessions to unlock analytics and insights.</p>
        </div>
      </div>
    )}
  </div>

  <!-- Tab: Calendar -->
  <div class="tab-panel" id="panel-calendar" data-tab-panel="calendar" style="display:none;">
    <CalendarWidget
      entryDates={monthlyEntryDates}
      year={calendarYear}
      month={calendarMonth}
    />
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('#dashboard-tabs .ds-tab');
    const panels: Record<string, HTMLElement | null> = {};

    tabs.forEach(tab => {
      const name = tab.getAttribute('data-tab');
      if (name) panels[name] = document.getElementById(`panel-${name}`);
    });

    function switchTab(name: string) {
      tabs.forEach(t => t.classList.toggle('active', t.getAttribute('data-tab') === name));
      Object.entries(panels).forEach(([key, panel]) => {
        if (panel) panel.style.display = key === name ? '' : 'none';
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const name = tab.getAttribute('data-tab');
        if (name) switchTab(name);
      });
    });
  });
</script>

<style>
  .right-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Glass card base ── */
  .glass-card {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
    transition: all 0.2s ease;
  }
  .glass-card:hover {
    background: rgba(255, 255, 255, 0.09);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .p-card-padding {
    padding: 1.5rem;
  }

  /* ── Today's Quests ── */
  .quests-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .quests-header-icon {
    color: var(--ds-accent-400);
    font-size: 1.5rem;
  }
  .quests-header-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ds-text-primary);
    margin: 0;
  }
  .quests-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ── Stats Grid ── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .stat-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .stat-card-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ds-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }
  .stat-card-icon {
    color: rgba(193, 199, 211, 0.5);
    font-size: 1.25rem;
  }

  .stat-card-body {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-card-value-row {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .stat-card-value {
    font-size: 3rem;
    font-weight: 700;
    color: var(--ds-text-primary);
    line-height: 1;
    font-family: var(--ds-font-mono);
  }
  .stat-card-divider {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ds-text-tertiary);
  }
  .stat-card-subtext {
    font-size: var(--ds-text-sm);
    color: var(--ds-text-tertiary);
    margin: 0.25rem 0 0 0;
  }
  .stat-progress-track {
    width: 100%;
    height: 0.375rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 9999px;
    margin-top: 1.5rem;
    overflow: hidden;
  }
  .stat-progress-fill {
    height: 100%;
    background: var(--ds-accent-400);
    border-radius: 9999px;
    transition: width 0.6s ease;
  }

  /* ── Up Next ── */
  .upnext-card {
    padding: 1rem;
    border-radius: 0.75rem;
    background: rgba(164, 201, 255, 0.1);
    border: 1px solid rgba(164, 201, 255, 0.2);
  }
  .upnext-empty {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.08);
  }
  .upnext-badge {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ds-accent-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 0.25rem;
  }
  .upnext-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ds-text-primary);
    margin: 0 0 0.5rem 0;
  }
  .upnext-desc {
    font-size: var(--ds-text-base);
    color: var(--ds-text-tertiary);
    margin: 0;
    line-height: 1.4;
  }

  /* ── Weekly Insight ── */
  .insight-card {
    border-left: 4px solid rgba(255, 198, 64, 0.5);
  }
  .insight-row {
    display: flex;
    gap: 1rem;
  }
  .insight-icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(255, 198, 64, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .insight-icon {
    color: var(--ds-secondary);
    font-size: 1.25rem;
    font-variation-settings: 'FILL' 1;
  }
  .insight-text-wrap {
    flex: 1;
  }
  .insight-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ds-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem 0;
  }
  .insight-body {
    font-size: var(--ds-text-base);
    color: var(--ds-text-primary);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Focus CTA ── */
  .focus-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1.5rem;
    border-radius: 1rem;
    background: linear-gradient(to right, var(--ds-accent-400), #2563eb);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    box-shadow: 0 0 20px rgba(96, 165, 250, 0.3);
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
  }
  .focus-cta:hover {
    transform: scale(1.01);
    box-shadow: 0 0 30px rgba(96, 165, 250, 0.4);
  }
  .focus-cta:active {
    transform: scale(0.98);
  }
  .focus-cta-icon {
    font-size: 1.5rem;
    font-variation-settings: 'FILL' 1;
  }
  .focus-cta-text {
    line-height: 1;
  }

  .focus-quote {
    text-align: center;
    font-size: var(--ds-text-sm);
    font-weight: 500;
    color: var(--ds-text-tertiary);
    margin: 0;
    opacity: 0.6;
    font-style: italic;
  }

  /* ── Empty State ── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    text-align: center;
  }
  .empty-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .empty-title {
    font-size: var(--ds-text-base);
    font-weight: 600;
    color: var(--ds-text-primary);
    margin: 0;
  }
  .empty-desc {
    font-size: var(--ds-text-sm);
    color: var(--ds-text-tertiary);
    margin: 0;
  }
</style>
