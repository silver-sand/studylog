---
export interface Props {
  subjects: Record<string, number>;
}

const { subjects } = Astro.props;
const entries = Object.entries(subjects);
const maxHours = Math.max(...entries.map(([, h]) => h), 1);

function barColor(subject: string): string {
  const name = subject.toLowerCase();
  const STANDARD: Record<string, string> = { physics: '#3b82f6', chemistry: '#22c55e', maths: '#f59e0b', mathematics: '#f59e0b', biology: '#ec4899', english: '#8b5cf6' };
  for (const [key, color] of Object.entries(STANDARD)) { if (name.includes(key)) return color; }
  const PALETTE = ['#3b82f6', '#22c55e', '#f59e0b', '#ec4899', '#8b5cf6', '#06b6d4', '#f43f5e', '#84cc16', '#f97316', '#14b8a6'];
  let hash = 0; for (let i = 0; i < subject.length; i++) { hash = ((hash << 5) - hash) + subject.charCodeAt(i); hash = hash & hash; }
  return PALETTE[Math.abs(hash) % PALETTE.length];
}
---

<div class="card">
  <h3 class="card-title">Hours by Subject</h3>
  {entries.length === 0 ? (
    <p class="empty">No data this week.</p>
  ) : (
    <div class="space-y-3">
      {entries
        .sort(([, a], [, b]) => b - a)
        .map(([subject, hours]) => {
          const width = Math.max((hours / maxHours) * 100, 4);
          return (
            <div>
              <div class="bar-label">
                <span>{subject}</span>
                <span class="bar-hrs">{hours.toFixed(1)}h</span>
              </div>
              <div class="bar-bg">
                <div
                  class="bar-fill"
                  style={`width: ${width}%; background: ${barColor(subject)}`}
                />
              </div>
            </div>
          );
        })}
    </div>
  )}
</div>

<style>
  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  .card-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .empty {
    font-size: 0.85rem;
    color: #475569;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #94a3b8;
    margin-bottom: 0.3rem;
  }
  .bar-hrs {
    font-family: 'JetBrains Mono', monospace;
    color: #64748b;
  }
  .bar-bg {
    width: 100%;
    height: 0.375rem;
    background: rgba(51, 65, 85, 0.4);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
