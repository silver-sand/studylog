---
export interface Props {
  subjects?: string[];
}

const { subjects = [] } = Astro.props;

const COLOR_PALETTE = ['#6366f1', '#22c55e', '#f59e0b', '#ec4899', '#a78bfa', '#06b6d4', '#f472b6', '#84cc16', '#fb923c', '#14b8a6'];
const subjectColorMap: Record<string, string> = {
  Physics: '#6366f1',
  Chemistry: '#22c55e',
  Mathematics: '#f59e0b',
  Maths: '#f59e0b',
  Biology: '#ec4899',
};
function getSubjectColor(subject: string): string {
  if (subjectColorMap[subject]) return subjectColorMap[subject];
  let hash = 0;
  for (let i = 0; i < subject.length; i++) { hash = ((hash << 5) - hash) + subject.charCodeAt(i); hash = hash & hash; }
  return COLOR_PALETTE[Math.abs(hash) % COLOR_PALETTE.length];
}
---

<div class="bg-[#0d1321] border border-white/5 rounded-2xl p-6 w-full animate-slide-up">
  <h4 class="text-sm font-headline font-semibold text-[#f8fafc] mb-5">Session Details</h4>

  <!-- Subject Chips -->
  <div class="mb-5">
    <label class="text-xs font-label text-slate-400 uppercase tracking-wider mb-3 block">Subject</label>
    <div class="flex flex-wrap gap-2" id="timer-subject-chips">
      {subjects.map((s) => {
        const color = getSubjectColor(s);
        return (
          <button
            type="button"
            data-subject={s}
            data-color={color}
            class="subject-chip px-4 py-2 rounded-full border border-slate-700 bg-[#050b18] text-slate-300 text-sm font-medium transition-all hover:border-slate-500 hover:text-[#f8fafc]"
          >
            <span class="w-2 h-2 rounded-full inline-block mr-2" style={`background-color: ${color}`}></span>
            {s}
          </button>
        );
      })}
    </div>
  </div>

  <!-- Topic Input -->
  <div class="mb-6">
    <label for="timer-topic-input" class="text-xs font-label text-slate-400 uppercase tracking-wider mb-3 block">Topic (optional)</label>
    <input
      type="text"
      id="timer-topic-input"
      placeholder="e.g. Kinematics, Organic Chemistry, Calculus..."
      class="w-full bg-[#050b18] border border-slate-700 rounded-xl px-4 py-3 text-sm text-[#f8fafc] placeholder-slate-500 focus:outline-none focus:border-[#6366f1] focus:ring-1 focus:ring-[#6366f1]/30 transition-all"
    />
  </div>

  <!-- Start Button -->
  <button id="timer-start-btn" class="w-full bg-[#6366f1] hover:bg-[#818cf8] text-white font-semibold py-3 px-6 rounded-xl transition-all duration-200 active:scale-[0.98] shadow-lg shadow-indigo-500/20 flex items-center justify-center gap-2">
    <span class="material-symbols-outlined text-lg filled-icon">play_arrow</span>
    Start Focus Session
  </button>

  <p class="text-xs text-slate-500 mt-3 text-center">Choose a subject and optionally enter a topic</p>
</div>

<script>
  (function() {
    const chips = document.querySelectorAll('#timer-subject-chips .subject-chip');
    const topicInput = document.getElementById('timer-topic-input');
    const startBtn = document.getElementById('timer-start-btn');
    let selectedSubject = '';

    // Chip toggle
    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => {
          c.classList.remove('bg-[#6366f1]', 'text-[#050b18]', 'border-[#6366f1]');
          c.classList.add('bg-[#050b18]', 'text-slate-300', 'border-slate-700');
        });
        chip.classList.remove('bg-[#050b18]', 'text-slate-300', 'border-slate-700');
        chip.classList.add('bg-[#6366f1]', 'text-[#050b18]', 'border-[#6366f1]');
        selectedSubject = chip.dataset.subject || '';
      });
    });

    // Start session
    startBtn.addEventListener('click', () => {
      if (!selectedSubject) {
        // Highlight to show it's required
        chips.forEach(c => c.style.animation = 'shake 0.4s ease');
        setTimeout(() => chips.forEach(c => c.style.animation = ''), 500);
        return;
      }
      const topic = topicInput.value.trim();

      // Fire the timer start event with subject/topic
      document.dispatchEvent(new CustomEvent('timer-start-session', {
        detail: { subject: selectedSubject, topic }
      }));
    });
  })();
</script>

<style>
  .animate-slide-up {
    animation: slide-up-fade 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slide-up-fade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-4px); }
    40% { transform: translateX(4px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(4px); }
  }
</style>
