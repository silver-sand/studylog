---
import type { SubjectBreakdownItem } from '../services/stats-service';

export interface Props {
  data: SubjectBreakdownItem[];
}

const { data } = Astro.props;
const maxHours = Math.max(...data.map((d) => d.hours), 1);

function barColor(subject: string): string {
  const name = subject.toLowerCase();
  if (name.includes('physics')) return '#3b82f6';
  if (name.includes('chemistry')) return '#22c55e';
  if (name.includes('math')) return '#f59e0b';
  if (name.includes('biology')) return '#ec4899';
  if (name.includes('english')) return '#8b5cf6';
  return '#64748b';
}
---

<div class="ds-card">
  <h3 class="card-title">Hours by Subject</h3>
  {data.length === 0 || data.every((d) => d.hours === 0) ? (
    <p class="ds-caption" style="text-align:center;padding:2rem 0;">Start logging your study sessions to see your progress here.</p>
  ) : (
    <div class="bars">
      {data.map((item) => {
        const width = Math.max((item.hours / maxHours) * 100, 5);
        return (
          <div class="bar-row">
            <div class="bar-label">
              <span class="bar-name">{item.subject}</span>
              <span class="bar-value">{item.hours}h <span class="bar-pct">{item.percentage}%</span></span>
            </div>
            <div class="bar-track">
              <div
                class="bar-fill"
                style={`width: ${width}%; background: ${barColor(item.subject)}`}
              />
            </div>
          </div>
        );
      })}
    </div>
  )}
</div>

<style>
  .card-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .bar-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
  }
  .bar-name {
    color: #94a3b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bar-value {
    font-family: 'JetBrains Mono', monospace;
    color: #64748b;
  }
  .bar-pct {
    color: #475569;
  }
  .bar-track {
    width: 100%;
    height: 0.5rem;
    background: rgba(51, 65, 85, 0.4);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
