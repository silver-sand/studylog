---
import type { SyllabusChapter } from '../types/review';
import { STATUS_ORDER, STATUS_LABELS } from '../types/review';

export interface Props {
  chapter: SyllabusChapter;
}

const { chapter } = Astro.props;

const activeIdx = STATUS_ORDER.indexOf(chapter.status);
const statusLabel = STATUS_LABELS[chapter.status] || 'Locked';

const colorMap: Record<string, string> = {
  not_started: '#475569',
  studied: '#f59e0b',
  revision_1: '#818cf8',
  revision_2: '#a78bfa',
  revision_3: '#e879f9',
  mastered: '#22c55e',
};

const bgMap: Record<string, string> = {
  not_started: 'bg-slate-800/50 text-slate-500',
  studied: 'bg-yellow-500/10 text-yellow-500',
  revision_1: 'bg-indigo-500/10 text-indigo-400',
  revision_2: 'bg-purple-500/10 text-purple-400',
  revision_3: 'bg-pink-500/10 text-pink-400',
  mastered: 'bg-emerald-500/10 text-emerald-400',
};

const isCompleted = chapter.status === 'mastered';
const isInProgress = chapter.status === 'studied';
const iconColor = colorMap[chapter.status] || '#475569';
const badgeClass = bgMap[chapter.status] || 'bg-slate-800/50 text-slate-500';
const ringClass = chapter.status === 'studied' ? 'ring-1 ring-indigo-500/20 border-indigo-500/30' : 'border-white/5';
---

<div
  class="chapter-item flex items-center gap-3 p-3 bg-[#050b18] rounded-xl border transition-all group hover:border-indigo-500/30 {ringClass}"
  data-chapter-id={chapter.id}
  data-status={chapter.status}
  data-class-level={chapter.classLevel || ''}
>
  <span
    class="chapter-icon material-symbols-outlined text-xl shrink-0"
    style={{ color: iconColor, fontVariationSettings: isCompleted ? "'FILL' 1" : "'FILL' 0" }}
  >{isCompleted ? 'check_circle' : 'radio_button_unchecked'}</span>
  <div class="flex-1 min-w-0 flex items-center gap-2.5">
    <p class="chapter-name text-sm font-medium truncate text-neutral-200 group-hover:text-white transition-colors">{chapter.chapter}</p>
    <span class="chapter-badge text-[10px] px-2 py-0.5 rounded-md uppercase font-bold tracking-wider shrink-0 {badgeClass}">{statusLabel}</span>
  </div>
</div>
