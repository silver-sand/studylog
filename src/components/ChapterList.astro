---
import type { SyllabusChapter } from '../types/review';
import { STATUS_ORDER, STATUS_LABELS } from '../types/review';

export interface Props {
  chapter: SyllabusChapter;
}

const { chapter } = Astro.props;

// Determine initial status
const activeIdx = STATUS_ORDER.indexOf(chapter.status);
const statusLabel = STATUS_LABELS[chapter.status] || 'Locked';

const colorMap: Record<string, string> = {
  not_started: '#475569',
  studied: '#f59e0b',
  revision_1: '#3b82f6',
  revision_2: '#8b5cf6',
  revision_3: '#ec4899',
  mastered: '#22c55e',
};

const bgMap: Record<string, string> = {
  not_started: 'bg-slate-800 text-slate-500',
  studied: 'bg-yellow-500/10 text-yellow-500',
  revision_1: 'bg-blue-500/10 text-blue-400',
  revision_2: 'bg-purple-500/10 text-purple-400',
  revision_3: 'bg-pink-500/10 text-pink-400',
  mastered: 'bg-emerald-500/10 text-emerald-400',
};

const isCompleted = chapter.status === 'mastered';
const isInProgress = chapter.status === 'studied';
const iconColor = colorMap[chapter.status] || '#475569';
const badgeClass = bgMap[chapter.status] || 'bg-slate-800 text-slate-500';
const ringClass = chapter.status === 'studied' ? 'ring-1 ring-indigo-500/20 border-indigo-500/40' : 'border-slate-800/50';
---

<div
  class="chapter-item flex items-center gap-3 p-3 bg-[#050b18] rounded-xl border transition-all group hover:border-indigo-500/30 {ringClass}"
  data-chapter-id={chapter.id}
  data-status={chapter.status}
>
  <span
    class="chapter-icon material-symbols-outlined shrink-0"
    style={`color: ${iconColor}; font-variation-settings: 'FILL' ${isCompleted ? 1 : 0};`}
  >{isCompleted ? 'check_circle' : isInProgress ? 'radio_button_unchecked' : 'radio_button_unchecked'}</span>
  <div class="flex-1 min-w-0">
    <p class="chapter-name text-sm font-semibold truncate text-white">{chapter.chapter}</p>
    <span class="chapter-badge text-[10px] px-2 py-0.5 rounded uppercase font-bold tracking-wider {badgeClass}">{statusLabel}</span>
  </div>
</div>
