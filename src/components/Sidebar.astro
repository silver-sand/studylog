---
export interface Props {
  currentPath: string;
  user?: { id: string; name: string; email: string; userType?: string; stream?: string; goal?: string; createdAt: string } | null;
}

const { currentPath, user } = Astro.props;
const isGuest = user?.userType === 'guest';

interface NavLink {
  href: string;
  label: string;
  icon: string;
}

const links: NavLink[] = [
  { href: '/dashboard', label: 'Dashboard', icon: 'dashboard' },
  { href: '/daily', label: 'Daily Log', icon: 'event_note' },
  { href: '/syllabus', label: 'Syllabus', icon: 'assignment' },
  { href: '/timer', label: 'Timer', icon: 'timer' },
  { href: '/mentor', label: 'AI Mentor', icon: 'smart_toy' },
  { href: '/weekly', label: 'Weekly Review', icon: 'calendar_month' },
  { href: '/settings', label: 'Settings', icon: 'settings' },
];

function isActive(href: string): boolean {
  if (href === '/daily') return currentPath === '/daily';
  if (href === '/dashboard') return currentPath === '/dashboard';
  return currentPath.startsWith(href);
}
---

<!-- Desktop Sidebar -->
<aside class="fixed left-0 top-0 h-full w-20 lg:w-64 bg-[#0d1321] border-r border-white/5 flex flex-col py-8 z-50 transition-all duration-300 ease-in-out hidden md:flex">
  <!-- Brand -->
  <div class="px-6 mb-10 flex items-center gap-3">
    <div class="w-8 h-8 rounded bg-indigo-500/20 text-indigo-500 flex items-center justify-center shrink-0">
      <span class="material-symbols-outlined filled-icon">menu_book</span>
    </div>
    <div class="hidden lg:block">
      <h1 class="font-headline font-black text-indigo-500 tracking-tight leading-none text-xl">StudyLog</h1>
      <p class="text-neutral-500 text-xs font-label uppercase tracking-wider mt-0.5">IIT-JEE Prep</p>
    </div>
  </div>

  <!-- Main Nav -->
  <div class="flex-1 px-4 space-y-1">
    {links.map(link => (
      <a
        href={link.href}
        class:list={{
          'flex items-center gap-4 px-3 py-2.5 rounded-lg font-label text-sm uppercase tracking-wider transition-all group': true,
          'bg-indigo-500/10 text-indigo-400 border-r-4 border-indigo-500 font-bold': isActive(link.href),
          'text-neutral-500 hover:text-neutral-300 hover:bg-white/5': !isActive(link.href),
        }}
      >
        <span
          class="material-symbols-outlined"
          class:list={{ 'filled-icon': isActive(link.href) }}
        >{link.icon}</span>
        <span class="hidden lg:block">{link.label}</span>
      </a>
    ))}
  </div>

  <!-- Footer: Start Focus button + User -->
  <div class="px-4 mt-auto space-y-1">
    <div class="px-3 mb-4 hidden lg:block">
      <a href="/timer" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-label text-sm uppercase tracking-wider py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-[18px] filled-icon">play_arrow</span>
        Start Focus
      </a>
    </div>
    <div class="flex items-center gap-3 px-3 py-2 rounded-lg">
      <div class="w-8 h-8 rounded-full bg-indigo-500/10 border border-white/10 flex items-center justify-center text-indigo-400 font-semibold text-sm shrink-0">
        {user?.name?.charAt(0)?.toUpperCase() || 'U'}
      </div>
      <div class="hidden lg:block min-w-0 flex-1">
        <p class="text-sm font-semibold text-white truncate">{user?.name || 'Student'}</p>
        <p class="text-[10px] text-neutral-500 truncate">{user?.email || 'Tier 1 Elite Track'}</p>
      </div>
    </div>
  </div>
</aside>

<!-- Mobile Bottom Nav -->
<nav class="fixed bottom-0 w-full z-50 md:hidden bg-[#050b18]/95 backdrop-blur-xl border-t border-white/[0.06] shadow-[0_-8px_24px_rgba(0,0,0,0.4)] h-[68px] flex justify-around items-center px-2" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
  {links.slice(0, 5).map(link => (
    <a
      href={link.href}
      class:list={{
        'flex flex-col items-center justify-center transition-all active:scale-90 duration-200 min-w-[56px] py-1.5 rounded-xl': true,
        'text-indigo-400 font-bold': isActive(link.href),
        'text-neutral-500 hover:text-neutral-300': !isActive(link.href),
      }}
    >
      <span
        class="material-symbols-outlined text-[22px]"
        class:list={{ 'filled-icon': isActive(link.href) }}
      >{link.icon}</span>
      <span class="font-body text-[9px] uppercase tracking-wide mt-0.5 font-medium">{link.label}</span>
    </a>
  ))}
</nav>

<script>
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });
  document.getElementById('exit-guest-btn')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });
</script>
