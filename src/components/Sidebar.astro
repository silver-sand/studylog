---
export interface Props {
  currentPath: string;
  user?: { id: string; name: string; email: string; stream?: string; goal?: string; createdAt: string } | null;
}

import AmbiencePlayer from './AmbiencePlayer.astro';

const { currentPath, user } = Astro.props;

interface NavLink {
  href: string;
  label: string;
  icon: string;
}

const links: NavLink[] = [
  {
    href: '/',
    label: 'Daily Log',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>`,
  },
  {
    href: '/dashboard',
    label: 'Dashboard',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>`,
  },
  {
    href: '/weekly',
    label: 'Weekly Reviews',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    href: '/syllabus',
    label: 'Syllabus',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect width="6" height="4" x="9" y="3" rx="1"/><path d="M9 14l2 2 4-4"/></svg>`,
  },
  {
    href: '/mentor',
    label: 'AI Mentor',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M16 14H8a4 4 0 0 0-4 4v2h16v-2a4 4 0 0 0-4-4z"/><circle cx="12" cy="7" r="1"/><line x1="10" y1="11" x2="14" y2="11"/></svg>`,
  },
  {
    href: '/timer',
    label: 'Timer',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    href: '/settings',
    label: 'Settings',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  },
];

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<aside class="sidebar">
  <div class="p-6 border-b border-slate-800/60">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center">
        <span class="text-white text-xs font-bold">SL</span>
      </div>
      <span class="text-lg font-semibold text-white tracking-tight">StudyLog</span>
    </a>
  </div>

  <nav class="flex-1 p-4 space-y-1">
    {links.map(link => (
      <a
        href={link.href}
        class:list={{
          'nav-link': true,
          'active': isActive(link.href),
        }}
      >
        <span class="nav-icon" set:html={link.icon}></span>
        <span>{link.label}</span>
      </a>
    ))}
  </nav>

  <AmbiencePlayer />

  <div class="p-4 border-t border-slate-800/60 space-y-1">
    {user ? (
      <>
        <p class="text-xs text-slate-400 truncate">{user.name}</p>
        <button id="logout-btn" class="text-xs text-slate-600 hover:text-red-400 transition-colors w-full text-left">Log out</button>
      </>
    ) : (
      <a href="/login" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">Log in</a>
    )}
  </div>
</aside>

<script>
  async function handleLogout() {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/login';
  }
  document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
  document.getElementById('mobile-logout-btn')?.addEventListener('click', handleLogout);
</script>

<!-- Mobile bottom nav -->
<nav class="mobile-nav">
  {links.map(link => (
    <a
      href={link.href}
      class:list={{
        'mobile-nav-link': true,
        'active': isActive(link.href),
      }}
    >
      <span class="mobile-nav-icon" set:html={link.icon}></span>
      <span>{link.label}</span>
    </a>
  ))}
  {user ? (
    <button id="mobile-logout-btn" class="mobile-nav-link" style="border:none;background:none;cursor:pointer;">
      <span class="mobile-nav-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
      </span>
      <span>Log out</span>
    </button>
  ) : (
    <a href="/login" class="mobile-nav-link">
      <span class="mobile-nav-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
      </span>
      <span>Log in</span>
    </a>
  )}
</nav>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 16rem;
    background: #0f172a;
    border-right: 1px solid rgba(51, 65, 85, 0.4);
    display: flex;
    flex-direction: column;
    z-index: 40;
  }

  @media (max-width: 767px) {
    .sidebar {
      display: none;
    }
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    color: #94a3b8;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    color: #e2e8f0;
    background: rgba(51, 65, 85, 0.4);
  }

  .nav-link.active {
    color: #f1f5f9;
    background: rgba(59, 130, 246, 0.1);
    font-weight: 500;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .nav-link.active .nav-icon {
    color: #60a5fa;
  }

  .mobile-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #0f172a;
    border-top: 1px solid rgba(51, 65, 85, 0.4);
    display: flex;
    justify-content: space-around;
    z-index: 40;
    padding: 0.5rem 0;
    padding-bottom: max(0.5rem, env(safe-area-inset-bottom));
  }

  @media (min-width: 768px) {
    .mobile-nav {
      display: none;
    }
  }

  .mobile-nav-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.625rem;
    color: #64748b;
    transition: color 0.15s;
  }

  .mobile-nav-link.active {
    color: #60a5fa;
  }

  .mobile-nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
  }
</style>
