---
import StudyRings from './StudyRings.astro';

export interface Props {
  coveragePercent: number;
  consistencyPercent: number;
  masteryPercent: number;
  readinessScore: number;
  readinessLabel: 'on_track' | 'behind' | 'critical';
  streak: number;
  weekDays: { day: string; completed: boolean }[];
  entriesThisWeek: number;
  studyDaysPerWeek: number;
  upcomingExams: { label: string; date: string }[];
  syllabusPercent: number;
  user: { name?: string } | null;
}

const {
  coveragePercent, consistencyPercent, masteryPercent,
  readinessScore, readinessLabel,
  streak, weekDays,
  upcomingExams, syllabusPercent, user,
} = Astro.props;

const dayNames = ['M','T','W','T','F','S','S'];
const todayIndex = new Date().getDay();
const mondayIndex = todayIndex === 0 ? 6 : todayIndex - 1;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
}

function daysUntil(dateStr: string): number {
  const now = new Date();
  const target = new Date(dateStr);
  const diff = target.getTime() - now.getTime();
  return Math.ceil(diff / (1000 * 60 * 60 * 24));
}
---

<div class="flex flex-col gap-8 animate-stagger">

  <!-- Profile Header -->
  <header class="flex items-center justify-between" style="--stagger-index:0">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-indigo-500/20 bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-lg font-bold">
        {user?.name ? user.name.charAt(0).toUpperCase() : 'U'}
      </div>
      <div>
        <h2 class="text-sm font-semibold text-white">{user?.name || 'Student'}</h2>
        <p class="text-xs text-neutral-500">Tier 1 Elite Track</p>
      </div>
    </div>
    <button class="w-10 h-10 rounded-lg hover:bg-white/5 flex items-center justify-center transition-colors">
      <span class="material-symbols-outlined text-neutral-400">notifications</span>
    </button>
  </header>

  <!-- Featured Progress Ring -->
  <div class="flex flex-col items-center mb-2" style="--stagger-index:1">
    <div class="relative mb-6">
      <StudyRings
        coveragePercent={coveragePercent}
        consistencyPercent={consistencyPercent}
        masteryPercent={masteryPercent}
        readinessScore={readinessScore}
        readinessLabel={readinessLabel}
      />
    </div>
    <h3 class="text-lg font-bold text-white mb-1">Exam Readiness</h3>
    <p class="text-sm text-neutral-500 text-center px-4 italic">
      {readinessScore >= 80
        ? "You're in the top tier of prep this week."
        : readinessScore >= 50
        ? 'Good progress! Keep the momentum going.'
        : 'Start building momentum with daily sessions.'}
    </p>
  </div>

  <!-- Streak Strip -->
  <div style="--stagger-index:2">
    <div class="flex items-center justify-between mb-4">
      <h4 class="text-xs font-label uppercase tracking-widest text-neutral-400">Current Streak</h4>
      <span class="text-xs font-bold text-[#F59E0B] flex items-center gap-1">
        {streak} DAYS <span class="material-symbols-outlined text-sm filled-icon">local_fire_department</span>
      </span>
    </div>
    <div class="grid grid-cols-7 gap-2">
      {Array.from({ length: 7 }).map((_, i) => {
        const dayAbbr = dayNames[i];
        const isCompleted = weekDays[i]?.completed ?? false;
        const isToday = i === mondayIndex;
        return (
          <div
            class={`aspect-square rounded-lg flex flex-col items-center justify-center transition-all duration-300 ${
              isCompleted
                ? 'bg-[#F59E0B]/10 border border-[#F59E0B]/20'
                : 'bg-white/5 border border-white/5'
            } ${isToday ? 'ring-2 ring-indigo-500/30' : ''}`}
          >
            <span class={`text-[10px] mb-1 ${isCompleted ? 'text-[#F59E0B]' : 'text-neutral-600'}`}>
              {dayAbbr}
            </span>
            {isCompleted ? (
              <span class="material-symbols-outlined text-xs text-[#F59E0B] filled-icon">local_fire_department</span>
            ) : (
              <span class="w-1.5 h-1.5 rounded-full bg-neutral-700"></span>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Upcoming Tests -->
  {upcomingExams.length > 0 && (
    <div style="--stagger-index:3">
      <div class="flex items-center justify-between mb-4">
        <h4 class="text-xs font-label uppercase tracking-widest text-neutral-400">Upcoming Tests</h4>
        <a href="/daily" class="text-[10px] text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1">
          View Schedule <span class="material-symbols-outlined text-[12px]">arrow_forward</span>
        </a>
      </div>
      <div class="space-y-3">
        {upcomingExams.map((exam) => {
          const days = daysUntil(exam.date);
          const iconMap = {
            'physics': 'science',
            'chemistry': 'science',
            'maths': 'calculate',
            'mathematics': 'calculate',
            'biology': 'biotech',
            'english': 'book',
          };
          const icon = Object.entries(iconMap).find(([key]) =>
            exam.label.toLowerCase().includes(key)
          )?.[1] || 'history_edu';
          const isUrgent = days <= 3;
          return (
            <div class="p-3 obsidian-glass rounded-xl flex items-center justify-between group cursor-pointer hover:bg-white/5 transition-all">
              <div class="flex items-center gap-3">
                <div class={`w-10 h-10 rounded-lg ${isUrgent ? 'bg-red-500/10 text-red-500' : 'bg-emerald-500/10 text-emerald-500'} flex items-center justify-center`}>
                  <span class="material-symbols-outlined text-lg">{icon}</span>
                </div>
                <div>
                  <h5 class="text-sm font-medium text-white group-hover:text-indigo-400 transition-colors">{exam.label}</h5>
                  <p class="text-[10px] text-neutral-500 uppercase tracking-wide">{formatDate(exam.date)}</p>
                </div>
              </div>
              <span class={`px-2 py-1 rounded-md text-[9px] font-bold ${days === 0 ? 'bg-red-500/20 text-red-400' : 'bg-white/5 text-neutral-400'}`}>
                {days === 0 ? 'TODAY' : days === 1 ? 'TOMORROW' : `${days} DAYS`}
              </span>
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- Syllabus Progress -->
  <div style="--stagger-index:4">
    <div class="flex items-center justify-between mb-2">
      <h4 class="text-xs font-label uppercase tracking-widest text-neutral-400">Syllabus Progress</h4>
      <span class="text-xs font-bold text-white">{syllabusPercent}%</span>
    </div>
    <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
      <div
        class="h-full rounded-full transition-all duration-1000 ease-out"
        class:list={{
          'bg-indigo-500': syllabusPercent >= 40,
          'bg-amber-500': syllabusPercent >= 20 && syllabusPercent < 40,
          'bg-red-500': syllabusPercent < 20,
        }}
        style={`width:${syllabusPercent}%`}
        id="syllabus-bar"
      ></div>
    </div>
  </div>
</div>

<script>
  window.addEventListener('load', () => {
    const bar = document.getElementById('syllabus-bar');
    if (bar) {
      const finalWidth = bar.style.width;
      bar.style.width = '0%';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          bar.style.transition = 'width 1s cubic-bezier(0.4, 0, 0.2, 1)';
          bar.style.width = finalWidth;
        });
      });
    }
  });
</script>
