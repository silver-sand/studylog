---
import StudyRings from './StudyRings.astro';
import StreakDisplay from './StreakDisplay.astro';

export interface Props {
  coveragePercent: number;
  consistencyPercent: number;
  masteryPercent: number;
  readinessScore: number;
  readinessLabel: 'on_track' | 'behind' | 'critical';
  streak: number;
  weekDays: { day: string; completed: boolean }[];
  entriesThisWeek: number;
  studyDaysPerWeek: number;
  upcomingExams: { label: string; date: string }[];
  syllabusPercent: number;
  user: { name?: string } | null;
}

const {
  coveragePercent, consistencyPercent, masteryPercent,
  readinessScore, readinessLabel,
  streak, weekDays, entriesThisWeek, studyDaysPerWeek,
  upcomingExams, syllabusPercent, user,
} = Astro.props;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<div class="left-column">
  <!-- Study Rings -->
  <div class="ds-card rings-card">
    <StudyRings
      coveragePercent={coveragePercent}
      consistencyPercent={consistencyPercent}
      masteryPercent={masteryPercent}
      readinessScore={readinessScore}
      readinessLabel={readinessLabel}
    />
  </div>

  <!-- Week Strip -->
  <div class="ds-card">
    <StreakDisplay
      streak={streak}
      weekDays={weekDays}
      entriesThisWeek={entriesThisWeek}
      studyDaysPerWeek={studyDaysPerWeek}
    />
  </div>

  <!-- Upcoming Exams -->
  {upcomingExams.length > 0 && (
    <div class="ds-card">
      <div class="ds-card-header">
        <h3 class="ds-card-title">Upcoming</h3>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        {upcomingExams.map(exam => (
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <span style="font-size:1rem;">📅</span>
            <div style="flex:1;">
              <div style="font-size:var(--ds-text-sm);color:var(--ds-text-primary);font-weight:500;">{exam.label}</div>
              <div style="font-size:var(--ds-text-xs);color:var(--ds-text-tertiary);">{formatDate(exam.date)}</div>
            </div>
          </div>
        ))}
      </div>
      <a href="/syllabus" class="ds-link-accent" style="font-size:var(--ds-text-xs);display:inline-block;margin-top:0.5rem;">
        View Schedule →
      </a>
    </div>
  )}

  <!-- Syllabus Progress -->
  <div class="ds-card">
    <div class="ds-flex-between">
      <span class="ds-card-title" style="margin-bottom:0;">Syllabus</span>
      <span class="ds-mono" style="font-size:var(--ds-text-xs);color:var(--ds-text-muted);">{syllabusPercent}%</span>
    </div>
    <div class="ds-progress ds-progress-lg" style="margin-top:0.5rem;">
      <div
        class="ds-progress-bar"
        class:list={{
          'ds-progress-bar--success': syllabusPercent >= 70,
          'ds-progress-bar--warning': syllabusPercent >= 40 && syllabusPercent < 70,
          'ds-progress-bar--danger': syllabusPercent < 40,
        }}
        style={`width:${syllabusPercent}%`}
      ></div>
    </div>
    <a href="/syllabus" class="ds-link-accent" style="font-size:var(--ds-text-xs);display:inline-block;margin-top:0.5rem;">
      Details →
    </a>
  </div>
</div>

<style>
  .left-column {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-3);
  }
  .rings-card {
    display: flex;
    justify-content: center;
    padding: var(--ds-space-3);
  }
</style>
