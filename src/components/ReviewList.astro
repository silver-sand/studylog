---
import { formatDisplayDate } from '../utils/date';
import EmptyState from './EmptyState.astro';
import type { WeeklyReview } from '../types/review';

export interface Props {
  reviews: WeeklyReview[];
}

const { reviews } = Astro.props;
---

<div>
  {reviews.length === 0 ? (
    <EmptyState
      title="No weekly reviews yet"
      description="Log some study entries for a week, then generate your first review."
    />
  ) : (
    <div class="space-y-2">
      {reviews.map(review => (
        <a
          href={`/weekly/${review.weekStart}`}
          class="review-item"
        >
          <div class="review-top">
            <span class="review-date">
              {formatDisplayDate(review.weekStart)} — {formatDisplayDate(review.weekEnd)}
            </span>
            <span class="review-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </div>
          {review.strengths.length > 0 && (
            <div class="strength-tags">
              {review.strengths.slice(0, 2).map(s => (
                <span class="strength-tag">{s.split(':')[0].replace('✅ ', '')}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .review-item {
    display: block;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.5rem;
    padding: 0.875rem 1rem;
    transition: border-color 0.15s;
  }
  .review-item:hover {
    border-color: rgba(51, 65, 85, 0.8);
  }
  .review-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .review-date {
    font-size: 0.85rem;
    font-weight: 500;
    color: #e2e8f0;
  }
  .review-arrow {
    color: #475569;
  }
  .strength-tags {
    display: flex;
    gap: 0.375rem;
    margin-top: 0.375rem;
  }
  .strength-tag {
    font-size: 0.7rem;
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
  }
</style>
