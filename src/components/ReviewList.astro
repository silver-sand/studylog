---
import { formatDisplayDate } from '../utils/date';
import EmptyState from './EmptyState.astro';
import type { WeeklyReview } from '../types/review';

export interface Props {
  reviews: WeeklyReview[];
}

const { reviews } = Astro.props;
---

<div>
  {reviews.length === 0 ? (
    <EmptyState
      title="No weekly reviews yet"
      description="Log some study entries for a week, then generate your first review."
    />
  ) : (
    <div class="review-list animate-stagger" style="--stagger-delay:0.06s;">
      {reviews.map((review, idx) => (
        <a
          href={`/weekly/${review.weekStart}`}
          class="review-item ds-card-glass card-lift animate-stagger-item"
          style="--stagger-index: {idx};"
        >
          <div class="review-top">
            <div class="review-date-group">
              <span class="review-date">{formatDisplayDate(review.weekStart)} — {formatDisplayDate(review.weekEnd)}</span>
              {review.strengths.length > 0 && (
                <div class="strength-tags">
                  {review.strengths.slice(0, 2).map(s => (
                    <span class="strength-tag">{s.split(':')[0].replace(/^✅\s*/, '')}</span>
                  ))}
                </div>
              )}
            </div>
            <span class="review-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </div>
          <div class="review-meta">
            <span class="review-meta-stat">{review.entryIds?.length || 0} entries</span>
            {review.insights?.length > 0 && (
              <span class="review-meta-stat">{review.insights.length} insights</span>
            )}
          </div>
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .review-list {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-1);
  }
  .review-item {
    padding: var(--ds-space-1) var(--ds-space-2);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-1);
  }
  .review-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .review-date-group {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
    flex-wrap: wrap;
  }
  .review-date {
    font-size: var(--ds-text-sm);
    font-weight: 500;
    color: var(--ds-text-primary);
  }
  .review-arrow {
    color: var(--ds-text-muted);
    flex-shrink: 0;
    transition: transform 0.15s;
  }
  .review-item:hover .review-arrow {
    transform: translateX(2px);
  }
  .review-meta {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
  }
  .review-meta-stat {
    font-size: var(--ds-text-2xs);
    color: var(--ds-text-muted);
    font-family: var(--ds-font-mono);
  }
  .strength-tags {
    display: flex;
    gap: var(--ds-space-1);
  }
  .strength-tag {
    font-size: var(--ds-text-2xs);
    color: var(--ds-success-500, #22c55e);
    background: color-mix(in srgb, var(--ds-success-500, #22c55e) 12%, transparent);
    padding: 0.05rem 0.4rem;
    border-radius: var(--ds-radius-full);
    font-weight: 500;
  }
</style>
