---
import type { FocusTrendItem } from '../services/stats-service';

export interface Props {
  data: FocusTrendItem[];
}

const { data } = Astro.props;
const maxRating = 5;
const chartHeight = 80;
const barAreaHeight = chartHeight - 18;

const points = data
  .map((d, i) => {
    const x = i * (100 / (data.length - 1 || 1));
    const y = barAreaHeight - (d.average / maxRating) * (barAreaHeight - 5);
    return `${x},${y}`;
  })
  .join(' ');
---

<div class="card">
  <h3 class="card-title">Focus Trend — Last {data.length} Days</h3>
  {data.length === 0 || data.every((d) => d.average === 0) ? (
    <p class="empty">No focus data yet.</p>
  ) : (
    <div class="chart-wrap">
      <svg viewBox={`0 0 100 ${chartHeight}`} class="chart-svg" preserveAspectRatio="none">
        <!-- Grid -->
        <line x1="0" y1="0" x2="100" y2="0" stroke="rgba(51,65,85,0.3)" stroke-width="0.3" />
        <line x1="0" y1={barAreaHeight * 0.5} x2="100" y2={barAreaHeight * 0.5} stroke="rgba(51,65,85,0.2)" stroke-width="0.3" />
        <line x1="0" y1={barAreaHeight} x2="100" y2={barAreaHeight} stroke="rgba(51,65,85,0.3)" stroke-width="0.3" />

        <!-- Area -->
        <polygon
          points={`0,${barAreaHeight} ${points} 100,${barAreaHeight}`}
          fill="url(#focusGrad)"
          opacity="0.2"
        />

        <!-- Line -->
        <polyline
          points={points}
          fill="none"
          stroke="#22c55e"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />

        <!-- Dots -->
        {data.map((d, i) => {
          const x = i * (100 / (data.length - 1 || 1));
          const y = barAreaHeight - (d.average / maxRating) * (barAreaHeight - 5);
          return (
            <circle
              cx={x}
              cy={y}
              r={d.average > 0 ? 1.5 : 0}
              fill="#22c55e"
              stroke="#0f172a"
              stroke-width="0.5"
            />
          );
        })}

        <defs>
          <linearGradient id="focusGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#22c55e" />
            <stop offset="100%" stop-color="#22c55e" stop-opacity="0" />
          </linearGradient>
        </defs>
      </svg>

      <div class="x-labels">
        {data.map((d) => (
          <span class="x-label">
            {d.label}
            {d.average > 0 && <span class="x-val">{d.average}</span>}
          </span>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  .card-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  .empty {
    font-size: 0.85rem;
    color: #475569;
  }
  .chart-wrap {
    width: 100%;
  }
  .chart-svg {
    width: 100%;
    height: 80px;
    overflow: visible;
  }
  .x-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.15rem;
  }
  .x-label {
    font-size: 0.55rem;
    color: #475569;
    font-family: 'JetBrains Mono', monospace;
    text-align: center;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .x-val {
    font-size: 0.65rem;
    color: #64748b;
    font-weight: 500;
  }
</style>
