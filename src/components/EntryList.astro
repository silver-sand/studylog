---
import { isToday, formatDisplayDate } from '../utils/date';
import type { Entry } from '../types/entry';

export interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;

function subjectColor(subject: string): string {
  const name = subject.toLowerCase();
  if (name.includes('physics')) return 'bg-blue-400/10 text-blue-400 border-blue-400/20';
  if (name.includes('chemistry')) return 'bg-emerald-400/10 text-emerald-400 border-emerald-400/20';
  if (name.includes('math')) return 'bg-amber-400/10 text-amber-400 border-amber-400/20';
  if (name.includes('biology')) return 'bg-rose-400/10 text-rose-400 border-rose-400/20';
  if (name.includes('english')) return 'bg-purple-400/10 text-purple-400 border-purple-400/20';
  return 'bg-slate-400/10 text-slate-400 border-slate-400/20';
}
---

<div>
  {entries.length === 0 ? (
    <div class="p-12 text-center">
      <span class="material-symbols-outlined text-4xl text-neutral-600 mb-3">history</span>
      <p class="text-neutral-500 text-sm">No entries yet. Start logging above!</p>
    </div>
  ) : (
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-white/5 bg-[#0a0f1a]/50">
          <th class="px-5 py-3.5 font-label text-[10px] uppercase tracking-widest text-neutral-500">Date</th>
          <th class="px-5 py-3.5 font-label text-[10px] uppercase tracking-widest text-neutral-500">Subjects</th>
          <th class="px-5 py-3.5 font-label text-[10px] uppercase tracking-widest text-neutral-500">Duration</th>
          <th class="px-5 py-3.5 font-label text-[10px] uppercase tracking-widest text-neutral-500 text-right pr-6">Rating</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/[0.03]">
        {entries.slice(0, 20).map(entry => (
          <tr class="hover:bg-white/[0.02] transition-colors group">
            <td class="px-5 py-4">
              <span class="text-sm font-medium text-white">
                {isToday(entry.date) ? 'Today' : formatDisplayDate(entry.date)}
              </span>
            </td>
            <td class="px-5 py-4">
              <div class="flex gap-1.5 flex-wrap">
                {entry.subjects.length > 0 ? entry.subjects.slice(0, 3).map((subject: string) => (
                  <span class={`px-2 py-0.5 rounded-full text-[10px] font-bold border ${subjectColor(subject)}`}>
                    {subject}
                  </span>
                )) : (
                  <span class="text-[10px] text-neutral-600">—</span>
                )}
              </div>
            </td>
            <td class="px-5 py-4">
              <span class="text-sm text-neutral-400 font-mono tabular-nums">
                {entry.hoursStudied ? `${entry.hoursStudied.toFixed(1)}h` : '—'}
              </span>
            </td>
            <td class="px-5 py-4 text-right pr-6">
              {entry.focusRating > 0 ? (
                <div class="flex justify-end text-amber-400/80 gap-0.5">
                  {[1, 2, 3, 4, 5].map(n => (
                    <span
                      class="material-symbols-outlined text-base"
                      class:list={{
                        'filled-icon text-amber-400': n <= entry.focusRating,
                        'text-neutral-700': n > entry.focusRating,
                      }}
                    >star</span>
                  ))}
                </div>
              ) : (
                <span class="text-neutral-600 text-sm">—</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</div>

<style>
  .filled-icon {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
