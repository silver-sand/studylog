---
export interface Props {
  streak: number;
  weekDays?: { day: string; completed: boolean }[];
  entriesThisWeek?: number;
  studyDaysPerWeek?: number;
}

const { streak, weekDays = [], entriesThisWeek = 0, studyDaysPerWeek = 5 } = Astro.props;
---

<div class="streak-card">
  <div class="streak-badge">
    <span class="streak-fire">🔥</span>
    <span class="streak-count">{streak}</span>
  </div>
  <span class="streak-label-text">
    {streak === 0 ? 'No active streak' :
     streak === 1 ? '1-day streak' :
     `${streak}-day streak`}
  </span>

  <div class="week-strip-wrap">
    <div class="ds-week-strip">
      {weekDays.map(d => (
        <div class="ds-week-day">
          <div class:list={['ds-week-dot', { 'ds-week-dot--filled': d.completed }]} />
          <span>{d.day}</span>
        </div>
      ))}
    </div>
    <span class="ds-body-sm" style="text-align:center;margin-top:0.125rem;">
      {entriesThisWeek}/{studyDaysPerWeek} days this week
    </span>
  </div>
</div>

<style>
  .streak-card {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(23, 32, 51, 0.8));
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .streak-badge {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
  .streak-fire {
    font-size: 1.5rem;
    line-height: 1;
  }
  .streak-count {
    font-size: 2.5rem;
    font-weight: 700;
    color: #f1f5f9;
    font-family: 'JetBrains Mono', monospace;
    line-height: 1;
  }
  .streak-label-text {
    font-size: 0.8rem;
    color: #94a3b8;
  }
  .week-strip-wrap {
    margin-top: 0.25rem;
    width: 100%;
  }
</style>
