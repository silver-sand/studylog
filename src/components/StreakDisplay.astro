---
export interface Props {
  streak: number;
  weekDays?: { day: string; completed: boolean }[];
  entriesThisWeek?: number;
  studyDaysPerWeek?: number;
}

const { streak, weekDays = [], entriesThisWeek = 0, studyDaysPerWeek = 5 } = Astro.props;

const dayLabels = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];

// Use weekDays from props if provided, otherwise build from dayLabels
const days = weekDays.length === 7
  ? weekDays.map((d, i) => ({ label: d.day.slice(0, 1), completed: d.completed }))
  : dayLabels.map((label, i) => ({
      label,
      completed: i < entriesThisWeek,
    }));
---

<div class="streak-card">
  <div class="streak-top-row">
    <div class="streak-title-group">
      <span class="material-symbols-outlined filled-icon text-amber-400 text-2xl" style="font-variation-settings: 'FILL' 1; filter: drop-shadow(0 0 6px rgba(251, 191, 36, 0.5));">local_fire_department</span>
      <span class="streak-count-text">{streak}-Day Streak</span>
    </div>
    <span class="streak-encouragement">Keep it up!</span>
  </div>

  <div class="week-strip">
    {days.map(d => (
      <div class:list={['day-cell', { 'day-cell--active': d.completed, 'day-cell--inactive': !d.completed }]}>
        <span class="day-label">{d.label}</span>
        {d.completed ? (
          <div class="day-dot day-dot--filled">
            <span class="material-symbols-outlined filled-icon text-amber-400 text-sm">local_fire_department</span>
          </div>
        ) : (
          <div class="day-dot day-dot--empty">
            <div class="day-dot-inner"></div>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .streak-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: var(--ds-space-3);
  }

  .streak-top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .streak-title-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .streak-count-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ds-text-primary);
    line-height: 1;
  }

  .streak-encouragement {
    font-size: var(--ds-text-sm);
    font-weight: 500;
    color: var(--ds-secondary);
  }

  .week-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 0.25rem;
  }

  .day-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.2s;
  }

  .day-cell--inactive {
    opacity: 0.3;
  }

  .day-label {
    font-size: var(--ds-text-sm);
    font-weight: 500;
    color: var(--ds-text-tertiary);
  }

  .day-dot {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .day-dot--filled {
    background: rgba(255, 198, 64, 0.2);
  }

  .day-dot--empty {
    background: rgba(255, 255, 255, 0.1);
  }

  .day-dot-inner {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: var(--ds-text-tertiary);
  }
</style>
