---
import type { TypeDistributionItem } from '../services/stats-service';

export interface Props {
  data: TypeDistributionItem[];
}

const { data } = Astro.props;
const totalHours = data.reduce((s, d) => s + d.hours, 0) || 1;

const typeColors: Record<string, string> = {
  theory: '#3b82f6',
  problem_solving: '#f59e0b',
  revision: '#8b5cf6',
  test: '#22c55e',
  other: '#64748b',
};
---

<div class="ds-card">
  <h3 class="card-title">Study Type Breakdown</h3>
  {data.length === 0 || data.every((d) => d.hours === 0) ? (
    <p class="ds-caption" style="text-align:center;padding:2rem 0;">Start logging your study sessions to see your progress here.</p>
  ) : (
    <div class="bars">
      {data.map((item) => {
        const width = (item.hours / totalHours) * 100;
        const color = typeColors[item.type] || '#64748b';
        return (
          <div class="bar-row">
            <div class="bar-label">
              <span class="bar-name">
                <span class="dot" style={`background: ${color}`}></span>
                {item.label}
              </span>
              <span class="bar-value">{item.hours}h · {item.count}x</span>
            </div>
            <div class="bar-track">
              <div
                class="bar-fill"
                style={`width: ${Math.max(width, 3)}%; background: ${color}`}
              />
            </div>
          </div>
        );
      })}
    </div>
  )}
</div>

<style>
  .card-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .bar-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
  }
  .bar-name {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #94a3b8;
  }
  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .bar-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: #64748b;
  }
  .bar-track {
    width: 100%;
    height: 0.5rem;
    background: rgba(51, 65, 85, 0.4);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
