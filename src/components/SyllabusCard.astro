---
import type { SyllabusProgress } from '../types/review';

export interface Props {
  subject: string;
  progress: SyllabusProgress;
  isExpanded: boolean;
  onToggle: string;
}

const { subject, progress, isExpanded } = Astro.props;

function subjectColor(s: string): string {
  const name = s.toLowerCase();
  if (name.includes('physics')) return 'blue';
  if (name.includes('chemistry')) return 'green';
  if (name.includes('math')) return 'amber';
  if (name.includes('biology')) return 'pink';
  return 'gray';
}

const color = subjectColor(subject);

const colorMap: Record<string, { bg: string; border: string; text: string; bar: string; glow: string }> = {
  blue: { bg: 'rgba(59, 130, 246, 0.08)', border: 'rgba(59, 130, 246, 0.25)', text: '#93c5fd', bar: '#3b82f6', glow: 'rgba(59, 130, 246, 0.3)' },
  green: { bg: 'rgba(34, 197, 94, 0.08)', border: 'rgba(34, 197, 94, 0.25)', text: '#86efac', bar: '#22c55e', glow: 'rgba(34, 197, 94, 0.3)' },
  amber: { bg: 'rgba(245, 158, 11, 0.08)', border: 'rgba(245, 158, 11, 0.25)', text: '#fcd34d', bar: '#f59e0b', glow: 'rgba(245, 158, 11, 0.3)' },
  pink: { bg: 'rgba(236, 72, 153, 0.08)', border: 'rgba(236, 72, 153, 0.25)', text: '#f9a8d4', bar: '#ec4899', glow: 'rgba(236, 72, 153, 0.3)' },
  gray: { bg: 'rgba(100, 116, 139, 0.08)', border: 'rgba(100, 116, 139, 0.25)', text: '#94a3b8', bar: '#64748b', glow: 'rgba(100, 116, 139, 0.3)' },
};

const c = colorMap[color];
---

<div class="syllabus-card" id={`card-${subject.replace(/\s+/g, '-')}`}>
  <div class="card-header">
    <div class="subject-info">
      <div class="subject-icon" style={`background: ${c.bg}; color: ${c.text}`}>
        {subject[0]}
      </div>
      <div>
        <h3 class="subject-name">{subject}</h3>
        <p class="subject-count">{progress.completed}/{progress.total} chapters</p>
      </div>
    </div>
    <div class="percent-wrap">
      <span class="percent-text" style={`color: ${c.text}`}>{progress.weightedPercent}%</span>
    </div>
  </div>

  <div class="syllabus-bar-bg">
    <div
      class="syllabus-bar-fill"
      style={`width: ${progress.weightedPercent}%; background: ${c.bar}; box-shadow: 0 0 8px ${c.glow}`}
    />
  </div>
</div>

<style>
  .syllabus-card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.25rem;
    cursor: pointer;
    transition: border-color 0.15s, transform 0.15s;
  }
  .syllabus-card:hover {
    border-color: rgba(71, 85, 105, 0.7);
    transform: translateY(-1px);
  }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .subject-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .subject-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .subject-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #e2e8f0;
    margin: 0;
  }
  .subject-count {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0.1rem 0 0 0;
    font-family: 'JetBrains Mono', monospace;
  }
  .percent-wrap {
    display: flex;
    align-items: center;
  }
  .percent-text {
    font-size: 1.1rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
  }
  .syllabus-bar-bg {
    width: 100%;
    height: 0.4rem;
    background: rgba(51, 65, 85, 0.5);
    border-radius: 999px;
    overflow: hidden;
  }
  .syllabus-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
