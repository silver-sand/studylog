---
import type { SyllabusProgress } from '../types/review';

export interface Props {
  subject: string;
  progress: SyllabusProgress;
}

const { subject, progress } = Astro.props;

function subjectColor(s: string): string {
  const name = s.toLowerCase();
  if (name.includes('physics')) return 'blue';
  if (name.includes('chemistry')) return 'green';
  if (name.includes('math')) return 'amber';
  if (name.includes('biology')) return 'pink';
  return 'gray';
}

const color = subjectColor(subject);

const colorMap: Record<string, { border: string; bar: string }> = {
  blue: { border: 'rgba(59, 130, 246, 0.3)', bar: '#3b82f6' },
  green: { border: 'rgba(34, 197, 94, 0.3)', bar: '#22c55e' },
  amber: { border: 'rgba(245, 158, 11, 0.3)', bar: '#f59e0b' },
  pink: { border: 'rgba(236, 72, 153, 0.3)', bar: '#ec4899' },
  gray: { border: 'rgba(100, 116, 139, 0.3)', bar: '#64748b' },
};

const c = colorMap[color];
---

<div class="syllabus-card" id={`card-${subject.replace(/\s+/g, '-')}`} data-subject={subject}>
  <div class="card-header">
    <div class="subject-info">
      <div class="subject-icon" style={`border-color: ${c.border}; color: var(--ds-text-primary);`}>
        {subject[0]}
      </div>
      <div>
        <h3 class="subject-name">{subject}</h3>
        <p class="subject-count">{progress.completed}/{progress.total} chapters</p>
      </div>
    </div>
    <div class="percent-wrap">
      <span class="percent-text" style={`color: ${c.bar}`}>{progress.weightedPercent}%</span>
    </div>
  </div>

  <div class="syllabus-bar-bg">
    <div
      class="syllabus-bar-fill"
      style={`width: ${progress.weightedPercent}%; background: ${c.bar}`}
    />
  </div>
</div>

<style>
  .syllabus-card {
    background: var(--ds-bg-surface);
    border: 1px solid var(--ds-border-default);
    border-radius: var(--ds-radius-lg);
    padding: var(--ds-space-2) var(--ds-space-3);
    transition: border-color 0.15s, transform 0.15s;
  }
  .syllabus-card:hover {
    border-color: var(--ds-border-hover);
  }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--ds-space-1);
  }
  .subject-info {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
  }
  .subject-icon {
    width: 2rem;
    height: 2rem;
    border-radius: var(--ds-radius-md);
    border: 1px solid var(--ds-border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .subject-name {
    font-size: var(--ds-text-sm);
    font-weight: var(--ds-weight-semibold);
    color: var(--ds-text-primary);
    margin: 0;
  }
  .subject-count {
    font-size: var(--ds-text-2xs);
    color: var(--ds-text-muted);
    margin: 0;
    font-family: var(--ds-font-mono);
  }
  .percent-wrap {
    display: flex;
    align-items: center;
  }
  .percent-text {
    font-size: var(--ds-text-lg);
    font-weight: var(--ds-weight-bold);
    font-family: var(--ds-font-mono);
  }
  .syllabus-bar-bg {
    width: 100%;
    height: 0.35rem;
    background: var(--ds-bg-elevated);
    border-radius: 999px;
    overflow: hidden;
  }
  .syllabus-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
