---
import type { SyllabusProgress } from '../types/review';

export interface Props {
  subject: string;
  progress: SyllabusProgress;
}

const { subject, progress } = Astro.props;

function subjectColor(s: string): string {
  const name = s.toLowerCase();
  const STANDARD: Record<string, string> = { physics: 'blue', chemistry: 'green', maths: 'amber', mathematics: 'amber', biology: 'pink' };
  for (const [key, color] of Object.entries(STANDARD)) { if (name.includes(key)) return color; }
  const PALETTE = ['blue', 'green', 'amber', 'pink', 'purple', 'cyan', 'rose', 'lime', 'orange', 'teal'];
  let hash = 0; for (let i = 0; i < s.length; i++) { hash = ((hash << 5) - hash) + s.charCodeAt(i); hash = hash & hash; }
  return PALETTE[Math.abs(hash) % PALETTE.length];
}

const color = subjectColor(subject);

const colorMap: Record<string, { accent: string; bar: string }> = {
  blue: { accent: '#3b82f6', bar: '#3b82f6' },
  green: { accent: '#22c55e', bar: '#22c55e' },
  amber: { accent: '#f59e0b', bar: '#f59e0b' },
  pink: { accent: '#ec4899', bar: '#ec4899' },
  purple: { accent: '#8b5cf6', bar: '#8b5cf6' },
  cyan: { accent: '#06b6d4', bar: '#06b6d4' },
  rose: { accent: '#f43f5e', bar: '#f43f5e' },
  lime: { accent: '#84cc16', bar: '#84cc16' },
  orange: { accent: '#f97316', bar: '#f97316' },
  teal: { accent: '#14b8a6', bar: '#14b8a6' },
  gray: { accent: '#64748b', bar: '#64748b' },
};

const c = colorMap[color] || colorMap.gray;
---

<div
  class="syllabus-card ds-card-glass card-lift animate-slide-up"
  id={`card-${subject.replace(/\s+/g, '-')}`}
  data-subject={subject}
  style="--subject-color: {c.accent};"
>
  <!-- Subject accent bar -->
  <div class="subject-accent-bar" style="background: {c.accent};"></div>

  <div class="card-header">
    <div class="subject-info">
      <div class="subject-icon" style="border-color: color-mix(in srgb, {c.accent} 30%, transparent); color: {c.accent};">
        {subject[0]}
      </div>
      <div>
        <h3 class="subject-name">{subject}</h3>
        <p class="subject-count">{progress.completed}/{progress.total} chapters</p>
      </div>
    </div>
    <div class="percent-wrap">
      <span class="percent-text count-up" style="color: {c.accent};">{progress.weightedPercent}%</span>
    </div>
  </div>

  <div class="syllabus-bar-bg">
    <div
      class="syllabus-bar-fill bar-fill"
      style="width: {progress.weightedPercent}%; background: {c.bar};"
      data-width="{progress.weightedPercent}"
    />
  </div>
</div>

<style>
  .syllabus-card {
    position: relative;
    padding: var(--ds-space-1) var(--ds-space-2);
    width: 100%;
    overflow: hidden;
  }
  .syllabus-card .subject-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 0 2px 2px 0;
  }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--ds-space-1);
  }
  .subject-info {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
    min-width: 0;
  }
  .subject-icon {
    width: clamp(1.5rem, 1.8vw, 2rem);
    height: clamp(1.5rem, 1.8vw, 2rem);
    border-radius: var(--ds-radius-md);
    border: 1px solid var(--ds-border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.65rem, 0.9vw, 0.8rem);
    font-weight: 700;
    flex-shrink: 0;
  }
  .subject-name {
    font-size: clamp(var(--ds-text-sm), 1.1vw, var(--ds-text-base));
    font-weight: var(--ds-weight-semibold);
    color: var(--ds-text-primary);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .subject-count {
    font-size: var(--ds-text-2xs);
    color: var(--ds-text-muted);
    margin: 0;
    font-family: var(--ds-font-mono);
  }
  .percent-wrap {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .percent-text {
    font-size: clamp(var(--ds-text-sm), 1.3vw, var(--ds-text-lg));
    font-weight: var(--ds-weight-bold);
    font-family: var(--ds-font-mono);
  }
  .syllabus-bar-bg {
    width: 100%;
    height: 0.25rem;
    background: var(--ds-bg-elevated);
    border-radius: 999px;
    overflow: hidden;
  }
  .syllabus-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
