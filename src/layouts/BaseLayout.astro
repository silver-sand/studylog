---
import Sidebar from '../components/Sidebar.astro';
import AuthPopup from '../components/AuthPopup.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import '../styles/design-system.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const user = getSessionUser(getTokenFromCookie(Astro.request));
const currentPath = Astro.url.pathname;
// Auth popup is always rendered (hidden by default) for sidebar button trigger
// Guest users are auto-created by middleware, no gate needed
const showAuthPopup = false;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#020617" />
    <meta name="description" content="AI-Powered Daily Study Progress Tracker" />
    <title>{title} — StudyLog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/design-system.css" />
  </head>
  <body class="bg-surface-950 text-slate-300 antialiased min-h-screen font-sans ds-page">
    <div class="flex min-h-screen">
      <Sidebar currentPath={Astro.url.pathname} user={user} />
      <main class="flex-1 p-6 md:p-8 lg:p-10 ml-0 md:ml-64 min-w-0 pb-20 md:pb-8">
        <slot />
      </main>
    </div>

    <AuthPopup />

    <style>
      /* Base styles are in design-system.css — this file only customizes Astro layout */
    </style>
  </body>
</html>
