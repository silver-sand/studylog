---
import Sidebar from '../components/Sidebar.astro';
import AuthPopup from '../components/AuthPopup.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import '../styles/design-system.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const user = getSessionUser(getTokenFromCookie(Astro.request));
const currentPath = Astro.url.pathname;
// Auth popup is always rendered (hidden by default) for sidebar button trigger
// Guest users are auto-created by middleware, no gate needed
const showAuthPopup = false;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#020617" />
    <meta name="description" content="AI-Powered Daily Study Progress Tracker" />
    <title>{title} — StudyLog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Public+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/design-system.css" />
  </head>
  <body class="bg-[#050505] text-[#E5E5E5] antialiased min-h-screen font-sans">
    <div class="flex min-h-screen">
      <Sidebar currentPath={Astro.url.pathname} user={user} />
      <main class="flex-1 ml-0 md:ml-20 lg:ml-64 min-w-0 pb-[80px] md:pb-0 page-enter">
        <slot />
      </main>
    </div>

    <AuthPopup />

    <script>
      // ── Scroll-triggered reveal: IntersectionObserver ──
      // Watches .reveal-on-scroll (and -left, -right, -scale) elements
      // and adds .revealed when they enter the viewport.
      // Also animates staggered children within a revealed container.
      const observer = new IntersectionObserver(
        entries => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll(
        '.reveal-on-scroll, .reveal-on-scroll-left, .reveal-on-scroll-right, .reveal-on-scroll-scale'
      ).forEach(el => observer.observe(el));

      // ── Ripple effect for .ripple-btn ──
      document.addEventListener('click', e => {
        const btn = e.target.closest('.ripple-btn');
        if (!btn) return;
        const rect = btn.getBoundingClientRect();
        const ripple = document.createElement('span');
        ripple.className = 'ripple-effect';
        const size = Math.max(rect.width, rect.height);
        ripple.style.width = ripple.style.height = size + 'px';
        ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
        ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
        btn.appendChild(ripple);
        ripple.addEventListener('animationend', () => ripple.remove());
      });

      // ── Page enter animation ──
      document.querySelector('.page-enter')?.classList.add('page-enter');
    </script>

    <style is:global>
      /* Base styles are in design-system.css — this file only customizes Astro layout */
    </style>
  </body>
</html>
