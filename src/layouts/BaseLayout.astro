---
import Sidebar from '../components/Sidebar.astro';
import AuthPopup from '../components/AuthPopup.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const user = getSessionUser(getTokenFromCookie(Astro.request));
const currentPath = Astro.url.pathname;
// Don't show auth popup on auth/onboarding pages
const showAuthPopup = !user && !['/login', '/signup', '/onboarding'].includes(currentPath);
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#020617" />
    <meta name="description" content="AI-Powered Daily Study Progress Tracker" />
    <title>{title} — StudyLog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface-950 text-slate-300 antialiased min-h-screen font-sans">
    <div class="flex min-h-screen">
      <Sidebar currentPath={Astro.url.pathname} user={user} />
      <main class="flex-1 p-6 md:p-8 lg:p-10 ml-0 md:ml-64 min-w-0 pb-20 md:pb-8">
        <slot />
      </main>
    </div>

    {showAuthPopup && <AuthPopup />}

    <style>
      ::selection {
        background: rgba(59, 130, 246, 0.25);
        color: #f1f5f9;
      }
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #334155;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #475569;
      }
      body {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
    </style>
  </body>
</html>
