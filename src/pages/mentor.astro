---
import BaseLayout from '../layouts/BaseLayout.astro';
import MentorChat from '../components/MentorChat.astro';
---

<BaseLayout title="AI Mentor">
  <div class="max-w-3xl mx-auto">
    <div class="mb-6">
      <h1 class="page-title">AI Mentor</h1>
      <p class="page-sub">Your AI study partner — ask questions, get quizzed, or just talk through what you're learning.</p>
    </div>

    <MentorChat />
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .page-sub {
    font-size: 0.875rem;
    color: #64748b;
  }
</style>
