---
import BaseLayout from '../layouts/BaseLayout.astro';
import MentorChat from '../components/MentorChat.astro';
import 'katex/dist/katex.min.css';
---

<BaseLayout title="AI Mentor">
  <!-- Main Content Wrapper -->
  <div class="flex-1 flex flex-col h-screen bg-[#050b18]">
    <!-- TopNavBar -->
    <header class="h-16 w-full bg-[#050b18]/80 backdrop-blur-md border-b border-white/5 shadow-sm flex justify-between items-center px-6 shrink-0 z-30">
      <div class="flex items-center gap-4">
        <h2 class="font-headline text-lg tracking-tight text-neutral-300 font-semibold">AI Mentor Session</h2>
        <div class="h-4 w-px bg-white/10 hidden md:block"></div>
        <span class="px-2.5 py-1 rounded bg-indigo-500/10 text-indigo-400 font-label text-xs uppercase tracking-wider hidden md:inline-flex items-center gap-1.5 border border-indigo-500/20">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          Active Connect
        </span>
      </div>
      <div class="flex items-center gap-2">
        <a href="/settings" class="p-2 text-neutral-500 hover:text-neutral-300 hover:bg-white/5 rounded-lg transition-all active:scale-95 duration-150 relative">
          <span class="material-symbols-outlined">notifications</span>
          <span class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-indigo-500 border-2 border-[#050b18]"></span>
        </a>
        <a href="/settings" class="p-2 text-neutral-500 hover:text-neutral-300 hover:bg-white/5 rounded-lg transition-all active:scale-95 duration-150">
          <span class="material-symbols-outlined">settings</span>
        </a>
        <div class="h-8 w-8 ml-2 rounded-full bg-[#1a2235] border border-white/10 overflow-hidden shrink-0 flex items-center justify-center text-neutral-500 font-headline font-semibold text-sm">U</div>
      </div>
    </header>

    <!-- Split Screen Layout -->
    <main class="flex-1 flex overflow-hidden">
      <!-- Left Panel: Past Sessions (30%) -->
      <aside class="hidden md:flex flex-col w-[30%] min-w-[300px] max-w-[400px] border-r border-white/5 bg-[#0d1321]/30">
        <div class="p-4 border-b border-white/5 flex justify-between items-center shrink-0">
          <h3 class="font-label text-sm uppercase tracking-wider text-neutral-400">Past Sessions</h3>
          <button class="p-1.5 text-neutral-500 hover:text-indigo-400 hover:bg-indigo-500/10 rounded transition-colors">
            <span class="material-symbols-outlined text-[18px]">add</span>
          </button>
        </div>
        <div class="flex-1 overflow-y-auto p-3 space-y-2" id="past-sessions">
          <!-- History items rendered by JS -->
          <div class="flex items-center justify-center h-full">
            <p class="text-xs text-neutral-500">Session history will appear here</p>
          </div>
        </div>
      </aside>

      <!-- Right Panel: Active Chat Canvas (70%) -->
      <section class="flex-1 flex flex-col bg-[#050b18] relative">
        <MentorChat />
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #1a2235; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #2a3449; }
</style>
