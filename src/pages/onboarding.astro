---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import { getDb } from '../db';
import { STREAMS } from '../utils/stream-map';
import { EXAM_DEFINITIONS } from '../utils/exam-map';
import { scopeDbToUser } from '../services/user-scope';
import { computeDailyAverage } from '../types/profile';

scopeDbToUser(Astro.request);
const db = getDb();
const user = getSessionUser(getTokenFromCookie(Astro.request));
if (!user) {
  return Astro.redirect('/');
}

const isUpdate = Astro.url.searchParams.has('update');
const settings = db.getSettings();

const existingProfile = user?.classLevel ? {
  name: user.name,
  classLevel: user.classLevel,
  stream: user.stream || '',
  selectedExams: settings.selectedExams || [],
  targetHours: settings.targetHoursPerWeek,
  studyDays: settings.studyDaysPerWeek,
  coaching: (user as any).coaching || '',
  weakSubjects: (user as any).weakSubjects || [],
  targetRank: (user as any).targetRank || '',
  subjects: settings.subjects || [],
} : null;

const CLASS_LEVELS = [
  { value: 'class_9', label: 'Class 9' },
  { value: 'class_10', label: 'Class 10' },
  { value: 'class_11', label: 'Class 11' },
  { value: 'class_12', label: 'Class 12' },
  { value: 'dropper', label: 'Dropper' },
  { value: 'college', label: 'College' },
  { value: 'other', label: 'Other' },
];
---

<BaseLayout title={isUpdate ? 'Update Study Profile' : 'Set Up Your Workspace'}>
  <main class="ds-flex-center" style="min-height:80vh;padding:2rem 1rem;">
    <div class="ds-onboarding-card" style="max-width:520px;width:100%;">

      <!-- Step indicator -->
      <div class="ds-flex-center ds-gap-md" id="step-indicator" style="margin-bottom:var(--ds-space-3);">
        <div class="ds-step active" data-step="0">1</div>
        <div class="ds-divider" style="width:1rem;"></div>
        <div class="ds-step" data-step="1">2</div>
        <div class="ds-divider" style="width:1rem;"></div>
        <div class="ds-step" data-step="2">3</div>
        <div class="ds-divider" style="width:1rem;"></div>
        <div class="ds-step" data-step="3">4</div>
        <div class="ds-divider" style="width:1rem;"></div>
        <div class="ds-step" data-step="4">5</div>
      </div>

      <!-- Step 0: Name + Class + Stream (combined) -->
      <div class="step-content" data-step="0">
        <p class="ds-caption" style="margin:0 0 var(--ds-space-1);color:var(--ds-accent-400);font-size:var(--ds-text-xs);">Step 1 of 5</p>
        <h2 class="ds-heading-section" style="font-size:var(--ds-text-xl);margin:0 0 0.25rem;">Let's get to know you 👋</h2>
        <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Your name, class, and stream help me configure everything.</p>
        <div style="display:flex;flex-direction:column;gap:var(--ds-space-3);">

          <input type="text" id="onboarding-name" class="ds-input" placeholder="Your name (e.g. Aarav, Priya...)" value={existingProfile?.name || (user.name !== 'Guest' ? user.name : '')} required />

          <select id="onboarding-classlevel" class="ds-input">
            <option value="">Select your class level</option>
            {CLASS_LEVELS.map(cl => {
              const isDisabled = cl.value === 'class_9' || cl.value === 'class_10';
              return (
                <option value={cl.value} selected={existingProfile?.classLevel === cl.value}
                  disabled={isDisabled}
                  style={isDisabled ? 'opacity:0.5;' : ''}>
                  {cl.label}{isDisabled ? ' (Coming Soon)' : ''}
                </option>
              );
            })}
          </select>

          <label class="ds-label-form" style="margin-bottom:0;">Your stream</label>
          <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
            {Object.entries(STREAMS).map(([key, stream]) => (
              <button type="button" class="stream-card" data-stream={key}
                style="display:flex;align-items:center;gap:var(--ds-space-2);padding:var(--ds-space-2) var(--ds-space-2);border-radius:var(--ds-radius-lg);border:1px solid var(--ds-border-subtle);background:var(--ds-bg-surface);cursor:pointer;text-align:left;transition:all 0.15s;">
                <span style="font-size:1.2rem;">{stream.icon}</span>
                <div>
                  <div style="font-weight:var(--ds-weight-semibold);color:var(--ds-text-primary);font-size:var(--ds-text-sm);">{stream.label}</div>
                  <div style="font-size:var(--ds-text-2xs);color:var(--ds-text-muted);">{stream.examKeys.length} exams available</div>
                </div>
              </button>
            ))}
          </div>
          <input type="hidden" id="onboarding-stream" value={existingProfile?.stream || ''} />
        </div>
      </div>

      <!-- Step 1: Exams -->
      <div class="step-content hidden" data-step="1">
        <p class="ds-caption" style="margin:0 0 var(--ds-space-1);color:var(--ds-accent-400);font-size:var(--ds-text-xs);">Step 2 of 5</p>
        <h2 class="ds-heading-section" style="font-size:var(--ds-text-xl);margin:0 0 0.25rem;">Which exams are you preparing for? 🎯</h2>
        <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Pick one or more. Subjects auto-configure from your selection.</p>
        <div class="exam-grid" id="exam-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:var(--ds-space-2);">
          {EXAM_DEFINITIONS.map(exam => (
            <button type="button"
              class="exam-card hidden"
              data-exam={exam.key}
              data-groups={JSON.stringify(exam.groups)}
              style="padding:var(--ds-space-1) var(--ds-space-2);border-radius:var(--ds-radius-lg);border:1px solid var(--ds-border-subtle);background:var(--ds-bg-surface);cursor:pointer;text-align:left;transition:all 0.15s;"
            >
              <div style="font-size:var(--ds-text-sm);font-weight:var(--ds-weight-semibold);color:var(--ds-text-primary);">{exam.label}</div>
              <div style="font-size:var(--ds-text-2xs);color:var(--ds-text-muted);">{exam.subjects.length} subjects</div>
            </button>
          ))}
        </div>
        <p class="ds-caption" style="margin-top:var(--ds-space-2);" id="exam-count">Select at least one exam</p>
        <input type="hidden" id="onboarding-exams" />
      </div>

      <!-- Step 2: Coaching + Subject Selection + Weak Subjects -->
      <div class="step-content hidden" data-step="2">
        <p class="ds-caption" style="margin:0 0 var(--ds-space-1);color:var(--ds-accent-400);font-size:var(--ds-text-xs);">Step 3 of 5</p>
        <h2 class="ds-heading-section" style="font-size:var(--ds-text-xl);margin:0 0 0.25rem;">Your study setup 💪</h2>
        <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Pick your subjects, coaching type, and flag tough topics.</p>

        <label class="ds-label-form" style="margin-bottom:var(--ds-space-1);">Subjects you study</label>
        <p class="ds-caption" style="margin:0 0 var(--ds-space-1);font-size:var(--ds-text-2xs);">Toggle on the ones you're actually taking. (PCM/PCB/PCMB/Full)</p>
        <div class="subject-toggle-grid" id="subject-toggle-grid" style="display:flex;flex-wrap:wrap;gap:var(--ds-space-1);margin-bottom:var(--ds-space-2);"></div>
        <input type="hidden" id="onboarding-subjects" />

        <label class="ds-label-form" style="margin-bottom:var(--ds-space-1);">Coaching</label>
        <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);margin-bottom:var(--ds-space-2);">
          {[
            { value: 'both', label: 'Coaching + Self-study', icon: '📚' },
            { value: 'coaching_only', label: 'Coaching only', icon: '🏫' },
            { value: 'self_study', label: 'Self-study only', icon: '💻' },
          ].map(({ value, label, icon }) => (
            <button type="button"
              class="coaching-option"
              data-coaching={value}
              style="display:flex;align-items:center;gap:var(--ds-space-2);padding:var(--ds-space-1) var(--ds-space-2);border-radius:var(--ds-radius-lg);border:1px solid var(--ds-border-subtle);background:var(--ds-bg-surface);cursor:pointer;text-align:left;">
              <span style="font-size:1.1rem;">{icon}</span>
              <span style="font-size:var(--ds-text-sm);color:var(--ds-text-primary);">{label}</span>
            </button>
          ))}
        </div>
        <input type="hidden" id="onboarding-coaching" value={existingProfile?.coaching || ''} />

        <label class="ds-label-form" style="margin-bottom:var(--ds-space-1);">Subjects needing extra attention</label>
        <div class="weak-subjects-grid" id="weak-subjects-grid" style="display:flex;flex-wrap:wrap;gap:var(--ds-space-1);"></div>
        <p class="ds-caption" style="margin-top:var(--ds-space-1);" id="weak-count">Pick subjects you find tough (optional)</p>
      </div>

      <!-- Step 3: Target + Hours/Days -->
      <div class="step-content hidden" data-step="3">
        <p class="ds-caption" style="margin:0 0 var(--ds-space-1);color:var(--ds-accent-400);font-size:var(--ds-text-xs);">Step 4 of 5</p>
        <h2 class="ds-heading-section" style="font-size:var(--ds-text-xl);margin:0 0 0.25rem;">Goal + Commitment 🌟</h2>
        <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">What are you aiming for, and how much time can you realistically put in?</p>

        <div style="display:flex;flex-direction:column;gap:var(--ds-space-2);margin-bottom:var(--ds-space-2);">
          <label class="ds-label-form" style="margin-bottom:0;">Target (score, rank, or goal)</label>
          <textarea id="onboarding-target" class="ds-input" rows="2" placeholder="e.g. Top 100 in JEE Advanced, 95% in Boards, or just stay consistent..." style="resize:vertical;min-height:56px;font-family:var(--ds-font-sans);">{existingProfile?.targetRank || ''}</textarea>
          <div style="display:flex;flex-wrap:wrap;gap:var(--ds-space-1);">
            {['Top 1000 in JEE', '90%+ in Boards', 'Just stay consistent', 'Rank under 5000'].map(ex => (
              <button type="button" class="target-suggestion" style="padding:var(--ds-space-1) var(--ds-space-1);border-radius:999px;border:1px solid var(--ds-border-subtle);background:var(--ds-bg-surface);cursor:pointer;font-size:var(--ds-text-xs);color:var(--ds-text-tertiary);">{ex}</button>
            ))}
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:var(--ds-space-2);">
          <label class="ds-label-form" style="margin-bottom:0;">Weekly commitment</label>
          <div style="display:flex;align-items:center;gap:var(--ds-space-3);">
            <input type="number" id="onboarding-hours" class="ds-input" min="1" max="168" value={existingProfile?.targetHours || '35'} style="width:4.5rem;text-align:center;font-family:var(--ds-font-mono);" />
            <span class="ds-body-sm">hours / week</span>
          </div>
          <div style="display:flex;align-items:center;gap:var(--ds-space-3);">
            <input type="number" id="onboarding-days" class="ds-input" min="1" max="7" value={existingProfile?.studyDays || '5'} style="width:4.5rem;text-align:center;font-family:var(--ds-font-mono);" />
            <span class="ds-body-sm">days / week</span>
          </div>
          <p class="ds-caption" style="margin:0;" id="daily-average-display">
            ≈ {computeDailyAverage(existingProfile?.targetHours || 35, existingProfile?.studyDays || 5)} hrs per study day
          </p>
        </div>
      </div>

      <!-- Step 4: Review -->
      <div class="step-content hidden" data-step="4">
        <p class="ds-caption" style="margin:0 0 var(--ds-space-1);color:var(--ds-accent-400);font-size:var(--ds-text-xs);">Last step!</p>
        <h2 class="ds-heading-section" style="font-size:var(--ds-text-xl);margin:0 0 0.25rem;">Here's your study profile 📋</h2>
        <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Everything look right? I'll set up your workspace based on this.</p>
        <div id="review-summary" style="display:flex;flex-direction:column;gap:var(--ds-space-2);padding:var(--ds-space-3);border-radius:var(--ds-radius-lg);background:var(--ds-bg-surface);border:1px solid var(--ds-border-subtle);">
          <div class="review-row"><span class="review-label">Name</span><span class="review-value" id="review-name"></span></div>
          <div class="review-row"><span class="review-label">Class</span><span class="review-value" id="review-class"></span></div>
          <div class="review-row"><span class="review-label">Stream</span><span class="review-value" id="review-stream"></span></div>
          <div class="review-row"><span class="review-label">Exams</span><span class="review-value" id="review-exams"></span></div>
          <div class="review-row"><span class="review-label">Coaching</span><span class="review-value" id="review-coaching"></span></div>
          <div class="review-row"><span class="review-label">Weak Subjects</span><span class="review-value" id="review-weak"></span></div>
          <div class="review-row"><span class="review-label">Subjects</span><span class="review-value" id="review-subjects"></span></div>
          <div class="review-row"><span class="review-label">Goal</span><span class="review-value" id="review-target"></span></div>
          <div class="review-row"><span class="review-label">Commitment</span><span class="review-value" id="review-commitment"></span></div>
        </div>
      </div>

      <div id="form-error" class="ds-error-text hidden" style="margin-top:var(--ds-space-2);padding:var(--ds-space-1) var(--ds-space-2);background:var(--ds-danger-bg);border:1px solid var(--ds-danger-border);border-radius:var(--ds-radius-md);"></div>

      <div style="display:flex;gap:var(--ds-space-3);margin-top:var(--ds-space-3);">
        <button id="prev-btn" class="ds-btn ds-btn-ghost hidden" style="flex-shrink:0;">← Back</button>
        <button id="next-btn" class="ds-btn ds-btn-primary" style="flex:1;">Continue →</button>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  window.__EXAM_SUBJECTS = {
    {EXAM_DEFINITIONS.map(e => `${JSON.stringify(e.key)}: ${JSON.stringify(e.subjects)}`).join(',\n    ')}
  };
  window.__STREAM_SUBJECTS = {
    {Object.entries(STREAMS).map(([k, s]) => `${JSON.stringify(k)}: ${JSON.stringify(s.subjects)}`).join(',\n    ')}
  };
  window.__PRE_FILL = {
    selectedExams: {JSON.stringify(existingProfile?.selectedExams || [])},
    stream: {JSON.stringify(existingProfile?.stream || '')},
    weakSubjects: {JSON.stringify(existingProfile?.weakSubjects || [])},
    subjects: {JSON.stringify(existingProfile?.subjects || [])},
  };
</script>

<script>
  const CLASS_LEVEL_LABELS = {
    class_9: 'Class 9', class_10: 'Class 10', class_11: 'Class 11', class_12: 'Class 12',
    dropper: 'Dropper', college: 'College', other: 'Other',
  };
  const COACHING_LABELS = {
    both: 'Coaching + Self-study',
    coaching_only: 'Coaching only',
    self_study: 'Self-studying',
  };
  const STREAM_LABELS = { science: 'Science', commerce: 'Commerce', humanities: 'Humanities' };

  const steps = [0, 1, 2, 3, 4];
  let currentStep = 0;

  const indicators = document.querySelectorAll('.ds-step');
  const stepContents = document.querySelectorAll('.step-content');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const errorDiv = document.getElementById('form-error');

  function showError(msg) { errorDiv.textContent = msg; errorDiv.classList.remove('hidden'); }
  function hideError() { errorDiv.classList.add('hidden'); }

  function updateStep(step) {
    currentStep = step;
    hideError();
    stepContents.forEach(el => el.classList.toggle('hidden', parseInt(el.dataset.step) !== step));

    indicators.forEach(el => {
      const s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === step);
      el.classList.toggle('completed', s < step);
    });
    prevBtn.classList.toggle('hidden', step <= 0);

    if (step === steps.length - 1) {
      nextBtn.textContent = '🎯 Generate My Workspace';
    } else {
      nextBtn.textContent = 'Continue →';
    }
  }

  function getStepData(step) {
    switch (step) {
      case 0: {
        const name = document.getElementById('onboarding-name').value.trim();
        const classLevel = document.getElementById('onboarding-classlevel').value;
        const stream = document.getElementById('onboarding-stream').value;
        if (!name) return { valid: false, msg: 'Please enter your name.' };
        if (!classLevel) return { valid: false, msg: 'Please select your class level.' };
        if (!stream) return { valid: false, msg: 'Please select your stream.' };
        return { valid: true, data: { name, classLevel, stream } };
      }
      case 1: {
        const selected = document.querySelectorAll('#exam-grid .exam-card.selected');
        if (selected.length === 0) return { valid: false, msg: 'Please select at least one exam.' };
        return { valid: true, data: { exams: Array.from(selected).map(c => c.dataset.exam) } };
      }
      case 2: {
        const selectedSubjects = Array.from(document.querySelectorAll('#subject-toggle-grid .subject-toggle-chip.selected')).map(c => c.dataset.subject);
        if (selectedSubjects.length === 0) return { valid: false, msg: 'Please select at least one subject you study.' };
        const coaching = document.getElementById('onboarding-coaching').value;
        if (!coaching) return { valid: false, msg: 'Please tell me about your coaching setup.' };
        const weakSubjects = Array.from(document.querySelectorAll('#weak-subjects-grid .weak-subject-chip.selected')).map(c => c.dataset.subject);
        return { valid: true, data: { subjects: selectedSubjects, coaching, weakSubjects } };
      }
      case 3: {
        const target = document.getElementById('onboarding-target').value.trim();
        const hours = parseInt(document.getElementById('onboarding-hours').value);
        const days = parseInt(document.getElementById('onboarding-days').value);
        if (isNaN(hours) || hours < 1 || hours > 168) return { valid: false, msg: 'Hours must be between 1 and 168.' };
        if (isNaN(days) || days < 1 || days > 7) return { valid: false, msg: 'Days must be between 1 and 7.' };
        return { valid: true, data: { targetRank: target, targetHours: hours, studyDays: days } };
      }
      case 4:
        return { valid: true };
    }
    return { valid: true };
  }

  function showEncouragement(step) {
    const name = document.getElementById('onboarding-name').value.trim() || 'there';
    const msgs = {
      0: `Great, thanks ${name}! Let's pick your exams.`,
      1: 'Perfect! Now let me understand your study habits.',
      2: 'Got it! Now set your goals.',
      3: "Almost there! Let's review everything.",
    };
    const msg = msgs[step];
    if (msg) {
      const existing = document.querySelector('.encouragement-toast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.className = 'encouragement-toast';
      toast.textContent = msg;
      document.querySelector('.ds-onboarding-card').appendChild(toast);
      setTimeout(() => toast.classList.add('show'), 10);
      setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 300); }, 1800);
    }
  }

  function loadWeakSubjects(subjects) {
    const grid = document.getElementById('weak-subjects-grid');
    grid.innerHTML = '';
    const preFill = window.__PRE_FILL?.weakSubjects || [];
    subjects.forEach(subject => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'weak-subject-chip' + (preFill.includes(subject) ? ' selected' : '');
      chip.dataset.subject = subject;
      chip.textContent = subject;
      chip.addEventListener('click', () => {
        chip.classList.toggle('selected');
        updateWeakCount();
      });
      grid.appendChild(chip);
    });
    updateWeakCount();
  }

  function loadSubjectToggles(subjects) {
    const grid = document.getElementById('subject-toggle-grid');
    if (!grid) return;
    grid.innerHTML = '';
    const saved = window.__PRE_FILL?.subjects || [];
    const hasSaved = saved.length > 0;
    subjects.forEach(subject => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'subject-toggle-chip' + ((!hasSaved || saved.includes(subject)) ? ' selected' : '');
      chip.dataset.subject = subject;
      chip.textContent = subject;
      chip.addEventListener('click', () => {
        chip.classList.toggle('selected');
        updateSubjectToggleCount();
      });
      grid.appendChild(chip);
    });
    updateSubjectToggleCount();
  }
  function updateSubjectToggleCount() {
    const selected = document.querySelectorAll('#subject-toggle-grid .subject-toggle-chip.selected');
    document.getElementById('onboarding-subjects').value = Array.from(selected).map(c => c.dataset.subject).join(',');
  }

  function updateWeakCount() {
    const count = document.querySelectorAll('#weak-subjects-grid .weak-subject-chip.selected').length;
    const total = document.querySelectorAll('#weak-subjects-grid .weak-subject-chip').length;
    document.getElementById('weak-count').textContent = count > 0
      ? `${count} subject${count !== 1 ? 's' : ''} flagged`
      : 'Pick subjects you find tough (optional)';
  }

  function filterExamsByStream(stream) {
    const preFillExams = window.__PRE_FILL?.selectedExams || [];
    document.querySelectorAll('#exam-grid .exam-card').forEach(card => {
      const groups = JSON.parse(card.dataset.groups || '[]');
      if (groups.includes(stream)) {
        card.classList.remove('hidden');
        if (preFillExams.includes(card.dataset.exam)) {
          card.classList.add('selected');
          card.style.borderColor = 'var(--ds-accent-500)';
        }
      } else {
        card.classList.add('hidden');
        card.classList.remove('selected');
        card.style.borderColor = 'var(--ds-border-subtle)';
      }
    });
    // Auto-select first exam when pre-fill is empty
    const visibleCards = document.querySelectorAll('#exam-grid .exam-card:not(.hidden)');
    if (visibleCards.length === 1 && preFillExams.length === 0) {
      visibleCards[0].classList.add('selected');
      visibleCards[0].style.borderColor = 'var(--ds-accent-500)';
    }
    updateExamCount();
  }

  function updateExamCount() {
    const count = document.querySelectorAll('#exam-grid .exam-card.selected').length;
    document.getElementById('exam-count').textContent = count + ' exam' + (count !== 1 ? 's' : '') + ' selected';
  }

  function updateDailyAverage() {
    const h = parseInt(document.getElementById('onboarding-hours').value) || 0;
    const d = parseInt(document.getElementById('onboarding-days').value) || 1;
    const avg = Math.round((h / d) * 10) / 10;
    document.getElementById('daily-average-display').textContent = `≈ ${avg} hrs per study day`;
  }

  function populateReviewSummary() {
    const name = document.getElementById('onboarding-name').value.trim();
    document.getElementById('review-name').textContent = name;
    document.getElementById('review-class').textContent = CLASS_LEVEL_LABELS[document.getElementById('onboarding-classlevel').value] || '';
    document.getElementById('review-stream').textContent = STREAM_LABELS[document.getElementById('onboarding-stream').value] || '';
    const exams = Array.from(document.querySelectorAll('#exam-grid .exam-card.selected')).map(c => c.textContent.trim().split('\n')[0].trim());
    document.getElementById('review-exams').textContent = exams.join(', ') || 'None';
    const coachingVal = document.getElementById('onboarding-coaching').value;
    document.getElementById('review-coaching').textContent = COACHING_LABELS[coachingVal] || 'Not specified';
    const weak = Array.from(document.querySelectorAll('#weak-subjects-grid .weak-subject-chip.selected')).map(c => c.dataset.subject);
    document.getElementById('review-weak').textContent = weak.length > 0 ? weak.join(', ') : 'None';
    const selectedSubjects = Array.from(document.querySelectorAll('#subject-toggle-grid .subject-toggle-chip.selected')).map(c => c.dataset.subject);
    document.getElementById('review-subjects').textContent = selectedSubjects.length > 0 ? selectedSubjects.join(', ') : 'None';
    document.getElementById('review-target').textContent = document.getElementById('onboarding-target').value.trim() || 'Not specified';
    const hours = document.getElementById('onboarding-hours').value;
    const days = document.getElementById('onboarding-days').value;
    const avg = Math.round((hours / days) * 10) / 10;
    document.getElementById('review-commitment').textContent = `${hours}h / ${days}d (≈${avg}h/day)`;
  }

  prevBtn.addEventListener('click', () => {
    if (currentStep > 0) updateStep(currentStep - 1);
  });

  nextBtn.addEventListener('click', async () => {
    const result = getStepData(currentStep);
    if (!result.valid) {
      showError(result.msg || 'Please complete this step to continue.');
      return;
    }

    // Step-specific preparation for the next step
    if (currentStep === 0) {
      const stream = document.getElementById('onboarding-stream').value;
      if (stream) filterExamsByStream(stream);
    }

    if (currentStep === 1) {
      const stream = document.getElementById('onboarding-stream').value;
      const selectedExams = Array.from(document.querySelectorAll('#exam-grid .exam-card.selected')).map(c => c.dataset.exam);
      const EXAMS = window.__EXAM_SUBJECTS || {};
      const STREAMS = window.__STREAM_SUBJECTS || {};
      const subjects = new Set();
      // Add stream subjects as base set
      if (stream && STREAMS[stream]) {
        STREAMS[stream].forEach(s => subjects.add(s));
      }
      // Add exam-specific subjects
      selectedExams.forEach(key => {
        if (EXAMS[key]) EXAMS[key].forEach(s => subjects.add(s));
      });
      const allSubjects = [...subjects];
      loadSubjectToggles(allSubjects);
      loadWeakSubjects(allSubjects);
    }

    if (currentStep === 3) {
      updateDailyAverage();
      populateReviewSummary();
    }

    if (currentStep < steps.length - 1) {
      showEncouragement(currentStep);
      updateStep(currentStep + 1);
    } else {
      // Submit
      nextBtn.disabled = true;
      nextBtn.textContent = 'Setting up your workspace...';

      try {
        const name = document.getElementById('onboarding-name').value.trim();
        const classLevel = document.getElementById('onboarding-classlevel').value;
        const stream = document.getElementById('onboarding-stream').value;
        const exams = Array.from(document.querySelectorAll('#exam-grid .exam-card.selected')).map(c => c.dataset.exam);
        const coaching = document.getElementById('onboarding-coaching').value;
        const weakSubjects = Array.from(document.querySelectorAll('#weak-subjects-grid .weak-subject-chip.selected')).map(c => c.dataset.subject);
        const targetRank = document.getElementById('onboarding-target').value.trim();
        const targetHours = document.getElementById('onboarding-hours').value;
        const studyDays = document.getElementById('onboarding-days').value;

        const subjects = Array.from(document.querySelectorAll('#subject-toggle-grid .subject-toggle-chip.selected')).map(c => c.dataset.subject);

        const res = await fetch('/api/onboarding', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name, classLevel, stream, selectedExams: exams,
            subjects,
            coaching, weakSubjects, targetRank,
            targetHours, studyDaysPerWeek: studyDays,
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Save failed' }));
          throw new Error(err.error || 'Save failed');
        }

        window.location.href = '/dashboard';
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Something went wrong');
        nextBtn.disabled = false;
        nextBtn.textContent = '🎯 Generate My Workspace';
      }
    }
  });

  // ── Stream selection ──
  document.querySelectorAll('.stream-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.stream-card').forEach(c => c.style.borderColor = 'var(--ds-border-subtle)');
      card.style.borderColor = 'var(--ds-accent-500)';
      document.getElementById('onboarding-stream').value = card.dataset.stream;
      hideError();
    });
  });

  // ── Exam selection ──
  document.getElementById('exam-grid').addEventListener('click', (e) => {
    const card = e.target.closest('.exam-card');
    if (!card || card.classList.contains('hidden')) return;
    card.classList.toggle('selected');
    card.style.borderColor = card.classList.contains('selected') ? 'var(--ds-accent-500)' : 'var(--ds-border-subtle)';
    updateExamCount();
    hideError();
  });

  // ── Coaching selection ──
  document.querySelectorAll('.coaching-option').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.coaching-option').forEach(b => {
        b.style.borderColor = 'var(--ds-border-subtle)';
        b.style.background = 'var(--ds-bg-surface)';
      });
      btn.style.borderColor = 'var(--ds-accent-500)';
      btn.style.background = 'var(--ds-accent-bg)';
      document.getElementById('onboarding-coaching').value = btn.dataset.coaching;
      hideError();
    });
  });

  // ── Target suggestions ──
  document.querySelectorAll('.target-suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('onboarding-target').value = btn.textContent;
      hideError();
    });
  });

  // ── Live daily average ──
  document.getElementById('onboarding-hours').addEventListener('input', updateDailyAverage);
  document.getElementById('onboarding-days').addEventListener('input', updateDailyAverage);

  // ── Enter key ──
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && currentStep > 0) nextBtn.click();
  });

  // ── Init ──
  updateStep(0);
</script>

<style>
  .hidden { display: none !important; }
  .review-row { display: flex; justify-content: space-between; align-items: center; padding: 0.2rem 0; }
  .review-label { font-size: var(--ds-text-sm); color: var(--ds-text-muted); }
  .review-value { font-size: var(--ds-text-sm); color: var(--ds-text-primary); font-weight: var(--ds-weight-medium); text-align: right; }

  .weak-subject-chip {
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--ds-border-default);
    border-radius: 999px;
    background: var(--ds-bg-surface);
    color: var(--ds-text-tertiary);
    cursor: pointer;
    font-size: var(--ds-text-xs);
    transition: all 0.15s;
    user-select: none;
  }
  .weak-subject-chip:hover {
    border-color: var(--ds-border-hover);
    color: var(--ds-text-primary);
  }
  .weak-subject-chip.selected {
    background: rgba(251, 191, 36, 0.15);
    border-color: #f59e0b;
    color: #fbbf24;
  }

  /* Encouragement toast */
  .encouragement-toast {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    background: var(--ds-bg-elevated);
    border: 1px solid var(--ds-accent-500);
    color: var(--ds-text-primary);
    padding: 0.75rem 1.5rem;
    border-radius: var(--ds-radius-lg);
    font-size: var(--ds-text-sm);
    font-weight: var(--ds-weight-medium);
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 10;
    white-space: nowrap;
  }
  .encouragement-toast.show {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  @media (max-width: 480px) {
    .exam-grid { grid-template-columns: 1fr !important; }
    .ds-onboarding-card { padding: var(--ds-space-3) var(--ds-space-2) !important; max-width: 100% !important; }
    .ds-onboarding-card .ds-step { width: 1.5rem; height: 1.5rem; font-size: var(--ds-text-2xs); }
    #step-indicator { flex-wrap: wrap; justify-content: center; }
  }

  .subject-toggle-chip {
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--ds-border-default);
    border-radius: 999px;
    background: var(--ds-bg-surface);
    color: var(--ds-text-tertiary);
    cursor: pointer;
    font-size: var(--ds-text-xs);
    transition: all 0.15s;
    user-select: none;
  }
  .subject-toggle-chip:hover {
    border-color: var(--ds-border-hover);
    color: var(--ds-text-primary);
  }
  .subject-toggle-chip.selected {
    background: rgba(99, 102, 241, 0.15);
    border-color: #6366f1;
    color: #818cf8;
  }
</style>
