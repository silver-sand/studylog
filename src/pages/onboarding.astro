---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import { STREAMS } from '../utils/stream-map';
import { EXAM_DEFINITIONS, getSubjectsForExamKeys } from '../utils/exam-map';

const user = getSessionUser(getTokenFromCookie(Astro.request));
if (!user) {
  return Astro.redirect('/');
}
---

<BaseLayout title="Get Started">
  <main class="onboarding-page">
    <div class="onboarding-card">
      <div class="step-indicator" id="step-indicator">
        <div class="step active" data-step="1">1</div>
        <div class="step-line"></div>
        <div class="step" data-step="2">2</div>
        <div class="step-line"></div>
        <div class="step" data-step="3">3</div>
      </div>

      <!-- Step 1: Name + Stream -->
      <div class="step-content" data-step="1">
        <h2 class="step-title">Welcome! Who are you?</h2>
        <p class="step-sub">Tell me your name and stream so I can set things up.</p>
        <input type="text" id="onboarding-name" class="form-input" placeholder="Your name" value={user.name !== 'Guest' ? user.name : ''} required />
        <div class="stream-options mt-4">
          {Object.entries(STREAMS).map(([key, stream]) => (
            <button type="button" class="stream-card" data-stream={key}>
              <span class="stream-icon">{stream.icon}</span>
              <span class="stream-name">{stream.label}</span>
              <span class="stream-desc">{stream.examKeys.length} exams available</span>
            </button>
          ))}
        </div>
        <input type="hidden" id="onboarding-stream" />
      </div>

      <!-- Step 2: Exams (multi-select based on stream) -->
      <div class="step-content hidden" data-step="2">
        <h2 class="step-title">Which exams are you preparing for?</h2>
        <p class="step-sub">Select one or more exams. Subjects will be auto-configured.</p>
        <div class="exam-grid" id="exam-grid">
          {EXAM_DEFINITIONS.map(exam => (
            <button type="button"
              class="exam-card hidden"
              data-exam={exam.key}
              data-group={exam.group}
            >
              <span class="exam-name">{exam.label}</span>
              <span class="exam-subjects">{exam.subjects.length} subjects</span>
            </button>
          ))}
        </div>
        <p class="mt-3 text-xs text-slate-500" id="exam-count">Select at least one exam</p>
        <input type="hidden" id="onboarding-exams" />
      </div>

      <!-- Step 3: Target -->
      <div class="step-content hidden" data-step="3">
        <h2 class="step-title">Set your weekly target</h2>
        <p class="step-sub">How many hours can you study per week?</p>
        <div class="target-input-group">
          <input type="number" id="onboarding-hours" class="form-input" min="1" max="168" value="35" />
          <span class="target-unit">hours / week</span>
        </div>
        <p class="target-hint">You can change this anytime in Settings.</p>
      </div>

      <div id="form-error" class="error hidden"></div>

      <div class="onboarding-actions">
        <button id="prev-btn" class="btn-ghost hidden">Back</button>
        <button id="next-btn" class="btn-primary">Continue</button>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const steps = [1, 2, 3];
  let currentStep = 1;
  const indicators = document.querySelectorAll('.step');
  const stepContents = document.querySelectorAll('.step-content');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const errorDiv = document.getElementById('form-error');
  const examGrid = document.getElementById('exam-grid');

  function showError(msg) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }
  function hideError() {
    errorDiv.classList.add('hidden');
  }

  function updateStep(step) {
    currentStep = step;
    hideError();
    stepContents.forEach(el => el.classList.toggle('hidden', parseInt(el.dataset.step) !== step));
    indicators.forEach(el => {
      const s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === step);
      el.classList.toggle('completed', s < step);
    });
    prevBtn.classList.toggle('hidden', step === 1);
    nextBtn.textContent = step === steps.length ? 'Finish' : 'Continue';
  }

  function getStepData(step) {
    switch (step) {
      case 1: {
        const name = document.getElementById('onboarding-name').value.trim();
        const stream = document.getElementById('onboarding-stream').value;
        return { valid: name.length > 0 && !!stream };
      }
      case 2: {
        const selected = document.querySelectorAll('#exam-grid .exam-card.selected');
        return { valid: selected.length > 0 };
      }
      case 3: {
        const hours = parseInt(document.getElementById('onboarding-hours').value);
        return { valid: hours > 0 && hours <= 168 };
      }
    }
    return { valid: true };
  }

  prevBtn.addEventListener('click', () => {
    if (currentStep > 1) updateStep(currentStep - 1);
  });

  nextBtn.addEventListener('click', async () => {
    const data = getStepData(currentStep);
    if (!data.valid) {
      showError('Please complete this step to continue.');
      return;
    }

    if (currentStep < steps.length) {
      // Before advancing to step 2, filter exams by selected stream
      if (currentStep === 1) {
        const stream = document.getElementById('onboarding-stream').value;
        document.querySelectorAll('#exam-grid .exam-card').forEach(card => {
          if (card.dataset.group === stream) {
            card.classList.remove('hidden');
            // If only one exam in this stream, pre-select it
          } else {
            card.classList.add('hidden');
            card.classList.remove('selected');
          }
        });
        // Auto-select first exam if only one
        const visibleCards = document.querySelectorAll('#exam-grid .exam-card:not(.hidden)');
        if (visibleCards.length === 1) {
          visibleCards[0].classList.add('selected');
        }
      }
      updateStep(currentStep + 1);
    } else {
      // Submit onboarding
      nextBtn.disabled = true;
      nextBtn.textContent = 'Saving...';

      try {
        const name = document.getElementById('onboarding-name').value.trim();
        const stream = document.getElementById('onboarding-stream').value;
        const selectedExams = [];
        document.querySelectorAll('#exam-grid .exam-card.selected').forEach(card => {
          selectedExams.push(card.dataset.exam);
        });
        const targetHours = document.getElementById('onboarding-hours').value;

        const res = await fetch('/api/onboarding', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, stream, selectedExams, targetHours }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Save failed' }));
          throw new Error(err.error || 'Save failed');
        }

        window.location.href = '/dashboard?tour=1';
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Something went wrong');
        nextBtn.disabled = false;
        nextBtn.textContent = 'Finish';
      }
    }
  });

  // Stream selection
  document.querySelectorAll('.stream-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.stream-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      document.getElementById('onboarding-stream').value = card.dataset.stream;
      hideError();
    });
  });

  // Exam selection (multi-select)
  examGrid.addEventListener('click', (e) => {
    const card = e.target.closest('.exam-card');
    if (!card) return;
    card.classList.toggle('selected');
    const count = document.querySelectorAll('#exam-grid .exam-card.selected').length;
    document.getElementById('exam-count').textContent = count + ' selected';
    hideError();
  });

  // Enter key advances
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') nextBtn.click();
  });
</script>

<style>
  .onboarding-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 2rem 1rem;
  }
  .onboarding-card {
    width: 100%;
    max-width: 500px;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 2rem 1.75rem;
  }
  .step-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .step {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(51, 65, 85, 0.4);
    color: #64748b;
    transition: all 0.2s;
  }
  .step.active {
    background: #2563eb;
    color: white;
  }
  .step.completed {
    background: #22c55e;
    color: white;
  }
  .step-line {
    width: 2rem;
    height: 2px;
    background: rgba(51, 65, 85, 0.4);
  }
  .step-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 0.5rem;
  }
  .step-sub {
    font-size: 0.8rem;
    color: #64748b;
    margin: 0 0 1.25rem;
  }
  .form-input {
    width: 100%;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.6);
    border-radius: 0.5rem;
    padding: 0.65rem 0.85rem;
    font-size: 0.875rem;
    color: #e2e8f0;
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .form-input:focus {
    border-color: rgba(59, 130, 246, 0.5);
  }
  .mt-3 { margin-top: 0.75rem; }
  .mt-4 { margin-top: 1rem; }
  .stream-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .stream-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
    color: inherit;
    font-family: inherit;
  }
  .stream-card:hover {
    border-color: rgba(71, 85, 105, 0.7);
  }
  .stream-card.selected {
    border-color: #2563eb;
    background: rgba(37, 99, 235, 0.1);
  }
  .stream-icon {
    font-size: 1.5rem;
  }
  .stream-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e2e8f0;
  }
  .stream-desc {
    font-size: 0.75rem;
    color: #64748b;
  }
  .exam-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .exam-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.85rem 0.5rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    color: inherit;
    font-family: inherit;
  }
  .exam-card:hover {
    border-color: rgba(71, 85, 105, 0.7);
  }
  .exam-card.selected {
    border-color: #2563eb;
    background: rgba(37, 99, 235, 0.1);
  }
  .exam-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: #e2e8f0;
  }
  .exam-subjects {
    font-size: 0.65rem;
    color: #64748b;
  }
  .target-input-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .target-input-group .form-input {
    width: 6rem;
    text-align: center;
    font-size: 1.1rem;
  }
  .target-unit {
    font-size: 0.9rem;
    color: #94a3b8;
  }
  .target-hint {
    font-size: 0.7rem;
    color: #475569;
    margin-top: 0.5rem;
  }
  .onboarding-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    gap: 0.75rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2563eb;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.65rem 1.5rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    flex: 1;
  }
  .btn-primary:hover:not(:disabled) {
    background: #3b82f6;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-ghost {
    background: transparent;
    border: 1px solid rgba(51, 65, 85, 0.4);
    color: #94a3b8;
    font-size: 0.875rem;
    padding: 0.65rem 1.25rem;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-ghost:hover {
    color: #e2e8f0;
    border-color: rgba(71, 85, 105, 0.7);
  }
  .error {
    color: #ef4444;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
    margin-top: 1rem;
  }
  .hidden { display: none; }
</style>
