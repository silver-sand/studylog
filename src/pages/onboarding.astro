---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';

const user = getSessionUser(getTokenFromCookie(Astro.request));
if (!user) {
  return Astro.redirect('/login');
}
---

<BaseLayout title="Get Started">
  <main class="onboarding-page">
    <div class="onboarding-card">
      <div class="step-indicator" id="step-indicator">
        <div class="step active" data-step="1">1</div>
        <div class="step-line"></div>
        <div class="step" data-step="2">2</div>
        <div class="step-line"></div>
        <div class="step" data-step="3">3</div>
        <div class="step-line"></div>
        <div class="step" data-step="4">4</div>
      </div>

      <!-- Step 1: Name -->
      <div class="step-content" data-step="1">
        <h2 class="step-title">Welcome! What should I call you?</h2>
        <p class="step-sub">This helps me personalize your experience.</p>
        <input type="text" id="onboarding-name" class="form-input" placeholder="Your name" value={user.name} required />
      </div>

      <!-- Step 2: Stream -->
      <div class="step-content hidden" data-step="2">
        <h2 class="step-title">Which stream are you in?</h2>
        <p class="step-sub">This determines your subject set and exam preferences.</p>
        <div class="stream-options">
          <button type="button" class="stream-card" data-stream="science">
            <span class="stream-icon">🔬</span>
            <span class="stream-name">Science</span>
            <span class="stream-desc">Physics, Chemistry, Mathematics, Biology</span>
          </button>
          <button type="button" class="stream-card" data-stream="commerce">
            <span class="stream-icon">📊</span>
            <span class="stream-name">Commerce</span>
            <span class="stream-desc">Accountancy, Business Studies, Economics</span>
          </button>
        </div>
        <input type="hidden" id="onboarding-stream" />
      </div>

      <!-- Step 3: Goal -->
      <div class="step-content hidden" data-step="3">
        <h2 class="step-title">What's your goal?</h2>
        <p class="step-sub">Select your primary exam target.</p>
        <div class="goal-options" id="goal-options">
          <button type="button" class="goal-card" data-goal="JEE">🎯 JEE Main / Advanced</button>
          <button type="button" class="goal-card" data-goal="NEET">🩺 NEET</button>
          <button type="button" class="goal-card" data-goal="CET">📋 MHT-CET</button>
          <button type="button" class="goal-card" data-goal="Boards">📚 Board Exams</button>
          <button type="button" class="goal-card" data-goal="CUET">🎓 CUET</button>
          <button type="button" class="goal-card" data-goal="GATE">⚙️ GATE</button>
          <button type="button" class="goal-card" data-goal="CAT">💼 CAT</button>
          <button type="button" class="goal-card" data-goal="UPSC">🏛️ UPSC</button>
        </div>
        <input type="hidden" id="onboarding-goal" />
      </div>

      <!-- Step 4: Target -->
      <div class="step-content hidden" data-step="4">
        <h2 class="step-title">Set your weekly target</h2>
        <p class="step-sub">How many hours can you study per week?</p>
        <div class="target-input-group">
          <input type="number" id="onboarding-hours" class="form-input" min="1" max="168" value="35" />
          <span class="target-unit">hours / week</span>
        </div>
        <p class="target-hint">You can change this anytime in Settings.</p>
      </div>

      <div id="form-error" class="error hidden"></div>

      <div class="onboarding-actions">
        <button id="prev-btn" class="btn-ghost hidden">Back</button>
        <button id="next-btn" class="btn-primary">Continue</button>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const steps = [1, 2, 3, 4];
  let currentStep = 1;
  const indicators = document.querySelectorAll('.step');
  const stepContents = document.querySelectorAll('.step-content');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const errorDiv = document.getElementById('form-error');

  function showError(msg) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }
  function hideError() {
    errorDiv.classList.add('hidden');
  }

  function updateStep(step) {
    currentStep = step;
    hideError();
    stepContents.forEach(el => el.classList.toggle('hidden', parseInt(el.dataset.step) !== step));
    indicators.forEach(el => {
      const s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === step);
      el.classList.toggle('completed', s < step);
    });
    prevBtn.classList.toggle('hidden', step === 1);
    nextBtn.textContent = step === steps.length ? 'Finish' : 'Continue';
  }

  function getStepData(step) {
    switch (step) {
      case 1: return { valid: (document.getElementById('onboarding-name') as HTMLInputElement).value.trim().length > 0 };
      case 2: return { valid: !!(document.getElementById('onboarding-stream') as HTMLInputElement).value };
      case 3: return { valid: !!(document.getElementById('onboarding-goal') as HTMLInputElement).value };
      case 4: return { valid: parseInt((document.getElementById('onboarding-hours') as HTMLInputElement).value) > 0 };
    }
    return { valid: true };
  }

  prevBtn.addEventListener('click', () => {
    if (currentStep > 1) updateStep(currentStep - 1);
  });

  nextBtn.addEventListener('click', async () => {
    const data = getStepData(currentStep);
    if (!data.valid) {
      showError('Please fill in this field to continue.');
      return;
    }

    if (currentStep < steps.length) {
      updateStep(currentStep + 1);
    } else {
      // Submit onboarding
      nextBtn.disabled = true;
      nextBtn.textContent = 'Saving...';

      try {
        const name = (document.getElementById('onboarding-name') as HTMLInputElement).value.trim();
        const stream = (document.getElementById('onboarding-stream') as HTMLInputElement).value;
        const goal = (document.getElementById('onboarding-goal') as HTMLInputElement).value;
        const targetHours = (document.getElementById('onboarding-hours') as HTMLInputElement).value;

        const res = await fetch('/api/onboarding', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, stream, goal, targetHours }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Save failed' }));
          throw new Error(err.error || 'Save failed');
        }

        window.location.href = '/dashboard';
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Something went wrong');
        nextBtn.disabled = false;
        nextBtn.textContent = 'Finish';
      }
    }
  });

  // Stream selection
  document.querySelectorAll('.stream-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.stream-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      (document.getElementById('onboarding-stream') as HTMLInputElement).value = card.dataset.stream;
      hideError();
    });
  });

  // Goal selection
  document.querySelectorAll('.goal-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.goal-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      (document.getElementById('onboarding-goal') as HTMLInputElement).value = card.dataset.goal;
      hideError();
    });
  });

  // Enter key advances
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') nextBtn.click();
  });
</script>

<style>
  .onboarding-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 2rem 1rem;
  }
  .onboarding-card {
    width: 100%;
    max-width: 460px;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 2rem 1.75rem;
  }
  .step-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .step {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(51, 65, 85, 0.4);
    color: #64748b;
    transition: all 0.2s;
  }
  .step.active {
    background: #2563eb;
    color: white;
  }
  .step.completed {
    background: #22c55e;
    color: white;
  }
  .step-line {
    width: 2rem;
    height: 2px;
    background: rgba(51, 65, 85, 0.4);
  }
  .step-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 0.5rem;
  }
  .step-sub {
    font-size: 0.8rem;
    color: #64748b;
    margin: 0 0 1.25rem;
  }
  .form-input {
    width: 100%;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.6);
    border-radius: 0.5rem;
    padding: 0.65rem 0.85rem;
    font-size: 0.875rem;
    color: #e2e8f0;
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .form-input:focus {
    border-color: rgba(59, 130, 246, 0.5);
  }
  .stream-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .stream-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
    color: inherit;
    font-family: inherit;
  }
  .stream-card:hover {
    border-color: rgba(71, 85, 105, 0.7);
  }
  .stream-card.selected {
    border-color: #2563eb;
    background: rgba(37, 99, 235, 0.1);
  }
  .stream-icon {
    font-size: 1.5rem;
  }
  .stream-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #e2e8f0;
  }
  .stream-desc {
    font-size: 0.75rem;
    color: #64748b;
  }
  .goal-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .goal-card {
    padding: 0.75rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    font-size: 0.8rem;
    color: #cbd5e1;
    font-family: inherit;
  }
  .goal-card:hover {
    border-color: rgba(71, 85, 105, 0.7);
  }
  .goal-card.selected {
    border-color: #2563eb;
    background: rgba(37, 99, 235, 0.1);
    color: #e2e8f0;
  }
  .target-input-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .target-input-group .form-input {
    width: 6rem;
    text-align: center;
    font-size: 1.1rem;
  }
  .target-unit {
    font-size: 0.9rem;
    color: #94a3b8;
  }
  .target-hint {
    font-size: 0.7rem;
    color: #475569;
    margin-top: 0.5rem;
  }
  .onboarding-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    gap: 0.75rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2563eb;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.65rem 1.5rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
    flex: 1;
  }
  .btn-primary:hover:not(:disabled) {
    background: #3b82f6;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-ghost {
    background: transparent;
    border: 1px solid rgba(51, 65, 85, 0.4);
    color: #94a3b8;
    font-size: 0.875rem;
    padding: 0.65rem 1.25rem;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-ghost:hover {
    color: #e2e8f0;
    border-color: rgba(71, 85, 105, 0.7);
  }
  .error {
    color: #ef4444;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
    margin-top: 1rem;
  }
  .hidden { display: none; }
</style>
