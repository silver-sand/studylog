---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS, getSubjectsForExamKeys } from '../utils/exam-map';
import { STREAMS, getExamsForStream } from '../utils/stream-map';
import { scopeDbToUser } from '../services/user-scope';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import AuthPopup from '../components/AuthPopup.astro';

scopeDbToUser(Astro.request);
const db = getDb();
const settings = db.getSettings();
const user = getSessionUser(getTokenFromCookie(Astro.request));
const isGuest = user?.userType === 'guest';

const userStream = user?.stream || '';
const defaultExams = settings.selectedExams?.length
  ? settings.selectedExams
  : EXAM_DEFINITIONS.filter(e => e.groups.includes(userStream)).map(e => e.key).slice(0, 1);
const allSubjects = getSubjectsForExamKeys(defaultExams);
const activeSubjects = settings.subjects?.length ? settings.subjects : allSubjects;
const dailyAvg = settings.studyDaysPerWeek > 0
  ? Math.round((settings.targetHoursPerWeek / settings.studyDaysPerWeek) * 10) / 10
  : 7;

let daysUntilExam = null;
if (settings.examDate) {
  const now = new Date();
  const examDt = new Date(settings.examDate);
  daysUntilExam = Math.max(0, Math.ceil((examDt.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
}

// Data bridge for client-side stream/exam/subject cascade
const settingsBridgeData = {
  exams: EXAM_DEFINITIONS.map(e => ({ key: e.key, label: e.label, groups: e.groups, subjects: e.subjects, syllabusKey: e.syllabusKey })),
  streams: Object.fromEntries(Object.entries(STREAMS).map(([k, s]) => [k, { label: s.label, icon: s.icon, subjects: s.subjects, examKeys: s.examKeys }])),
  savedStream: userStream,
  savedExams: defaultExams,
  savedSubjects: activeSubjects,
};
---

<BaseLayout title="Settings">
  <!-- Main content area matching Stitch's layout -->
  <main class="flex-1 flex flex-col h-full overflow-hidden pt-16 md:pt-0 bg-[#050b18]">
    <header class="px-8 py-6 flex-shrink-0">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-[#f1f5f9]">Settings</h2>
      <p class="text-[#94a3b8] text-sm mt-1">Manage your account, study preferences, and app appearance.</p>
    </header>

    <div class="flex-1 overflow-hidden px-8 pb-8 flex flex-col lg:flex-row gap-4 lg:gap-8">
      <!-- Mobile tab navigation (visible below lg) -->
      <div class="flex lg:hidden gap-1 -mx-2 px-2 overflow-x-auto flex-shrink-0 scrollbar-hide" id="mobile-settings-nav">
        <button class="px-4 py-2 rounded-lg text-sm font-medium text-indigo-400 bg-[#0d1321] border border-slate-700/50 whitespace-nowrap settings-nav-btn active" data-tab="profile">Profile</button>
        <button class="px-4 py-2 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 whitespace-nowrap transition-colors settings-nav-btn" data-tab="preferences">Study Preferences</button>
        <button class="px-4 py-2 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 whitespace-nowrap transition-colors settings-nav-btn" data-tab="appearance">Appearance</button>
        <button class="px-4 py-2 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 whitespace-nowrap transition-colors settings-nav-btn" data-tab="notifications">Notifications</button>
        <button class="px-4 py-2 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 whitespace-nowrap transition-colors settings-nav-btn" data-tab="account">Account</button>
        <button class="px-4 py-2 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 whitespace-nowrap transition-colors settings-nav-btn" data-tab="data">Data</button>
      </div>

      <!-- Secondary Navigation (Content Area) — matching Stitch 5-panel nav, hidden on mobile -->
      <nav class="w-48 flex-shrink-0 flex flex-col gap-1 overflow-y-auto pr-4 hidden lg:flex">
        <button class="text-left px-4 py-2.5 rounded-lg text-sm font-medium text-indigo-400 bg-[#0d1321] border border-slate-700/50 settings-nav-btn active" data-tab="profile">
          Profile
        </button>
        <button class="text-left px-4 py-2.5 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 transition-colors settings-nav-btn" data-tab="preferences">
          Study Preferences
        </button>
        <button class="text-left px-4 py-2.5 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 transition-colors settings-nav-btn" data-tab="appearance">
          Appearance
        </button>
        <button class="text-left px-4 py-2.5 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 transition-colors settings-nav-btn" data-tab="notifications">
          Notifications
        </button>
        <button class="text-left px-4 py-2.5 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 transition-colors settings-nav-btn" data-tab="account">
          Account
        </button>
        <button class="text-left px-4 py-2.5 rounded-lg text-sm font-medium text-[#94a3b8] hover:text-[#f1f5f9] hover:bg-[#0d1321]/50 transition-colors settings-nav-btn" data-tab="data">
          Data
        </button>
      </nav>

      <!-- Scrollable Settings Sections -->
      <div class="flex-1 overflow-y-auto pr-4 space-y-8 max-w-3xl pb-24 md:pb-8 scroll-smooth" id="settings-content">

        <!-- ═══════ PROFILE ═══════ -->
        <section class="bg-[#0d1321] rounded-xl border border-slate-800 p-6 settings-section" id="section-profile">
          <h3 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-6">Profile</h3>
          <div class="flex items-center gap-6 mb-8">
            <div class="relative group cursor-pointer">
              <div class="w-20 h-20 rounded-full bg-indigo-500/10 border-2 border-slate-700 flex items-center justify-center text-indigo-400 text-2xl font-bold">
                {user?.name?.charAt(0)?.toUpperCase() || 'U'}
              </div>
              <div class="absolute inset-0 bg-black/50 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="material-symbols-outlined text-white text-xl">photo_camera</span>
              </div>
            </div>
            <div>
              <button class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-sm font-medium rounded-lg transition-colors mb-2 text-white">Change Avatar</button>
              <p class="text-xs text-[#94a3b8]">JPG, GIF or PNG. Max size of 2MB.</p>
            </div>
          </div>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-[#94a3b8] mb-1">Full Name</label>
              <input class="w-full bg-[#050b18] border border-slate-700 rounded-lg px-4 py-2 text-[#f1f5f9] focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" type="text" value={user?.name || ''} />
            </div>
            <div>
              <label class="block text-sm font-medium text-[#94a3b8] mb-1">Email Address</label>
              <input class="w-full bg-[#050b18] border border-slate-700 rounded-lg px-4 py-2 text-[#f1f5f9] focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" type="email" value={user?.email || ''} />
            </div>
            <div class="pt-2">
              <button id="save-profile-btn" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium rounded-lg transition-colors shadow-lg shadow-indigo-500/20 ripple-btn">Save Profile</button>
            </div>
          </div>
        </section>

        <!-- ═══════ STUDY PREFERENCES ═══════ -->
        <section class="bg-[#0d1321] rounded-xl border border-slate-800 p-6 settings-section hidden" id="section-preferences">
          <h3 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-6">Study Preferences</h3>
          <div class="space-y-6">
            <!-- Stream -->
            <div>
              <label class="block text-sm font-medium text-[#94a3b8] mb-2">Stream</label>
              <div class="flex flex-wrap gap-2" id="stream-grid">
                {Object.entries(STREAMS).map(([key, stream]) => (
                  <button
                    class:list={{
                      'px-3 py-1.5 rounded-full border text-sm font-medium transition-all': true,
                      'border-indigo-500 bg-indigo-500/10 text-indigo-400': userStream === key,
                      'border-slate-700 text-[#94a3b8] hover:border-slate-500 hover:text-white': userStream !== key,
                    }}
                    data-stream={key}
                  >
                    {stream.icon} {stream.label}
                  </button>
                ))}
              </div>
            </div>

            <!-- Exams -->
            <div>
              <label class="block text-sm font-medium text-[#94a3b8] mb-2">Target Exams</label>
              <div class="flex flex-wrap gap-2" id="exam-grid">
                {EXAM_DEFINITIONS.filter(exam => exam.groups.includes(userStream)).map(exam => {
                  const isSelected = defaultExams.includes(exam.key);
                  return (
                    <button
                      class:list={{
                        'px-3 py-1.5 rounded-full border text-sm font-medium transition-all flex items-center gap-1': true,
                        'border-indigo-500 bg-indigo-500/10 text-indigo-400': isSelected,
                        'border-slate-700 text-[#94a3b8] hover:border-slate-500 hover:text-white': !isSelected,
                      }}
                      data-exam={exam.key}
                    >
                      {exam.label}
                      {isSelected && <span class="material-symbols-outlined text-[16px]">close</span>}
                    </button>
                  );
                })}
              </div>
            </div>

            <!-- Active Subjects (toggleable) -->
            <div>
              <label class="block text-sm font-medium text-[#94a3b8] mb-2">Active Subjects</label>
              <p class="text-xs text-[#94a3b8] mb-2">Toggle the subjects you want tracked in your syllabus.</p>
              <div class="flex flex-wrap gap-2" id="active-subjects-grid">
                {allSubjects.map(subject => {
                  const isActive = activeSubjects.includes(subject);
                  return (
                    <button
                      class:list={{
                        'px-3 py-1.5 rounded-full border text-sm font-medium transition-all': true,
                        'border-indigo-500 bg-indigo-500/10 text-indigo-400': isActive,
                        'border-slate-700 text-[#94a3b8] hover:border-slate-500 hover:text-white': !isActive,
                      }}
                      data-subject={subject}
                    >
                      {subject}
                    </button>
                  );
                })}
                {allSubjects.length === 0 && <p class="text-xs text-[#94a3b8]">Select at least one exam to see subjects.</p>}
              </div>
            </div>

            <!-- Weekly Target -->
            <div class="pt-4 border-t border-slate-800">
              <label class="block text-sm font-medium text-[#94a3b8] mb-2">Daily Study Goal (Hours)</label>
              <div class="flex items-center gap-3">
                <input
                  type="number"
                  id="target-hours"
                  name="targetHoursPerWeek"
                  min="1"
                  max="168"
                  value={settings.targetHoursPerWeek || 35}
                  class="w-24 bg-[#050b18] border border-slate-700 rounded-lg px-4 py-2 text-[#f1f5f9] focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
                />
                <span class="text-sm text-[#94a3b8]">hours per week</span>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <input
                type="number"
                id="study-days"
                name="studyDaysPerWeek"
                min="1"
                max="7"
                value={settings.studyDaysPerWeek || 5}
                class="w-24 bg-[#050b18] border border-slate-700 rounded-lg px-4 py-2 text-[#f1f5f9] focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
              />
              <span class="text-sm text-[#94a3b8]">days per week</span>
            </div>

            <!-- Exam Date -->
            <div class="pt-4 border-t border-slate-800">
              <label class="block text-sm font-medium text-[#94a3b8] mb-2">Exam Date</label>
              <input
                type="date"
                id="exam-date"
                name="examDate"
                value={settings.examDate || ''}
                class="bg-[#050b18] border border-slate-700 rounded-lg px-4 py-2 text-[#f1f5f9] focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 transition-colors"
              />
              {daysUntilExam !== null && (
                <span class="text-sm text-indigo-400 ml-3">{daysUntilExam === 0 ? 'Exam day!' : `${daysUntilExam} days away`}</span>
              )}
            </div>

            <button id="save-preferences-btn" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium rounded-lg transition-colors shadow-lg shadow-indigo-500/20 ripple-btn">
              Save Preferences
            </button>
          </div>
        </section>

        <!-- ═══════ APPEARANCE ═══════ -->
        <section class="bg-[#0d1321] rounded-xl border border-slate-800 p-6 settings-section hidden" id="section-appearance">
          <h3 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-6">Appearance</h3>
          <div class="space-y-6">
            <div>
              <p class="text-sm text-[#94a3b8] mb-4">Currently the app uses a dark-first design. Light mode support is coming soon.</p>
              <div class="space-y-3">
                <div class="flex items-center gap-4 p-4 bg-[#050b18] rounded-xl border border-indigo-500/30">
                  <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-400">
                    <span class="material-symbols-outlined">dark_mode</span>
                  </div>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-white">Dark Mode</p>
                    <p class="text-xs text-[#94a3b8]">Current default — optimized for focus</p>
                  </div>
                  <span class="material-symbols-outlined text-indigo-400 filled-icon text-lg">check_circle</span>
                </div>
                <div class="flex items-center gap-4 p-4 bg-[#050b18] rounded-xl border border-slate-800 opacity-50">
                  <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center text-slate-500">
                    <span class="material-symbols-outlined">light_mode</span>
                  </div>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-white">Light Mode</p>
                    <p class="text-xs text-[#94a3b8]">Coming soon</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="pt-4 border-t border-slate-800">
              <div class="flex items-center justify-between py-2">
                <div>
                  <p class="text-sm font-medium text-white">Font Size</p>
                  <p class="text-xs text-[#94a3b8]">Uses system default</p>
                </div>
              </div>
              <div class="flex items-center justify-between py-2">
                <div>
                  <p class="text-sm font-medium text-white">Reduce Motion</p>
                  <p class="text-xs text-[#94a3b8]">Respects system preference</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- ═══════ NOTIFICATIONS ═══════ -->
        <section class="bg-[#0d1321] rounded-xl border border-slate-800 p-6 settings-section hidden" id="section-notifications">
          <h3 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-6">Notifications</h3>
          <div class="space-y-0 divide-y divide-slate-800">
            <div class="flex items-center justify-between py-4">
              <div>
                <p class="text-sm font-medium text-white">Study Reminders</p>
                <p class="text-xs text-[#94a3b8]">Get reminded to log your study sessions daily</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" checked disabled class="sr-only peer" />
                <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:bg-indigo-600 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
              </label>
            </div>
            <div class="flex items-center justify-between py-4">
              <div>
                <p class="text-sm font-medium text-white">Weekly Review Ready</p>
                <p class="text-xs text-[#94a3b8]">Notify when your weekly AI review is generated</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" checked disabled class="sr-only peer" />
                <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:bg-indigo-600 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
              </label>
            </div>
            <div class="flex items-center justify-between py-4">
              <div>
                <p class="text-sm font-medium text-white">Streak Alerts</p>
                <p class="text-xs text-[#94a3b8]">Remind you to keep your study streak alive</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" disabled class="sr-only peer" />
                <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:bg-indigo-600 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
              </label>
            </div>
            <div class="flex items-center justify-between py-4">
              <div>
                <p class="text-sm font-medium text-white">AI Mentor Suggestions</p>
                <p class="text-xs text-[#94a3b8]">Get proactive tips from your AI mentor</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" checked disabled class="sr-only peer" />
                <div class="w-11 h-6 bg-slate-700 rounded-full peer peer-checked:bg-indigo-600 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
              </label>
            </div>
          </div>
          <p class="text-xs text-center text-[#94a3b8] mt-6 pt-4 border-t border-slate-800">Notifications are currently disabled. Coming in a future update.</p>
        </section>

        <!-- ═══════ ACCOUNT ═══════ -->
        <section class="bg-[#0d1321] rounded-xl border border-slate-800 p-6 settings-section hidden" id="section-account">
          <h3 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-6">Account</h3>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-full bg-indigo-500/10 border border-slate-700 flex items-center justify-center text-indigo-400 text-lg font-bold shrink-0">
              {user?.name?.charAt(0)?.toUpperCase() || 'U'}
            </div>
            <div>
              <p class="text-base font-semibold text-white">{user?.name || 'User'}</p>
              <p class="text-sm text-[#94a3b8]">{user?.email || ''}</p>
              {isGuest && <p class="text-xs text-yellow-400 mt-1">Guest account — data is temporary</p>}
              {!isGuest && <p class="text-xs text-emerald-400 mt-1">Signed in — your data is saved permanently</p>}
            </div>
          </div>
          {isGuest && (
            <a href="#" id="guest-signup-btn" class="w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium text-sm py-3 px-6 rounded-lg transition-colors">
              <span class="material-symbols-outlined text-lg">login</span>
              Sign Up to Save Your Data
            </a>
          )}
          {!isGuest && (
            <button type="button" id="account-logout-btn" class="w-full flex items-center justify-center gap-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 font-medium text-sm py-3 px-6 rounded-lg transition-colors border border-red-500/20 ripple-btn">
              <span class="material-symbols-outlined text-lg">logout</span>
              Log Out
            </button>
          )}
        </section>

        <!-- ═══════ DATA ═══════ -->
        <section class="bg-[#0d1321] rounded-xl border border-slate-800 p-6 settings-section hidden" id="section-data">
          <h3 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-6">Data</h3>
          <p class="text-sm text-[#94a3b8] mb-6">Download your study data as a backup, or restore from a previous backup. Restoring will <strong class="text-red-400">replace all</strong> your current data.</p>

          <!-- Download -->
          <div class="space-y-4">
            <div class="bg-[#050b18] rounded-xl border border-slate-700 p-5">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-white">Download Backup</p>
                  <p class="text-xs text-[#94a3b8]">Save all your entries, reviews, syllabus progress, and settings as a JSON file.</p>
                </div>
                <button id="data-download-btn" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors shrink-0 ripple-btn">
                  Download
                </button>
              </div>
            </div>

            <!-- Upload / Restore -->
            <div class="bg-[#050b18] rounded-xl border border-slate-700 p-5">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-400 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-sm font-medium text-white">Restore from Backup</p>
                  <p class="text-xs text-[#94a3b8]">Upload a previously downloaded backup file to restore your data. This replaces all existing data.</p>
                </div>
                <button id="data-upload-btn" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 text-white text-sm font-medium rounded-lg transition-colors shrink-0 ripple-btn">
                  Upload
                </button>
              </div>
              <input type="file" id="data-file-input" accept=".json" class="hidden" />
            </div>

            <!-- Status area -->
            <div id="data-status" class="hidden text-sm rounded-lg px-4 py-3"></div>

            <!-- Confirmation dialog (hidden by default) -->
            <div id="data-confirm-overlay" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/60" style="backdrop-filter:blur(4px);">
              <div class="bg-[#0d1321] border border-slate-700 rounded-xl p-6 max-w-md mx-4 shadow-2xl">
                <h4 class="text-lg font-headline font-semibold text-[#f1f5f9] mb-3">Restore Backup?</h4>
                <div id="data-confirm-preview" class="text-sm text-[#94a3b8] mb-4 space-y-1"></div>
                <p class="text-sm text-red-400 mb-5 font-medium">This will replace ALL your current data. This cannot be undone.</p>
                <div class="flex gap-3 justify-end">
                  <button id="data-confirm-cancel" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white text-sm font-medium rounded-lg transition-colors ripple-btn">Cancel</button>
                  <button id="data-confirm-proceed" class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium rounded-lg transition-colors ripple-btn">Restore Data</button>
                </div>
              </div>
            </div>
          </div>
        </section>

      </div>
    </div>
  </main>
</BaseLayout>

<!-- Data bridge: exam definitions & stream subjects for client-side cascade -->
<div id="settings-data-store" data-value={JSON.stringify(settingsBridgeData)} hidden aria-hidden="true"></div>

<script>
  // ── Settings data bridge ──
  var SETTINGS_DATA = {};
  try {
    var dataEl = document.getElementById('settings-data-store');
    if (dataEl) SETTINGS_DATA = JSON.parse(dataEl.dataset.value);
  } catch(e) { console.error('Settings data bridge error:', e); }

  function getStreamExams(stream) {
    if (!stream || !SETTINGS_DATA.streams || !SETTINGS_DATA.streams[stream]) return [];
    return SETTINGS_DATA.streams[stream].examKeys || [];
  }

  function getStreamSubjects(stream) {
    if (!stream || !SETTINGS_DATA.streams || !SETTINGS_DATA.streams[stream]) return [];
    return SETTINGS_DATA.streams[stream].subjects || [];
  }

  function getSubjectsForExamKeys(keys) {
    var set = {};
    if (!SETTINGS_DATA.exams) return [];
    keys.forEach(function(key) {
      SETTINGS_DATA.exams.forEach(function(exam) {
        if (exam.key === key) {
          exam.subjects.forEach(function(s) { set[s] = true; });
        }
      });
    });
    return Object.keys(set);
  }

  function rebuildExamGrid(stream, selectedKeys) {
    var grid = document.getElementById('exam-grid');
    if (!grid) return;
    var examKeys = getStreamExams(stream);
    var visibleExams = SETTINGS_DATA.exams.filter(function(e) { return examKeys.indexOf(e.key) !== -1; });
    selectedKeys = selectedKeys || [];
    grid.innerHTML = '';
    visibleExams.forEach(function(exam) {
      var isSelected = selectedKeys.indexOf(exam.key) !== -1;
      var btn = document.createElement('button');
      btn.className = 'px-3 py-1.5 rounded-full border text-sm font-medium transition-all flex items-center gap-1' +
        (isSelected ? ' border-indigo-500 bg-indigo-500/10 text-indigo-400' : ' border-slate-700 text-[#94a3b8] hover:border-slate-500 hover:text-white');
      btn.dataset.exam = exam.key;
      btn.textContent = exam.label;
      if (isSelected) {
        var close = document.createElement('span');
        close.className = 'material-symbols-outlined text-[16px]';
        close.textContent = 'close';
        btn.appendChild(close);
      }
      btn.addEventListener('click', function() {
        btn.classList.toggle('border-indigo-500');
        btn.classList.toggle('bg-indigo-500/10');
        btn.classList.toggle('text-indigo-400');
        btn.classList.toggle('border-slate-700');
        btn.classList.toggle('text-[#94a3b8]');
        // Also toggle hover classes
        btn.classList.toggle('hover:border-slate-500');
        btn.classList.toggle('hover:text-white');
        // Rebuild subjects
        rebuildSubjectGrid();
      });
      grid.appendChild(btn);
    });
  }

  function rebuildSubjectGrid() {
    var grid = document.getElementById('active-subjects-grid');
    if (!grid) return;

    // Get stream for the subject label text
    var streamEl = document.querySelector('#stream-grid button.border-indigo-500');
    var stream = streamEl ? streamEl.dataset.stream : (SETTINGS_DATA.savedStream || 'science');

    // Collect selected exams
    var selectedExamKeys = Array.from(document.querySelectorAll('#exam-grid button[data-exam].border-indigo-500'))
      .map(function(b) { return b.dataset.exam; }).filter(Boolean);

    var subjects;
    if (selectedExamKeys.length > 0) {
      subjects = getSubjectsForExamKeys(selectedExamKeys);
    } else {
      subjects = getStreamSubjects(stream);
    }

    // Get currently selected subjects
    var currentSelected = Array.from(document.querySelectorAll('#active-subjects-grid button.border-indigo-500'))
      .map(function(b) { return b.dataset.subject; }).filter(Boolean);
    var selectedSet = {};
    currentSelected.forEach(function(s) { selectedSet[s] = true; });

    grid.innerHTML = '';
    if (subjects.length === 0) {
      grid.innerHTML = '<p class="text-xs text-[#94a3b8]">Select at least one exam to see subjects.</p>';
      return;
    }
    subjects.forEach(function(subject) {
      var isActive = selectedSet[subject] || false;
      var btn = document.createElement('button');
      btn.className = 'px-3 py-1.5 rounded-full border text-sm font-medium transition-all' +
        (isActive ? ' border-indigo-500 bg-indigo-500/10 text-indigo-400' : ' border-slate-700 text-[#94a3b8] hover:border-slate-500 hover:text-white');
      btn.dataset.subject = subject;
      btn.textContent = subject;
      btn.addEventListener('click', function() {
        btn.classList.toggle('border-indigo-500');
        btn.classList.toggle('bg-indigo-500/10');
        btn.classList.toggle('text-indigo-400');
        btn.classList.toggle('border-slate-700');
        btn.classList.toggle('text-[#94a3b8]');
        btn.classList.toggle('hover:border-slate-500');
        btn.classList.toggle('hover:text-white');
      });
      grid.appendChild(btn);
    });
  }

  // ── Settings tab navigation ──
  const navBtns = document.querySelectorAll('.settings-nav-btn');
  const sections = {};
  document.querySelectorAll('.settings-section').forEach(s => {
    const id = s.id.replace('section-', '');
    sections[id] = s;
  });

  navBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      if (!tab || !sections[tab]) return;

      // Update nav
      navBtns.forEach(b => {
        b.classList.remove('active', 'text-indigo-400', 'bg-[#0d1321]', 'border', 'border-slate-700/50');
        b.classList.add('text-[#94a3b8]');
      });
      btn.classList.add('active', 'text-indigo-400', 'bg-[#0d1321]', 'border', 'border-slate-700/50');
      btn.classList.remove('text-[#94a3b8]');

      // Show section
      Object.entries(sections).forEach(([key, el]) => {
        el.classList.toggle('hidden', key !== tab);
      });
    });
  });

  // ── Stream selection — cascades to exams and subjects ──
  document.querySelectorAll('#stream-grid button').forEach(btn => {
    btn.addEventListener('click', function() {
      // Update visual state
      document.querySelectorAll('#stream-grid button').forEach(function(b) {
        b.classList.remove('border-indigo-500', 'bg-indigo-500/10', 'text-indigo-400');
        b.classList.add('border-slate-700', 'text-[#94a3b8]');
      });
      btn.classList.remove('border-slate-700', 'text-[#94a3b8]');
      btn.classList.add('border-indigo-500', 'bg-indigo-500/10', 'text-indigo-400');

      var stream = btn.dataset.stream;
      // Rebuild exam grid for this stream, auto-select first exam
      var streamExamKeys = getStreamExams(stream);
      var firstExam = streamExamKeys.length > 0 ? [streamExamKeys[0]] : [];
      rebuildExamGrid(stream, firstExam);
      // Rebuild subjects
      rebuildSubjectGrid();
    });
  });

  // ── Subject toggle ──
  document.querySelectorAll('#active-subjects-grid button').forEach(btn => {
    btn.addEventListener('click', function() {
      btn.classList.toggle('border-indigo-500');
      btn.classList.toggle('bg-indigo-500/10');
      btn.classList.toggle('text-indigo-400');
      btn.classList.toggle('border-slate-700');
      btn.classList.toggle('text-[#94a3b8]');
      btn.classList.toggle('hover:border-slate-500');
      btn.classList.toggle('hover:text-white');
    });
  });

  // ── Logout ──
  document.getElementById('account-logout-btn')?.addEventListener('click', () => {
    // Navigate directly — the GET handler clears the cookie and redirects to /
    window.location.href = '/api/auth/logout';
  });

  // ── Save Profile ──
  document.getElementById('save-profile-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('save-profile-btn');
    if (!btn || btn.disabled) return;
    const nameInput = document.querySelector('#section-profile input[type="text"]');
    const emailInput = document.querySelector('#section-profile input[type="email"]');
    const original = btn.textContent;
    btn.disabled = true;
    btn.innerHTML = '<span class="ds-btn-spinner-icon" style="width:1rem;height:1rem;border-color:white;border-top-color:transparent;display:inline-block;margin-right:0.5rem;"></span>Saving...';
    try {
      const res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameInput?.value?.trim() || undefined,
          email: emailInput?.value?.trim() || undefined,
        }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed' }));
        throw new Error(err.error || 'Failed to save');
      }
      btn.textContent = '✓ Saved';
      setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2000);
    } catch (err) {
      btn.textContent = 'Failed — try again';
      setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2000);
    }
  });

  // ── Save Preferences ──
  document.getElementById('save-preferences-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('save-preferences-btn');
    if (!btn || btn.disabled) return;
    const original = btn.textContent;
    btn.disabled = true;
    btn.innerHTML = '<span class="ds-btn-spinner-icon" style="width:1rem;height:1rem;border-color:white;border-top-color:transparent;display:inline-block;margin-right:0.5rem;"></span>Saving...';

    // Collect selected exams
    const selectedExams = Array.from(document.querySelectorAll('#exam-grid button[data-exam].border-indigo-500'))
      .map(b => b.dataset.exam)
      .filter(Boolean);

    // Collect stream
    const streamEl = document.querySelector('#stream-grid button.border-indigo-500');
    const stream = streamEl?.dataset?.stream || '';

    // Collect active subjects (toggled on)
    const activeSubjects = Array.from(document.querySelectorAll('#active-subjects-grid button.border-indigo-500'))
      .map(b => b.dataset.subject)
      .filter(Boolean);

    // Collect numeric values
    const targetHoursPerWeek = parseInt(document.getElementById('target-hours')?.value) || 35;
    const studyDaysPerWeek = parseInt(document.getElementById('study-days')?.value) || 5;
    const examDate = document.getElementById('exam-date')?.value || null;

    try {
      const res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          selectedExams: selectedExams.length > 0 ? selectedExams : undefined,
          stream: stream || undefined,
          targetHoursPerWeek,
          studyDaysPerWeek,
          examDate: examDate || undefined,
          subjects: activeSubjects.length > 0 ? activeSubjects : undefined,
        }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed' }));
        throw new Error(err.error || 'Failed to save');
      }
      btn.textContent = '✓ Saved';
      setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2000);
    } catch (err) {
      btn.textContent = 'Failed — try again';
      setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2000);
    }
  });

  // ── Data: Download Backup ──
  document.getElementById('data-download-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('data-download-btn');
    const status = document.getElementById('data-status');
    const original = btn?.textContent || 'Download';
    if (!btn || !status) return;

    btn.textContent = 'Downloading...';
    btn.disabled = true;
    status.classList.add('hidden');

    try {
      const res = await fetch('/api/export');
      if (!res.ok) throw new Error('Download failed');

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `studylog-backup-${new Date().toISOString().slice(0, 10)}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);

      status.className = 'text-sm rounded-lg px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400';
      status.textContent = '✓ Backup downloaded successfully.';
      status.classList.remove('hidden');
    } catch (err) {
      status.className = 'text-sm rounded-lg px-4 py-3 bg-red-500/10 border border-red-500/20 text-red-400';
      status.textContent = '✗ Download failed. Please try again.';
      status.classList.remove('hidden');
    } finally {
      btn.textContent = original;
      btn.disabled = false;
    }
  });

  // ── Data: Upload / Restore ──
  let pendingImportData = null;

  document.getElementById('data-upload-btn')?.addEventListener('click', () => {
    document.getElementById('data-file-input')?.click();
  });

  document.getElementById('data-file-input')?.addEventListener('change', async (e) => {
    const input = e.currentTarget;
    const file = input.files?.[0];
    const status = document.getElementById('data-status');
    if (!file || !status) return;

    status.classList.add('hidden');
    pendingImportData = null;

    if (!file.name.endsWith('.json')) {
      status.className = 'text-sm rounded-lg px-4 py-3 bg-red-500/10 border border-red-500/20 text-red-400';
      status.textContent = '✗ Please select a .json file.';
      status.classList.remove('hidden');
      input.value = '';
      return;
    }

    try {
      const text = await file.text();
      const data = JSON.parse(text);

      if (!data.version || !data.data || !Array.isArray(data.data?.entries)) {
        throw new Error('Invalid backup format');
      }

      const preview = document.getElementById('data-confirm-preview');
      if (!preview) return;
      const entriesCount = data.data.entries?.length || 0;
      const reviewsCount = data.data.weeklyReviews?.length || 0;
      const dailyCount = data.data.dailyReviews?.length || 0;
      const syllabusCount = data.data.syllabus?.length || 0;
      const mockTestsCount = data.data.mockTests?.length || 0;

      let dateRange = 'N/A';
      if (entriesCount > 0) {
        const dates = data.data.entries.map((e: any) => e.date).filter(Boolean).sort();
        if (dates.length > 0) {
          dateRange = `${dates[0]} — ${dates[dates.length - 1]}`;
        }
      }

      preview.innerHTML = `
        <p><strong class="text-white">Entries:</strong> ${entriesCount}</p>
        <p><strong class="text-white">Date range:</strong> ${dateRange}</p>
        <p><strong class="text-white">Weekly reviews:</strong> ${reviewsCount}</p>
        <p><strong class="text-white">Daily reviews:</strong> ${dailyCount}</p>
        <p><strong class="text-white">Syllabus chapters:</strong> ${syllabusCount}</p>
        <p><strong class="text-white">Mock tests:</strong> ${mockTestsCount}</p>
      `;

      pendingImportData = data;
      document.getElementById('data-confirm-overlay')?.classList.remove('hidden');
      input.value = '';
    } catch (err) {
      status.className = 'text-sm rounded-lg px-4 py-3 bg-red-500/10 border border-red-500/20 text-red-400';
      status.textContent = `✗ Invalid backup file: ${err instanceof Error ? err.message : 'Parse error'}`;
      status.classList.remove('hidden');
      input.value = '';
    }
  });

  document.getElementById('data-confirm-cancel')?.addEventListener('click', () => {
    document.getElementById('data-confirm-overlay')?.classList.add('hidden');
    pendingImportData = null;
  });

  document.getElementById('data-confirm-proceed')?.addEventListener('click', async () => {
    const overlay = document.getElementById('data-confirm-overlay');
    const status = document.getElementById('data-status');
    const proceedBtn = document.getElementById('data-confirm-proceed');
    const cancelBtn = document.getElementById('data-confirm-cancel');
    if (!overlay || !status || !proceedBtn || !cancelBtn) return;

    if (!pendingImportData) return;

    proceedBtn.textContent = 'Restoring...';
    proceedBtn.disabled = true;
    cancelBtn.disabled = true;

    try {
      const res = await fetch('/api/import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(pendingImportData),
      });

      const result = await res.json();
      if (!res.ok) throw new Error(result.error || 'Import failed');

      status.className = 'text-sm rounded-lg px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400';
      status.textContent = `✓ Restored: ${result.entriesImported} entries, ${result.weeklyReviewsImported} weekly reviews, ${result.dailyReviewsImported} daily reviews, ${result.syllabusImported} syllabus chapters, ${result.mockTestsImported} mock tests.`;
      status.classList.remove('hidden');
    } catch (err) {
      status.className = 'text-sm rounded-lg px-4 py-3 bg-red-500/10 border border-red-500/20 text-red-400';
      status.textContent = `✗ Restore failed: ${err instanceof Error ? err.message : 'Unknown error'}`;
      status.classList.remove('hidden');
    } finally {
      overlay.classList.add('hidden');
      pendingImportData = null;
      proceedBtn.textContent = 'Restore Data';
      proceedBtn.disabled = false;
      cancelBtn.disabled = false;
    }
  });
</script>

<style>
  .settings-section {
    animation: fade-in 0.25s ease forwards;
  }
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
