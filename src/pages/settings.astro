<script is:inline>
  window.__EXAM_SUBJECTS = {
    {EXAM_DEFINITIONS.map(e => `${JSON.stringify(e.key)}: ${JSON.stringify(e.subjects)}`).join(',\n    ')}
  };
  window.__EXAM_LABELS = {
    {EXAM_DEFINITIONS.map(e => `${JSON.stringify(e.key)}: ${JSON.stringify(e.label)}`).join(',\n    ')}
  };
</script>

<script>
  // ── Tab switching ──
  const tabs = document.querySelectorAll('.settings-tab');
  const panels = {
    profile: document.getElementById('panel-profile'),
    preferences: document.getElementById('panel-preferences'),
    appearance: document.getElementById('panel-appearance'),
    notifications: document.getElementById('panel-notifications'),
    account: document.getElementById('panel-account'),
  };

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      // Update tab active state
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      // Switch panel with animation
      Object.entries(panels).forEach(([key, panel]) => {
        const isActive = key === target;
        if (isActive) {
          panel.classList.add('active');
          // Re-trigger entrance animation for staggered children
          const staggerItems = panel.querySelectorAll('.animate-slide-up');
          staggerItems.forEach((el, i) => {
            el.style.animation = 'none';
            void el.offsetHeight;
            el.style.animation = '';
            el.style.setProperty('--stagger-index', i);
          });
        } else {
          panel.classList.remove('active');
        }
      });
    });
  });

  // ── Stream selection ──
  const streamChips = document.querySelectorAll('#stream-grid .settings-chip');
  const examItems = document.querySelectorAll('#exam-grid .settings-chip--item');

  function filterExamsByStream(stream) {
    examItems.forEach(item => {
      const groups = JSON.parse(item.dataset.groups || '[]');
      if (groups.includes(stream)) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
        item.dataset.selected = '0';
        item.classList.remove('settings-chip--exam-selected');
      }
    });
  }

  streamChips.forEach(chip => {
    chip.addEventListener('click', () => {
      streamChips.forEach(c => {
        c.dataset.selected = '0';
        c.classList.remove('settings-chip--selected');
      });
      chip.dataset.selected = '1';
      chip.classList.add('settings-chip--selected');
      filterExamsByStream(chip.dataset.stream);
      updateSubjectGrid();
      updateWorkspacePreview();
    });
  });

  const activeStream = document.querySelector('#stream-grid .settings-chip[data-selected="1"]');
  if (activeStream) filterExamsByStream(activeStream.dataset.stream);

  // ── Exam chips (multi-select) ──
  examItems.forEach(chip => {
    chip.addEventListener('click', () => {
      const isSelected = chip.dataset.selected === '1';
      const selectedCount = document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').length;
      if (isSelected && selectedCount <= 1) return;
      chip.dataset.selected = isSelected ? '0' : '1';
      chip.classList.toggle('settings-chip--exam-selected');
      updateSubjectGrid();
      updateWorkspacePreview();
    });
  });

  // ── Subject grid ──
  const EXAMS = window.__EXAM_SUBJECTS || {};

  function updateSubjectGrid() {
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });

    const subjects = new Set();
    selectedExams.forEach(key => {
      if (EXAMS[key]) EXAMS[key].forEach(s => subjects.add(s));
    });

    const grid = document.getElementById('subjects-grid');
    grid.innerHTML = '';
    if (subjects.size === 0) {
      grid.innerHTML = '<p class="ds-caption">Select at least one exam to see subjects.</p>';
      return;
    }
    subjects.forEach(subject => {
      const div = document.createElement('div');
      div.className = 'settings-chip settings-chip--selected';
      div.dataset.subject = subject;
      div.textContent = subject;
      grid.appendChild(div);
    });
  }

  // ── Workspace preview live update ──
  function updateWorkspacePreview() {
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });

    const previewEl = document.querySelector('.workspace-grid');
    if (!previewEl) return;

    const examChipsContainer = previewEl.querySelector('.wp-block:first-child > div:last-child');
    if (examChipsContainer) {
      examChipsContainer.innerHTML = '';
      if (selectedExams.length > 0) {
        const LABELS = window.__EXAM_LABELS || {};
        selectedExams.forEach(key => {
          const chip = document.createElement('span');
          chip.className = 'wp-chip';
          chip.textContent = LABELS[key] || key;
          examChipsContainer.appendChild(chip);
        });
      } else {
        examChipsContainer.innerHTML = '<span class="ds-caption" style="margin:0;">No exams configured</span>';
      }
    }

    const subjects = new Set();
    selectedExams.forEach(key => {
      if (EXAMS[key]) EXAMS[key].forEach(s => subjects.add(s));
    });
    const blocks = previewEl.querySelectorAll('.wp-block');
    if (blocks.length >= 2) {
      const val = blocks[1].querySelector('.wp-value');
      const desc = blocks[1].querySelector('.ds-caption');
      if (val) val.textContent = `${subjects.size} subjects`;
      if (desc) {
        const arr = [...subjects];
        desc.textContent = arr.length > 0 ? arr.slice(0, 4).join(', ') + (arr.length > 4 ? ` +${arr.length - 4} more` : '') : 'No subjects';
      }
    }
  }

  // ── Live daily average ──
  function updateDailyAverage() {
    const hours = parseFloat(document.getElementById('target-hours').value) || 0;
    const days = parseInt(document.getElementById('study-days').value) || 1;
    const avg = Math.round((hours / days) * 10) / 10;
    document.getElementById('daily-avg-display').textContent = `${avg} hrs/day`;
  }
  document.getElementById('target-hours')?.addEventListener('input', updateDailyAverage);
  document.getElementById('study-days')?.addEventListener('input', updateDailyAverage);

  // ── Guest signup links ──
  document.getElementById('guest-signup-link')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.openAuthPopup('signup');
  });
  document.getElementById('guest-signup-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.openAuthPopup('signup');
  });

  // ── Logout ──
  const logoutBtn = document.getElementById('account-logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    logoutBtn.disabled = true;
    logoutBtn.innerHTML = '<span class="loading-spinner"></span> Logging out...';
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });

  // ── Form submit with success animation ──
  const form = document.getElementById('settings-form');
  const saveBtn = document.getElementById('save-btn');
  const saveBtnText = document.getElementById('save-btn-text');
  const saveBtnIcon = document.getElementById('save-btn-icon');
  const successDiv = document.getElementById('settings-success');
  const errorDiv = document.getElementById('settings-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successDiv.style.display = 'none';
    errorDiv.style.display = 'none';

    const targetHours = parseFloat(document.getElementById('target-hours').value);
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });
    const examDate = document.getElementById('exam-date').value || null;
    const stream = document.querySelector('#stream-grid .settings-chip[data-selected="1"]')?.dataset?.stream || '';
    const studyDays = parseInt(document.getElementById('study-days')?.value) || 5;

    if (selectedExams.length === 0) {
      errorDiv.textContent = 'Select at least one exam.';
      errorDiv.style.display = 'block';
      return;
    }

    saveBtn.disabled = true;
    saveBtnText.textContent = 'Saving...';

    try {
      const res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetHoursPerWeek: targetHours, selectedExams, examDate, stream, studyDaysPerWeek: studyDays }),
      });
      if (!res.ok) throw new Error('Failed to save');

      // Success animation
      saveBtnText.textContent = 'Saved';
      saveBtnIcon.classList.remove('hidden');
      successDiv.style.display = 'flex';
      saveBtn.classList.add('btn-saved');

      setTimeout(() => {
        window.location.reload();
      }, 1200);
    } catch (err) {
      errorDiv.textContent = 'Failed to save settings.';
      errorDiv.style.display = 'block';
      saveBtn.disabled = false;
      saveBtnText.textContent = 'Save Changes';
      saveBtnIcon.classList.add('hidden');
    }
  });
</script>

