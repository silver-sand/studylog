---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS, getSubjectsForExamKeys } from '../utils/exam-map';
import { STREAMS, getExamsForStream } from '../utils/stream-map';
import { scopeDbToUser } from '../services/user-scope';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';

scopeDbToUser(Astro.request);
const db = getDb();
const settings = db.getSettings();
const user = getSessionUser(getTokenFromCookie(Astro.request));
const isGuest = user?.userType === 'guest';

// Determine user's stream from settings or first exam
const defaultExams = settings.selectedExams?.length ? settings.selectedExams : ['JEE'];
const userStream = settings.stream || 'science';
---

<BaseLayout title="Settings">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <h1 class="page-title">Settings</h1>
      <p class="page-sub">Configure your study preferences</p>
    </div>

    <form id="settings-form" class="space-y-6">
      <!-- Account -->
      <div class="card" id="account-card">
        <div class="account-header">
          <div class="account-avatar">{user?.name?.charAt(0)?.toUpperCase() || '?'}</div>
          <div class="account-info">
            <h2 class="card-title" style="margin-bottom:0.1rem">{user?.name || 'User'}</h2>
            <p class="account-email">{user?.email || ''}</p>
            {isGuest && <p class="text-xs text-amber-400/80 mt-1">Guest — <a href="#" onclick="event.preventDefault();window.openAuthPopup('signup')" class="text-blue-400 hover:text-blue-300 underline">Sign up</a> to save your data permanently</p>}
          </div>
        </div>
        {!isGuest && (
          <button type="button" id="account-logout-btn" class="logout-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="3" y1="12" y2="12"/></svg>
            Log out
          </button>
        )}
      </div>

      <!-- Target Hours -->
      <div class="card">
        <h2 class="card-title">Weekly Target</h2>
        <p class="card-desc">Your goal for total study hours per week.</p>
        <div class="flex items-center gap-3 mt-3">
          <input
            type="number"
            id="target-hours"
            name="targetHoursPerWeek"
            min="1"
            max="168"
            step="1"
            value={settings.targetHoursPerWeek}
            class="form-input w-20 text-center font-mono"
          />
          <span class="text-sm text-slate-500">hours per week</span>
        </div>
      </div>

      <!-- Stream -->
      <div class="card">
        <h2 class="card-title">Your Stream</h2>
        <p class="card-desc">Select your stream to filter available exams.</p>
        <div class="stream-grid" id="stream-grid">
          {Object.entries(STREAMS).map(([key, stream]) => (
            <div
              class:list={{ 'chip': true, 'chip-selected': userStream === key }}
              data-stream={key}
              data-selected={userStream === key ? '1' : '0'}
            >
              <span class="text-base mr-1">{stream.icon}</span>
              <span>{stream.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Exams (multi-select) -->
      <div class="card">
        <h2 class="card-title">Exams / Entrance</h2>
        <p class="card-desc">Which exams are you preparing for?</p>
        <div class="exam-grid" id="exam-grid">
          {EXAM_DEFINITIONS.map(exam => {
            const isSelected = defaultExams.includes(exam.key);
            return (
              <div
                class:list={{ 'chip': true, 'chip-selected-exam': isSelected, 'exam-grid-item': true }}
                data-exam={exam.key}
                data-selected={isSelected ? '1' : '0'}
                data-group={exam.group}
              >
                <span class="exam-label">{exam.label}</span>
                <span class="exam-subjects text-xs opacity-60">{exam.subjects.length} subjects</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Subjects (auto-computed from exams, shown as info) -->
      <div class="card">
        <h2 class="card-title">Subjects</h2>
        <p class="card-desc">Subjects are auto-selected based on your exams. <span class="text-amber-400/70">Settings &rarr; Exams</span> to change.</p>
        <div class="subject-grid" id="subjects-grid">
          {getSubjectsForExamKeys(defaultExams).map(subject => (
            <div class="chip chip-selected" data-subject={subject}>
              {subject}
            </div>
          ))}
        </div>
      </div>

      <!-- Exam Date -->
      <div class="card">
        <h2 class="card-title">Exam Date</h2>
        <p class="card-desc">When is your exam? Used for pace prediction.</p>
        <div class="flex items-center gap-3 mt-3">
          <input
            type="date"
            id="exam-date"
            name="examDate"
            value={settings.examDate || ''}
            class="form-input font-mono"
          />
          {settings.examDate && (
            <span class="text-sm text-slate-500" id="exam-date-label"></span>
          )}
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <button type="submit" id="save-btn" class="btn-primary">
          Save Settings
        </button>
        <div id="settings-success" class="text-sm text-emerald-400 hidden">Saved.</div>
      </div>
      <div id="settings-error" class="error hidden"></div>
    </form>
  </div>
</BaseLayout>

<script is:inline>
  window.__EXAM_SUBJECTS = {
    {EXAM_DEFINITIONS.map(e => `${JSON.stringify(e.key)}: ${JSON.stringify(e.subjects)}`).join(',\n    ')}
  };
</script>

<script>
  // ── Stream selection ──
  const streamChips = document.querySelectorAll('#stream-grid .chip');
  const examItems = document.querySelectorAll('#exam-grid .exam-grid-item');

  function filterExamsByStream(stream) {
    examItems.forEach(item => {
      const group = item.dataset.group;
      if (group === stream) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
        // Deselect hidden exams
        item.dataset.selected = '0';
        item.classList.remove('chip-selected-exam');
      }
    });
  }

  streamChips.forEach(chip => {
    chip.addEventListener('click', () => {
      streamChips.forEach(c => {
        c.dataset.selected = '0';
        c.classList.remove('chip-selected');
      });
      chip.dataset.selected = '1';
      chip.classList.add('chip-selected');
      filterExamsByStream(chip.dataset.stream);
      updateSubjectGrid();
    });
  });

  // Filter on load
  const activeStream = document.querySelector('#stream-grid .chip[data-selected="1"]');
  if (activeStream) filterExamsByStream(activeStream.dataset.stream);

  // ── Exam chips (multi-select) ──
  examItems.forEach(chip => {
    chip.addEventListener('click', () => {
      const isSelected = chip.dataset.selected === '1';
      // Deselect all if only one would remain selected
      const selectedCount = document.querySelectorAll('#exam-grid .chip[data-selected="1"]').length;
      if (isSelected && selectedCount <= 1) return;
      chip.dataset.selected = isSelected ? '0' : '1';
      chip.classList.toggle('chip-selected-exam');
      updateSubjectGrid();
    });
  });

  // ── Subject grid (auto-computed from exams) ──
  const EXAMS = window.__EXAM_SUBJECTS || {};

  function updateSubjectGrid() {
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });

    const subjects = new Set();
    selectedExams.forEach(key => {
      if (EXAMS[key]) EXAMS[key].forEach(s => subjects.add(s));
    });

    const grid = document.getElementById('subjects-grid');
    grid.innerHTML = '';
    if (subjects.size === 0) {
      grid.innerHTML = '<p class="text-sm text-slate-500">Select at least one exam to see subjects.</p>';
      return;
    }
    subjects.forEach(subject => {
      const div = document.createElement('div');
      div.className = 'chip chip-selected';
      div.dataset.subject = subject;
      div.textContent = subject;
      grid.appendChild(div);
    });
  }

  // ── Logout ──
  const logoutBtn = document.getElementById('account-logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    logoutBtn.disabled = true;
    logoutBtn.innerHTML = 'Logging out...';
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/dashboard';
  });

  // ── Form submit ──
  const form = document.getElementById('settings-form');
  const saveBtn = document.getElementById('save-btn');
  const successDiv = document.getElementById('settings-success');
  const errorDiv = document.getElementById('settings-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successDiv.classList.add('hidden');
    errorDiv.classList.add('hidden');

    const targetHours = parseFloat(document.getElementById('target-hours').value);

    const selectedExams = [];
    document.querySelectorAll('#exam-grid .chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });

    const examDate = document.getElementById('exam-date').value || null;

    if (selectedExams.length === 0) {
      errorDiv.textContent = 'Select at least one exam.';
      errorDiv.classList.remove('hidden');
      return;
    }

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      const res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetHoursPerWeek: targetHours, selectedExams, examDate }),
      });

      if (!res.ok) throw new Error('Failed to save');

      successDiv.classList.remove('hidden');
      saveBtn.textContent = 'Saved';
      setTimeout(() => {
        saveBtn.textContent = 'Save Settings';
        saveBtn.disabled = false;
        successDiv.classList.add('hidden');
      }, 2000);
    } catch (err) {
      errorDiv.textContent = 'Failed to save settings.';
      errorDiv.classList.remove('hidden');
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Settings';
    }
  });
</script>

<style>
  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .page-sub {
    font-size: 0.875rem;
    color: #64748b;
  }
  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 0.25rem;
  }
  .card-desc {
    font-size: 0.825rem;
    color: #64748b;
  }
  .form-input {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.6);
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: #e2e8f0;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .form-input:focus {
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.2);
  }
  .stream-grid, .subject-grid, .exam-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  @media (min-width: 768px) {
    .stream-grid, .subject-grid, .exam-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .chip {
    padding: 0.5rem 1rem;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(51, 65, 85, 0.5);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    font-size: 0.825rem;
    color: #94a3b8;
    user-select: none;
  }
  .chip:hover {
    border-color: rgba(71, 85, 105, 0.8);
    color: #e2e8f0;
  }
  .chip-selected {
    background: rgba(59, 130, 246, 0.12);
    border-color: rgba(59, 130, 246, 0.5);
    color: #93c5fd;
    box-shadow: 0 0 6px rgba(59, 130, 246, 0.15);
  }
  .chip-selected-exam {
    background: rgba(236, 72, 153, 0.12);
    border-color: rgba(236, 72, 153, 0.5);
    color: #f9a8d4;
    box-shadow: 0 0 6px rgba(236, 72, 153, 0.15);
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2563eb;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-primary:hover:not(:disabled) {
    background: #3b82f6;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .error {
    color: #ef4444;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
  }
  .hidden {
    display: none;
  }

  /* ── Account card ── */
  #account-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .account-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }
  .account-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #2563eb, #8b5cf6);
    color: white;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .account-info {
    min-width: 0;
  }
  .account-email {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0.1rem 0 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(239, 68, 68, 0.1);
    color: #fca5a5;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.5rem 0.85rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(239, 68, 68, 0.2);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Inter', sans-serif;
    flex-shrink: 0;
  }
  .logout-btn:hover:not(:disabled) {
    background: rgba(239, 68, 68, 0.18);
    border-color: rgba(239, 68, 68, 0.35);
  }
  .logout-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .exam-grid-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .exam-label {
    font-size: 0.8rem;
    font-weight: 500;
  }
  .exam-subjects {
    font-size: 0.65rem;
    color: inherit;
    opacity: 0.6;
  }
</style>
