---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS, getSubjectsForExamKeys } from '../utils/exam-map';
import { STREAMS, getExamsForStream } from '../utils/stream-map';
import { scopeDbToUser } from '../services/user-scope';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import AuthPopup from '../components/AuthPopup.astro';

scopeDbToUser(Astro.request);
const db = getDb();
const settings = db.getSettings();
const user = getSessionUser(getTokenFromCookie(Astro.request));
const isGuest = user?.userType === 'guest';

// Determine user's stream and default exams
const userStream = user?.stream || 'science';
const defaultExams = settings.selectedExams?.length
  ? settings.selectedExams
  : EXAM_DEFINITIONS.filter(e => e.groups.includes(userStream)).map(e => e.key).slice(0, 1);
const activeSubjects = getSubjectsForExamKeys(defaultExams);
const dailyAvg = settings.studyDaysPerWeek > 0
  ? Math.round((settings.targetHoursPerWeek / settings.studyDaysPerWeek) * 10) / 10
  : 7;

// Compute days until exam
let daysUntilExam = null;
if (settings.examDate) {
  const now = new Date();
  const examDt = new Date(settings.examDate);
  daysUntilExam = Math.max(0, Math.ceil((examDt.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
}
---

<BaseLayout title="Settings">
  <div class="animate-slide-up">

    <!-- Page Header -->
    <div class="ds-page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:var(--ds-space-3);">
      <div>
        <h1 class="ds-heading-page">Settings</h1>
        <p class="ds-body-sm">Manage your profile, study preferences, and account</p>
      </div>
    </div>

    <!-- ── Premium Tab Bar ── -->
    <div class="settings-tabs" id="settings-tabs">
      <button class="settings-tab active" data-tab="profile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </button>
      <button class="settings-tab" data-tab="preferences">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="21" y2="21"/><line x1="4" x2="20" y1="14" y2="14"/><line x1="4" x2="9" y1="3" y2="3"/><line x1="15" x2="20" y1="3" y2="3"/><line x1="4" x2="5" y1="7" y2="7"/><line x1="12" x2="20" y1="7" y2="7"/></svg>
        Study Preferences
      </button>
      <button class="settings-tab" data-tab="appearance">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        Appearance
      </button>
      <button class="settings-tab" data-tab="notifications">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        Notifications
      </button>
      <button class="settings-tab" data-tab="account">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Account
      </button>
    </div>

    <form id="settings-form">

      <!-- ════════════════════════════════════════════ -->
      <!-- TAB 1: PROFILE                               -->
      <!-- ════════════════════════════════════════════════ -->
      <div class="settings-tab-panel active" id="panel-profile">

        <!-- Account Card -->
        <div class="ds-card-glass card-lift animate-slide-up" style="display:flex;align-items:center;gap:var(--ds-space-3);flex-wrap:wrap;">
          <div class="account-avatar">{user?.name?.charAt(0)?.toUpperCase() || '?'}</div>
          <div style="flex:1;min-width:0;">
            <h2 class="ds-heading-card" style="margin:0;">{user?.name || 'User'}</h2>
            <p class="ds-caption" style="margin:0.15rem 0 0;">{user?.email || ''}</p>
            {isGuest && <p class="ds-caption" style="color:var(--ds-warning-400);margin-top:var(--ds-space-1);">Guest — <a href="#" id="guest-signup-link" class="ds-link-accent">Sign up</a> to save your data permanently</p>}
          </div>
        </div>

        <!-- Profile Summary -->
        <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:1;">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Profile Summary</span>
          </div>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Your academic background as used by the AI Mentor.</p>

          <div class="profile-summary">
            {user?.classLevel && (
              <div class="ps-chip">
                <span class="ps-chip-icon">&#x1F4DA;</span>
                <span>Class {user.classLevel.replace('class_', '')}</span>
              </div>
            )}
            {user?.stream && (
              <div class="ps-chip">
                <span class="ps-chip-icon">{user.stream === 'science' ? '&#x1F52C;' : user.stream === 'commerce' ? '&#x1F4CA;' : '&#x1F4D6;'}</span>
                <span>{user.stream.charAt(0).toUpperCase() + user.stream.slice(1)}</span>
              </div>
            )}
            {(user as any)?.coaching && (
              <div class="ps-chip">
                <span class="ps-chip-icon">&#x1F3AF;</span>
                <span>{{coaching_only: 'Coaching only', self_study: 'Self-study', both: 'Coaching + Self-study'}[(user as any).coaching] || (user as any).coaching}</span>
              </div>
            )}
            {(user as any)?.targetRank && (
              <div class="ps-chip ps-chip-goal">
                <span class="ps-chip-icon">&#x1F31F;</span>
                <span>Goal: {(user as any).targetRank}</span>
              </div>
            )}
          </div>

          {(user as any)?.weakSubjects?.length > 0 && (
            <div style="margin-top:var(--ds-space-2);">
              <p class="ds-caption" style="margin:0 0 var(--ds-space-1);">Focus areas (subjects needing extra attention):</p>
              <div style="display:flex;flex-wrap:wrap;gap:0.375rem;">
                {(user as any).weakSubjects.map((s: string) => (
                  <span class="ps-weak-chip">{s}</span>
                ))}
              </div>
            </div>
          )}

          <a href="/onboarding?update=1" class="ds-btn ds-btn-secondary ds-btn-sm press-effect" style="margin-top:var(--ds-space-2);display:inline-flex;align-items:center;gap:0.25rem;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Update Onboarding
          </a>
        </div>

        <!-- Stream & Exams -->
        <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:2;">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            <span>Stream & Exams</span>
          </div>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Select your stream and the exams you're preparing for.</p>

          <label class="ds-label-form" style="margin-bottom:var(--ds-space-1);">Stream</label>
          <div class="settings-chip-grid" id="stream-grid">
            {Object.entries(STREAMS).map(([key, stream]) => (
              <div
                class:list={{ 'settings-chip': true, 'settings-chip--selected': userStream === key }}
                data-stream={key}
                data-selected={userStream === key ? '1' : '0'}
              >
                <span>{stream.icon}</span>
                <span>{stream.label}</span>
              </div>
            ))}
          </div>

          <label class="ds-label-form" style="margin-top:var(--ds-space-2);margin-bottom:var(--ds-space-1);">Exams</label>
          <div class="settings-chip-grid" id="exam-grid">
            {EXAM_DEFINITIONS.filter(exam => exam.groups.includes(userStream)).map(exam => {
              const isSelected = defaultExams.includes(exam.key);
              return (
                <div
                  class:list={{ 'settings-chip': true, 'settings-chip--exam-selected': isSelected, 'settings-chip--item': true }}
                  data-exam={exam.key}
                  data-selected={isSelected ? '1' : '0'}
                  data-groups={exam.groups.join(',')}
                >
                  <span class="settings-chip-label">{exam.label}</span>
                  <span class="settings-chip-sub">{exam.subjects.length} subjects</span>
                </div>
              );
            })}
          </div>

          <!-- Active Subjects (auto-computed) -->
          <label class="ds-label-form" style="margin-top:var(--ds-space-2);margin-bottom:var(--ds-space-1);">Active Subjects</label>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-1);">Subjects are auto-selected based on your exams.</p>
          <div class="settings-chip-grid" id="subjects-grid">
            {activeSubjects.map(subject => (
              <div class="settings-chip settings-chip--selected" data-subject={subject}>
                {subject}
              </div>
            ))}
            {activeSubjects.length === 0 && <p class="ds-caption">Select at least one exam to see subjects.</p>}
          </div>
        </div>

      </div>

      <!-- ════════════════════════════════════════════ -->
      <!-- TAB 2: STUDY PREFERENCES                     -->
      <!-- ════════════════════════════════════════════════ -->
      <div class="settings-tab-panel" id="panel-preferences">

        <!-- Weekly Target -->
        <div class="ds-card-glass card-lift animate-slide-up">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            <span>Weekly Target</span>
          </div>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Your goal for total study hours and days per week.</p>

          <div class="target-row">
            <div class="target-field">
              <label class="ds-label-form" for="target-hours">Hours / Week</label>
              <div class="target-input-group">
                <input
                  type="number"
                  id="target-hours"
                  name="targetHoursPerWeek"
                  min="1"
                  max="168"
                  step="1"
                  value={settings.targetHoursPerWeek}
                  class="ds-input"
                  style="width:5rem;text-align:center;font-family:var(--ds-font-mono);"
                />
                <span class="ds-caption">hrs</span>
              </div>
            </div>
            <div class="target-field">
              <label class="ds-label-form" for="study-days">Days / Week</label>
              <div class="target-input-group">
                <input
                  type="number"
                  id="study-days"
                  name="studyDaysPerWeek"
                  min="1"
                  max="7"
                  step="1"
                  value={settings.studyDaysPerWeek}
                  class="ds-input"
                  style="width:4rem;text-align:center;font-family:var(--ds-font-mono);"
                />
                <span class="ds-caption">days</span>
              </div>
            </div>
            <div class="target-stats">
              <span class="ds-label" style="font-size:var(--ds-text-2xs);">Daily Average</span>
              <span class="target-daily-avg" id="daily-avg-display">{dailyAvg} hrs/day</span>
            </div>
          </div>
        </div>

        <!-- Exam Date -->
        <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:1;">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Exam Date</span>
          </div>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">When is your exam? Used for pace prediction and study timeline.</p>
          <div style="display:flex;align-items:center;gap:var(--ds-space-3);flex-wrap:wrap;">
            <input
              type="date"
              id="exam-date"
              name="examDate"
              value={settings.examDate || ''}
              class="ds-input"
              style="font-family:var(--ds-font-mono);width:auto;"
            />
            {daysUntilExam !== null && (
              <span class="ds-caption" style="color:var(--ds-accent-400);font-weight:500;">
                {daysUntilExam === 0 ? '&#x1F4CC; Exam day!' : `&#x1F4C5; ${daysUntilExam} days away`}
              </span>
            )}
          </div>
        </div>

        <!-- Workspace Preview -->
        <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:2;">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>Workspace Preview</span>
          </div>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Your current study configuration at a glance.</p>
          <div class="workspace-grid">
            <div class="wp-block">
              <span class="wp-label">Active Exams</span>
              <div style="display:flex;flex-wrap:wrap;gap:0.375rem;margin-top:0.375rem;">
                {defaultExams.length > 0 ? defaultExams.map(key => {
                  const examDef = EXAM_DEFINITIONS.find(e => e.key === key);
                  return <span class="wp-chip">{examDef?.label || key}</span>;
                }) : <span class="ds-caption" style="margin:0;">No exams configured</span>}
              </div>
            </div>
            <div class="wp-block">
              <span class="wp-label">Subjects Tracked</span>
              <span class="wp-value">{activeSubjects.length} subjects</span>
              <p class="ds-caption" style="margin:0.375rem 0 0;">{activeSubjects.slice(0, 4).join(', ')}{activeSubjects.length > 4 ? ` +${activeSubjects.length - 4} more` : ''}</p>
            </div>
            <div class="wp-block">
              <span class="wp-label">Weekly Commitment</span>
              <span class="wp-value">{settings.targetHoursPerWeek}h / {settings.studyDaysPerWeek || 0} days</span>
              {dailyAvg > 0 && <p class="ds-caption" style="margin:0.375rem 0 0;">&#x2248; {dailyAvg} hrs/study day</p>}
            </div>
            <div class="wp-block">
              <span class="wp-label">Exam Timeline</span>
              {daysUntilExam !== null ? (
                <>
                  <span class="wp-value">{daysUntilExam} days</span>
                  <p class="ds-caption" style="margin:0.375rem 0 0;">until {settings.examDate ? new Date(settings.examDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : 'exam'}</p>
                </>
              ) : (
                <span class="ds-caption" style="margin:0;">No exam date set</span>
              )}
            </div>
          </div>
        </div>

      </div>

      <!-- ════════════════════════════════════════════ -->
      <!-- TAB 3: APPEARANCE                            -->
      <!-- ════════════════════════════════════════════════ -->
      <div class="settings-tab-panel" id="panel-appearance">

        <div class="ds-card-glass card-lift animate-slide-up">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <span>Theme</span>
          </div>
          <p class="ds-caption" style="margin:0 0 var(--ds-space-2);">Currently the app uses a dark-first design. Light mode support is coming soon.</p>

          <div class="appearance-card">
            <div class="appearance-option active">
              <div class="appearance-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              </div>
              <div>
                <span class="appearance-label">Dark Mode</span>
                <span class="appearance-desc">Current default — optimized for focus</span>
              </div>
              <div class="appearance-check">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
            </div>
            <div class="appearance-option disabled">
              <div class="appearance-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" x2="12" y1="1" y2="3"/><line x1="12" x2="12" y1="21" y2="23"/><line x1="4.22" x2="5.64" y1="4.22" y2="5.64"/><line x1="18.36" x2="19.78" y1="18.36" y2="19.78"/><line x1="1" x2="3" y1="12" y2="12"/><line x1="21" x2="23" y1="12" y2="12"/><line x1="4.22" x2="5.64" y1="19.78" y2="18.36"/><line x1="18.36" x2="19.78" y1="5.64" y2="4.22"/></svg>
              </div>
              <div>
                <span class="appearance-label">Light Mode</span>
                <span class="appearance-desc">Coming soon</span>
              </div>
            </div>
          </div>
        </div>

        <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:1;">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            <span>Display</span>
          </div>
          <div class="settings-row">
            <div>
              <span class="settings-row-label">Font Size</span>
              <span class="settings-row-desc">Uses system default — adjust in your browser settings</span>
            </div>
          </div>
          <div class="settings-row" style="border-bottom:none;padding-bottom:0;">
            <div>
              <span class="settings-row-label">Reduce Motion</span>
              <span class="settings-row-desc">Animations respect your system's prefers-reduced-motion setting</span>
            </div>
          </div>
        </div>

      </div>

      <!-- ════════════════════════════════════════════ -->
      <!-- TAB 4: NOTIFICATIONS                         -->
      <!-- ════════════════════════════════════════════════ -->
      <div class="settings-tab-panel" id="panel-notifications">

        <div class="ds-card-glass card-lift animate-slide-up">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span>Notification Preferences</span>
          </div>

          <div class="settings-row">
            <div>
              <span class="settings-row-label">Study Reminders</span>
              <span class="settings-row-desc">Get reminded to log your study sessions daily</span>
            </div>
            <label class="toggle">
              <input type="checkbox" checked disabled />
              <span class="toggle-slider"></span>
            </label>
          </div>

          <div class="settings-row">
            <div>
              <span class="settings-row-label">Weekly Review Ready</span>
              <span class="settings-row-desc">Notify when your weekly AI review is generated</span>
            </div>
            <label class="toggle">
              <input type="checkbox" checked disabled />
              <span class="toggle-slider"></span>
            </label>
          </div>

          <div class="settings-row">
            <div>
              <span class="settings-row-label">Streak Alerts</span>
              <span class="settings-row-desc">Remind you to keep your study streak alive</span>
            </div>
            <label class="toggle">
              <input type="checkbox" disabled />
              <span class="toggle-slider"></span>
            </label>
          </div>

          <div class="settings-row" style="border-bottom:none;padding-bottom:0;">
            <div>
              <span class="settings-row-label">AI Mentor Suggestions</span>
              <span class="settings-row-desc">Get proactive tips and suggestions from your AI mentor</span>
            </div>
            <label class="toggle">
              <input type="checkbox" checked disabled />
              <span class="toggle-slider"></span>
            </label>
          </div>

          <p class="ds-caption" style="text-align:center;margin-top:var(--ds-space-2);padding-top:var(--ds-space-2);border-top:1px solid var(--ds-border-subtle);">Notifications are currently disabled. Coming in a future update.</p>
        </div>

      </div>

      <!-- ════════════════════════════════════════════ -->
      <!-- TAB 5: ACCOUNT                               -->
      <!-- ════════════════════════════════════════════════ -->
      <div class="settings-tab-panel" id="panel-account">

        <div class="ds-card-glass card-lift animate-slide-up">
          <div class="settings-section-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Account Details</span>
          </div>

          <div style="display:flex;align-items:center;gap:var(--ds-space-3);margin-bottom:var(--ds-space-2);">
            <div class="account-avatar" style="width:3rem;height:3rem;font-size:1.15rem;">{user?.name?.charAt(0)?.toUpperCase() || '?'}</div>
            <div>
              <h2 class="ds-heading-card" style="margin:0;">{user?.name || 'User'}</h2>
              <p class="ds-caption" style="margin:0.1rem 0 0">{user?.email || ''}</p>
              {isGuest && <p class="ds-caption" style="color:var(--ds-warning-400);margin-top:0.25rem;">Guest account — data is temporary</p>}
