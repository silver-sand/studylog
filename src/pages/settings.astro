---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS, getSubjectsForExamKeys } from '../utils/exam-map';
import { STREAMS, getExamsForStream } from '../utils/stream-map';
import { scopeDbToUser } from '../services/user-scope';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import AuthPopup from '../components/AuthPopup.astro';

scopeDbToUser(Astro.request);
const db = getDb();
const settings = db.getSettings();
const user = getSessionUser(getTokenFromCookie(Astro.request));
const isGuest = user?.userType === 'guest';

// Determine user's stream and default exams
const userStream = user?.stream || 'science';
const defaultExams = settings.selectedExams?.length
  ? settings.selectedExams
  : EXAM_DEFINITIONS.filter(e => e.groups.includes(userStream)).map(e => e.key).slice(0, 1);
const activeSubjects = getSubjectsForExamKeys(defaultExams);
const dailyAvg = settings.studyDaysPerWeek > 0
  ? Math.round((settings.targetHoursPerWeek / settings.studyDaysPerWeek) * 10) / 10
  : 7;

// Compute days until exam
let daysUntilExam = null;
if (settings.examDate) {
  const now = new Date();
  const examDt = new Date(settings.examDate);
  daysUntilExam = Math.max(0, Math.ceil((examDt.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
}
---

<BaseLayout title="Study Profile">
  <div class="ds-page">
    <div class="ds-page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:var(--ds-space-3);">
      <div>
        <h1 class="ds-heading-page">Study Profile</h1>
        <p class="ds-body-sm">Your workspace configuration — exams, targets, and preferences</p>
      </div>
      <a href="/onboarding?update=1" class="ds-btn ds-btn-secondary ds-btn-sm" style="white-space:nowrap;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.25rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Update Onboarding
      </a>
    </div>

    <form id="settings-form" style="display:flex;flex-direction:column;gap:var(--ds-space-3);">

      <!-- ── Account Card ── -->
      <div class="ds-card" id="account-card">
        <div class="account-header">
          <div class="account-avatar">{user?.name?.charAt(0)?.toUpperCase() || '?'}</div>
          <div class="account-info">
            <h2 class="ds-heading-section" style="margin-bottom:0.1rem">{user?.name || 'User'}</h2>
            <p class="account-email">{user?.email || ''}</p>
            {isGuest && <p class="ds-caption" style="color:var(--ds-warning-400);margin-top:var(--ds-space-1);">Guest — <a href="#" onclick="event.preventDefault();window.openAuthPopup('signup')" class="ds-link-accent">Sign up</a> to save your data permanently</p>}
          </div>
        </div>
        {!isGuest && (
          <button type="button" id="account-logout-btn" class="ds-btn ds-btn-danger ds-btn-sm" style="flex-shrink:0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="3" y1="12" y2="12"/></svg>
            Log out
          </button>
        )}
      </div>

      <!-- ── Study Profile Summary ── -->
      <div class="ds-card">
        <h2 class="ds-heading-section">Your Profile</h2>
        <p class="ds-caption">Your academic background as used by the AI Mentor.</p>
        <div class="profile-summary" style="display:flex;flex-wrap:wrap;gap:var(--ds-space-2);margin-top:var(--ds-space-3);">
          {user?.classLevel && (
            <div class="ps-chip">
              <span class="ps-chip-icon">📚</span>
              <span>Class {user.classLevel.replace('class_', '')}</span>
            </div>
          )}
          {user?.stream && (
            <div class="ps-chip">
              <span class="ps-chip-icon">{user.stream === 'science' ? '🔬' : user.stream === 'commerce' ? '📊' : '📖'}</span>
              <span>{user.stream.charAt(0).toUpperCase() + user.stream.slice(1)}</span>
            </div>
          )}
          {(user as any)?.coaching && (
            <div class="ps-chip">
              <span class="ps-chip-icon">🎯</span>
              <span>{{coaching_only: 'Coaching only', self_study: 'Self-study', both: 'Coaching + Self-study'}[(user as any).coaching] || (user as any).coaching}</span>
            </div>
          )}
          {(user as any)?.targetRank && (
            <div class="ps-chip ps-chip-goal">
              <span class="ps-chip-icon">🌟</span>
              <span>Goal: {(user as any).targetRank}</span>
            </div>
          )}
        </div>
        {(user as any)?.weakSubjects?.length > 0 && (
          <div style="margin-top:var(--ds-space-2);">
            <p class="ds-caption" style="margin:0 0 var(--ds-space-1);">Focus areas (subjects needing extra attention):</p>
            <div style="display:flex;flex-wrap:wrap;gap:var(--ds-space-1-5);">
              {(user as any).weakSubjects.map((s: string) => (
                <span class="ps-weak-chip">{s}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- ── Workspace Preview ── -->
      <div class="ds-card">
        <h2 class="ds-heading-section">Workspace Preview</h2>
        <p class="ds-caption">Your current study configuration at a glance.</p>
        <div class="workspace-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:var(--ds-space-2);margin-top:var(--ds-space-3);">
          <!-- Active Exams -->
          <div class="wp-block">
            <span class="wp-label">Active Exams</span>
            <div style="display:flex;flex-wrap:wrap;gap:var(--ds-space-1);margin-top:var(--ds-space-1);">
              {defaultExams.length > 0 ? defaultExams.map(key => {
                const examDef = EXAM_DEFINITIONS.find(e => e.key === key);
                return <span class="wp-chip">{examDef?.label || key}</span>;
              }) : <span class="ds-caption" style="margin:0;">No exams configured</span>}
            </div>
          </div>

          <!-- Subjects tracked -->
          <div class="wp-block">
            <span class="wp-label">Subjects Tracked</span>
            <span class="wp-value">{activeSubjects.length} subjects</span>
            <p class="ds-caption" style="margin:var(--ds-space-1) 0 0;">{activeSubjects.slice(0, 4).join(', ')}{activeSubjects.length > 4 ? ` +${activeSubjects.length - 4} more` : ''}</p>
          </div>

          <!-- Weekly commitment -->
          <div class="wp-block">
            <span class="wp-label">Weekly Commitment</span>
            <span class="wp-value">{settings.targetHoursPerWeek}h / {settings.studyDaysPerWeek || 0} days</span>
            {dailyAvg > 0 && <p class="ds-caption" style="margin:var(--ds-space-1) 0 0;">≈ {dailyAvg} hrs/study day</p>}
          </div>

          <!-- Exam timeline -->
          <div class="wp-block">
            <span class="wp-label">Exam Timeline</span>
            {daysUntilExam !== null ? (
              <>
                <span class="wp-value">{daysUntilExam} days</span>
                <p class="ds-caption" style="margin:var(--ds-space-1) 0 0;">until {settings.examDate ? new Date(settings.examDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : 'exam'}</p>
              </>
            ) : (
              <span class="ds-caption" style="margin:0;">No exam date set</span>
            )}
          </div>
        </div>
      </div>

      <!-- ── Weekly Target ── -->
      <div class="ds-card">
        <h2 class="ds-heading-section">Weekly Target</h2>
        <p class="ds-caption">Your goal for total study hours and days per week.</p>
        <div style="display:flex;align-items:center;gap:var(--ds-space-4);margin-top:var(--ds-space-3);flex-wrap:wrap;">
          <div style="display:flex;align-items:center;gap:var(--ds-space-2);">
            <input
              type="number"
              id="target-hours"
              name="targetHoursPerWeek"
              min="1"
              max="168"
              step="1"
              value={settings.targetHoursPerWeek}
              class="ds-input"
              style="width:5rem;text-align:center;font-family:var(--ds-font-mono);"
            />
            <span class="ds-caption">hours / week</span>
          </div>
          <div style="display:flex;align-items:center;gap:var(--ds-space-2);">
            <input
              type="number"
              id="study-days"
              name="studyDaysPerWeek"
              min="1"
              max="7"
              step="1"
              value={settings.studyDaysPerWeek}
              class="ds-input"
              style="width:4rem;text-align:center;font-family:var(--ds-font-mono);"
            />
            <span class="ds-caption">days / week</span>
          </div>
          <span class="ds-caption" id="daily-avg-display" style="color:var(--ds-text-tertiary);">≈ {dailyAvg} hrs/day</span>
        </div>
      </div>

      <!-- ── Stream & Exams ── -->
      <div class="ds-card">
        <h2 class="ds-heading-section">Stream & Exams</h2>
        <p class="ds-caption">Select your stream and the exams you're preparing for.</p>

        <label class="ds-label-form" style="margin-top:var(--ds-space-3);margin-bottom:var(--ds-space-1);">Stream</label>
        <div class="settings-chip-grid" id="stream-grid">
          {Object.entries(STREAMS).map(([key, stream]) => (
            <div
              class:list={{ 'settings-chip': true, 'settings-chip--selected': userStream === key }}
              data-stream={key}
              data-selected={userStream === key ? '1' : '0'}
            >
              <span>{stream.icon}</span>
              <span>{stream.label}</span>
            </div>
          ))}
        </div>

        <label class="ds-label-form" style="margin-top:var(--ds-space-2);margin-bottom:var(--ds-space-1);">Exams</label>
        <div class="settings-chip-grid" id="exam-grid">
          {EXAM_DEFINITIONS.filter(exam => exam.groups.includes(userStream)).map(exam => {
            const isSelected = defaultExams.includes(exam.key);
            return (
              <div
                class:list={{ 'settings-chip': true, 'settings-chip--exam-selected': isSelected, 'settings-chip--item': true }}
                data-exam={exam.key}
                data-selected={isSelected ? '1' : '0'}
                data-groups={exam.groups.join(',')}
              >
                <span class="settings-chip-label">{exam.label}</span>
                <span class="settings-chip-sub">{exam.subjects.length} subjects</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- ── Subjects (auto-computed from exams) ── -->
      <div class="ds-card">
        <h2 class="ds-heading-section">Active Subjects</h2>
        <p class="ds-caption">Subjects are auto-selected based on your exams. Change exams above to update.</p>
        <div class="settings-chip-grid" id="subjects-grid">
          {activeSubjects.map(subject => (
            <div class="settings-chip settings-chip--selected" data-subject={subject}>
              {subject}
            </div>
          ))}
          {activeSubjects.length === 0 && <p class="ds-caption">Select at least one exam to see subjects.</p>}
        </div>
      </div>

      <!-- ── Exam Date ── -->
      <div class="ds-card">
        <h2 class="ds-heading-section">Exam Date</h2>
        <p class="ds-caption">When is your exam? Used for pace prediction and study timeline.</p>
        <div style="display:flex;align-items:center;gap:var(--ds-space-3);margin-top:var(--ds-space-3);">
          <input
            type="date"
            id="exam-date"
            name="examDate"
            value={settings.examDate || ''}
            class="ds-input"
            style="font-family:var(--ds-font-mono);"
          />
          {daysUntilExam !== null && (
            <span class="ds-caption" style="color:var(--ds-accent-400);">
              {daysUntilExam === 0 ? '📌 Exam day!' : `📅 ${daysUntilExam} days away`}
            </span>
          )}
        </div>
      </div>

      <!-- ── Actions ── -->
      <div style="display:flex;align-items:center;gap:var(--ds-space-3);">
        <button type="submit" id="save-btn" class="ds-btn ds-btn-primary">
          Save Changes
        </button>
        <div id="settings-success" class="ds-caption" style="color:var(--ds-success-500);" hidden>Saved.</div>
      </div>
      <div id="settings-error" class="ds-error-text" hidden></div>
    </form>
  </div>

  <!-- Include AuthPopup for guest signup flow -->
  <AuthPopup />
</BaseLayout>

<script is:inline>
  window.__EXAM_SUBJECTS = {
    {EXAM_DEFINITIONS.map(e => `${JSON.stringify(e.key)}: ${JSON.stringify(e.subjects)}`).join(',\n    ')}
  };
  window.__EXAM_LABELS = {
    {EXAM_DEFINITIONS.map(e => `${JSON.stringify(e.key)}: ${JSON.stringify(e.label)}`).join(',\n    ')}
  };
</script>

<script>
  // ── Stream selection ──
  const streamChips = document.querySelectorAll('#stream-grid .settings-chip');
  const examItems = document.querySelectorAll('#exam-grid .settings-chip--item');

  function filterExamsByStream(stream) {
    examItems.forEach(item => {
      const groups = JSON.parse(item.dataset.groups || '[]');
      if (groups.includes(stream)) {
        item.classList.remove('hidden');
      } else {
        item.classList.add('hidden');
        item.dataset.selected = '0';
        item.classList.remove('settings-chip--exam-selected');
      }
    });
  }

  streamChips.forEach(chip => {
    chip.addEventListener('click', () => {
      streamChips.forEach(c => {
        c.dataset.selected = '0';
        c.classList.remove('settings-chip--selected');
      });
      chip.dataset.selected = '1';
      chip.classList.add('settings-chip--selected');
      filterExamsByStream(chip.dataset.stream);
      updateSubjectGrid();
      updateWorkspacePreview();
    });
  });

  const activeStream = document.querySelector('#stream-grid .settings-chip[data-selected="1"]');
  if (activeStream) filterExamsByStream(activeStream.dataset.stream);

  // ── Exam chips (multi-select) ──
  examItems.forEach(chip => {
    chip.addEventListener('click', () => {
      const isSelected = chip.dataset.selected === '1';
      const selectedCount = document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').length;
      if (isSelected && selectedCount <= 1) return;
      chip.dataset.selected = isSelected ? '0' : '1';
      chip.classList.toggle('settings-chip--exam-selected');
      updateSubjectGrid();
      updateWorkspacePreview();
    });
  });

  // ── Subject grid ──
  const EXAMS = window.__EXAM_SUBJECTS || {};

  function updateSubjectGrid() {
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });

    const subjects = new Set();
    selectedExams.forEach(key => {
      if (EXAMS[key]) EXAMS[key].forEach(s => subjects.add(s));
    });

    const grid = document.getElementById('subjects-grid');
    grid.innerHTML = '';
    if (subjects.size === 0) {
      grid.innerHTML = '<p class="ds-caption">Select at least one exam to see subjects.</p>';
      return;
    }
    subjects.forEach(subject => {
      const div = document.createElement('div');
      div.className = 'settings-chip settings-chip--selected';
      div.dataset.subject = subject;
      div.textContent = subject;
      grid.appendChild(div);
    });
  }

  // ── Workspace preview live update ──
  function updateWorkspacePreview() {
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });

    // Update exam chips in preview
    const previewEl = document.querySelector('.workspace-grid');
    if (!previewEl) return;

    // Update exam count chip
    const examChipsContainer = previewEl.querySelector('.wp-block:first-child > div:last-child');
    if (examChipsContainer) {
      examChipsContainer.innerHTML = '';
      if (selectedExams.length > 0) {
        const LABELS = window.__EXAM_LABELS || {};
        selectedExams.forEach(key => {
          const chip = document.createElement('span');
          chip.className = 'wp-chip';
          chip.textContent = LABELS[key] || key;
          examChipsContainer.appendChild(chip);
        });
      } else {
        examChipsContainer.innerHTML = '<span class="ds-caption" style="margin:0;">No exams configured</span>';
      }
    }

    // Update subjects tracked
    const subjects = new Set();
    selectedExams.forEach(key => {
      if (EXAMS[key]) EXAMS[key].forEach(s => subjects.add(s));
    });
    const subjectBlock = previewEl.querySelectorAll('.wp-block')[1];
    if (subjectBlock) {
      const val = subjectBlock.querySelector('.wp-value');
      const desc = subjectBlock.querySelector('.ds-caption');
      if (val) val.textContent = `${subjects.size} subjects`;
      if (desc) {
        const arr = [...subjects];
        desc.textContent = arr.length > 0 ? arr.slice(0, 4).join(', ') + (arr.length > 4 ? ` +${arr.length - 4} more` : '') : 'No subjects';
      }
    }
  }

  // ── Live daily average ──
  function updateDailyAverage() {
    const hours = parseFloat(document.getElementById('target-hours').value) || 0;
    const days = parseInt(document.getElementById('study-days').value) || 1;
    const avg = Math.round((hours / days) * 10) / 10;
    document.getElementById('daily-avg-display').textContent = `≈ ${avg} hrs/day`;
  }
  document.getElementById('target-hours').addEventListener('input', updateDailyAverage);
  document.getElementById('study-days').addEventListener('input', updateDailyAverage);

  // ── Logout ──
  const logoutBtn = document.getElementById('account-logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    logoutBtn.disabled = true;
    logoutBtn.textContent = 'Logging out...';
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });

  // ── Form submit ──
  const form = document.getElementById('settings-form');
  const saveBtn = document.getElementById('save-btn');
  const successDiv = document.getElementById('settings-success');
  const errorDiv = document.getElementById('settings-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successDiv.hidden = true;
    errorDiv.hidden = true;

    const targetHours = parseFloat(document.getElementById('target-hours').value);
    const selectedExams = [];
    document.querySelectorAll('#exam-grid .settings-chip[data-selected="1"]').forEach(chip => {
      selectedExams.push(chip.dataset.exam);
    });
    const examDate = document.getElementById('exam-date').value || null;
    const stream = document.querySelector('#stream-grid .settings-chip[data-selected="1"]')?.dataset?.stream || '';
    const studyDays = parseInt(document.getElementById('study-days')?.value) || 5;

    if (selectedExams.length === 0) {
      errorDiv.textContent = 'Select at least one exam.';
      errorDiv.hidden = false;
      return;
    }

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      const res = await fetch('/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetHoursPerWeek: targetHours, selectedExams, examDate, stream, studyDaysPerWeek: studyDays }),
      });
      if (!res.ok) throw new Error('Failed to save');
      successDiv.hidden = false;
      saveBtn.textContent = 'Saved';
      // Reload workspace preview data
      setTimeout(() => {
        window.location.reload();
      }, 1000);
    } catch (err) {
      errorDiv.textContent = 'Failed to save settings.';
      errorDiv.hidden = false;
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });
</script>

<style>
  /* ── Settings chip grid ── */
  .settings-chip-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--ds-space-2);
    margin-top: var(--ds-space-1);
  }
  @media (min-width: 768px) {
    .settings-chip-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .settings-chip {
    padding: var(--ds-space-1) var(--ds-space-2);
    background: var(--ds-bg-surface);
    border: 1px solid var(--ds-border-default);
    border-radius: var(--ds-radius-md);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    font-size: var(--ds-text-sm);
    color: var(--ds-text-tertiary);
    user-select: none;
  }
  .settings-chip:hover {
    border-color: var(--ds-border-hover);
    color: var(--ds-text-primary);
  }
  .settings-chip--selected {
    background: var(--ds-accent-bg);
    border-color: var(--ds-accent-500);
    color: var(--ds-accent-300);
  }
  .settings-chip--exam-selected {
    background: rgba(236, 72, 153, 0.12);
    border-color: rgba(236, 72, 153, 0.5);
    color: #f9a8d4;
  }
  .settings-chip--item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .settings-chip-label {
    font-size: var(--ds-text-xs);
    font-weight: 500;
  }
  .settings-chip-sub {
    font-size: var(--ds-text-2xs);
    opacity: 0.6;
  }

  /* ── Workspace preview blocks ── */
  .workspace-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--ds-space-2);
  }
  @media (max-width: 480px) {
    .workspace-grid { grid-template-columns: 1fr; }
  }

  .wp-block {
    padding: var(--ds-space-2);
    background: var(--ds-bg-elevated);
    border: 1px solid var(--ds-border-subtle);
    border-radius: var(--ds-radius-md);
  }
  .wp-label {
    font-size: var(--ds-text-2xs);
    font-weight: var(--ds-weight-semibold);
    color: var(--ds-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .wp-value {
    display: block;
    font-size: var(--ds-text-lg);
    font-weight: var(--ds-weight-bold);
    color: var(--ds-text-primary);
    margin-top: 0.15rem;
  }
  .wp-chip {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background: var(--ds-accent-bg);
    border: 1px solid var(--ds-accent-500);
    border-radius: 999px;
    font-size: var(--ds-text-2xs);
    color: var(--ds-accent-300);
  }

  /* ── Profile chips ── */
  .profile-summary {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ds-space-2);
  }
  .ps-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    background: var(--ds-bg-surface);
    border: 1px solid var(--ds-border-default);
    border-radius: 999px;
    font-size: var(--ds-text-xs);
    color: var(--ds-text-primary);
  }
  .ps-chip-icon {
    font-size: 0.85rem;
  }
  .ps-chip-goal {
    background: rgba(251, 191, 36, 0.1);
    border-color: rgba(251, 191, 36, 0.3);
    color: #fbbf24;
  }
  .ps-weak-chip {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: rgba(239, 68, 68, 0.1);
