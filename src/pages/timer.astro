---
import BaseLayout from '../layouts/BaseLayout.astro';
import StudyTimer from '../components/StudyTimer.astro';
import TourTooltip from '../components/TourTooltip.astro';
import { getDb } from '../db';
import { scopeDbToUser } from '../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();
const settings = db.getSettings();
const subjects = settings.subjects || ['Physics', 'Chemistry', 'Mathematics', 'Biology'];
---

<BaseLayout title="Study Timer">
  <div class="max-w-lg mx-auto">
    <div class="mb-6">
      <h1 class="page-title">Study Timer</h1>
      <p class="page-sub">Track your study sessions with precision. When you're done, save directly as a log entry.</p>
    </div>

    <StudyTimer subjects={subjects} />
  </div>

  <TourTooltip
    tourId="timer-intro"
    title="⏱️ Study Timer"
    description="Select a subject and optional topic, then press Start. Pause and resume as needed. When you stop, you can save the session as a study log entry."
    position="bottom"
  />
</BaseLayout>

<style>
  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .page-sub {
    font-size: 0.875rem;
    color: #64748b;
  }
</style>
