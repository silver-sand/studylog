---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryForm from '../components/EntryForm.astro';
import EntryList from '../components/EntryList.astro';
import DailyReviewCard from '../components/DailyReviewCard.astro';
import { createAIServiceFromEnv } from '../ai';
import { getDb } from '../db';
import { formatDate } from '../utils/date';
import { getDailyReviewByDate } from '../services/daily-review-service';
import { scopeDbToUser } from '../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();
const today = formatDate(new Date());
const todayEntry = db.getEntryByDate(today);
const recentEntries = db.listEntries({ limit: 50 });
const settings = db.getSettings();
const ai = createAIServiceFromEnv();
const aiProvider = ai.constructor.name;

// Try to load today's daily review
const todayReview = getDailyReviewByDate(today);
const hasEntriesToday = recentEntries.some(e => e.date === today);
---

<BaseLayout title="Daily Log">
  <div class="ds-page">
    <!-- Header -->
    <div class="ds-page-header ds-page-header--compact">
      <h1 class="ds-heading-page" style="margin-bottom:0.25rem;">Daily Study Log</h1>
      <p class="ds-body-sm" style="margin:0;">
        {todayEntry ? 'Update today\'s entry' : 'What did you study today?'}
      </p>
      <p class="ds-caption" style="margin-top:var(--ds-space-1);">
        AI: {aiProvider === 'MockAIService' ? 'Offline mode' : 'Gemini'}
      </p>
    </div>

    <!-- Entry Form -->
    <div style="margin-bottom:var(--ds-space-8);">
      <EntryForm todayEntry={todayEntry ? {
        id: todayEntry.id,
        date: todayEntry.date,
        content: todayEntry.content,
        hoursStudied: todayEntry.hoursStudied,
        studyType: todayEntry.studyType,
        focusRating: todayEntry.focusRating,
        examType: todayEntry.examType,
      } : null} defaultExamType={settings.selectedExams?.[0] || 'JEE'} />
    </div>

    <!-- Daily Review -->
    {hasEntriesToday && (
      <div style="margin-bottom:var(--ds-space-8);" id="daily-review-section">
        <div style="display:flex;flex-direction:column;">
          {todayReview ? (
            <DailyReviewCard review={todayReview} />
          ) : (
            <div class="ds-card" style="text-align:center;padding:var(--ds-space-6);">
              <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);margin-bottom:var(--ds-space-4);line-height:1.5;">
                You have entries for today. Generate an AI-powered daily review to summarize your progress.
              </p>
              <button id="generate-daily-btn" class="ds-btn ds-btn-primary">
                Generate Daily Review
              </button>
            </div>
          )}
          {todayReview && (
            <button id="refresh-daily-btn" class="ds-btn ds-btn-ghost ds-btn-sm" style="margin-top:var(--ds-space-3);">
              Refresh Review
            </button>
          )}
        </div>
      </div>
    )}

    <!-- Recent Entries -->
    <div>
      <h2 class="ds-heading-section">Recent Entries</h2>
      <EntryList entries={recentEntries} />
    </div>
  </div>
</BaseLayout>

<script>
  const generateBtn = document.getElementById('generate-daily-btn');
  const refreshBtn = document.getElementById('refresh-daily-btn');
  const section = document.getElementById('daily-review-section');

  async function loadDailyReview() {
    if (!section) return;
    section.innerHTML = '<p class="text-sm text-slate-500">Generating daily review...</p>';

    try {
      const res = await fetch('/api/daily', { method: 'POST' });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed' }));
        throw new Error(err.error || 'Failed to generate');
      }
      const review = await res.json();

      // Re-render the section with the new review
      window.location.reload();
    } catch (err) {
      section.innerHTML = `
        <div class="p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-sm text-red-400">
          Failed to generate daily review: ${err.message}
        </div>
        <button onclick="loadDailyReview()" class="btn-secondary mt-2">
          Try Again
        </button>
      `;
    }
  }

  generateBtn?.addEventListener('click', loadDailyReview);
  refreshBtn?.addEventListener('click', loadDailyReview);

  // ── Pick up timer data from sessionStorage ──
  (function() {
    try {
      const raw = sessionStorage.getItem('studyTimerData');
      if (!raw) return;
      const data = JSON.parse(raw);
      sessionStorage.removeItem('studyTimerData');

      if (data.hours) {
        const hoursField = document.getElementById('hours') as HTMLInputElement;
        if (hoursField) hoursField.value = data.hours;
      }
      if (data.subject) {
        const ta = document.getElementById('entry-content') as HTMLTextAreaElement;
        if (ta && !ta.value) {
          const topic = data.topic ? ` - ${data.topic}` : '';
          ta.value = `Studied ${data.subject}${topic}`;
          const evt = new Event('input');
          ta.dispatchEvent(evt);
        }
      }
    } catch (e) {
      // Ignore parse errors
    }
  })();

  // Auto-dismiss entry form success — refresh daily review when entries change
  const form = document.querySelector('form');
  form?.addEventListener('submit', async (e) => {
    setTimeout(async () => {
      if (generateBtn && section) {
        try {
          const res = await fetch('/api/daily?date=' + new Date().toISOString().split('T')[0]);
          if (res.ok) {
            const review = await res.json();
            if (review && review.id) {
              window.location.reload();
            }
          }
        } catch {}
      }
    }, 2000);
  });
</script>

<style>
  /* Minimal overrides — most styling uses design system classes */
  .hidden { display: none; }
</style>
