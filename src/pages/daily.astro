---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryForm from '../components/EntryForm.astro';
import EntryList from '../components/EntryList.astro';
import DailyReviewCard from '../components/DailyReviewCard.astro';
import { createAIServiceFromEnv } from '../ai';
import { getDb } from '../db';
import { formatDate } from '../utils/date';
import { getDailyReviewByDate } from '../services/daily-review-service';
import { scopeDbToUser } from '../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();
const today = formatDate(new Date());
const todayEntry = db.getEntryByDate(today);
const recentEntries = db.listEntries({ limit: 50 });
const settings = db.getSettings();
const ai = createAIServiceFromEnv();
const aiProvider = ai.constructor.name;

// Try to load today's daily review
const todayReview = getDailyReviewByDate(today);
const hasEntriesToday = recentEntries.some(e => e.date === today);

// Stats for right column
const todayHours = todayEntry?.hoursStudied || 0;
const targetHours = 8;
const todayFocus = todayEntry?.focusRating || 0;
const streak = db.getStreak();

// Today's summary
function getFocusLabel(rating: number): string {
  if (rating >= 4) return 'High';
  if (rating >= 3) return 'Medium';
  if (rating > 0) return 'Low';
  return '—';
}

const todayDate = new Date();
const dateDisplay = todayDate.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title="Daily Log">
  <!-- Main Content Area — Stitch Daily Log Layout -->
  <main class="p-6 md:p-10 min-h-screen pb-24 md:pb-10 bg-[#050b18]">

    <!-- Header -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
      <div>
        <h2 class="text-3xl md:text-4xl font-headline font-bold text-[#dce2f5] tracking-tight">Daily Log</h2>
        <p class="text-[#8b919d] mt-1 flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">event</span>
          {dateDisplay}
        </p>
      </div>
      <div class="hidden md:flex items-center gap-4">
        <div id="live-session-badge" class="bg-[#0d1321]/50 border border-slate-800 rounded-lg px-4 py-2 flex items-center gap-3 hidden">
          <span class="w-2 h-2 rounded-full bg-[#60a5fa] animate-pulse"></span>
          <span class="text-xs font-label text-[#8b919d]">Live Study Session Active</span>
        </div>
      </div>
    </header>

    <!-- Two-column grid: Form (2/3) + Summary (1/3) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Left: Entry Form + History (2/3) -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Entry Form Card -->
        <section class="bg-[#0d1321] rounded-2xl p-6 md:p-8 shadow-xl shadow-black/20 border border-slate-800/50">
          <div class="flex items-center gap-3 mb-6">
            <span class="material-symbols-outlined text-[#60a5fa]">edit_note</span>
            <h3 class="text-xl font-bold text-[#dce2f5]">New Entry</h3>
          </div>
          <EntryForm
            todayEntry={todayEntry ? {
              id: todayEntry.id,
              date: todayEntry.date,
              content: todayEntry.content,
              hoursStudied: todayEntry.hoursStudied,
              studyType: todayEntry.studyType,
              focusRating: todayEntry.focusRating,
              examType: todayEntry.examType,
            } : null}
            defaultExamType={settings.selectedExams?.[0] || 'JEE'}
          />
        </section>

        <!-- Daily Review -->
        {hasEntriesToday && (
          <section id="daily-review-section">
            {todayReview ? (
              <DailyReviewCard review={todayReview} />
            ) : (
              <div class="bg-[#0d1321] rounded-2xl p-6 md:p-8 shadow-xl shadow-black/20 border border-slate-800/50 text-center">
                <p class="text-sm text-[#8b919d] mb-6 leading-relaxed">
                  You have entries for today. Generate an AI-powered daily review to summarize your progress.
                </p>
                <button id="generate-daily-btn" class="bg-[#60a5fa] hover:bg-[#60a5fa]/90 text-[#050b18] font-bold py-3 px-8 rounded-xl transition-all active:scale-[0.98]">
                  Generate Daily Review
                </button>
              </div>
            )}
            {todayReview && (
              <button id="refresh-daily-btn" class="text-[#60a5fa] text-sm hover:underline mt-3">
                Refresh Review
              </button>
            )}
          </section>
        )}

        <!-- History Section — Past Week table -->
        <section>
          <div class="flex items-center justify-between mb-6 px-2">
            <h3 class="text-xl font-bold text-[#dce2f5] flex items-center gap-3">
              <span class="material-symbols-outlined text-[#8b919d]">history</span>
              Past Week
            </h3>
          </div>
          {recentEntries.length > 0 ? (
            <div class="overflow-hidden rounded-2xl border border-slate-800 bg-[#0d1321]/30">
              <EntryList entries={recentEntries} />
            </div>
          ) : (
            <div class="bg-[#0d1321]/30 rounded-2xl p-12 border border-slate-800 text-center">
              <span class="material-symbols-outlined text-4xl text-[#8b919d]/40 mb-3">history</span>
              <p class="text-[#8b919d]">No entries yet. Start logging above!</p>
            </div>
          )}
        </section>
      </div>

      <!-- Right: Summary Column (1/3) -->
      <div class="space-y-6">

        <!-- Today's Summary Card -->
        <div class="bg-[#0d1321] rounded-2xl p-6 shadow-lg border border-slate-800 group hover:border-[#60a5fa]/30 transition-all">
          <h3 class="text-sm font-label text-[#8b919d] mb-6 flex items-center justify-between">
            Today's Summary
            <span class="material-symbols-outlined text-xs">info</span>
          </h3>
          <div class="space-y-6">
            <div class="flex items-center justify-between">
              <span class="text-[#8b919d]">Total Hours</span>
              <div class="text-right">
                <span class="text-2xl font-bold text-[#dce2f5]">{todayHours.toFixed(1)}</span>
                <span class="text-sm text-[#8b919d]">/ {targetHours}.0</span>
              </div>
            </div>
            <div class="w-full bg-[#050b18] h-2 rounded-full overflow-hidden">
              <div
                class="bg-[#60a5fa] h-full rounded-full transition-all duration-1000"
                style={`width:${Math.min((todayHours / targetHours) * 100, 100)}%; box-shadow: 0 0 12px rgba(96, 165, 250, 0.4);`}
              ></div>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[#8b919d]">Focus Quality</span>
              <div class="flex items-center gap-2">
                <span class="text-lg font-bold text-[#60a5fa]">{getFocusLabel(todayFocus)}</span>
                {todayFocus > 0 && (
                  <span class="material-symbols-outlined text-[#60a5fa] filled-icon">bolt</span>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Study Streak Card -->
        <div class="bg-gradient-to-br from-[#60a5fa]/10 to-[#0d1321] rounded-2xl p-6 border border-[#60a5fa]/20 relative overflow-hidden group">
          <div class="absolute -right-4 -bottom-4 opacity-10 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-outlined text-9xl filled-icon" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
          </div>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-2">
              <span class="material-symbols-outlined text-[#60a5fa] filled-icon">local_fire_department</span>
              <h3 class="text-sm font-label text-[#8b919d] uppercase tracking-widest">Study Streak</h3>
            </div>
            <p class="text-4xl font-headline font-black text-[#dce2f5]">{streak} Days</p>
            <p class="text-xs text-[#60a5fa] mt-2 font-medium">Keep it going! You're building great momentum.</p>
          </div>
        </div>

        <!-- Motivation Card -->
        <div class="bg-[#0d1321] rounded-2xl overflow-hidden shadow-lg border border-slate-800">
          <div class="h-32 bg-slate-800 relative">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1321] to-transparent"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-20">
              <span class="material-symbols-outlined text-6xl filled-icon" style="font-variation-settings: 'FILL' 1;">auto_stories</span>
            </div>
          </div>
          <div class="p-6">
            <h4 class="font-bold text-[#dce2f5] mb-2">Did you know?</h4>
            <p class="text-sm text-[#8b919d] leading-relaxed italic">
              "Taking a 10-minute break every hour increases long-term retention by up to 20%."
            </p>
            <a href="https://en.wikipedia.org/wiki/Active_recall" target="_blank" class="mt-4 flex items-center gap-2 text-[#60a5fa] text-xs font-bold group no-underline">
              Learn more about active recall
              <span class="material-symbols-outlined text-xs group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  const generateBtn = document.getElementById('generate-daily-btn');
  const refreshBtn = document.getElementById('refresh-daily-btn');
  const section = document.getElementById('daily-review-section');

  async function loadDailyReview() {
    if (!section) return;
    section.innerHTML = '<p class="text-sm text-[#8b919d]">Generating daily review...</p>';

    try {
      const res = await fetch('/api/daily', { method: 'POST' });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed' }));
        throw new Error(err.error || 'Failed to generate');
      }
      window.location.reload();
    } catch (err) {
      section.innerHTML = `
        <div class="bg-red-500/10 border border-red-500/20 text-sm text-red-400 p-4 rounded-lg">
          Failed to generate daily review: ${err.message}
        </div>
        <button onclick="loadDailyReview()" class="text-[#60a5fa] text-sm mt-2 hover:underline">Try Again</button>
      `;
    }
  }

  generateBtn?.addEventListener('click', loadDailyReview);
  refreshBtn?.addEventListener('click', loadDailyReview);

  // ── Show live session badge if timer is active ──
  (function() {
    try {
      const state = JSON.parse(localStorage.getItem('sl-timer-state') || '{}');
      if (state.isActive) {
        const badge = document.getElementById('live-session-badge');
        if (badge) badge.classList.remove('hidden');
      }
    } catch (e) {}
  })();

  // Pick up timer data from sessionStorage
  (function() {
    try {
      const raw = sessionStorage.getItem('studyTimerData');
      if (!raw) return;
      const data = JSON.parse(raw);
      sessionStorage.removeItem('studyTimerData');

      if (data.hours) {
        const hoursField = document.getElementById('hours') as HTMLInputElement;
        if (hoursField) hoursField.value = data.hours;
      }
      if (data.subject) {
        const ta = document.getElementById('entry-content') as HTMLTextAreaElement;
        if (ta && !ta.value) {
          const topic = data.topic ? ` - ${data.topic}` : '';
          ta.value = `Studied ${data.subject}${topic}`;
          const evt = new Event('input');
          ta.dispatchEvent(evt);
        }
      }
    } catch (e) {}
  })();
</script>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    vertical-align: middle;
  }
  .filled-icon {
    font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
</style>
