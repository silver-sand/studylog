---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryForm from '../components/EntryForm.astro';
import EntryList from '../components/EntryList.astro';
import DailyReviewCard from '../components/DailyReviewCard.astro';
import { createAIServiceFromEnv } from '../ai';
import { getDb } from '../db';
import { formatDate } from '../utils/date';
import { getDailyReviewByDate } from '../services/daily-review-service';
import { scopeDbToUser } from '../services/user-scope';
import { EXAM_DEFINITIONS } from '../utils/exam-map';

scopeDbToUser(Astro.request);
const db = getDb();
const today = formatDate(new Date());
const todayEntry = db.getEntryByDate(today);
const recentEntries = db.listEntries({ limit: 50 });
const settings = db.getSettings();
const ai = createAIServiceFromEnv();
const aiProvider = ai.constructor.name;

// Try to load today's daily review
const todayReview = getDailyReviewByDate(today);
const hasEntriesToday = recentEntries.some(e => e.date === today);

// Stats for right column
const todayHours = todayEntry?.hoursStudied || 0;
const targetHours = 8;
const todayFocus = todayEntry?.focusRating || 0;
const streak = db.getStreak();

// Today's summary
function getFocusLabel(rating: number): string {
  if (rating >= 4) return 'High';
  if (rating >= 3) return 'Medium';
  if (rating > 0) return 'Low';
  return '—';
}

const todayDate = new Date();
const dateDisplay = todayDate.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title="Daily Log">
  <!-- Main Content Area -->
  <main class="p-6 md:p-10 min-h-screen pb-24 md:pb-10 bg-[#050b18]">

    <!-- Header -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10 animate-stagger" style="--stagger-index:0">
      <div>
        <h2 class="text-3xl md:text-4xl font-headline font-bold text-white tracking-tight">Daily Log</h2>
        <p class="text-neutral-500 mt-1 flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">event</span>
          {dateDisplay}
        </p>
      </div>
      <div class="hidden md:flex items-center gap-4">
        <div id="live-session-badge" class="bg-[#0d1321]/50 border border-white/5 rounded-lg px-4 py-2 flex items-center gap-3 hidden">
          <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
          <span class="text-xs font-label text-neutral-500">Live Study Session Active</span>
        </div>
      </div>
    </header>

    <!-- Two-column grid: Form (2/3) + Summary (1/3) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Left: Entry Form + History (2/3) -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Entry Form Card -->
        <section class="ds-card-gradient rounded-2xl p-6 md:p-8 card-lift reveal-on-scroll" style="--stagger-index:1">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-9 h-9 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center">
              <span class="material-symbols-outlined text-lg text-indigo-400">edit_note</span>
            </div>
            <h3 class="text-xl font-bold text-white">New Entry</h3>
          </div>
          <EntryForm
            todayEntry={todayEntry ? {
              id: todayEntry.id,
              date: todayEntry.date,
              content: todayEntry.content,
              hoursStudied: todayEntry.hoursStudied,
              studyType: todayEntry.studyType,
              focusRating: todayEntry.focusRating,
              examType: todayEntry.examType,
            } : null}
            defaultExamType={settings.selectedExams?.[0] || ''}
            subjects={settings.subjects || []}
            exams={settings.selectedExams?.length ? settings.selectedExams.map(e => EXAM_DEFINITIONS.find(ed => ed.key === e)?.label || e) : []}
          />
        </section>

        <!-- Daily Review -->
        {hasEntriesToday && (
          <section id="daily-review-section" class="card-lift reveal-on-scroll" style="--stagger-index:2">
            {todayReview ? (
              <DailyReviewCard review={todayReview} />
            ) : (
              <div class="obsidian-glass rounded-2xl p-8 md:p-10 text-center">
                <div class="w-14 h-14 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mx-auto mb-5">
                  <span class="material-symbols-outlined text-2xl text-indigo-400">auto_awesome</span>
                </div>
                <p class="text-sm text-neutral-400 mb-6 leading-relaxed max-w-md mx-auto">
                  You have entries for today. Generate an AI-powered daily review to summarize your progress and get insights.
                </p>
                <button id="generate-daily-btn" class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-8 rounded-xl transition-all active:scale-[0.98] shadow-lg inline-flex items-center gap-2 glow-button">
                  <span class="material-symbols-outlined text-[18px]">auto_awesome</span>
                  Generate Review
                </button>
              </div>
            )}
            {todayReview && (
              <div class="flex justify-center mt-4">
                <button id="refresh-daily-btn" class="text-indigo-400 text-xs hover:text-indigo-300 transition-colors flex items-center gap-1.5 px-3 py-1.5 rounded-lg hover:bg-indigo-500/10">
                  <span class="material-symbols-outlined text-[14px]">refresh</span>
                  Refresh Review
                </button>
              </div>
            )}
          </section>
        )}

        <!-- History Section — Past Week table -->
        <section class="card-lift reveal-on-scroll" style="--stagger-index:3">
          <div class="flex items-center justify-between mb-5 px-1">
            <h3 class="text-lg font-bold text-white flex items-center gap-2.5">
              <span class="material-symbols-outlined text-neutral-500">history</span>
              Past Week
            </h3>
          </div>
          {recentEntries.length > 0 ? (
            <div class="overflow-hidden rounded-2xl border border-white/5 bg-[#0d1321]/30">
              <EntryList entries={recentEntries} />
            </div>
          ) : (
            <div class="obsidian-glass rounded-2xl p-12 text-center">
              <span class="material-symbols-outlined text-4xl text-neutral-600 mb-3 block">history</span>
              <p class="text-neutral-500 text-sm">No entries yet. Start logging above!</p>
            </div>
          )}
        </section>
      </div>

      <!-- Right: Summary Column (1/3) -->
      <div class="space-y-6">

        <!-- Today's Summary Card -->
        <div class="ds-card-gradient rounded-2xl p-6 card-lift reveal-on-scroll" style="--stagger-index:1">
          <h3 class="text-[11px] font-label text-neutral-500 uppercase tracking-widest mb-5 flex items-center justify-between">
            Today's Summary
            <span class="material-symbols-outlined text-[14px] text-neutral-600">info</span>
          </h3>
          <div class="space-y-5">
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-neutral-400">Hours Studied</span>
                <div class="text-right">
                  <span class="text-2xl font-bold text-white font-mono tabular-nums">{todayHours.toFixed(1)}</span>
                  <span class="text-sm text-neutral-600">/{targetHours}.0</span>
                </div>
              </div>
              <div class="w-full bg-[#050b18] h-2 rounded-full overflow-hidden">
                <div
                  class="bg-indigo-500 h-full rounded-full transition-all duration-1000 ease-out"
                  style={`width:${Math.min((todayHours / targetHours) * 100, 100)}%; box-shadow: 0 0 12px rgba(99, 102, 241, 0.4);`}
                ></div>
              </div>
            </div>
            <div class="flex items-center justify-between pt-1">
              <span class="text-sm text-neutral-400">Focus Quality</span>
              <div class="flex items-center gap-2">
                <span class="text-lg font-bold text-indigo-400 font-mono">{getFocusLabel(todayFocus)}</span>
                {todayFocus > 0 && (
                  <span class="material-symbols-outlined text-indigo-400 filled-icon">bolt</span>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Study Streak Card -->
        <div class="relative overflow-hidden rounded-2xl p-6 card-lift reveal-on-scroll" style="--stagger-index:2; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(99, 102, 241, 0.03)); border: 1px solid rgba(99, 102, 241, 0.15);">
          <div class="absolute -right-6 -bottom-6 opacity-[0.06] transition-transform duration-700">
            <span class="material-symbols-outlined text-9xl filled-icon" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
          </div>
          <div class="relative z-10">
            <div class="flex items-center gap-2.5 mb-3">
              <span class="material-symbols-outlined text-amber-400 filled-icon pulse-glow" style="font-variation-settings: 'FILL' 1; filter: drop-shadow(0 0 6px rgba(251, 191, 36, 0.4));">local_fire_department</span>
              <h3 class="text-[11px] font-label text-neutral-500 uppercase tracking-widest">Study Streak</h3>
            </div>
            <p class="text-4xl font-headline font-black text-white">{streak} Days</p>
            <p class="text-xs text-amber-400/70 mt-2 font-medium">Keep it going! You're building great momentum.</p>
          </div>
        </div>

        <!-- Motivation Card -->
        <div class="obsidian-glass rounded-2xl overflow-hidden card-lift reveal-on-scroll" style="--stagger-index:3">
          <div class="h-28 bg-gradient-to-br from-indigo-500/10 to-purple-500/5 relative">
            <div class="absolute inset-0 flex items-center justify-center opacity-10">
              <span class="material-symbols-outlined text-5xl filled-icon text-indigo-400" style="font-variation-settings: 'FILL' 1;">auto_stories</span>
            </div>
          </div>
          <div class="p-5">
            <h4 class="font-bold text-white text-sm mb-1.5">💡 Did you know?</h4>
            <p class="text-sm text-neutral-400 leading-relaxed italic">
              Taking a 10-minute break every hour increases long-term retention by up to 20%.
            </p>
            <a href="https://en.wikipedia.org/wiki/Active_recall" target="_blank" class="mt-3 inline-flex items-center gap-1.5 text-indigo-400 text-[11px] font-medium hover:text-indigo-300 transition-colors group no-underline">
              Learn about active recall
              <span class="material-symbols-outlined text-[14px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  const generateBtn = document.getElementById('generate-daily-btn');
  const refreshBtn = document.getElementById('refresh-daily-btn');
  const section = document.getElementById('daily-review-section');

  async function loadDailyReview() {
    if (!section) return;
    section.innerHTML = '<div class="obsidian-glass rounded-2xl p-8 text-center"><p class="text-sm text-neutral-400">Generating daily review...</p></div>';

    try {
      const res = await fetch('/api/daily', { method: 'POST' });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed' }));
        throw new Error(err.error || 'Failed to generate');
      }
      window.location.reload();
    } catch (err) {
      section.innerHTML = `
        <div class="bg-red-500/10 border border-red-500/20 text-sm text-red-400 p-4 rounded-lg">
          Failed to generate daily review: ${err.message}
        </div>
        <div class="flex justify-center mt-3">
          <button onclick="location.reload()" class="text-indigo-400 text-sm flex items-center gap-1 hover:text-indigo-300 transition-colors">
            <span class="material-symbols-outlined text-[14px]">refresh</span> Try Again
          </button>
        </div>
      `;
    }
  }

  generateBtn?.addEventListener('click', loadDailyReview);
  refreshBtn?.addEventListener('click', loadDailyReview);

  // ── Show live session badge if timer is active ──
  (function() {
    try {
      const state = JSON.parse(localStorage.getItem('sl-timer-state') || '{}');
      if (state.isActive) {
        const badge = document.getElementById('live-session-badge');
        if (badge) badge.classList.remove('hidden');
      }
    } catch (e) {}
  })();

  // Pick up timer data from sessionStorage
  (function() {
    try {
      const raw = sessionStorage.getItem('studyTimerData');
      if (!raw) return;
      const data = JSON.parse(raw);
      sessionStorage.removeItem('studyTimerData');

      if (data.hours) {
        const hoursField = document.getElementById('hours') as HTMLInputElement;
        if (hoursField) hoursField.value = data.hours;
      }
      if (data.subject) {
        const ta = document.getElementById('entry-content') as HTMLTextAreaElement;
        if (ta && !ta.value) {
          const topic = data.topic ? ` - ${data.topic}` : '';
          ta.value = `Studied ${data.subject}${topic}`;
          const evt = new Event('input');
          ta.dispatchEvent(evt);
        }
      }
    } catch (e) {}
  })();
</script>

<style>
  .glow-button {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
    transition: all 0.3s ease;
  }
  .glow-button:hover {
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.5);
    transform: translateY(-2px);
  }
</style>
