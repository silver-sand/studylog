---
import BaseLayout from '../layouts/BaseLayout.astro';
import SyllabusCard from '../components/SyllabusCard.astro';
import ChapterList from '../components/ChapterList.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS } from '../utils/exam-map';
import { scopeDbToUser } from '../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();

interface ExamData {
  key: string;
  label: string;
  progress: import('../types/review').SyllabusProgress[];
  chapters: import('../types/review').SyllabusChapter[];
  totalChapters: number;
  completedChapters: number;
  overallPercent: number;
}

// Build exam data from user's selected exams
const settings = db.getSettings();
const selectedExamKeys: string[] = settings.selectedExams?.length ? settings.selectedExams : ['JEE'];

// Map selected exam keys to definitions, group by syllabusKey
const userExamDefs = selectedExamKeys
  .map(key => EXAM_DEFINITIONS.find(e => e.key === key))
  .filter((e): e is (typeof EXAM_DEFINITIONS)[number] => !!e);

// Group exams sharing a syllabusKey, merging their subjects
const syllabusGroups = new Map<string, { primaryLabel: string; examKeys: string[]; subjects: Set<string> }>();
for (const exam of userExamDefs) {
  if (!syllabusGroups.has(exam.syllabusKey)) {
    syllabusGroups.set(exam.syllabusKey, {
      primaryLabel: exam.label,
      examKeys: [exam.key],
      subjects: new Set(exam.subjects),
    });
  } else {
    const g = syllabusGroups.get(exam.syllabusKey)!;
    g.examKeys.push(exam.key);
    exam.subjects.forEach(s => g.subjects.add(s));
  }
}

// Build ExamData per syllabus group — filtered to only the user's subjects
const exams: ExamData[] = [...syllabusGroups.entries()].map(([syllabusKey, group]) => {
  const subjects = [...group.subjects];
  db.seedSyllabusData(syllabusKey, subjects);
  const progress = db.getSyllabusProgress(syllabusKey, subjects);
  const chapters = db.getSyllabus(syllabusKey).filter(ch => subjects.includes(ch.subject));
  const totalChapters = progress.reduce((s, p) => s + p.total, 0);
  const weightedSum = progress.reduce((s, p) => s + p.weightedPercent * p.total, 0);
  const overallPercent = totalChapters > 0 ? Math.round(weightedSum / totalChapters) : 0;
  const completedChapters = progress.reduce((s, p) => s + p.completed, 0);
  return {
    key: syllabusKey,
    label: group.primaryLabel,
    progress,
    chapters,
    totalChapters,
    completedChapters,
    overallPercent,
  };
});

const defaultExam = exams[0];
const defaultKey = defaultExam?.key;
const filteredExams = exams;

// Subject icon mapping
const subjectIcon: Record<string, string> = {
  physics: 'bolt',
  chemistry: 'science',
  mathematics: 'functions',
  maths: 'functions',
  biology: 'biotech',
  english: 'book',
};
---

<BaseLayout title="Syllabus">
  <main class="min-h-screen pb-24 md:pb-8 bg-[#050b18]">
    <!-- Top bar -->
    <header class="w-full h-16 flex justify-between items-center px-6 bg-[#0d1321] sticky top-0 z-40">
      <div class="flex items-center gap-4">
        <span class="md:hidden material-symbols-outlined text-[#60a5fa]">menu</span>
        <h2 class="font-headline text-xl font-black text-[#60a5fa] tracking-tight">Syllabus</h2>
      </div>
      <div class="flex items-center gap-4">
        <div class="hidden sm:flex items-center bg-[#050b18] px-3 py-1.5 rounded-full border border-slate-800">
          <span class="material-symbols-outlined text-slate-500 text-sm">search</span>
          <input class="bg-transparent border-none focus:ring-0 text-sm text-slate-300 w-48 placeholder-slate-500" placeholder="Search chapters..." type="text" />
        </div>
        <div class="flex items-center gap-2">
          <button class="hover:bg-slate-800 rounded-full p-2 transition-all active:opacity-80">
            <span class="material-symbols-outlined text-slate-400">notifications</span>
          </button>
          <button class="hover:bg-slate-800 rounded-full p-2 transition-all active:opacity-80">
            <span class="material-symbols-outlined text-slate-400">account_circle</span>
          </button>
        </div>
      </div>
    </header>

    <div class="p-4 md:p-8 max-w-7xl mx-auto space-y-8">
      {filteredExams.length === 0 ? (
        <div class="bg-[#0d1321] border border-slate-800 rounded-2xl p-12 text-center">
          <span class="material-symbols-outlined text-5xl text-slate-600 mb-4">assignment</span>
          <p class="text-lg font-semibold text-white">No exams configured</p>
          <p class="text-sm text-slate-400 mt-2">Select your exams in Settings to start tracking syllabus progress.</p>
          <a href="/settings" class="inline-block mt-6 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-lg transition-all active:scale-95">
            Go to Settings
          </a>
        </div>
      ) : (
        filteredExams.map((exam) => {
          const circumference = 440;
          const offset = circumference - (exam.overallPercent / 100) * circumference;
          return (
          <div class="space-y-8" key={exam.key}>
            <!-- Overall Summary Card -->
            <section class="relative overflow-hidden bg-[#0d1321] rounded-2xl p-6 md:p-8 border border-slate-800 shadow-2xl">
              <div class="relative z-10 grid md:grid-cols-2 gap-8 items-center">
                <div>
                  <span class="text-indigo-400 font-bold text-xs uppercase tracking-[0.2em] mb-2 block">Preparation Status</span>
                  <h2 class="text-3xl md:text-4xl font-black text-white mb-4">You've covered {exam.overallPercent}% of your syllabus.</h2>
                  <p class="text-slate-400 mb-6 max-w-md">Keep up the momentum! You've completed {exam.completedChapters} of {exam.totalChapters} chapters.</p>
                  <div class="flex gap-4">
                    <button class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-lg transition-all active:scale-95 flex items-center gap-2">
                      <span class="material-symbols-outlined text-sm">rocket_launch</span>
                      Resume Studying
                    </button>
                    <button class="bg-slate-800 hover:bg-slate-700 text-slate-200 font-bold py-2.5 px-6 rounded-lg transition-all">
                      View Analytics
                    </button>
                  </div>
                </div>
                <div class="flex justify-center md:justify-end">
                  <div class="relative w-40 h-40 flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90">
                      <circle class="text-slate-800" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-width="12"></circle>
                      <circle class="text-indigo-500 progress-ring-circle" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-dasharray={circumference} stroke-dashoffset={offset} stroke-linecap="round" stroke-width="12"></circle>
                    </svg>
                    <div class="absolute flex flex-col items-center">
                      <span class="text-4xl font-black text-white">{exam.overallPercent}%</span>
                      <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Complete</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-indigo-600/10 blur-[100px] rounded-full"></div>
            </section>

            <!-- Subjects Grid -->
            <div class="space-y-6">
              {exam.progress.map((p) => {
                const subjectChapters = exam.chapters.filter(ch => ch.subject === p.subject);
                const sName = p.subject.toLowerCase();
                const icon = subjectIcon[sName] || 'school';
                const subjColor = sName.includes('physics') ? '#3b82f6' :
                  sName.includes('chemistry') ? '#22c55e' :
                  sName.includes('math') ? '#f59e0b' :
                  sName.includes('biology') ? '#ec4899' : '#6366f1';
                return (
                  <div class="bg-[#0d1321] border border-slate-800 rounded-2xl overflow-hidden shadow-lg transition-all hover:border-indigo-500/30 subject-section">
                    <button class="w-full flex flex-col md:flex-row md:items-center justify-between p-6 gap-4 text-left subject-toggle">
                      <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-indigo-500/10 rounded-xl flex items-center justify-center" style={`background: ${subjColor}15;`}>
                          <span class="material-symbols-outlined" style={`color: ${subjColor}; font-variation-settings: 'FILL' 1;`}>{icon}</span>
                        </div>
                        <div>
                          <h3 class="text-xl font-bold text-white">{p.subject}</h3>
                          <p class="text-sm text-slate-500">{p.completed} of {p.total} Chapters Completed</p>
                        </div>
                      </div>
                      <div class="flex-1 max-w-md w-full">
                        <div class="flex justify-between text-xs font-bold mb-2">
                          <span class="text-indigo-400">PROGRESS</span>
                          <span class="text-slate-400">{p.weightedPercent}%</span>
                        </div>
                        <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
                          <div class="h-full rounded-full progress-fill-anim" style={`width: ${p.weightedPercent}%; background: ${subjColor};`}></div>
                        </div>
                      </div>
                      <span class="material-symbols-outlined text-indigo-500 transition-transform duration-300 subject-chevron">expand_more</span>
                    </button>
                    <div class="subject-content px-6 pb-8">
                      <div class="border-t border-slate-800/50 pt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                        {subjectChapters.length === 0 ? (
                          <div class="col-span-full py-8 flex flex-col items-center justify-center text-slate-500">
                            <span class="material-symbols-outlined text-3xl mb-2">info</span>
                            <p class="text-sm">No chapters loaded yet.</p>
                          </div>
                        ) : (
                          subjectChapters.map(ch => <ChapterList chapter={ch} />)
                        )}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
          );
        })
      )}
    </div>
  </main>
</BaseLayout>

<script>
  // ── Subject collapse/expand ──
  document.querySelectorAll('.subject-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.subject-section');
      if (!section) return;
      const content = section.querySelector('.subject-content');
      const chevron = section.querySelector('.subject-chevron');
      if (!content || !chevron) return;

      if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        chevron.classList.add('rotate-180');
      } else {
        content.classList.add('hidden');
        chevron.classList.remove('rotate-180');
      }
    });
  });

  // ── Chapter status toggle (cycles through statuses) ──
  const STATUS_CYCLE = ['not_started', 'studied', 'revision_1', 'revision_2', 'revision_3', 'mastered'];
  const STATUS_ICONS = ['radio_button_unchecked', 'radio_button_unchecked', 'radio_button_unchecked', 'radio_button_unchecked', 'radio_button_unchecked', 'check_circle'];
  const STATUS_COLORS = {
    not_started: { icon: '#475569', label: '#475569' },
    studied: { icon: '#f59e0b', label: '#f59e0b' },
    revision_1: { icon: '#3b82f6', label: '#3b82f6' },
    revision_2: { icon: '#8b5cf6', label: '#8b5cf6' },
    revision_3: { icon: '#ec4899', label: '#ec4899' },
    mastered: { icon: '#22c55e', label: '#22c55e' },
  };
  const STATUS_LABELS = {
    not_started: 'Locked',
    studied: 'In Progress',
    revision_1: 'Revision 1',
    revision_2: 'Revision 2',
    revision_3: 'Revision 3',
    mastered: 'Completed',
  };
  const STATUS_BG = {
    not_started: 'bg-slate-800 text-slate-500',
    studied: 'bg-yellow-500/10 text-yellow-500',
    revision_1: 'bg-blue-500/10 text-blue-400',
    revision_2: 'bg-purple-500/10 text-purple-400',
    revision_3: 'bg-pink-500/10 text-pink-400',
    mastered: 'bg-emerald-500/10 text-emerald-400',
  };

  document.querySelectorAll('.chapter-item').forEach(item => {
    item.addEventListener('click', async () => {
      const chapterId = item.dataset.chapterId;
      const currentStatus = item.dataset.status || 'not_started';
      const currentIdx = STATUS_CYCLE.indexOf(currentStatus);
      const nextIdx = (currentIdx + 1) % STATUS_CYCLE.length;
      const nextStatus = STATUS_CYCLE[nextIdx];

      item.style.opacity = '0.5';
      try {
        const res = await fetch('/api/syllabus', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: chapterId, status: nextStatus }),
        });
        if (!res.ok) throw new Error('Update failed');

        // Update visual state
        item.dataset.status = nextStatus;
        const icon = item.querySelector('.chapter-icon');
        const badge = item.querySelector('.chapter-badge');
        if (icon) {
          icon.textContent = nextIdx === STATUS_CYCLE.length - 1 ? 'check_circle' : 'radio_button_unchecked';
          icon.style.fontVariationSettings = nextIdx === STATUS_CYCLE.length - 1 ? "'FILL' 1" : "'FILL' 0";
          icon.style.color = STATUS_COLORS[nextStatus as keyof typeof STATUS_COLORS].icon;
        }
        if (badge) {
          badge.textContent = STATUS_LABELS[nextStatus as keyof typeof STATUS_LABELS];
          badge.className = `chapter-badge text-[10px] px-2 py-0.5 rounded uppercase font-bold tracking-wider ${STATUS_BG[nextStatus as keyof typeof STATUS_BG]}`;
        }
      } catch (err) {
        // Revert on error
      } finally {
        item.style.opacity = '1';
      }
    });
  });

  // ── Search input filter ──
  document.querySelector('input[placeholder="Search chapters..."]')?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll('.chapter-item').forEach(item => {
      const name = item.querySelector('.chapter-name')?.textContent?.toLowerCase() || '';
      item.style.display = name.includes(query) ? '' : 'none';
    });
    // Show/hide empty subject sections
    document.querySelectorAll('.subject-section').forEach(section => {
      const visible = section.querySelectorAll('.chapter-item[style*="display: none"]').length === 0;
      // Only hide if ALL items in section are hidden
      const totalItems = section.querySelectorAll('.chapter-item').length;
      const hiddenItems = section.querySelectorAll('.chapter-item[style*="display: none"]').length;
      if (totalItems > 0 && hiddenItems === totalItems) {
        section.style.display = 'none';
      } else {
        section.style.display = '';
      }
    });
  });
</script>

<style>
  .progress-ring-circle {
    transition: stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .progress-fill-anim {
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .chapter-item {
    cursor: pointer;
    transition: opacity 0.2s, border-color 0.2s;
  }
  .chapter-item:hover {
    border-color: rgba(99, 102, 241, 0.5) !important;
  }
  .subject-content {
    transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .subject-content.hidden {
    display: none;
  }
  .rotate-180 {
    transform: rotate(180deg);
  }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #050b18; }
  ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
</style>
