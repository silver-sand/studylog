---
import BaseLayout from '../layouts/BaseLayout.astro';
import SyllabusCard from '../components/SyllabusCard.astro';
import ChapterList from '../components/ChapterList.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS } from '../utils/exam-map';
import { scopeDbToUser } from '../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();

interface ExamData {
  key: string;
  label: string;
  progress: import('../types/review').SyllabusProgress[];
  chapters: import('../types/review').SyllabusChapter[];
  totalChapters: number;
  completedChapters: number;
  overallPercent: number;
}

// Build exam data from user's selected exams
const settings = db.getSettings();
const selectedExamKeys: string[] = settings.selectedExams?.length ? settings.selectedExams : ['JEE'];

// Map selected exam keys to definitions, group by syllabusKey
const userExamDefs = selectedExamKeys
  .map(key => EXAM_DEFINITIONS.find(e => e.key === key))
  .filter((e): e is (typeof EXAM_DEFINITIONS)[number] => !!e);

// Group exams sharing a syllabusKey, merging their subjects
const syllabusGroups = new Map<string, { primaryLabel: string; examKeys: string[]; subjects: Set<string> }>();
for (const exam of userExamDefs) {
  if (!syllabusGroups.has(exam.syllabusKey)) {
    syllabusGroups.set(exam.syllabusKey, {
      primaryLabel: exam.label,
      examKeys: [exam.key],
      subjects: new Set(exam.subjects),
    });
  } else {
    const g = syllabusGroups.get(exam.syllabusKey)!;
    g.examKeys.push(exam.key);
    exam.subjects.forEach(s => g.subjects.add(s));
  }
}

// Build ExamData per syllabus group — filtered to only the user's subjects
const exams: ExamData[] = [...syllabusGroups.entries()].map(([syllabusKey, group]) => {
  const subjects = [...group.subjects];
  // Seed ONLY the relevant subjects so commerce users don't get science chapters
  db.seedSyllabusData(syllabusKey, subjects);
  const progress = db.getSyllabusProgress(syllabusKey, subjects);
  const chapters = db.getSyllabus(syllabusKey).filter(ch => subjects.includes(ch.subject));
  const totalChapters = progress.reduce((s, p) => s + p.total, 0);
  const weightedSum = progress.reduce((s, p) => s + p.weightedPercent * p.total, 0);
  const overallPercent = totalChapters > 0 ? Math.round(weightedSum / totalChapters) : 0;
  const completedChapters = progress.reduce((s, p) => s + p.completed, 0);
  return {
    key: syllabusKey,
    label: group.primaryLabel,
    progress,
    chapters,
    totalChapters,
    completedChapters,
    overallPercent,
  };
});

const defaultExam = exams[0];
const defaultKey = defaultExam?.key;
const filteredExams = exams;

// Subject color helper (used for the subject badge icon)
function subjectColor(s: string): string {
  const name = s.toLowerCase();
  if (name.includes('physics')) return '#3b82f6';
  if (name.includes('chemistry')) return '#22c55e';
  if (name.includes('math')) return '#f59e0b';
  if (name.includes('biology')) return '#ec4899';
  return '#64748b';
}
---

<BaseLayout title="Syllabus Tracker">
    <div style="max-width:min(56rem,100%);" class="animate-slide-up">

    <!-- Header -->
    <div class="ds-page-header">
      <h1 class="ds-heading-page">Syllabus Tracker</h1>
      <p class="ds-body-sm">Track your syllabus completion across subjects and chapters</p>
    </div>

    <!-- No exams configured -->
    {filteredExams.length === 0 && (
      <div class="ds-card-glass" style="text-align:center;padding:var(--ds-space-5);">
        <div class="ds-empty">
          <div class="ds-empty-icon">📋</div>
          <p class="ds-empty-title">No exams configured</p>
          <p class="ds-empty-desc">Select your exams in Study Profile to start tracking syllabus progress.</p>
          <a href="/settings" class="ds-btn ds-btn-primary ds-empty-action">Go to Study Profile</a>
        </div>
      </div>
    )}

    <!-- Exam Tabs — Premium Pill Style -->
    {filteredExams.length > 0 && (
      <>
      <div class="exam-tabs" style="display:flex;gap:var(--ds-space-1);margin-bottom:var(--ds-space-3);overflow-x:auto;padding-bottom:2px;">
        {filteredExams.map((exam) => (
          <button
            class:list={{ 'exam-tab': true, active: exam.key === defaultKey }}
            data-exam={exam.key}
          >
            <span class="exam-tab-label">{exam.label}</span>
            <span class="exam-tab-pct"
              style={exam.overallPercent >= 80 ? 'color:#22c55e' : exam.overallPercent >= 40 ? 'color:#f59e0b' : ''}
            >{exam.overallPercent}%</span>
          </button>
        ))}
      </div>

      <!-- Per-Exam Content -->
      {filteredExams.map((exam) => (
        <div
          class:list={{ 'exam-content': true, hidden: exam.key !== defaultKey }}
          data-exam-content={exam.key}
        >
          <!-- Overall progress bar — Glass card -->
          <div class="ds-card-glass card-lift animate-slide-up" style="margin-bottom:var(--ds-space-2);padding:var(--ds-space-2);">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--ds-space-1);">
              <span style="font-size:var(--ds-text-sm);font-weight:var(--ds-weight-medium);color:var(--ds-text-secondary);">Overall Progress</span>
              <span style="font-family:var(--ds-font-mono);font-size:var(--ds-text-xs);color:var(--ds-text-tertiary);"
                id={`progress-text-${exam.key}`}
              >{exam.completedChapters}/{exam.totalChapters} chapters ({exam.overallPercent}%)</span>
            </div>
            <div class="ds-progress">
              <div class="ds-progress-bar bar-fill" id={`progress-fill-${exam.key}`}
                style="width: {exam.overallPercent}%;"
              ></div>
            </div>
          </div>

          <!-- Subject sections with staggered entrance -->
          <div class="subject-sections animate-stagger" style="--stagger-delay: 0.08s;">
            {exam.progress.map((p, idx) => {
              const subjectChapters = exam.chapters.filter(
                (ch) => ch.subject === p.subject
              );
              const sName = p.subject.toLowerCase();
              const subjColor = sName.includes('physics') ? '#3b82f6' :
                sName.includes('chemistry') ? '#22c55e' :
                sName.includes('math') ? '#f59e0b' :
                sName.includes('biology') ? '#ec4899' : '#64748b';
              return (
                <div
                  class="subject-section animate-stagger-item card-lift"
                  data-subject={p.subject}
                  style="--stagger-index: {idx}; --subject-color: {subjColor};"
                >
                  <div class="subject-header" role="button" tabindex="0"
                    aria-label={`Toggle ${p.subject} chapters`}>
                    <div class="subject-accent-bar" style="background: {subjColor};"></div>
                    <SyllabusCard subject={p.subject} progress={p} />
                    <div class="collapse-chevron">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                      </svg>
                    </div>
                  </div>
                  <div class="chapter-collapse">
                    <ChapterList chapters={subjectChapters} subject={p.subject} />
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
      </>
    )}
  </div>
</BaseLayout>

<script>
  // ── Exam tab switching with entrance animation ──
  const tabs = document.querySelectorAll('.exam-tab');
  const contents = new Map();
  document.querySelectorAll('.exam-content').forEach((el) => {
    contents.set(el.dataset.examContent, el);
  });

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const exam = tab.dataset.exam;
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      contents.forEach((content, key) => {
        if (key === exam) {
          content.classList.remove('hidden');
          // Re-trigger stagger animations
          content.querySelectorAll('.animate-stagger-item').forEach(el => {
            el.style.animation = 'none';
            void el.offsetHeight;
            el.style.animation = '';
          });
        } else {
          content.classList.add('hidden');
        }
      });
    });
  });

  // ── Smooth collapse/expand with height animation ──
  document.querySelectorAll('.subject-header').forEach(header => {
    header.addEventListener('click', () => {
      const section = header.closest('.subject-section');
      if (!section) return;
      const collapse = section.querySelector('.chapter-collapse');
      if (!collapse) return;

      if (section.classList.contains('collapsed')) {
        // Expand
        section.classList.remove('collapsed');
        collapse.style.maxHeight = collapse.scrollHeight + 'px';
      } else {
        // Collapse
        collapse.style.maxHeight = collapse.scrollHeight + 'px';
        void collapse.offsetHeight;
        collapse.style.maxHeight = '0';
        section.classList.add('collapsed');
      }
    });

    // Keyboard support
    header.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        header.click();
      }
    });
  });

  // ── Listen for chapter status updates from ChapterList ──
  document.addEventListener('syllabus-updated', async (e) => {
    const { examType } = e.detail;
    if (!examType) return;

    try {
      const res = await fetch(`/api/syllabus?exam=${encodeURIComponent(examType)}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.progress) return;

      const examContent = document.querySelector(`[data-exam-content="${examType}"]`);
      if (!examContent) return;

      const progressData = data.progress;

      // Update each subject card
      examContent.querySelectorAll('.syllabus-card').forEach(card => {
        const subj = card.dataset.subject;
        if (!subj) return;
        const p = progressData.find((pd) => pd.subject === subj);
        if (!p) return;

        const percentEl = card.querySelector('.percent-text');
        if (percentEl) {
          percentEl.textContent = `${p.weightedPercent}%`;
        }

        const fill = card.querySelector('.syllabus-bar-fill');
        if (fill) fill.style.width = `${p.weightedPercent}%`;

        const countEl = card.querySelector('.subject-count');
        if (countEl) countEl.textContent = `${p.completed}/${p.total} chapters`;
      });

      // Update overall progress
      const totalChapters = progressData.reduce((s, p) => s + p.total, 0);
      const weightedSum = progressData.reduce((s, p) => s + p.weightedPercent * p.total, 0);
      const overallPercent = totalChapters > 0 ? Math.round(weightedSum / totalChapters) : 0;

      const progressText = document.getElementById(`progress-text-${examType}`);
      if (progressText) progressText.textContent = `${overallPercent}% (${totalChapters} chapters)`;

      const progressFill = document.getElementById(`progress-fill-${examType}`);
      if (progressFill) progressFill.style.width = `${overallPercent}%`;

      // Update tab percentage
      tabs.forEach(tab => {
        if (tab.dataset.exam === examType) {
          const pctEl = tab.querySelector('.exam-tab-pct');
          if (pctEl) {
            pctEl.textContent = `${overallPercent}%`;
            pctEl.style.color = overallPercent >= 80 ? '#22c55e' : overallPercent >= 40 ? '#f59e0b' : '';
          }
        }
      });

      try { localStorage.setItem('sl-checklist-syllabus', '1'); } catch(e) {}
    } catch (err) {
      // Silently fail
    }
  });
</script>

<style>
  /* ── Premium Pill Exam Tabs ── */
  .exam-tabs {
    display: flex;
    gap: var(--ds-space-1);
    padding-bottom: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .exam-tab {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
    padding: var(--ds-space-1) var(--ds-space-2);
    background: var(--ds-bg-elevated);
    border: 1px solid var(--ds-border-default);
    border-radius: var(--ds-radius-full);
    color: var(--ds-text-tertiary);
    font-size: var(--ds-text-sm);
    font-family: var(--ds-font-sans);
    cursor: pointer;
    transition: all 0.2s var(--ds-ease-spring);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .exam-tab:hover {
    color: var(--ds-text-primary);
    background: var(--ds-bg-hover);
    border-color: var(--ds-border-hover);
    transform: translateY(-1px);
  }
  .exam-tab.active {
    color: var(--ds-text-primary);
    background: color-mix(in srgb, var(--ds-accent-500) 15%, transparent);
    border-color: color-mix(in srgb, var(--ds-accent-500) 30%, transparent);
    font-weight: var(--ds-weight-semibold);
  }
  .exam-tab-label {
    font-weight: var(--ds-weight-medium);
  }
  .exam-tab-pct {
    font-size: var(--ds-text-2xs);
    font-family: var(--ds-font-mono);
    color: var(--ds-text-muted);
  }

  /* ── Subject sections with smooth collapse ── */
  .subject-sections {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-1);
  }

  .subject-section {
    display: flex;
    flex-direction: column;
    background: var(--ds-bg-surface);
    border: 1px solid var(--ds-border-default);
    border-radius: var(--ds-radius-lg);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .subject-section:hover {
    border-color: var(--ds-border-hover);
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  :root.dark .subject-section:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .subject-section .subject-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 0 2px 2px 0;
    z-index: 1;
    pointer-events: none;
  }

  .subject-header {
    display: flex;
    align-items: center;
    cursor: pointer;
    user-select: none;
    position: relative;
  }
  .subject-header > .syllabus-card {
    flex: 1;
    border: none;
    background: transparent;
    box-shadow: none;
  }
  .subject-header > .syllabus-card:hover {
    transform: none;
  }
  .subject-header > .syllabus-card .subject-accent-bar {
    display: none;
  }

  /* Chevron button */
  .collapse-chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    margin-right: var(--ds-space-1);
    color: var(--ds-text-muted);
    transition: transform 0.3s var(--ds-ease-spring);
    border-radius: var(--ds-radius-full);
  }
  .collapse-chevron:hover {
    background: var(--ds-bg-hover);
  }
  .collapsed .collapse-chevron {
    transform: rotate(-90deg);
  }

  /* Height-animated collapse */
  .chapter-collapse {
    max-height: 2000px;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .collapsed .chapter-collapse {
    max-height: 0 !important;
  }

  .hidden { display: none; }
</style>
