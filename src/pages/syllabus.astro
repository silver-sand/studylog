---
import BaseLayout from '../layouts/BaseLayout.astro';
import SyllabusCard from '../components/SyllabusCard.astro';
import ChapterList from '../components/ChapterList.astro';
import { getDb } from '../db';
import { EXAM_DEFINITIONS } from '../utils/exam-map';
import { scopeDbToUser } from '../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();

interface ExamData {
  key: string;
  label: string;
  progress: import('../types/review').SyllabusProgress[];
  chapters: import('../types/review').SyllabusChapter[];
  totalChapters: number;
  completedChapters: number;
  overallPercent: number;
}

// Build exam data from user's selected exams
const settings = db.getSettings();
const selectedExamKeys: string[] = settings.selectedExams?.length ? settings.selectedExams : ['JEE'];

const userExamDefs = selectedExamKeys
  .map(key => EXAM_DEFINITIONS.find(e => e.key === key))
  .filter((e): e is (typeof EXAM_DEFINITIONS)[number] => !!e);

const syllabusGroups = new Map<string, { primaryLabel: string; examKeys: string[]; subjects: Set<string> }>();
for (const exam of userExamDefs) {
  if (!syllabusGroups.has(exam.syllabusKey)) {
    syllabusGroups.set(exam.syllabusKey, {
      primaryLabel: exam.label,
      examKeys: [exam.key],
      subjects: new Set(exam.subjects),
    });
  } else {
    const g = syllabusGroups.get(exam.syllabusKey)!;
    g.examKeys.push(exam.key);
    exam.subjects.forEach(s => g.subjects.add(s));
  }
}

const exams: ExamData[] = [...syllabusGroups.entries()].map(([syllabusKey, group]) => {
  const allSubjects = [...group.subjects];
  const activeSubjects = settings.subjects?.length ? settings.subjects : allSubjects;
  db.seedSyllabusData(syllabusKey, allSubjects);
  const progress = db.getSyllabusProgress(syllabusKey, activeSubjects);
  const chapters = db.getSyllabus(syllabusKey).filter(ch => activeSubjects.includes(ch.subject));
  const totalChapters = progress.reduce((s, p) => s + p.total, 0);
  const weightedSum = progress.reduce((s, p) => s + p.weightedPercent * p.total, 0);
  const overallPercent = totalChapters > 0 ? Math.round(weightedSum / totalChapters) : 0;
  const completedChapters = progress.reduce((s, p) => s + p.completed, 0);
  return {
    key: syllabusKey,
    label: group.primaryLabel,
    progress,
    chapters,
    totalChapters,
    completedChapters,
    overallPercent,
  };
});

const defaultExam = exams[0];
const defaultKey = defaultExam?.key;
const filteredExams = exams;

const subjectIcon: Record<string, string> = {
  physics: 'bolt',
  chemistry: 'science',
  mathematics: 'functions',
  maths: 'functions',
  biology: 'biotech',
  english: 'book',
};
---

<BaseLayout title="Syllabus">
  <main class="min-h-screen pb-24 md:pb-8 bg-[#050b18]">
    <!-- Top bar -->
    <header class="w-full h-16 flex justify-between items-center px-6 border-b border-white/[0.04] bg-[#050b18]/80 backdrop-blur-md sticky top-0 z-40">
      <div class="flex items-center gap-4">
        <span class="md:hidden material-symbols-outlined text-neutral-400">menu</span>
        <h2 class="font-headline text-xl font-black text-white tracking-tight">Syllabus Tracker</h2>
      </div>
      <div class="flex items-center gap-4">
        <div class="hidden sm:flex items-center bg-[#0d1321]/60 px-3 py-1.5 rounded-full border border-white/5">
          <span class="material-symbols-outlined text-neutral-500 text-sm">search</span>
          <input class="bg-transparent border-none focus:ring-0 text-sm text-neutral-300 w-48 placeholder-neutral-600" placeholder="Search chapters..." type="text" />
        </div>
        <div class="flex items-center gap-2">
          <a href="/settings" class="hover:bg-white/5 rounded-full p-2 transition-all active:opacity-80">
            <span class="material-symbols-outlined text-neutral-500">notifications</span>
          </a>
          <a href="/settings" class="hover:bg-white/5 rounded-full p-2 transition-all active:opacity-80">
            <span class="material-symbols-outlined text-neutral-500">settings</span>
          </a>
        </div>
      </div>
    </header>

    <div class="p-4 md:p-8 max-w-7xl mx-auto space-y-8">
      {filteredExams.length === 0 ? (
        <div class="obsidian-glass rounded-2xl p-12 text-center card-lift reveal-on-scroll">
          <div class="w-16 h-16 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mx-auto mb-5">
            <span class="material-symbols-outlined text-3xl text-indigo-400">assignment</span>
          </div>
          <p class="text-lg font-semibold text-white mb-2">No exams configured</p>
          <p class="text-sm text-neutral-500 mt-2 max-w-sm mx-auto">Select your exams in Settings to start tracking syllabus progress and chapter completion.</p>
          <a href="/settings" class="inline-block mt-6 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 px-6 rounded-xl transition-all active:scale-95 shadow-lg shadow-indigo-500/20 glow-button">
            Go to Settings
          </a>
        </div>
      ) : (
        filteredExams.map((exam, examIdx) => {
          const circumference = 440;
          const offset = circumference - (exam.overallPercent / 100) * circumference;
          return (
          <div class="space-y-8 animate-stagger" style={`--stagger-index:${examIdx}`} key={exam.key} data-exam-key={exam.key}>
            <!-- Overall Summary Card -->
            <section class="relative overflow-hidden ds-card-gradient rounded-2xl p-6 md:p-8 card-lift reveal-on-scroll">
              <div class="relative z-10 grid md:grid-cols-2 gap-8 items-center">
                <div>
                  <span class="text-indigo-400 font-bold text-[10px] uppercase tracking-[0.2em] mb-3 block">Preparation Status</span>
                  <h2 class="text-3xl md:text-4xl font-black text-white mb-3">You've covered {exam.overallPercent}% of your syllabus.</h2>
                  <p class="text-neutral-400 mb-6 max-w-md">Keep up the momentum! You've completed {exam.completedChapters} of {exam.totalChapters} chapters.</p>
                  <div class="flex gap-3">
                    <a href="/daily" class="bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-400 text-white font-bold py-2.5 px-6 rounded-xl transition-all active:scale-95 flex items-center gap-2 shadow-lg shadow-indigo-500/20 glow-button">
                      <span class="material-symbols-outlined text-sm">rocket_launch</span>
                      Resume Studying
                    </a>
                    <a href="/dashboard" class="bg-[#0d1321] hover:bg-[#1a2440] text-neutral-300 font-bold py-2.5 px-6 rounded-xl transition-all border border-white/5">
                      Dashboard
                    </a>
                  </div>
                </div>
                <div class="flex justify-center md:justify-end">
                  <div class="relative w-40 h-40 flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90">
                      <circle class="text-white/5" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-width="12"></circle>
                      <circle class="text-indigo-500 progress-ring-circle" cx="80" cy="80" fill="transparent" r="70" stroke="currentColor" stroke-dasharray={circumference} stroke-dashoffset={offset} stroke-linecap="round" stroke-width="12" style="filter: drop-shadow(0 0 8px rgba(99, 102, 241, 0.3));"></circle>
                    </svg>
                    <div class="absolute flex flex-col items-center">
                      <span class="text-4xl font-black text-white" id="overall-pct">{exam.overallPercent}%</span>
                      <span class="text-[10px] text-neutral-500 font-bold uppercase tracking-widest">Complete</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-indigo-500/10 blur-[100px] rounded-full pointer-events-none"></div>
            </section>

            <!-- Class Level Filter -->
            <div class="flex items-center gap-3" data-class-filter>
              <span class="text-[10px] font-bold uppercase tracking-widest text-neutral-500">Filter:</span>
              <button class="px-3 py-1.5 rounded-lg text-[11px] font-medium border border-indigo-500 bg-indigo-500/10 text-indigo-400 transition-all" data-level="all">All</button>
              <button class="px-3 py-1.5 rounded-lg text-[11px] font-medium border border-white/10 text-neutral-400 hover:border-white/20 transition-all" data-level="11">Class 11</button>
              <button class="px-3 py-1.5 rounded-lg text-[11px] font-medium border border-white/10 text-neutral-400 hover:border-white/20 transition-all" data-level="12">Class 12</button>
            </div>

            <!-- Subjects Grid -->
            <div class="space-y-5" id="progress-tracker">
              {exam.progress.map((p, subjIdx) => {
                const subjectChapters = exam.chapters.filter(ch => ch.subject === p.subject);
                const sName = p.subject.toLowerCase();
                const icon = subjectIcon[sName] || 'school';
                const subjColor = sName.includes('physics') ? '#3b82f6' :
                  sName.includes('chemistry') ? '#22c55e' :
                  sName.includes('math') ? '#f59e0b' :
                  sName.includes('biology') ? '#ec4899' : '#6366f1';
                return (
                  <div class="card-lift reveal-on-scroll" style={`--stagger-index:${subjIdx}`} key={p.subject}>
                    <div class="bg-[#0d1321]/40 border border-white/5 rounded-2xl overflow-hidden transition-all hover:border-indigo-500/20 subject-section">
                      <button class="w-full flex flex-col md:flex-row md:items-center justify-between p-5 md:p-6 gap-4 text-left subject-toggle group">
                        <div class="flex items-center gap-4">
                          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style={{ background: `${subjColor}15` }}>
                            <span class="material-symbols-outlined" style={{ color: subjColor, fontVariationSettings: "'FILL' 1" }}>{icon}</span>
                          </div>
                          <div>
                            <h3 class="text-lg font-bold text-white group-hover:text-indigo-400 transition-colors">{p.subject}</h3>
                            <p class="text-sm text-neutral-500">{p.completed} of {p.total} chapters completed</p>
                          </div>
                        </div>
                        <div class="flex-1 max-w-xs w-full md:ml-4">
                          <div class="flex justify-between text-[10px] font-bold mb-2">
                            <span class="text-indigo-400 uppercase tracking-wider">Progress</span>
                            <span class="text-neutral-500 font-mono">{p.weightedPercent}%</span>
                          </div>
                          <div class="w-full bg-white/5 h-2 rounded-full overflow-hidden">
                            <div class="h-full rounded-full progress-fill-anim" style={{ width: `${p.weightedPercent}%`, background: subjColor }}></div>
                          </div>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                          <span class="text-[10px] text-neutral-500 font-mono" id="subject-completed">{p.completed}/{p.total}</span>
                          <span class="material-symbols-outlined text-indigo-400 transition-transform duration-300 subject-chevron">expand_more</span>
                        </div>
                      </button>
                      <div class="subject-content px-6 pb-7">
                        <div class="border-t border-white/[0.04] pt-5 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2.5">
                          {subjectChapters.length === 0 ? (
                            <div class="col-span-full py-8 flex flex-col items-center justify-center text-neutral-500">
                              <span class="material-symbols-outlined text-3xl mb-2">info</span>
                              <p class="text-sm">No chapters loaded yet.</p>
                            </div>
                          ) : (
                            subjectChapters.map(ch => <ChapterList chapter={ch} />)
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
          );
        })
      )}
    </div>
  </main>
</BaseLayout>

<script>
  // ── STATUS WEIGHTS ──
  const STATUS_WEIGHTS = {
    not_started: 0,
    studied: 0.2,
    revision_1: 0.4,
    revision_2: 0.6,
    revision_3: 0.8,
    mastered: 1,
  };

  // ── Recalculate a single subject's progress bar ──
  function recalculateSubjectProgress(section) {
    const items = section.querySelectorAll('.chapter-item');
    const total = items.length;
    let sumWeight = 0;
    let masteredCount = 0;

    items.forEach(item => {
      const status = item.dataset.status || 'not_started';
      sumWeight += STATUS_WEIGHTS[status] || 0;
      if (status === 'mastered') masteredCount++;
    });

    const weightedPercent = total > 0 ? Math.round((sumWeight / total) * 100) : 0;

    const progressBar = section.querySelector('.progress-fill-anim');
    const percentText = section.querySelector('.flex.justify-between .text-neutral-500.font-mono');
    const completedText = section.querySelector('.text-sm.text-neutral-500');
    const countBadge = section.querySelector('[id="subject-completed"]');

    if (progressBar) progressBar.style.width = `${weightedPercent}%`;
    if (percentText) percentText.textContent = `${weightedPercent}%`;
    if (completedText) completedText.textContent = `${masteredCount} of ${total} chapters completed`;
    if (countBadge) countBadge.textContent = `${masteredCount}/${total}`;
  }

  // ── Recalculate the overall exam hero section ──
  function recalculateOverallProgress(examContainer) {
    const sections = examContainer.querySelectorAll('.subject-section');
    let totalWeightedSum = 0;
    let totalChapters = 0;
    let totalMastered = 0;

    sections.forEach(section => {
      const items = section.querySelectorAll('.chapter-item');
      let sumWeight = 0;
      let mastered = 0;
      items.forEach(item => {
        const status = item.dataset.status || 'not_started';
        sumWeight += STATUS_WEIGHTS[status] || 0;
        if (status === 'mastered') mastered++;
      });
      totalWeightedSum += sumWeight;
      totalChapters += items.length;
      totalMastered += mastered;
    });

    const overallPercent = totalChapters > 0 ? Math.round((totalWeightedSum / totalChapters) * 100) : 0;

    const heroTitle = examContainer.querySelector('h2');
    const heroSubtext = examContainer.querySelector('.text-neutral-400.mb-6');
    const ringCircle = examContainer.querySelector('.progress-ring-circle');
    const ringPercentText = document.getElementById('overall-pct');

    if (heroTitle) heroTitle.textContent = `You've covered ${overallPercent}% of your syllabus.`;
    if (heroSubtext) heroSubtext.textContent = `Keep up the momentum! You've completed ${totalMastered} of ${totalChapters} chapters.`;
    if (ringPercentText) ringPercentText.textContent = `${overallPercent}%`;

    if (ringCircle) {
      const circumference = 440;
      const offset = circumference - (overallPercent / 100) * circumference;
      ringCircle.style.strokeDashoffset = offset;
    }
  }

  // ── Subject collapse/expand ──
  document.querySelectorAll('.subject-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.subject-section');
      if (!section) return;
      const content = section.querySelector('.subject-content');
      const chevron = section.querySelector('.subject-chevron');
      if (!content || !chevron) return;

      if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        chevron.classList.add('rotate-180');
      } else {
        content.classList.add('hidden');
        chevron.classList.remove('rotate-180');
      }
    });
  });

  // ── Chapter status toggle ──
  const STATUS_CYCLE = ['not_started', 'studied', 'revision_1', 'revision_2', 'revision_3', 'mastered'];
  const STATUS_COLORS = {
    not_started: { icon: '#475569', label: '#475569' },
    studied: { icon: '#f59e0b', label: '#f59e0b' },
    revision_1: { icon: '#818cf8', label: '#818cf8' },
    revision_2: { icon: '#a78bfa', label: '#a78bfa' },
    revision_3: { icon: '#e879f9', label: '#e879f9' },
    mastered: { icon: '#22c55e', label: '#22c55e' },
  };
  const STATUS_LABELS = {
    not_started: 'Locked',
    studied: 'In Progress',
    revision_1: 'Revision 1',
    revision_2: 'Revision 2',
    revision_3: 'Revision 3',
    mastered: 'Completed',
  };
  const STATUS_BG = {
    not_started: 'bg-slate-800/50 text-slate-500',
    studied: 'bg-yellow-500/10 text-yellow-500',
    revision_1: 'bg-indigo-500/10 text-indigo-400',
    revision_2: 'bg-purple-500/10 text-purple-400',
    revision_3: 'bg-pink-500/10 text-pink-400',
    mastered: 'bg-emerald-500/10 text-emerald-400',
  };

  document.querySelectorAll('.chapter-item').forEach(item => {
    item.addEventListener('click', async () => {
      const chapterId = item.dataset.chapterId;
      const currentStatus = item.dataset.status || 'not_started';
      const currentIdx = STATUS_CYCLE.indexOf(currentStatus);
      const nextIdx = (currentIdx + 1) % STATUS_CYCLE.length;
      const nextStatus = STATUS_CYCLE[nextIdx];

      item.style.opacity = '0.5';
      try {
        const res = await fetch('/api/syllabus', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: chapterId, status: nextStatus }),
        });
        if (!res.ok) throw new Error('Update failed');

        item.dataset.status = nextStatus;
        const icon = item.querySelector('.chapter-icon');
        const badge = item.querySelector('.chapter-badge');
        if (icon) {
          icon.textContent = nextIdx === STATUS_CYCLE.length - 1 ? 'check_circle' : 'radio_button_unchecked';
          icon.style.fontVariationSettings = nextIdx === STATUS_CYCLE.length - 1 ? "'FILL' 1" : "'FILL' 0";
          icon.style.color = STATUS_COLORS[nextStatus as keyof typeof STATUS_COLORS].icon;
        }
        if (badge) {
          badge.textContent = STATUS_LABELS[nextStatus as keyof typeof STATUS_LABELS];
          badge.className = `chapter-badge text-[10px] px-2 py-0.5 rounded uppercase font-bold tracking-wider ${STATUS_BG[nextStatus as keyof typeof STATUS_BG]}`;
        }

        const section = item.closest('.subject-section');
        if (section) recalculateSubjectProgress(section);

        const examContainer = item.closest('[data-exam-key]');
        if (examContainer) recalculateOverallProgress(examContainer);

        document.dispatchEvent(new CustomEvent('syllabus-updated'));
      } catch (err) {
        // Revert on error
      } finally {
        item.style.opacity = '1';
      }
    });
  });

  // ── Search input filter ──
  document.querySelector('input[placeholder="Search chapters..."]')?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll('.chapter-item').forEach(item => {
      const name = item.querySelector('.chapter-name')?.textContent?.toLowerCase() || '';
      item.style.display = name.includes(query) ? '' : 'none';
    });
    document.querySelectorAll('.subject-section').forEach(section => {
      const totalItems = section.querySelectorAll('.chapter-item').length;
      const hiddenItems = section.querySelectorAll('.chapter-item[style*="display: none"]').length;
      if (totalItems > 0 && hiddenItems === totalItems) {
        section.style.display = 'none';
      } else {
        section.style.display = '';
      }
    });
  });

  // ── Class level filter ──
  document.querySelectorAll('[data-class-filter] button').forEach(btn => {
    btn.addEventListener('click', () => {
      const container = btn.closest('[data-exam-key]');
      if (!container) return;
      const level = btn.dataset.level;

      const filterBar = container.querySelector('[data-class-filter]');
      if (!filterBar) return;
      filterBar.querySelectorAll('button').forEach(b => {
        b.classList.remove('border-indigo-500', 'bg-indigo-500/10', 'text-indigo-400');
        b.classList.add('border-white/10', 'text-neutral-400');
      });
      btn.classList.remove('border-white/10', 'text-neutral-400');
      btn.classList.add('border-indigo-500', 'bg-indigo-500/10', 'text-indigo-400');

      container.querySelectorAll('.chapter-item').forEach(item => {
        const cls = item.dataset.classLevel || '';
        if (level === 'all' || !cls || cls === level) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });

      container.querySelectorAll('.subject-section').forEach(section => {
        const items = section.querySelectorAll('.chapter-item');
        const visible = Array.from(items).some(item => item.style.display !== 'none');
        section.style.display = visible ? '' : 'none';
      });
    });
  });
</script>

<style>
  .progress-ring-circle {
    transition: stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .progress-fill-anim {
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .chapter-item {
    cursor: pointer;
    transition: opacity 0.2s, border-color 0.2s, background 0.2s;
  }
  .chapter-item:hover {
    border-color: rgba(99, 102, 241, 0.4) !important;
    background: rgba(99, 102, 241, 0.03);
  }
  .subject-content {
    transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .subject-content.hidden {
    display: none;
  }
  .rotate-180 {
    transform: rotate(180deg);
  }
  .glow-button {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
    transition: all 0.3s ease;
  }
  .glow-button:hover {
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.5);
    transform: translateY(-2px);
  }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.06); border-radius: 10px; }
</style>
