---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getDb } from '../../db';
import { formatDisplayDate, getMonday, getSunday } from '../../utils/date';
import { scopeDbToUser } from '../../services/user-scope';

const { weekStart } = Astro.params;
scopeDbToUser(Astro.request);
const db = getDb();
const review = weekStart ? db.getReviewByWeek(weekStart) : null;
const validDate = weekStart && /^\d{4}-\d{2}-\d{2}$/.test(weekStart);

// Compute prev/next week for navigation
function shiftWeek(dateStr: string, delta: number): string {
  const d = new Date(dateStr);
  d.setDate(d.getDate() + delta);
  return d.toISOString().split('T')[0];
}
const prevWeekStart = weekStart ? shiftWeek(weekStart, -7) : '';
const nextWeekStart = weekStart ? shiftWeek(weekStart, 7) : '';
const hasPrev = !!db.getReviewByWeek(prevWeekStart);
const hasNext = !!db.getReviewByWeek(nextWeekStart);
---

<BaseLayout title={review ? 'Weekly Review' : 'Not Found'}>
  <div class="max-w-3xl mx-auto">
    {!validDate ? (
      <EmptyState
        title="Invalid Date"
        description="The week identifier doesn't look like a valid date."
      />
    ) : !review ? (
      <EmptyState
        title="No Review Found"
        description={`No review for the week starting ${weekStart}. Go to the Weekly page to generate one.`}
      />
    ) : (
      <>
        <div class="mb-8">
          <a href="/weekly" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Back to Weekly Reviews
          </a>
          <div class="review-header">
            <div class="review-nav">
              {hasPrev ? (
                <a href={`/weekly/${prevWeekStart}`} class="nav-arrow" title="Previous week">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </a>
              ) : (
                <span class="nav-arrow disabled">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </span>
              )}
            </div>
            <div class="review-header-text">
              <h1 class="page-title">Weekly Review</h1>
              <p class="page-sub">
                {formatDisplayDate(review.weekStart)} — {formatDisplayDate(review.weekEnd)}
              </p>
            </div>
            <div class="review-nav">
              {hasNext ? (
                <a href={`/weekly/${nextWeekStart}`} class="nav-arrow" title="Next week">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              ) : (
                <span class="nav-arrow disabled">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              )}
            </div>
          </div>
        </div>

        <div class="mb-4 flex gap-2 items-center">
          <button id="regenerate-weekly-btn" class="btn-ghost-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
            Regenerate
          </button>
          <div id="regenerate-error" class="error hidden"></div>
        </div>
        <div id="review-content">
          <ReviewCard review={review} />
        </div>
      </>
    )}
  </div>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    color: #60a5fa;
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: #93c5fd;
  }
  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .page-sub {
    font-size: 0.875rem;
    color: #64748b;
  }
  .review-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .review-header-text {
    flex: 1;
  }
  .review-nav {
    display: flex;
    align-items: center;
  }
  .nav-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    color: #64748b;
    transition: all 0.15s ease;
    text-decoration: none;
  }
  .nav-arrow:hover {
    color: #e2e8f0;
    background: rgba(51, 65, 85, 0.4);
  }
  .nav-arrow.disabled {
    opacity: 0.25;
    cursor: default;
  }
  .nav-arrow.disabled:hover {
    color: #64748b;
    background: transparent;
  }
  .btn-ghost-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: transparent;
    color: #64748b;
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(51, 65, 85, 0.4);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Inter', sans-serif;
  }
  .btn-ghost-sm:hover {
    color: #94a3b8;
    border-color: rgba(71, 85, 105, 0.6);
  }
  .btn-ghost-sm:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .error {
    color: #ef4444;
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
  }
  .hidden {
    display: none;
  }
</style>

<script>
  const btn = document.getElementById('regenerate-weekly-btn');
  const errorDiv = document.getElementById('regenerate-error');
  const reviewContent = document.getElementById('review-content');
  let originalBtnHtml = '';

  btn?.addEventListener('click', async () => {
    if (!btn || !errorDiv) return;
    btn.disabled = true;
    originalBtnHtml = btn.innerHTML;
    btn.innerHTML = '<span class="loading-spinner"></span> Regenerating...';
    errorDiv.classList.add('hidden');

    try {
      const weekStart = window.location.pathname.split('/weekly/')[1];
      const res = await fetch('/api/reviews/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ weekStart }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Failed' }));
        throw new Error(err.error || 'Failed to regenerate');
      }
      window.location.reload();
    } catch (err) {
      errorDiv.textContent = err instanceof Error ? err.message : 'Something went wrong';
      errorDiv.classList.remove('hidden');
      btn.disabled = false;
      btn.innerHTML = originalBtnHtml;
    }
  });
</script>
