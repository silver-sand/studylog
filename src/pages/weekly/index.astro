---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewList from '../../components/ReviewList.astro';
import { getDb } from '../../db';
import { getMonday, getSunday, formatDisplayDate } from '../../utils/date';
import { scopeDbToUser } from '../../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();
const reviews = db.listReviews();
const range = {
  weekStart: getMonday(),
  weekEnd: getSunday(),
};
const currentReview = db.getReviewByWeek(range.weekStart);

// Stats for the premium stat row
const entries = db.listEntries({ limit: 200 });
const thisWeekEntries = entries.filter(e => e.date >= range.weekStart && e.date <= range.weekEnd);
const totalHoursThisWeek = thisWeekEntries.reduce((s, e) => s + (e.hoursStudied || 0), 0);
const subjectsThisWeek = new Set(thisWeekEntries.map(e => e.studyType).filter(Boolean));
const insightCount = currentReview?.insights?.length || 0;
const weekScore = currentReview
  ? Math.min(100, Math.round(
    (currentReview.strengths?.length || 0) * 15 +
    (currentReview.insights?.length || 0) * 5 +
    Math.min(totalHoursThisWeek, 35) * 1.5
  ))
  : totalHoursThisWeek > 0 ? Math.round(Math.min(totalHoursThisWeek / 25, 1) * 65) : 0;
---

<BaseLayout title="Weekly Reviews">
  <div class="animate-slide-up">

    <!-- Header -->
    <div class="ds-page-header">
      <h1 class="ds-heading-page" style="margin-bottom:0.25rem;">Weekly Reviews</h1>
      <p class="ds-body-sm" style="margin:0;">AI-powered study summaries and insights</p>
    </div>

    <!-- Top Stat Row -->
    <div class="weekly-stats animate-stagger" style="--stagger-delay: 0.08s;margin-bottom:var(--ds-space-3);">
      <div class="ds-card-glass card-lift" style="padding:var(--ds-space-2);text-align:center;--stagger-index:0;">
        <div class="stat-value count-up">{weekScore}%</div>
        <div class="stat-label">Week Score</div>
      </div>
      <div class="ds-card-glass card-lift" style="padding:var(--ds-space-2);text-align:center;--stagger-index:1;">
        <div class="stat-value count-up">{subjectsThisWeek.size}</div>
        <div class="stat-label">Subjects</div>
      </div>
      <div class="ds-card-glass card-lift" style="padding:var(--ds-space-2);text-align:center;--stagger-index:2;">
        <div class="stat-value count-up">{totalHoursThisWeek.toFixed(1)}</div>
        <div class="stat-label">Hours</div>
      </div>
      <div class="ds-card-glass card-lift" style="padding:var(--ds-space-2);text-align:center;--stagger-index:3;">
        <div class="stat-value count-up">{insightCount}</div>
        <div class="stat-label">AI Insights</div>
      </div>
    </div>

    <!-- Current Week row -->
    <div class="ds-card-glass card-lift animate-slide-up" style="margin-bottom:var(--ds-space-3);padding:var(--ds-space-2);--stagger-index:0;">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--ds-space-1);">
        <div>
          <h2 style="font-size:var(--ds-text-sm);font-weight:600;color:var(--ds-text-primary);margin:0;">This Week</h2>
          <p style="font-size:var(--ds-text-xs);color:var(--ds-text-tertiary);margin:0.15rem 0 0;">{formatDisplayDate(range.weekStart)} — {formatDisplayDate(range.weekEnd)}</p>
        </div>
        <div style="display:flex;gap:var(--ds-space-1);align-items:center;">
          {currentReview ? (
            <>
              <a href={`/weekly/${range.weekStart}`} class="ds-btn ds-btn-primary ds-btn-sm press-effect">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                View Review
              </a>
              <button id="regenerate-weekly-btn" class="ds-btn ds-btn-ghost ds-btn-sm press-effect" data-week-start={range.weekStart}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
                Regenerate
              </button>
            </>
          ) : (
            <button id="generate-review-btn" class="ds-btn ds-btn-primary ds-btn-sm pulse-glow press-effect">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Generate Review
            </button>
          )}
        </div>
      </div>
      <div id="generate-error" class="ds-error-text hidden" style="margin-top:var(--ds-space-2);"></div>
    </div>

    <!-- Two-column: Subject Performance + AI Insights -->
    {currentReview && (
      <div class="weekly-grid animate-stagger" style="--stagger-delay: 0.1s;margin-bottom:var(--ds-space-3);">
        <!-- Subject Performance -->
        <div class="ds-card-glass card-lift" style="padding:var(--ds-space-2);--stagger-index:0;">
          <div class="section-title-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
            Subject Performance
          </div>
          <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
            {[...subjectsThisWeek].length > 0 ? [...subjectsThisWeek].map(subj => {
              const subjEntries = thisWeekEntries.filter(e => e.studyType === subj);
              const subjHours = subjEntries.reduce((s, e) => s + (e.hoursStudied || 0), 0);
              const pct = totalHoursThisWeek > 0 ? Math.round((subjHours / totalHoursThisWeek) * 100) : 0;
              return (
                <div class="subject-row">
                  <div class="subject-row-label">
                    <span>{subj.replace('_', ' ')}</span>
                    <span class="subject-row-hours">{subjHours.toFixed(1)}h</span>
                  </div>
                  <div class="ds-progress">
                    <div class="ds-progress-bar bar-fill" style="width: {pct}%;"></div>
                  </div>
                </div>
              );
            }) : (
              <p style="font-size:var(--ds-text-xs);color:var(--ds-text-muted);margin:0;">No subject data this week.</p>
            )}
          </div>
        </div>

        <!-- AI Insights -->
        <div class="ds-card-glass card-lift" style="padding:var(--ds-space-2);--stagger-index:1;">
          <div class="section-title-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>
            </svg>
            AI Insights
          </div>
          {currentReview.insights?.length > 0 ? (
            <div style="display:flex;flex-direction:column;gap:var(--ds-space-1);">
              {currentReview.insights.slice(0, 4).map(insight => (
                <div class="insight-row">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="var(--ds-accent-500)" stroke="none"><circle cx="12" cy="12" r="8"/></svg>
                  <span>{insight}</span>
                </div>
              ))}
              {currentReview.insights.length > 4 && (
                <a href={`/weekly/${range.weekStart}`} style="font-size:var(--ds-text-xs);color:var(--ds-accent-400);margin-top:var(--ds-space-1);">
                  +{currentReview.insights.length - 4} more insights
                </a>
              )}
            </div>
          ) : (
            <p style="font-size:var(--ds-text-xs);color:var(--ds-text-muted);margin:0;">No insights available.</p>
          )}
        </div>
      </div>
    )}

    <!-- AI Tip Card -->
    {currentReview?.recommendations?.length > 0 && (
      <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:2;margin-bottom:var(--ds-space-3);padding:var(--ds-space-2);border-left:3px solid var(--ds-accent-500);">
        <div style="display:flex;align-items:flex-start;gap:var(--ds-space-2);">
          <div style="flex-shrink:0;width:2rem;height:2rem;border-radius:var(--ds-radius-full);background:var(--ds-warning-bg);display:flex;align-items:center;justify-content:center;color:var(--ds-warning-400);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>
            </svg>
          </div>
          <div style="flex:1;">
            <p style="font-size:var(--ds-text-xs);font-weight:600;color:var(--ds-text-primary);margin:0 0 0.25rem;">🤖 AI Tip</p>
            <p style="font-size:var(--ds-text-xs);color:var(--ds-text-secondary);margin:0;line-height:1.5;">{currentReview.recommendations[0]}</p>
          </div>
        </div>
      </div>
    )}

    <!-- Notes & Reflections -->
    <div class="ds-card-glass card-lift animate-slide-up" style="--stagger-index:3;margin-bottom:var(--ds-space-3);padding:var(--ds-space-2);">
      <div style="display:flex;align-items:center;gap:var(--ds-space-1);margin-bottom:var(--ds-space-1);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        <span style="font-size:var(--ds-text-xs);font-weight:600;color:var(--ds-text-primary);">Notes & Reflections</span>
      </div>
      <textarea
        id="weekly-notes"
        class="ds-input"
        placeholder="Write your reflections on this week..."
        rows="3"
        style="width:100%;resize:vertical;min-height:4rem;"
      ></textarea>
    </div>

    <!-- Past Reviews -->
    <div style="margin-bottom:var(--ds-space-4);">
      <h2 class="ds-heading-section" style="font-size:var(--ds-text-xs);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:var(--ds-space-2);">Past Reviews</h2>
      <ReviewList reviews={reviews.filter(r => r.weekStart !== range.weekStart)} />
    </div>
  </div>
</BaseLayout>

<script>
  const generateBtn = document.getElementById('generate-review-btn');
  const regenerateBtn = document.getElementById('regenerate-weekly-btn');
  const errorDiv = document.getElementById('generate-error');
  let originalBtnHtml = '';

  async function generateReview(weekStart) {
    const btn = weekStart ? regenerateBtn : generateBtn;
    if (!btn || !errorDiv) return;
    btn.disabled = true;
    originalBtnHtml = btn.innerHTML;
    btn.innerHTML = '<span class="loading-spinner"></span> ' + (weekStart ? 'Regenerating...' : 'Generating...');
    errorDiv.classList.add('hidden');

    try {
      const body = weekStart ? JSON.stringify({ weekStart }) : '{}';
      const res = await fetch('/api/reviews/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body,
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Generation failed' }));
        throw new Error(err.error || `HTTP ${res.status}`);
      }
      const review = await res.json();
      // Track for getting-started checklist
      try { localStorage.setItem('sl-checklist-review', '1'); } catch(e) {}
      window.location.href = `/weekly/${review.weekStart}`;
    } catch (err) {
      errorDiv.textContent = err instanceof Error ? err.message : 'Something went wrong';
      errorDiv.classList.remove('hidden');
      btn.disabled = false;
      btn.innerHTML = originalBtnHtml;
    }
  }

  generateBtn?.addEventListener('click', () => generateReview(null));
  regenerateBtn?.addEventListener('click', () => generateReview(regenerateBtn.dataset.weekStart));
</script>

<style>
  .hidden { display: none; }

  /* ── Weekly Stats Row ── */
  .weekly-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--ds-space-2);
  }
  @media (max-width: 480px) {
    .weekly-stats { grid-template-columns: repeat(2, 1fr); }
  }
  .stat-value {
    font-size: var(--ds-text-xl);
    font-weight: 800;
    color: var(--ds-text-primary);
    font-family: var(--ds-font-mono);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .stat-label {
    font-size: var(--ds-text-2xs);
    color: var(--ds-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    margin-top: 0.2rem;
  }

  /* ── Section Title ── */
  .section-title-sm {
    display: flex;
    align-items: center;
    gap: var(--ds-space-1);
    font-size: var(--ds-text-xs);
    font-weight: 600;
    color: var(--ds-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--ds-space-1);
  }

  /* ── Weekly Grid (two-column) ── */
  .weekly-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--ds-space-2);
  }
  @media (max-width: 640px) {
    .weekly-grid { grid-template-columns: 1fr; }
  }

  /* ── Subject row ── */
  .subject-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .subject-row-label {
    display: flex;
    justify-content: space-between;
    font-size: var(--ds-text-xs);
    color: var(--ds-text-secondary);
  }
  .subject-row-hours {
    font-family: var(--ds-font-mono);
    color: var(--ds-text-muted);
  }

  /* ── Insight row ── */
  .insight-row {
    display: flex;
    align-items: flex-start;
    gap: var(--ds-space-1);
    font-size: var(--ds-text-xs);
    color: var(--ds-text-secondary);
    line-height: 1.5;
  }
  .insight-row svg {
    flex-shrink: 0;
    margin-top: 0.35rem;
  }
</style>
