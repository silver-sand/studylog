---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewList from '../../components/ReviewList.astro';
import { getDb } from '../../db';
import { getMonday, getSunday, formatDisplayDate } from '../../utils/date';
import { scopeDbToUser } from '../../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();
const reviews = db.listReviews();
const range = {
  weekStart: getMonday(),
  weekEnd: getSunday(),
};
const currentReview = db.getReviewByWeek(range.weekStart);
---

<BaseLayout title="Weekly Reviews">
  <div class="max-w-3xl mx-auto">
    <div class="mb-8">
      <h1 class="ds-heading-page" style="margin-bottom:0.25rem;">Weekly Reviews</h1>
      <p class="ds-body-sm" style="margin:0;">AI-generated study summaries and insights</p>
    </div>

    <!-- Current Week -->
    <div class="ds-card mb-8">
      <h2 class="ds-heading-section" style="margin-bottom:0.25rem;">
        This Week
      </h2>
      <p class="ds-caption" style="margin-bottom:0.5rem;">{formatDisplayDate(range.weekStart)} — {formatDisplayDate(range.weekEnd)}</p>
      <p class="ds-caption mb-4">
        {currentReview
          ? 'Review ready for this week.'
          : 'Generate a review from your entries this week.'}
      </p>

      {currentReview ? (
        <div class="ds-flex-between" style="flex-wrap:wrap;gap:var(--ds-space-2);">
          <a
            href={`/weekly/${range.weekStart}`}
            class="ds-btn ds-btn-secondary"
          >
            View Review
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:1px;"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <button id="regenerate-weekly-btn" class="ds-btn ds-btn-ghost ds-btn-sm" data-week-start={range.weekStart}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
            Regenerate
          </button>
        </div>
      ) : (
        <button
          id="generate-review-btn"
          class="ds-btn ds-btn-primary"
        >
          Generate Review
        </button>
      )}

      <div id="generate-error" class="ds-error-text hidden" style="margin-top:var(--ds-space-3);"></div>
    </div>

    <!-- Past Reviews -->
    <div>
      <h2 class="ds-heading-section" style="font-size:var(--ds-text-xs);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:var(--ds-space-3);">Past Reviews</h2>
      <ReviewList reviews={reviews.filter(r => r.weekStart !== range.weekStart)} />
    </div>
  </div>
</BaseLayout>

<script>
  const generateBtn = document.getElementById('generate-review-btn');
  const regenerateBtn = document.getElementById('regenerate-weekly-btn');
  const errorDiv = document.getElementById('generate-error');
  let originalBtnHtml = '';

  async function generateReview(weekStart) {
    const btn = weekStart ? regenerateBtn : generateBtn;
    if (!btn || !errorDiv) return;
    btn.disabled = true;
    originalBtnHtml = btn.innerHTML;
    btn.innerHTML = '<span class="loading-spinner"></span> ' + (weekStart ? 'Regenerating...' : 'Generating...');
    errorDiv.classList.add('hidden');

    try {
      const body = weekStart ? JSON.stringify({ weekStart }) : '{}';
      const res = await fetch('/api/reviews/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body,
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Generation failed' }));
        throw new Error(err.error || `HTTP ${res.status}`);
      }
      const review = await res.json();
      // Track for getting-started checklist
      try { localStorage.setItem('sl-checklist-review', '1'); } catch(e) {}
      window.location.href = `/weekly/${review.weekStart}`;
    } catch (err) {
      errorDiv.textContent = err instanceof Error ? err.message : 'Something went wrong';
      errorDiv.classList.remove('hidden');
      btn.disabled = false;
      btn.innerHTML = originalBtnHtml;
    }
  }

  generateBtn?.addEventListener('click', () => generateReview(null));
  regenerateBtn?.addEventListener('click', () => generateReview(regenerateBtn.dataset.weekStart));
</script>

<style>
  .hidden { display: none; }
</style>
