---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewList from '../../components/ReviewList.astro';
import { getDb } from '../../db';
import { getMonday, getSunday, formatDisplayDate } from '../../utils/date';

const db = getDb();
const reviews = db.listReviews();
const range = {
  weekStart: getMonday(),
  weekEnd: getSunday(),
};
const currentReview = db.getReviewByWeek(range.weekStart);
---

<BaseLayout title="Weekly Reviews">
  <div class="max-w-3xl mx-auto">
    <div class="mb-8">
      <h1 class="page-title">Weekly Reviews</h1>
      <p class="page-sub">AI-generated study summaries and insights</p>
    </div>

    <!-- Current Week -->
    <div class="card mb-8">
      <h2 class="card-title">
        This Week
      </h2>
      <p class="week-range">{formatDisplayDate(range.weekStart)} — {formatDisplayDate(range.weekEnd)}</p>
      <p class="card-desc mb-4">
        {currentReview
          ? 'Review ready for this week.'
          : 'Generate a review from your entries this week.'}
      </p>

      {currentReview ? (
        <div class="flex gap-2 items-center flex-wrap">
          <a
            href={`/weekly/${range.weekStart}`}
            class="btn-secondary"
          >
            View Review
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <button id="regenerate-weekly-btn" class="btn-ghost-sm" data-week-start={range.weekStart}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
            Regenerate
          </button>
        </div>
      ) : (
        <button
          id="generate-review-btn"
          class="btn-primary"
        >
          Generate Review
        </button>
      )}

      <div id="generate-error" class="error hidden mt-3"></div>
    </div>

    <!-- Past Reviews -->
    <div>
      <h2 class="section-title">Past Reviews</h2>
      <ReviewList reviews={reviews.filter(r => r.weekStart !== range.weekStart)} />
    </div>
  </div>
</BaseLayout>

<script>
  const generateBtn = document.getElementById('generate-review-btn');
  const regenerateBtn = document.getElementById('regenerate-weekly-btn');
  const errorDiv = document.getElementById('generate-error');

  async function generateReview(weekStart) {
    const btn = weekStart ? regenerateBtn : generateBtn;
    if (!btn || !errorDiv) return;
    btn.disabled = true;
    btn.textContent = weekStart ? 'Regenerating...' : 'Generating...';
    errorDiv.classList.add('hidden');

    try {
      const body = weekStart ? JSON.stringify({ weekStart }) : '{}';
      const res = await fetch('/api/reviews/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body,
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Generation failed' }));
        throw new Error(err.error || `HTTP ${res.status}`);
      }
      const review = await res.json();
      window.location.href = `/weekly/${review.weekStart}`;
    } catch (err) {
      errorDiv.textContent = err instanceof Error ? err.message : 'Something went wrong';
      errorDiv.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = weekStart ? 'Regenerate' : 'Generate Review';
    }
  }

  generateBtn?.addEventListener('click', () => generateReview(null));
  regenerateBtn?.addEventListener('click', () => generateReview(regenerateBtn.dataset.weekStart));
</script>

<style>
  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .page-sub {
    font-size: 0.875rem;
    color: #64748b;
  }
  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(51, 65, 85, 0.4);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-bottom: 0.25rem;
  }
  .week-range {
    font-size: 0.8rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }
  .card-desc {
    font-size: 0.825rem;
    color: #64748b;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: #2563eb;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-primary:hover:not(:disabled) {
    background: #3b82f6;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(51, 65, 85, 0.4);
    color: #e2e8f0;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-secondary:hover {
    background: rgba(51, 65, 85, 0.7);
  }
  .arrow {
    margin-top: 1px;
  }
  .btn-ghost-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: transparent;
    color: #64748b;
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(51, 65, 85, 0.4);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Inter', sans-serif;
  }
  .btn-ghost-sm:hover {
    color: #94a3b8;
    border-color: rgba(71, 85, 105, 0.6);
  }
  .btn-ghost-sm:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .error {
    color: #ef4444;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 0.375rem;
  }
</style>
