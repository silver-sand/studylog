---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewList from '../../components/ReviewList.astro';
import { getDb } from '../../db';
import { getMonday, getSunday, formatDisplayDate } from '../../utils/date';
import { scopeDbToUser } from '../../services/user-scope';

scopeDbToUser(Astro.request);
const db = getDb();
const reviews = db.listReviews();
const range = {
  weekStart: getMonday(),
  weekEnd: getSunday(),
};
const currentReview = db.getReviewByWeek(range.weekStart);

// Stats for the premium stat row — Stitch style
const entries = db.listEntries({ limit: 200 });
const thisWeekEntries = entries.filter(e => e.date >= range.weekStart && e.date <= range.weekEnd);
const totalHoursThisWeek = thisWeekEntries.reduce((s, e) => s + (e.hoursStudied || 0), 0);
const subjectsThisWeek = new Set(thisWeekEntries.map(e => e.studyType).filter(Boolean));
const insightCount = currentReview?.insights?.length || 0;
const weekScore = currentReview
  ? Math.min(100, Math.round(
    (currentReview.strengths?.length || 0) * 15 +
    (currentReview.insights?.length || 0) * 5 +
    Math.min(totalHoursThisWeek, 35) * 1.5
  ))
  : totalHoursThisWeek > 0 ? Math.round(Math.min(totalHoursThisWeek / 25, 1) * 65) : 0;

const weekDays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
const dayHours = weekDays.map((_, i) => {
  const d = new Date(range.weekStart);
  d.setDate(d.getDate() + i);
  const dateStr = d.toISOString().split('T')[0];
  const dayEntries = thisWeekEntries.filter(e => e.date === dateStr);
  const hours = dayEntries.reduce((s, e) => s + (e.hoursStudied || 0), 0);
  const focus = dayEntries.length > 0 ? Math.round(dayEntries.reduce((s, e) => s + (e.focusRating || 0), 0) / dayEntries.length) : 0;
  return { day: weekDays[i], hours, focus, date: dateStr };
});
const maxHours = Math.max(...dayHours.map(d => d.hours), 4);
const weekTotal = totalHoursThisWeek;

// Subject breakdown for current week
const subjectData = [...subjectsThisWeek].map(s => {
  const subjEntries = thisWeekEntries.filter(e => e.studyType === s);
  const hours = subjEntries.reduce((sum, e) => sum + (e.hoursStudied || 0), 0);
  return { name: s, hours };
}).sort((a, b) => b.hours - a.hours);

// Week-over-week comparison (mock for now)
const prevWeekStart = new Date(range.weekStart);
prevWeekStart.setDate(prevWeekStart.getDate() - 7);
const prevWeekEnd = new Date(prevWeekStart);
prevWeekEnd.setDate(prevWeekEnd.getDate() + 6);
const prevWeekEntries = entries.filter(e => e.date >= prevWeekStart.toISOString().split('T')[0] && e.date <= prevWeekEnd.toISOString().split('T')[0]);
const prevTotal = prevWeekEntries.reduce((s, e) => s + (e.hoursStudied || 0), 0);
const hourChange = prevTotal > 0 ? Math.round(((weekTotal - prevTotal) / prevTotal) * 100) : 0;
---

<BaseLayout title="Weekly Review">
  <main class="ml-20 lg:ml-64 h-screen overflow-y-auto bg-neutral-950 p-8 lg:p-12" style="background-color: #050505;">
    <div class="max-w-7xl mx-auto">
      <!-- Header Section -->
      <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
        <div>
          <h1 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-2">Weekly Review</h1>
          <p class="text-neutral-500 text-sm">Analyze your progress, spot trends, and plan for the week ahead.</p>
        </div>
        <div class="flex items-center gap-4 bg-[#141416] px-4 py-2 rounded-xl border border-white/5">
          <button class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/5 text-neutral-400 transition-colors">
            <span class="material-symbols-outlined text-sm">chevron_left</span>
          </button>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-indigo-400 text-sm">calendar_today</span>
            <span class="text-sm font-semibold text-white tracking-wide">{formatDisplayDate(range.weekStart)} — {formatDisplayDate(range.weekEnd)}</span>
          </div>
          <button class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/5 text-neutral-400 transition-colors">
            <span class="material-symbols-outlined text-sm">chevron_right</span>
          </button>
        </div>
      </header>

      <!-- Stat Cards Row — Stitch style -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        <div class="obsidian-glass p-6 rounded-2xl">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-label uppercase tracking-widest text-neutral-400">Hours Studied</h3>
            <span class="material-symbols-outlined text-indigo-400">schedule</span>
          </div>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-white">{weekTotal.toFixed(1)}h</span>
            {hourChange !== 0 && (
              <span class="text-sm font-medium flex items-center" class:list={{ 'text-emerald-400': hourChange > 0, 'text-red-400': hourChange < 0 }}>
                <span class="material-symbols-outlined text-xs mr-0.5">{hourChange > 0 ? 'arrow_upward' : 'arrow_downward'}</span>{Math.abs(hourChange)}%
              </span>
            )}
          </div>
        </div>
        <div class="obsidian-glass p-6 rounded-2xl">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-label uppercase tracking-widest text-neutral-400">Sessions</h3>
            <span class="material-symbols-outlined text-indigo-400">task_alt</span>
          </div>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-white">{thisWeekEntries.length}</span>
            <span class="text-sm font-medium text-neutral-500 mb-1">sessions</span>
          </div>
        </div>
        <div class="obsidian-glass p-6 rounded-2xl">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-label uppercase tracking-widest text-neutral-400">Subjects</h3>
            <span class="material-symbols-outlined text-indigo-400">category</span>
          </div>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-white">{subjectsThisWeek.size}</span>
            <span class="text-sm font-medium text-neutral-500 mb-1">Well spread</span>
          </div>
        </div>
        <div class="obsidian-glass p-6 rounded-2xl border border-[#F59E0B]/20">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-xs font-label uppercase tracking-widest text-[#F59E0B]">Streak</h3>
            <span class="material-symbols-outlined text-[#F59E0B] filled-icon">local_fire_department</span>
          </div>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-[#F59E0B]">{db.getStreakInfo()} Days</span>
            <span class="text-sm font-medium text-[#F59E0B]/70 mb-1">Perfect week</span>
          </div>
        </div>
      </div>

      <!-- Two-Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-10">
        <!-- Left Column (Primary 2/3) -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Daily Breakdown -->
          <div class="obsidian-glass p-6 rounded-2xl">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-lg font-bold text-white">Daily Breakdown</h2>
              <span class="text-xs text-neutral-500">Target: 4h / day</span>
            </div>
            <div class="space-y-5">
              {dayHours.map(d => {
                const pct = Math.min((d.hours / 4) * 100, 100);
                const focusColor = d.focus >= 7 ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' :
                  d.focus >= 4 ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20' : 'bg-red-500/10 text-red-400 border-red-500/20';
                return (
                <div class="grid grid-cols-12 gap-4 items-center">
                  <div class="col-span-2 md:col-span-1">
                    <span class="text-sm font-medium text-neutral-400">{d.day}</span>
                  </div>
                  <div class="col-span-7 md:col-span-8">
                    <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                      <div class="h-full rounded-full progress-bar-anim" style={`width: ${pct}%; background: ${d.hours >= 4 ? '#6366f1' : d.hours >= 2 ? '#818cf8' : '#6366f1/60'};`}></div>
                    </div>
                  </div>
                  <div class="col-span-3 text-right flex items-center justify-end gap-3">
                    <span class="text-sm font-medium text-white">{d.hours.toFixed(1)}h</span>
                    {d.focus > 0 && (
                      <span class={`text-xs px-2 py-0.5 rounded border ${focusColor}`}>{d.focus}/10</span>
                    )}
                  </div>
                </div>
                );
              })}
            </div>
          </div>

          <!-- Subject Breakdown -->
          <div class="obsidian-glass p-6 rounded-2xl">
            <h2 class="text-lg font-bold text-white mb-6">Subject Breakdown</h2>
            <div class="space-y-4">
              {subjectData.length > 0 ? subjectData.map(s => {
                const pct = weekTotal > 0 ? Math.round((s.hours / weekTotal) * 100) : 0;
                const colorMap = {
                  physics: '#6366f1',
                  chemistry: '#22c55e',
                  mathematics: '#3b82f6',
                  maths: '#3b82f6',
                  biology: '#ec4899',
                  english: '#f59e0b',
                };
                const barColor = colorMap[s.name.toLowerCase()] || '#6366f1';
                return (
                <div>
                  <div class="flex justify-between text-sm mb-1">
                    <span class="text-neutral-300">{s.name}</span>
                    <span class="font-medium text-white">{s.hours.toFixed(1)}h</span>
                  </div>
                  <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full rounded-full progress-bar-anim" style={`width: ${pct}%; background: ${barColor};`}></div>
                  </div>
                </div>
                );
              }) : (
                <p class="text-sm text-neutral-500">No subject data this week.</p>
              )}
            </div>
          </div>
        </div>

        <!-- Right Column (Secondary 1/3) -->
        <div class="space-y-8">
          <!-- Week Comparison -->
          <div class="obsidian-glass p-6 rounded-2xl">
            <h2 class="text-lg font-bold text-white mb-4">Week over Week</h2>
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-4 border-b border-white/5">
                <span class="text-sm text-neutral-400">Total Hours</span>
                <div class="flex items-center gap-1" class:list={{ 'text-emerald-400': hourChange >= 0, 'text-red-400': hourChange < 0 }}>
                  <span class="material-symbols-outlined text-sm">{hourChange >= 0 ? 'trending_up' : 'trending_down'}</span>
                  <span class="text-sm font-bold">{hourChange >= 0 ? '+' : ''}{hourChange}%</span>
                </div>
              </div>
              <div class="flex justify-between items-center pb-4 border-b border-white/5">
                <span class="text-sm text-neutral-400">Consistency</span>
                <div class="flex items-center gap-1 text-emerald-400">
                  <span class="material-symbols-outlined text-sm">trending_up</span>
                  <span class="text-sm font-bold">+8%</span>
                </div>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-neutral-400">Avg Focus</span>
                <div class="flex items-center gap-1 text-emerald-400">
                  <span class="material-symbols-outlined text-sm">trending_up</span>
                  <span class="text-sm font-bold">+3%</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Focus Trend bar chart -->
          <div class="obsidian-glass p-6 rounded-2xl">
            <h2 class="text-lg font-bold text-white mb-4">Focus Intensity</h2>
            <div class="h-24 flex items-end justify-between gap-1 mt-6">
              {dayHours.map(d => {
                const h = Math.max((d.focus / 10) * 100, 5);
                return (
                  <div class="w-full bg-indigo-500 rounded-t-sm opacity-60 hover:opacity-100 transition-opacity progress-bar-anim" style={`height: ${h}%;`} title={`${d.day}: ${d.focus}/10`}></div>
                );
              })}
            </div>
            <div class="flex justify-between mt-2 text-[10px] text-neutral-500 uppercase">
              <span>Mon</span>
              <span>Sun</span>
            </div>
          </div>

          <!-- Highlights -->
          <div class="obsidian-glass p-6 rounded-2xl">
            <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-[#F59E0B] text-xl filled-icon">stars</span>
              Highlights
            </h2>
            <ul class="space-y-4">
              {currentReview?.strengths?.length > 0 ? currentReview.strengths.slice(0, 3).map(s => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-[#F59E0B]/20 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-[#F59E0B] text-xs">done</span>
                  </div>
                  <p class="text-sm text-neutral-300">{s}</p>
                </li>
              )) : (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-indigo-400 text-xs">bolt</span>
                  </div>
                  <p class="text-sm text-neutral-300">Start logging study sessions to see highlights.</p>
                </li>
              )}
            </ul>
          </div>
        </div>
      </div>

      <!-- AI Review Summary -->
      <div class="obsidian-glass p-6 rounded-2xl mb-8 border border-indigo-500/20">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-indigo-500/20 rounded-xl flex items-center justify-center">
            <span class="material-symbols-outlined text-indigo-400">auto_awesome</span>
          </div>
          <div>
            <h2 class="text-lg font-bold text-white">AI Review Summary</h2>
            <p class="text-xs text-neutral-500">Generated based on your study patterns</p>
          </div>
        </div>
        <div class="space-y-6">
          <p class="text-sm text-neutral-300 leading-relaxed">
            {currentReview?.summary || 'No AI summary available yet. Generate a review to see insights about your study patterns.'}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-3">
              <h3 class="text-xs font-label uppercase tracking-widest text-emerald-400">Strengths</h3>
              <ul class="space-y-2">
                {currentReview?.strengths?.length > 0 ? currentReview.strengths.slice(0, 3).map(s => (
                  <li class="flex items-center gap-2 text-sm text-neutral-400">
                    <span class="material-symbols-outlined text-emerald-400 text-xs">check_circle</span>
                    {s}
                  </li>
                )) : (
                  <li class="text-sm text-neutral-500">No strengths identified yet.</li>
                )}
              </ul>
            </div>
            <div class="space-y-3">
              <h3 class="text-xs font-label uppercase tracking-widest text-yellow-400">Opportunities</h3>
              <ul class="space-y-2">
                {currentReview?.weaknesses?.length > 0 ? currentReview.weaknesses.slice(0, 3).map(w => (
                  <li class="flex items-center gap-2 text-sm text-neutral-400">
                    <span class="material-symbols-outlined text-yellow-400 text-xs">error</span>
                    {w}
                  </li>
                )) : (
                  <li class="text-sm text-neutral-500">No opportunities found yet.</li>
                )}
              </ul>
            </div>
          </div>
          {currentReview?.recommendations?.length > 0 && (
            <div class="bg-indigo-500/10 rounded-xl p-4 border border-indigo-500/10">
              <div class="flex items-center gap-2 mb-1">
                <span class="material-symbols-outlined text-indigo-400 text-sm">lightbulb</span>
                <span class="text-xs font-bold text-indigo-400 uppercase tracking-wider">AI Tip</span>
              </div>
              <p class="text-sm text-neutral-300">{currentReview.recommendations[0]}</p>
            </div>
          )}
        </div>
        {!currentReview && (
          <button id="generate-review-btn" class="mt-6 bg-indigo-600 hover:bg-indigo-500 text-white font-medium text-sm px-6 py-2.5 rounded-lg transition-colors">
            Generate AI Review
          </button>
        )}
        {currentReview && (
          <button id="regenerate-review-btn" class="mt-4 text-indigo-400 text-xs hover:underline flex items-center gap-1">
            <span class="material-symbols-outlined text-sm">refresh</span>
            Regenerate Review
          </button>
        )}
      </div>

      <!-- Notes & Reflections -->
      <div class="obsidian-glass p-6 rounded-2xl mb-12">
        <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-indigo-400">edit_note</span>
          Notes &amp; Reflections
        </h2>
        <textarea
          class="w-full bg-[#141416] border border-white/10 rounded-xl p-4 text-sm text-neutral-300 placeholder-neutral-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all resize-y min-h-[120px]"
          placeholder="What worked well this week? What distractions did you face? How will you adjust for next week?"
          id="weekly-notes"
        >{currentReview?.notes || ''}</textarea>
        <div class="flex justify-end mt-4">
          <button id="save-reflection-btn" class="bg-indigo-500 hover:bg-indigo-400 text-white font-medium text-sm px-6 py-2.5 rounded-lg transition-colors">
            Save Reflection
          </button>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  // ── Progress bar entrance animation ──
  window.addEventListener('load', () => {
    document.querySelectorAll('.progress-bar-anim').forEach(bar => {
      const finalWidth = bar.style.width;
      bar.style.width = '0%';
      setTimeout(() => {
        bar.style.transition = 'width 1s cubic-bezier(0.4, 0, 0.2, 1)';
        bar.style.width = finalWidth;
      }, 100);
    });
  });

  // ── Generate / Regenerate review ──
  const generateBtn = document.getElementById('generate-review-btn');
  const regenerateBtn = document.getElementById('regenerate-review-btn');

  async function handleGenerate(regenerate = false) {
    const btn = regenerate ? regenerateBtn : generateBtn;
    if (!btn) return;
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = 'Generating...';
    try {
      const res = await fetch('/api/reviews/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: regenerate ? JSON.stringify({ weekStart: '{{range.weekStart}}' }) : '{}',
      });
      if (!res.ok) throw new Error('Failed');
      const review = await res.json();
      try { localStorage.setItem('sl-checklist-review', '1'); } catch(e) {}
      window.location.reload();
    } catch (err) {
      btn.innerHTML = 'Failed — try again';
      setTimeout(() => { btn.innerHTML = original; btn.disabled = false; }, 2000);
    }
  }

  generateBtn?.addEventListener('click', () => handleGenerate(false));
  regenerateBtn?.addEventListener('click', () => handleGenerate(true));
</script>

<style>
  .obsidian-glass {
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
</style>
