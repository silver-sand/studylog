---
import AuthPopup from '../components/AuthPopup.astro';
import { getSessionUser, getTokenFromCookie } from '../services/auth-service';
import '../styles/design-system.css';

const user = getSessionUser(getTokenFromCookie(Astro.request));
const isGuest = user?.userType === 'guest';
const isAuthenticated = !!user && !isGuest;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#020617" />
  <meta name="description" content="StudyLog — AI-powered daily micro-log and auto-review for competitive exam prep. Track what you study, get weekly reviews." />
  <title>StudyLog — AI-Powered Study Tracker</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body style="background:var(--ds-bg-base);color:var(--ds-text-secondary);font-family:var(--ds-font-sans);-webkit-font-smoothing:antialiased;min-height:100vh;overflow-x:hidden;">
  <!-- ── Navigation ── -->
  <header class="ds-landing-header">
    <div style="max-width:72rem;margin:0 auto;padding:0 var(--ds-space-6);height:4rem;display:flex;align-items:center;justify-content:space-between;">
      <a href="/" style="display:flex;align-items:center;gap:var(--ds-space-2-5);text-decoration:none;">
        <div style="width:2rem;height:2rem;border-radius:var(--ds-radius-lg);background:var(--ds-accent-600);display:flex;align-items:center;justify-content:center;">
          <span style="color:white;font-size:var(--ds-text-xs);font-weight:var(--ds-weight-bold);">SL</span>
        </div>
        <span style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;letter-spacing:var(--ds-tracking-tight);">StudyLog</span>
      </a>
      <nav style="display:flex;align-items:center;gap:var(--ds-space-4);">
        <a href="#features" style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);text-decoration:none;transition:color var(--ds-transition-base);display:none;">Features</a>
        <a href="#how-it-works" style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);text-decoration:none;transition:color var(--ds-transition-base);display:none;">How It Works</a>
        {isAuthenticated ? (
          <a href="/daily" class="ds-btn ds-btn-primary ds-btn-sm">Dashboard</a>
        ) : (
          <>
            <button onclick="window.openAuthPopup('login')" class="ds-btn ds-btn-ghost ds-btn-sm">Log In</button>
            <button onclick="window.openAuthPopup('signup')" class="ds-btn ds-btn-primary ds-btn-sm">Get Started Free</button>
          </>
        )}
      </nav>
    </div>
  </header>

  <!-- ── Hero ── -->
  <section class="ds-landing-hero">
    <div style="max-width:48rem;margin:0 auto;text-align:center;">
      <div style="display:inline-flex;align-items:center;gap:var(--ds-space-1-5);padding:var(--ds-space-1) var(--ds-space-3);border-radius:var(--ds-radius-full);background:var(--ds-accent-bg);border:1px solid var(--ds-accent-border);color:var(--ds-accent-400);font-size:var(--ds-text-xs);font-weight:var(--ds-weight-medium);margin-bottom:var(--ds-space-8);">
        <span style="width:0.5rem;height:0.5rem;border-radius:50%;background:var(--ds-accent-400);"></span>
        AI-Powered Study Analytics
      </div>
      <h1 style="font-size:var(--ds-text-4xl);font-weight:var(--ds-weight-extrabold);color:white;line-height:var(--ds-leading-tight);letter-spacing:var(--ds-tracking-tight);margin:0 0 var(--ds-space-6);">
        Your study journey,<br />
        <span style="background:linear-gradient(to right,var(--ds-accent-400),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">intelligently tracked</span>
      </h1>
      <p style="font-size:var(--ds-text-lg);color:var(--ds-text-tertiary);max-width:36rem;margin:0 auto var(--ds-space-10);line-height:var(--ds-leading-relaxed);">
        Micro-log your daily study sessions, get AI-powered weekly reviews, track syllabus progress across multiple exams, and stay on pace — all in one place.
      </p>
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:var(--ds-space-4);">
        {isAuthenticated ? (
          <a href="/daily" class="ds-btn ds-btn-primary ds-btn-lg" style="gap:var(--ds-space-2);">
            Go to Dashboard
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        ) : (
          <>
            <button id="start-guest-btn" class="ds-btn ds-btn-primary ds-btn-lg" style="gap:var(--ds-space-2);">
              Start Tracking Free
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
            <button onclick="window.openAuthPopup('signup')" class="ds-btn ds-btn-outline ds-btn-lg">Create Account</button>
          </>
        )}
      </div>
      <p style="font-size:var(--ds-text-xs);color:var(--ds-text-muted);margin-top:var(--ds-space-6);">No credit card. Start instantly.</p>
    </div>
  </section>

  <!-- ── Features ── -->
  <section id="features" class="ds-landing-section">
    <div style="max-width:64rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:var(--ds-space-14);">
        <h2 style="font-size:var(--ds-text-3xl);font-weight:var(--ds-weight-bold);color:white;margin:0 0 var(--ds-space-4);letter-spacing:var(--ds-tracking-tight);">Everything you need to stay on track</h2>
        <p style="color:var(--ds-text-tertiary);max-width:24rem;margin:0 auto;">Designed for competitive exam prep. Built for consistency, not complexity.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(18rem,1fr));gap:var(--ds-space-6);">
        <!-- Feature 1 -->
        <div class="ds-feature-card">
          <div class="ds-feature-icon" style="background:var(--ds-accent-bg);border:1px solid var(--ds-accent-border);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Micro Daily Log</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Log what you studied in seconds. Track hours, subjects, chapters, and focus level. No complex journaling required.</p>
        </div>

        <!-- Feature 2 -->
        <div class="ds-feature-card">
          <div class="ds-feature-icon" style="background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.25);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">AI Weekly Reviews</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Get insightful AI-generated weekly reviews. Spot patterns, track consistency, and discover what's working.</p>
        </div>

        <!-- Feature 3 -->
        <div class="ds-feature-card">
          <div class="ds-feature-icon" style="background:rgba(251,191,36,0.1);border:1px solid rgba(251,191,36,0.25);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect width="6" height="4" x="9" y="3" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Syllabus Progress</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Track your syllabus chapter by chapter. See completion percentages, revision status, and weak areas per subject.</p>
        </div>

        <!-- Feature 4 -->
        <div class="ds-feature-card">
          <div class="ds-feature-icon" style="background:rgba(167,139,250,0.1);border:1px solid rgba(167,139,250,0.25);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Multi-Exam Support</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Prepare for JEE, NEET, CBSE, CUET, CAT, UPSC, and more. Switch between exams without losing data.</p>
        </div>

        <!-- Feature 5 -->
        <div class="ds-feature-card">
          <div class="ds-feature-icon" style="background:rgba(251,113,133,0.1);border:1px solid rgba(251,113,133,0.25);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fb7185" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Pace Prediction</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Know if you're on track. See projected completion dates and get early warnings when you're falling behind.</p>
        </div>

        <!-- Feature 6 -->
        <div class="ds-feature-card">
          <div class="ds-feature-icon" style="background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.25);">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22d3ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M16 14H8a4 4 0 0 0-4 4v2h16v-2a4 4 0 0 0-4-4z"/></svg>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">AI Mentor</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Ask your personal AI mentor anything. Get study advice, concept explanations, and syllabus guidance in real-time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How It Works ── -->
  <section id="how-it-works" class="ds-landing-section">
    <div style="max-width:56rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:var(--ds-space-14);">
        <h2 style="font-size:var(--ds-text-3xl);font-weight:var(--ds-weight-bold);color:white;margin:0 0 var(--ds-space-4);letter-spacing:var(--ds-tracking-tight);">How it works</h2>
        <p style="color:var(--ds-text-tertiary);max-width:24rem;margin:0 auto;">Three simple steps to transform your study tracking.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:var(--ds-space-8);">
        <div style="text-align:center;">
          <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(37,99,235,0.2);border:1px solid rgba(59,130,246,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto var(--ds-space-4);">
            <span style="font-size:var(--ds-text-2xl);font-weight:var(--ds-weight-bold);color:var(--ds-accent-400);">1</span>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Log Daily</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Spend 30 seconds logging what you studied, for how long, and your focus level.</p>
        </div>
        <div style="text-align:center;">
          <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(34,197,94,0.2);border:1px solid rgba(34,197,94,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto var(--ds-space-4);">
            <span style="font-size:var(--ds-text-2xl);font-weight:var(--ds-weight-bold);color:var(--ds-success-text);">2</span>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Get Insights</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">AI analyzes your entries and generates weekly reviews with strengths, weaknesses, and recommendations.</p>
        </div>
        <div style="text-align:center;">
          <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(139,92,246,0.2);border:1px solid rgba(139,92,246,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto var(--ds-space-4);">
            <span style="font-size:var(--ds-text-2xl);font-weight:var(--ds-weight-bold);color:#a78bfa;">3</span>
          </div>
          <h3 style="font-size:var(--ds-text-lg);font-weight:var(--ds-weight-semibold);color:white;margin:0 0 var(--ds-space-2);">Stay on Track</h3>
          <p style="font-size:var(--ds-text-sm);color:var(--ds-text-tertiary);line-height:var(--ds-leading-relaxed);margin:0;">Monitor syllabus progress, pace predictions, and chapter health. Adjust your plan before it's too late.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="ds-landing-section">
    <div style="max-width:32rem;margin:0 auto;text-align:center;">
      <h2 style="font-size:var(--ds-text-3xl);font-weight:var(--ds-weight-bold);color:white;margin:0 0 var(--ds-space-4);letter-spacing:var(--ds-tracking-tight);">Ready to study smarter?</h2>
      <p style="font-size:var(--ds-text-lg);color:var(--ds-text-tertiary);margin:0 0 var(--ds-space-8);">Start tracking your study sessions today. No account required to begin.</p>
      {isAuthenticated ? (
        <a href="/daily" class="ds-btn ds-btn-primary ds-btn-lg" style="gap:var(--ds-space-2);">
          Go to Dashboard
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      ) : (
        <button id="cta-guest-btn" class="ds-btn ds-btn-primary ds-btn-lg" style="gap:var(--ds-space-2);">
          Start Tracking Free
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      )}
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer style="padding:var(--ds-space-8) var(--ds-space-6);border-top:1px solid var(--ds-border-subtle);">
    <div style="max-width:64rem;margin:0 auto;display:flex;flex-direction:column;align-items:center;justify-content:space-between;gap:var(--ds-space-4);">
      <div style="display:flex;align-items:center;gap:var(--ds-space-2);font-size:var(--ds-text-sm);color:var(--ds-text-muted);">
        <span>© 2026 StudyLog</span>
      </div>
      <div style="display:flex;align-items:center;gap:var(--ds-space-6);font-size:var(--ds-text-xs);color:var(--ds-text-muted);">
        <span>Built for students who mean business.</span>
      </div>
    </div>
  </footer>

  <AuthPopup />

  <script>
    async function createGuestSession() {
      try {
        const res = await fetch('/api/auth/guest', { method: 'POST' });
        if (res.ok) {
          window.location.href = '/daily';
        } else {
          // Fallback: go to daily anyway
          window.location.href = '/daily';
        }
      } catch {
        window.location.href = '/daily';
      }
    }

    document.getElementById('start-guest-btn')?.addEventListener('click', (e) => {
      e.preventDefault();
      createGuestSession();
    });

    document.getElementById('cta-guest-btn')?.addEventListener('click', (e) => {
      e.preventDefault();
      createGuestSession();
    });
  </script>

  <style>
    html { scroll-behavior: smooth; }
    @media (min-width: 640px) {
      a[href="#features"], a[href="#how-it-works"] { display: block !important; }
    }
  </style>
</body>
</html>
