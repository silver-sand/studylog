---
import BaseLayout from '../layouts/BaseLayout.astro';
import StreakDisplay from '../components/StreakDisplay.astro';
import WeeklyProgress from '../components/WeeklyProgress.astro';
import StatsCard from '../components/StatsCard.astro';
import SubjectHoursChart from '../components/SubjectHoursChart.astro';
import StudyTrendChart from '../components/StudyTrendChart.astro';
import StudyTypeBreakdown from '../components/StudyTypeBreakdown.astro';
import FocusTrend from '../components/FocusTrend.astro';
import WeekComparison from '../components/WeekComparison.astro';
import WeakChapters from '../components/WeakChapters.astro';
import DailyActionCard from '../components/DailyActionCard.astro';
import ExamPaceWidget from '../components/ExamPaceWidget.astro';
import MockTestWidget from '../components/MockTestWidget.astro';
import TourTooltip from '../components/TourTooltip.astro';
import GuidedTour from '../components/GuidedTour.astro';
import GettingStarted from '../components/GettingStarted.astro';
import { getDashboardStats } from '../services/stats-service';
import { getDb } from '../db';
import { scopeDbToUser } from '../services/user-scope';
import { getSyllabusKeyForExam } from '../utils/exam-map';

scopeDbToUser(Astro.request);
const stats = getDashboardStats();
const settings = getDb().getSettings();
const selectedExams = settings.selectedExams?.length ? settings.selectedExams : ['JEE'];
const examKey = getSyllabusKeyForExam(selectedExams[0]);
---

<BaseLayout title="Dashboard">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8">
      <h1 class="page-title">Dashboard</h1>
      <p class="page-sub">Your study progress at a glance</p>
    </div>

    <!-- Getting Started Checklist -->
    <GettingStarted />

    <!-- Top Row: Streak + Progress -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6" id="tour-progress">
      <div>
        <StreakDisplay streak={stats.streak} />
      </div>
      <div class="md:col-span-2">
        <WeeklyProgress
          currentHours={stats.totalHoursThisWeek}
          targetHours={stats.targetHoursPerWeek}
          percent={stats.weeklyProgressPercent}
        />
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6" id="tour-stats">
      <StatsCard
        label="This Week"
        value={`${stats.entriesThisWeek}`}
        subtext="study days"
      />
      <StatsCard
        label="This Month"
        value={`${stats.entriesThisMonth}`}
        subtext="entries logged"
      />
      <MockTestWidget />
      <ExamPaceWidget />
    </div>

    <!-- Two-column chart row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6" id="tour-daily">
    </div>

    <!-- Two-column chart row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
      <StudyTrendChart data={stats.dailyTrend} />
      <StudyTypeBreakdown data={stats.typeDistribution} />
    </div>

    <!-- Two-column row: subject hours + week comparison -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
      <SubjectHoursChart data={stats.subjectBreakdown} />
      <WeekComparison data={stats.weekComparison} />
    </div>

    <!-- Focus trend row -->
    <div class="mb-6">
      <FocusTrend data={stats.focusTrend} />
    </div>

  </div>

  <TourTooltip
    tourId="dashboard-overview"
    title="📊 Your Dashboard"
    description="See your study streak, weekly progress, charts, and weak areas at a glance. Log your study sessions from the Daily Log page."
    selector=".page-title"
    position="bottom"
  />

  <GuidedTour
    tourId="dashboard-walkthrough"
    steps={[
      {
        title: '👋 Welcome to StudyLog!',
        description: 'This is your command center. Everything you need to track your studies — streak, progress, insights, and AI-powered guidance — all in one place.',
        targetSelector: '#tour-progress',
        position: 'bottom',
      },
      {
        title: '📊 Key Stats at a Glance',
        description: 'Quick overview of your study days this week, monthly entries, mock test scores, and your exam pace prediction.',
        targetSelector: '#tour-stats',
        position: 'top',
      },
      {
        title: '🎯 Daily Action & Weak Areas',
        description: 'Get AI-powered suggestions for what to study today and see which chapters need the most attention.',
        targetSelector: '#tour-daily',
        position: 'bottom',
      },
      {
        title: '📈 Charts & Insights',
        description: 'Visualize your study trends, subject breakdowns, week-over-week comparisons, and focus patterns across time.',
        targetSelector: '.grid-cols-1.md\\:grid-cols-2',
        position: 'top',
      },
      {
        title: '🧭 Explore the Sidebar',
        description: 'Navigate between all features using the sidebar: Daily Log, Dashboard, Syllabus Tracker, AI Mentor, Timer, Weekly Reviews, and Settings. Each tool helps you study smarter.',
        targetSelector: '.sidebar',
        position: 'right',
      },
      {
        title: '✅ You\'re Ready!',
        description: 'Start by logging your first study session, then explore each tool at your own pace. Your progress and insights will grow with every entry.',
        position: 'bottom',
      },
    ]}
  />
</BaseLayout>

<style>
  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .page-sub {
    font-size: 0.875rem;
    color: #64748b;
  }
</style>
