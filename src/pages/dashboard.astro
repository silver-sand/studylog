---
import BaseLayout from '../layouts/BaseLayout.astro';
import GettingStarted from '../components/GettingStarted.astro';
import DashboardLeftColumn from '../components/DashboardLeftColumn.astro';
import DashboardRightColumn from '../components/DashboardRightColumn.astro';
import CalendarWidget from '../components/CalendarWidget.astro';
import { getDashboardStats, getMonthlyEntryDates } from '../services/stats-service';
import { getDb } from '../db';
import { scopeDbToUser } from '../services/user-scope';
import { getSyllabusKeyForExam } from '../utils/exam-map';

scopeDbToUser(Astro.request);
const db = getDb();
const stats = getDashboardStats();
const settings = db.getSettings();
const selectedExams = settings.selectedExams?.length ? settings.selectedExams : ['JEE'];
const examKey = getSyllabusKeyForExam(selectedExams[0]);
const userId = db.getCurrentUser();
const user = userId ? db.getUserById(userId) : null;
const hasEntries = stats.totalHoursThisWeek > 0 || stats.entriesThisMonth > 0;

// Progress for syllabus bar
const syllProgress = db.getSyllabusProgress(examKey);
const hasAnyProgress = syllProgress.some(p => p.weightedPercent > 0);
const syllabusPercent = hasAnyProgress
  ? Math.round(syllProgress.reduce((s, p) => s + p.weightedPercent, 0) / syllProgress.length)
  : 0;

// Calendar data
const now = new Date();
const thisYear = now.getFullYear();
const thisMonth = now.getMonth() + 1;
const entryDates = getMonthlyEntryDates(thisYear, thisMonth);
---

<BaseLayout title="Dashboard">
  <!-- Full-height grid layout matching Stitch Premium Dashboard exactly -->
  <div class="h-full min-h-screen grid grid-cols-1 xl:grid-cols-3 overflow-hidden">

    <!-- Left Column (1/3) — Darker surface bg, scrollable -->
    <section class="xl:col-span-1 border-r border-white/5 bg-[#0A0A0B] p-8 overflow-y-auto custom-scrollbar reveal-on-scroll">
      {!hasEntries && <GettingStarted />}

      <DashboardLeftColumn
        coveragePercent={stats.coveragePercent}
        consistencyPercent={stats.consistencyPercent}
        masteryPercent={stats.masteryPercent}
        readinessScore={stats.readinessScore}
        readinessLabel={stats.readinessLabel}
        streak={stats.streak}
        weekDays={stats.weekDays}
        entriesThisWeek={stats.entriesThisWeek}
        studyDaysPerWeek={settings.studyDaysPerWeek || 5}
        upcomingExams={stats.upcomingExams}
        syllabusPercent={syllabusPercent}
        user={user}
      >
        <Fragment slot="calendar">
          <CalendarWidget entryDates={entryDates} year={thisYear} month={thisMonth} />
        </Fragment>
      </DashboardLeftColumn>
    </section>

    <!-- Right Column (2/3) — Base bg color, scrollable, flex layout -->
    <section class="xl:col-span-2 bg-[#050505] p-8 lg:p-12 overflow-y-auto flex flex-col custom-scrollbar reveal-on-scroll">
      <DashboardRightColumn
        totalHoursThisWeek={stats.totalHoursThisWeek}
        targetHoursPerWeek={stats.targetHoursPerWeek}
        weeklyProgressPercent={stats.weeklyProgressPercent}
        entriesThisWeek={stats.entriesThisWeek}
        studyDaysPerWeek={settings.studyDaysPerWeek || 5}
        recentEntries={stats.recentEntries}
        examKey={examKey}
        hasEntries={hasEntries}
        dailyTrend={stats.dailyTrend}
        subjectBreakdown={stats.subjectBreakdown}
        weekComparison={stats.weekComparison}
        user={user}
      />
    </section>

  </div>
</BaseLayout>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }
</style>
